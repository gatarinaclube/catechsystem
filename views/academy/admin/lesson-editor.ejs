<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
    <style>
      .editor-surface {
        min-height: 520px;
      }

      .codex-editor {
        color: #111827;
      }

      .ce-block__content,
      .ce-toolbar__content {
        max-width: 760px;
      }
    </style>
  </head>
  <body class="bg-[#f8faf7] text-[#1f2933]">
    <main class="mx-auto max-w-7xl px-5 py-8">
      <nav class="flex flex-wrap items-center justify-between gap-3">
        <a href="/academy/admin" class="text-sm font-black text-[#31513d]">← Admin Academy</a>
        <div class="flex flex-wrap gap-3">
          <a href="/academy/admin/midia" class="text-sm font-bold text-[#31513d]">Biblioteca de mídia</a>
          <a href="/academy/app/aulas/<%= lesson.slug %>" class="text-sm font-bold text-[#b9892e]">Ver aula</a>
        </div>
      </nav>

      <form id="academy-lesson-editor-form" method="post" action="/academy/admin/aulas/<%= lesson.id %>/editor" class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px]">
        <section class="rounded-[28px] bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <div class="text-xs font-black uppercase tracking-[0.22em] text-[#b9892e]">CMS Academy</div>
              <h1 class="mt-3 text-4xl font-black">Editor de Aula</h1>
              <p class="mt-2 max-w-2xl text-slate-500">Edite o conteúdo principal, mídia, arquivos e SEO sem mexer no código.</p>
            </div>
            <button class="rounded-full bg-[#31513d] px-6 py-3 font-black text-white">Salvar aula</button>
          </div>

          <div class="mt-8 grid gap-4 md:grid-cols-2">
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Título
              <input name="title" value="<%= lesson.title %>" required class="rounded-2xl border border-slate-200 p-4 text-lg font-black text-slate-900" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Slug
              <input name="slug" value="<%= lesson.slug %>" class="rounded-2xl border border-slate-200 p-4" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600 md:col-span-2">
              Resumo
              <textarea name="summary" rows="3" class="rounded-2xl border border-slate-200 p-4"><%= lesson.summary || '' %></textarea>
            </label>
          </div>

          <div class="mt-8 rounded-[24px] border border-slate-200 bg-slate-50 p-4">
            <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
              <div>
                <h2 class="text-xl font-black">Editor rico</h2>
                <p class="text-sm text-slate-500">Suporta títulos, listas, checklists, citações, separadores e embeds. Se o editor externo não carregar, use o HTML abaixo.</p>
              </div>
              <span class="rounded-full bg-[#31513d]/10 px-3 py-1 text-xs font-black uppercase tracking-widest text-[#31513d]">EditorJS ready</span>
            </div>
            <div id="academy-editorjs" class="editor-surface rounded-2xl bg-white px-4 py-6 shadow-inner"></div>
            <textarea id="academy-editor-fallback" name="richText" rows="12" class="mt-4 w-full rounded-2xl border border-slate-200 p-4 font-mono text-sm"><%= lesson.richText || '' %></textarea>
            <input id="academy-content-json" type="hidden" name="contentJson" value="<%= lesson.contentJson || '' %>" />
          </div>

          <section class="mt-8 grid gap-4 md:grid-cols-2">
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Imagem/capa URL
              <input name="imageUrl" value="<%= lesson.imageUrl || '' %>" class="rounded-2xl border border-slate-200 p-4" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Open Graph imagem
              <input name="ogImageUrl" value="<%= lesson.ogImageUrl || '' %>" class="rounded-2xl border border-slate-200 p-4" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600 md:col-span-2">
              Vídeo embed YouTube/Vimeo
              <textarea name="videoEmbed" rows="4" class="rounded-2xl border border-slate-200 p-4 font-mono text-sm"><%= lesson.videoEmbed || '' %></textarea>
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600 md:col-span-2">
              Arquivos complementares JSON
              <textarea name="filesJson" rows="4" class="rounded-2xl border border-slate-200 p-4 font-mono text-sm"><%= lesson.filesJson || '' %></textarea>
            </label>
          </section>
        </section>

        <aside class="grid content-start gap-5">
          <section class="rounded-[28px] bg-white p-5 shadow-sm">
            <h2 class="text-xl font-black">Publicação</h2>
            <div class="mt-4 grid gap-3">
              <label class="grid gap-2 text-sm font-bold text-slate-600">
                Status
                <select name="status" class="rounded-2xl border border-slate-200 p-3">
                  <% Object.values(contentStatuses).forEach(function(status) { %>
                    <option value="<%= status %>" <%= lesson.status === status ? 'selected' : '' %>><%= contentStatusLabels[status] || status %></option>
                  <% }) %>
                </select>
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-600">
                Módulo
                <select name="moduleId" required class="rounded-2xl border border-slate-200 p-3">
                  <% modules.forEach(function(module) { %>
                    <option value="<%= module.id %>" <%= lesson.moduleId === module.id ? 'selected' : '' %>><%= module.category.title %> · <%= module.title %></option>
                  <% }) %>
                </select>
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-600">
                Autor/especialista
                <select name="authorId" class="rounded-2xl border border-slate-200 p-3">
                  <option value="">Sem autor</option>
                  <% authors.forEach(function(author) { %>
                    <option value="<%= author.id %>" <%= lesson.authorId === author.id ? 'selected' : '' %>><%= author.name %></option>
                  <% }) %>
                </select>
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-600">
                Acesso
                <select name="level" class="rounded-2xl border border-slate-200 p-3">
                  <% Object.values(levels).forEach(function(level) { %>
                    <option value="<%= level %>" <%= lesson.level === level ? 'selected' : '' %>><%= levelLabels[level] || level %></option>
                  <% }) %>
                </select>
              </label>
              <div class="grid grid-cols-2 gap-3">
                <label class="grid gap-2 text-sm font-bold text-slate-600">
                  Ordem
                  <input name="sortOrder" type="number" value="<%= lesson.sortOrder %>" class="rounded-2xl border border-slate-200 p-3" />
                </label>
                <label class="grid gap-2 text-sm font-bold text-slate-600">
                  Duração
                  <input name="durationMinutes" type="number" value="<%= lesson.durationMinutes || '' %>" class="rounded-2xl border border-slate-200 p-3" />
                </label>
              </div>
              <label class="grid gap-2 text-sm font-bold text-slate-600">
                Leitura estimada
                <input name="estimatedReadingMinutes" type="number" value="<%= lesson.estimatedReadingMinutes || '' %>" class="rounded-2xl border border-slate-200 p-3" />
              </label>
            </div>
          </section>

          <section class="rounded-[28px] bg-white p-5 shadow-sm">
            <h2 class="text-xl font-black">SEO</h2>
            <div class="mt-4 grid gap-3">
              <input name="metaTitle" value="<%= lesson.metaTitle || '' %>" placeholder="Meta title" class="rounded-2xl border border-slate-200 p-3" />
              <textarea name="metaDescription" rows="4" placeholder="Meta description" class="rounded-2xl border border-slate-200 p-3"><%= lesson.metaDescription || '' %></textarea>
              <textarea name="relatedLessonIdsJson" rows="3" placeholder="Aulas relacionadas JSON" class="rounded-2xl border border-slate-200 p-3 font-mono text-sm"><%= lesson.relatedLessonIdsJson || '' %></textarea>
            </div>
          </section>

          <section class="rounded-[28px] bg-white p-5 shadow-sm">
            <h2 class="text-xl font-black">Mídia vinculada</h2>
            <% if (lesson.media.length) { %>
              <div class="mt-4 grid gap-3">
                <% lesson.media.forEach(function(media) { %>
                  <a href="<%= media.url %>" class="rounded-2xl bg-slate-50 p-3 text-sm font-bold text-[#31513d]"><%= media.title || media.url %></a>
                <% }) %>
              </div>
            <% } else { %>
              <p class="mt-3 text-sm text-slate-500">Nenhuma mídia vinculada ainda.</p>
            <% } %>
          </section>
        </aside>
      </form>

      <section class="mt-8 rounded-[28px] bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h2 class="text-2xl font-black">Upload e biblioteca da aula</h2>
            <p class="mt-2 text-sm text-slate-500">Envie imagem, PDF, MP4 ou WebM. O arquivo fica registrado na biblioteca e vinculado a esta aula.</p>
          </div>
        </div>

        <form method="post" action="/academy/admin/midia" enctype="multipart/form-data" class="mt-5 grid gap-3 rounded-3xl border border-slate-200 bg-slate-50 p-4 md:grid-cols-2">
          <input type="hidden" name="lessonId" value="<%= lesson.id %>" />
          <input name="title" placeholder="Título do arquivo" class="rounded-2xl border border-slate-200 p-3" />
          <input name="altText" placeholder="Texto alternativo" class="rounded-2xl border border-slate-200 p-3" />
          <select name="type" class="rounded-2xl border border-slate-200 p-3">
            <option value="">Detectar automaticamente</option>
            <option value="IMAGE">Imagem</option>
            <option value="DOCUMENT">Documento</option>
            <option value="VIDEO">Vídeo</option>
          </select>
          <input type="file" name="file" required accept="image/*,application/pdf,video/mp4,video/webm" class="rounded-2xl border border-slate-200 bg-white p-3" />
          <button class="rounded-2xl bg-[#31513d] p-3 font-black text-white md:col-span-2">Enviar e vincular</button>
        </form>

        <% if (mediaLibrary.length) { %>
          <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            <% mediaLibrary.forEach(function(media) { %>
              <article class="rounded-2xl border border-slate-200 p-3">
                <div class="text-xs font-black uppercase tracking-widest text-slate-400"><%= media.type %></div>
                <a href="<%= media.url %>" target="_blank" class="mt-1 block font-black text-[#31513d]"><%= media.title || media.url %></a>
                <div class="mt-1 text-xs text-slate-500"><%= media.mimeType || '' %></div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/@editorjs/editorjs@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@editorjs/header@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@editorjs/list@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@editorjs/checklist@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@editorjs/quote@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@editorjs/delimiter@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@editorjs/table@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/@editorjs/embed@latest"></script>
    <script src="/js/academy-editor.js"></script>
  </body>
</html>

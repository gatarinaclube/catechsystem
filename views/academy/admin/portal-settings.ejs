              <% }) %>
            </div>

            <div class="grid gap-3 p-4 md:grid-cols-[1.4fr_1fr]">
              <%
                const previewRows = settings.portalNewsRows || [];
                const previewRowArticles = previewRows
                  .map(function(row) { return row.left || {}; })
                  .filter(function(article) {
                    return article.title || article.imageUrl || article.body || article.externalUrl;
                  });
                const previewAllArticles = (settings.portalFeatured || []).concat(previewRowArticles);
                const previewOrderArticles = function(items) {
                  return items.slice().sort(function(a, b) {
                    return Number(a.sortOrder || 999) - Number(b.sortOrder || 999);
                  });
                };
                const previewFeaturedArticles = previewOrderArticles(previewAllArticles.filter(function(article) {
                  return (article.placement || 'featured') === 'featured';
                }));
                const previewSideArticles = previewOrderArticles(previewAllArticles.filter(function(article) {
                  return article.placement === 'side';
                }));
                const previewListArticles = previewOrderArticles(previewAllArticles.filter(function(article) {
                  return article.placement === 'list';
                }));
                const mainFeature = previewFeaturedArticles[0] || {};
              %>
              <article>
                <div class="aspect-[16/9] overflow-hidden rounded-2xl bg-slate-100">
                  <% if (mainFeature.imageUrl) { %><img src="<%= mainFeature.imageUrl %>" alt="" class="h-full w-full object-cover" /><% } %>
                </div>
                <p class="mt-3 text-[10px] font-black uppercase tracking-widest text-[#b88b38]"><%= mainFeature.category || 'Destaque' %></p>
                <h3 class="portal-preview-title mt-1 font-black text-[#31513d]"><%= mainFeature.title || 'Matéria principal' %></h3>
                <p class="mt-1 line-clamp-2 text-xs text-slate-500"><%= mainFeature.subtitle || 'Resumo da notícia principal.' %></p>
              </article>
              <div class="grid gap-3">
                <% [0,1].forEach(function(index) { const item = previewSideArticles[index] || {}; %>
                  <article class="grid grid-cols-[74px_1fr] gap-3">
                    <div class="aspect-square overflow-hidden rounded-xl bg-slate-100">
                      <% if (item.imageUrl) { %><img src="<%= item.imageUrl %>" alt="" class="h-full w-full object-cover" /><% } %>
                    </div>
                    <div>
                      <p class="text-[9px] font-black uppercase tracking-widest text-[#b88b38]"><%= item.category || 'Notícia' %></p>
                      <h4 class="text-sm font-black leading-tight text-[#31513d]"><%= item.title || `Destaque ${index + 1}` %></h4>
                    </div>
                  </article>
                <% }) %>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-2 border-t border-slate-100 p-4">
              <% (settings.portalBannerB || [{},{},{}]).slice(0,3).forEach(function(banner, index) { %>
                <% if (banner.imageUrl) { %>
                  <img src="<%= banner.imageUrl %>" alt="Banner B" class="h-12 w-full rounded-xl object-cover" style="object-fit: <%= banner.fit === 'contain' ? 'contain' : 'cover' %>; object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; transform: scale(<%= Number(banner.scale || 100) / 100 %>);" />
                <% } else { %>
                  <div class="grid h-12 place-items-center rounded-xl bg-[#f7f3ea] text-[10px] font-black text-slate-400">B <%= index + 1 %></div>
                <% } %>
              <% }) %>
            </div>

	            <div class="grid gap-3 border-t border-slate-100 p-4">
	              <% previewListArticles.slice(0,2).forEach(function(left) { %>
                <article class="grid grid-cols-[92px_1fr] gap-3">
                  <div class="aspect-[4/3] overflow-hidden rounded-xl bg-slate-100">
                    <% if (left.imageUrl) { %><img src="<%= left.imageUrl %>" alt="" class="h-full w-full object-cover" /><% } %>
                  </div>
                  <div>
                    <p class="text-[9px] font-black uppercase tracking-widest text-[#b88b38]"><%= left.category || 'Matéria' %></p>
                    <h4 class="text-sm font-black leading-tight text-[#31513d]"><%= left.title || 'Título da matéria' %></h4>
                    <p class="mt-1 line-clamp-2 text-xs text-slate-500"><%= left.caption || left.subtitle || '' %></p>
                  </div>
	                </article>
	              <% }) %>
	            </div>
	            <% if (settings.portalSocialLinks && settings.portalSocialLinks.length) { %>
	              <div class="flex flex-wrap justify-center gap-2 border-t border-slate-100 p-4">
	                <% settings.portalSocialLinks.forEach(function(social) { %>
	                  <img src="<%= social.iconUrl %>" alt="<%= social.title || 'Rede social' %>" class="h-8 w-8 rounded-full border border-slate-200 object-contain p-1" />
	                <% }) %>
	              </div>
	            <% } %>
	          </div>
        </aside>
      </section>
    </main>

    <script>
      const findPositionEditor = (element) => element?.closest("[data-position-editor]") || element?.closest("[data-banner-editor]");

      const attachImagePreview = (scope = document) => {
        scope.querySelectorAll('input[type="file"][accept*="image"]').forEach((input) => {
          if (input.dataset.previewReady === "true") return;
          input.dataset.previewReady = "true";
          input.addEventListener("change", () => {
            const file = input.files && input.files[0];
            if (!file) return;
            const url = URL.createObjectURL(file);
            const positionEditor = input.closest("[data-position-editor]");
            const bannerEditor = input.closest("[data-banner-editor]");
            const editor = positionEditor || bannerEditor;
            let preview = editor?.querySelector("[data-position-preview]") || input.parentElement?.querySelector(".admin-upload-live-preview");
            if (!preview) {
              preview = document.createElement("img");
              preview.className = "admin-upload-live-preview";
              if (input.name && input.name.startsWith("portalBannerC")) {
                preview.classList.add("banner-c-preview");
              }
              preview.alt = "Prévia da nova imagem selecionada";
              if (editor) {
                const frame = document.createElement("div");
                frame.className = "admin-upload-preview-frame";
                if (input.name && input.name.startsWith("portalBannerC")) {
                  frame.classList.add("banner-c-preview-frame");
                } else if (input.name && (input.name.startsWith("portalFeaturedImage") || input.name.startsWith("portalNewsImage"))) {
                  frame.classList.add("article-preview-frame");
                }
                preview.dataset.positionPreview = "true";
                frame.appendChild(preview);
                input.insertAdjacentElement("beforebegin", frame);
              } else {
                input.insertAdjacentElement("afterend", preview);
              }
            }
            preview.src = url;
            if (editor) applyPosition(editor);
          });
        });
      };

      const applyPosition = (scope) => {
        if (!scope) return;
        const preview = scope.querySelector("[data-position-preview]");
        const x = scope.querySelector("[data-position-x]")?.value || 50;
        const y = scope.querySelector("[data-position-y]")?.value || 50;
        const scale = scope.querySelector("[data-position-scale]")?.value || 100;
        const fit = scope.querySelector("[data-position-fit]")?.value || "cover";
        const xLabel = scope.querySelector("[data-position-x-label]");
        const yLabel = scope.querySelector("[data-position-y-label]");
        const scaleLabel = scope.querySelector("[data-scale-label]");
        if (xLabel) xLabel.textContent = `${x}%`;
        if (yLabel) yLabel.textContent = `${y}%`;
        if (scaleLabel) scaleLabel.textContent = `${scale}%`;
        if (preview) {
          preview.style.objectPosition = `${x}% ${y}%`;
          preview.style.objectFit = fit;
          preview.style.setProperty("--banner-scale", String(Number(scale) / 100));
        }
      };

      (() => {
        document.addEventListener("input", (event) => {
          if (!event.target.matches("[data-position-x], [data-position-y], [data-position-scale], [data-position-fit]")) return;
          applyPosition(findPositionEditor(event.target));
        });
        document.addEventListener("change", (event) => {
          if (!event.target.matches("[data-position-fit]")) return;
          applyPosition(findPositionEditor(event.target));
        });
      })();

      (() => {
        attachImagePreview();
      })();

      (() => {
        const featuredList = document.querySelector("[data-featured-list]");
        const addFeatured = document.querySelector("[data-add-featured]");
        if (!featuredList || !addFeatured) return;
        const targetLimits = { featured: 1, side: 2 };

        const targetPlacement = (value) => String(value || "").split(":")[0];

        const updateArticleTargetAvailability = () => {
          const selects = Array.from(document.querySelectorAll("[data-article-target]"));
          const counts = selects.reduce((acc, select) => {
            const placement = targetPlacement(select.value);
            acc[placement] = (acc[placement] || 0) + 1;
            return acc;
          }, {});

          selects.forEach((select) => {
            const currentPlacement = targetPlacement(select.value);
            select.querySelectorAll("option").forEach((option) => {
              const placement = targetPlacement(option.value);
              const limit = targetLimits[placement];
              option.disabled = Boolean(limit && placement !== currentPlacement && (counts[placement] || 0) >= limit);
            });
          });
        };
        window.updateArticleTargetAvailability = updateArticleTargetAvailability;

        const refreshFeatured = () => {
          featuredList.querySelectorAll("[data-featured-card]").forEach((card, index) => {
            const title = card.querySelector('input[name="portalFeaturedTitle"]')?.value?.trim() || "Sem título";
            const targetSelect = card.querySelector("[data-article-target]");
            const targetLabel = targetSelect?.selectedOptions?.[0]?.textContent?.trim() || `Destaque/matéria ${index + 1}`;
            const summary = card.querySelector("summary");
            const fileInput = card.querySelector('input[type="file"][name^="portalFeaturedImage"]');
            if (fileInput) fileInput.name = `portalFeaturedImage${index}`;
            card.querySelectorAll("[data-body-image-slot]").forEach((slotEl, slot) => {
              const file = slotEl.querySelector("[data-body-image-file]");
              const urlField = slotEl.querySelector("[data-body-image-url-field]");
              const captionField = slotEl.querySelector("[data-body-image-caption-field]");
              if (file) file.name = `portalFeaturedBodyImage${index}_${slot}`;
              if (urlField) urlField.name = `portalFeaturedBodyImageUrl${index}_${slot}`;
              if (captionField) captionField.name = `portalFeaturedBodyImageCaption${index}_${slot}`;
            });
            if (summary) summary.textContent = `${targetLabel} · ${title}`;
          });
          updateArticleTargetAvailability();
        };

        addFeatured.addEventListener("click", () => {
          const template = featuredList.querySelector("[data-featured-card]");
          if (!template) return;
          const nextIndex = featuredList.querySelectorAll("[data-featured-card]").length + 1;
          const clone = template.cloneNode(true);
          clone.querySelectorAll("input, textarea").forEach((field) => {
            if (field.type === "file") {
              field.value = "";
              delete field.dataset.previewReady;
              return;
            }
            field.value = "";
          });
          clone.querySelectorAll("select").forEach((field) => {
            if (field.matches("[data-position-fit]")) {
              field.value = "cover";
            } else if (field.matches("[data-article-target]")) {
              field.value = `list:${nextIndex}`;
            }
          });
          clone.querySelectorAll(".admin-upload-preview-frame").forEach((frame) => frame.remove());
          clone.querySelectorAll("img").forEach((image) => image.remove());
          clone.querySelectorAll("[data-body-image-url-field], [data-body-image-caption-field]").forEach((field) => {
            field.value = "";
          });
          if ("open" in clone) clone.open = true;
          featuredList.appendChild(clone);
          attachImagePreview(clone);
          refreshFeatured();
        });

        featuredList.addEventListener("input", refreshFeatured);
        featuredList.addEventListener("change", refreshFeatured);
        refreshFeatured();
      })();

	      (() => {
	        const bannerCList = document.querySelector("[data-banner-c-list]");
	        const addBannerC = document.querySelector("[data-add-banner-c]");
	        if (!bannerCList || !addBannerC) return;

        const refreshBannerC = () => {
          bannerCList.querySelectorAll("[data-banner-c-card]").forEach((card, index) => {
            const summary = card.querySelector("summary");
            const fileInput = card.querySelector('input[type="file"][name^="portalBannerC"]');
            if (fileInput) fileInput.name = `portalBannerC${index}`;
            if (summary) summary.textContent = `Banner C ${index + 1}`;
          });
        };

        addBannerC.addEventListener("click", () => {
          const template = bannerCList.querySelector("[data-banner-c-card]");
          if (!template) return;
          const clone = template.cloneNode(true);
          clone.querySelectorAll("input").forEach((field) => {
            if (field.type === "file") {
              field.value = "";
              delete field.dataset.previewReady;
              return;
            }
            if (field.type === "range") {
              field.value = field.matches("[data-position-scale]") ? "100" : "50";
              return;
            }
            field.value = field.name === "portalBannerCAltText" ? "Banner C" : "";
          });
          clone.querySelectorAll("[data-position-fit]").forEach((field) => {
            field.value = "cover";
          });
          clone.querySelectorAll(".admin-upload-preview-frame").forEach((frame) => frame.remove());
          clone.querySelectorAll("img").forEach((image) => image.remove());
          if ("open" in clone) clone.open = true;
          bannerCList.appendChild(clone);
          attachImagePreview(clone);
          applyPosition(clone);
          refreshBannerC();
        });

	        refreshBannerC();
	      })();

	      (() => {
	        const socialList = document.querySelector("[data-social-list]");
	        const addSocialLink = document.querySelector("[data-add-social-link]");
	        if (!socialList || !addSocialLink) return;

	        const refreshSocialLinks = () => {
	          socialList.querySelectorAll("[data-social-card]").forEach((card, index) => {
	            const title = card.querySelector('input[name="portalSocialTitle"]')?.value?.trim() || "Sem título";
	            const summary = card.querySelector("summary");
	            const sortOrder = card.querySelector('input[name="portalSocialSortOrder"]');
	            const fileInput = card.querySelector('input[type="file"][name^="portalSocialIcon"]');
	            if (sortOrder && !sortOrder.value) sortOrder.value = String(index + 1);
	            if (fileInput) fileInput.name = `portalSocialIcon${index}`;
	            if (summary) summary.textContent = `Rede social ${index + 1} · ${title}`;
	          });
	        };

	        addSocialLink.addEventListener("click", () => {
	          const template = socialList.querySelector("[data-social-card]");
	          if (!template) return;
	          const nextIndex = socialList.querySelectorAll("[data-social-card]").length + 1;
	          const clone = template.cloneNode(true);
	          clone.querySelectorAll("input").forEach((field) => {
	            if (field.type === "file") {
	              field.value = "";
	              delete field.dataset.previewReady;
	              return;
	            }
	            field.value = field.name === "portalSocialSortOrder" ? String(nextIndex) : "";
	          });
	          clone.querySelectorAll("img").forEach((image) => image.remove());
	          if ("open" in clone) clone.open = true;
	          socialList.appendChild(clone);
	          attachImagePreview(clone);
	          refreshSocialLinks();
	        });

	        socialList.addEventListener("input", refreshSocialLinks);
	        socialList.addEventListener("change", refreshSocialLinks);
	        refreshSocialLinks();
	      })();

	      (() => {
	        const eventList = document.querySelector("[data-event-list]");
	        const addEvent = document.querySelector("[data-add-event]");
	        if (!eventList || !addEvent) return;

	        const refreshEvents = () => {
	          eventList.querySelectorAll("[data-event-card]").forEach((card, index) => {
	            const title = card.querySelector('input[name="portalEventTitle"]')?.value?.trim() || "Sem título";
	            const summary = card.querySelector("summary");
	            const sortOrder = card.querySelector('input[name="portalEventSortOrder"]');
	            if (sortOrder && !sortOrder.value) sortOrder.value = String(index + 1);
	            if (summary) summary.textContent = `Evento ${index + 1} · ${title}`;
	          });
	        };

	        addEvent.addEventListener("click", () => {
	          const template = eventList.querySelector("[data-event-card]");
	          if (!template) return;
	          const nextIndex = eventList.querySelectorAll("[data-event-card]").length + 1;
	          const clone = template.cloneNode(true);
	          clone.querySelectorAll("input, textarea").forEach((field) => {
	            field.value = field.name === "portalEventSortOrder" ? String(nextIndex) : "";
	          });
	          if ("open" in clone) clone.open = true;
	          eventList.appendChild(clone);
	          refreshEvents();
	        });

	        eventList.addEventListener("input", refreshEvents);
	        refreshEvents();
	      })();

	      (() => {
	        const podcastList = document.querySelector("[data-podcast-list]");
	        const addPodcastVideo = document.querySelector("[data-add-podcast-video]");
	        if (!podcastList || !addPodcastVideo) return;

	        const refreshPodcastVideos = () => {
	          podcastList.querySelectorAll("[data-podcast-card]").forEach((card, index) => {
	            const title = card.querySelector('input[name="portalPodcastTitle"]')?.value?.trim() || "Sem título";
	            const summary = card.querySelector("summary");
	            const sortOrder = card.querySelector('input[name="portalPodcastSortOrder"]');
	            if (sortOrder && !sortOrder.value) sortOrder.value = String(index + 1);
	            if (summary) summary.textContent = `Podcast ${index + 1} · ${title}`;
	          });
	        };

	        addPodcastVideo.addEventListener("click", () => {
	          const template = podcastList.querySelector("[data-podcast-card]");
	          if (!template) return;
	          const nextIndex = podcastList.querySelectorAll("[data-podcast-card]").length + 1;
	          const clone = template.cloneNode(true);
	          clone.querySelectorAll("input, textarea").forEach((field) => {
	            field.value = field.name === "portalPodcastSortOrder" ? String(nextIndex) : "";
	          });
	          if ("open" in clone) clone.open = true;
	          podcastList.appendChild(clone);
	          refreshPodcastVideos();
	        });

	        podcastList.addEventListener("input", refreshPodcastVideos);
	        refreshPodcastVideos();
	      })();

	      (() => {
	        const portalRows = document.querySelector("[data-portal-rows]");
	        const addPortalRow = document.querySelector("[data-add-portal-row]");
        if (!portalRows || !addPortalRow) return;

        const refreshPortalRows = () => {
          portalRows.querySelectorAll("[data-portal-row]").forEach((row, index) => {
            const title = row.querySelector('input[name="portalNewsLeftTitle"]')?.value?.trim() || "Sem título";
            const targetSelect = row.querySelector("[data-article-target]");
            const targetLabel = targetSelect?.selectedOptions?.[0]?.textContent?.trim() || `Matéria ${index + 1}`;
            const summary = row.querySelector("summary");
            const fileInput = row.querySelector('input[type="file"][name^="portalNewsImage"]');
            if (fileInput) fileInput.name = `portalNewsImage${index}`;
            row.querySelectorAll("[data-body-image-slot]").forEach((slotEl, slot) => {
              const file = slotEl.querySelector("[data-body-image-file]");
              const urlField = slotEl.querySelector("[data-body-image-url-field]");
              const captionField = slotEl.querySelector("[data-body-image-caption-field]");
              if (file) file.name = `portalNewsLeftBodyImage${index}_${slot}`;
              if (urlField) urlField.name = `portalNewsLeftBodyImageUrl${index}_${slot}`;
              if (captionField) captionField.name = `portalNewsLeftBodyImageCaption${index}_${slot}`;
            });
            if (summary) summary.textContent = `${targetLabel} · ${title}`;
          });
          window.updateArticleTargetAvailability?.();
        };

        addPortalRow.addEventListener("click", () => {
          const template = portalRows.querySelector("[data-portal-row]");
          if (!template) return;
          const nextIndex = portalRows.querySelectorAll("[data-portal-row]").length + 1;
          const clone = template.cloneNode(true);
          clone.querySelectorAll("input, textarea").forEach((field) => {
            if (field.type === "file") {
              field.value = "";
              delete field.dataset.previewReady;
              return;
            }
            field.value = "";
          });
          clone.querySelectorAll("select").forEach((field) => {
            if (field.matches("[data-position-fit]")) {
              field.value = "cover";
            } else if (field.matches("[data-article-target]")) {
              field.value = `list:${Math.min(nextIndex, 200)}`;
            }
          });
          clone.querySelectorAll(".admin-upload-preview-frame").forEach((frame) => frame.remove());
          clone.querySelectorAll("img").forEach((image) => image.remove());
          clone.querySelectorAll("[data-body-image-url-field], [data-body-image-caption-field]").forEach((field) => {
            field.value = "";
          });
          if ("open" in clone) clone.open = true;
          portalRows.appendChild(clone);
          attachImagePreview(clone);
          refreshPortalRows();
        });

        portalRows.addEventListener("input", refreshPortalRows);
        portalRows.addEventListener("change", refreshPortalRows);
        refreshPortalRows();
      })();
    </script>
  </body>
</html>

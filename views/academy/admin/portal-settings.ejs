<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .admin-upload-live-preview {
        margin-top: 0.75rem;
        display: block;
        width: 100%;
        aspect-ratio: 45 / 13;
        max-height: none;
        object-fit: cover;
        object-position: 50% 50%;
        transform: scale(var(--banner-scale, 1));
        border-radius: 1rem;
        border: 1px solid rgba(49, 81, 61, 0.18);
        background: #0f172a;
      }
      .admin-upload-preview-frame {
        margin-top: 0.75rem;
        width: 100%;
        aspect-ratio: 45 / 13;
        overflow: hidden;
        border-radius: 1rem;
        border: 1px solid rgba(49, 81, 61, 0.18);
        background: #0f172a;
      }
      .admin-upload-preview-frame.banner-c-preview-frame {
        aspect-ratio: 42 / 13;
      }
      .admin-upload-preview-frame .admin-upload-live-preview {
        margin-top: 0;
        height: 100%;
        border: 0;
        border-radius: 0;
        background: transparent;
      }
      .admin-upload-live-preview.banner-c-preview {
        aspect-ratio: 42 / 13;
      }
      .banner-position-controls {
        overflow: hidden;
      }
      .banner-position-controls input[type="range"] {
        width: 100%;
      }
      .banner-control-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
      }
      .banner-control-value {
        border-radius: 999px;
        background: #fff;
        padding: 0.15rem 0.55rem;
        color: #31513d;
        font-size: 0.72rem;
        font-weight: 900;
      }
      [data-banner-editor],
      [data-banner-editor] input {
        min-width: 0;
      }
      [data-banner-editor] input[type="file"] {
        max-width: 100%;
        font-size: 0.82rem;
      }
      .portal-preview {
        color: <%= settings.portalTextColor || '#1f2933' %>;
        font-family: "<%= settings.portalFontFamily || 'Inter' %>", system-ui, sans-serif;
      }
      .portal-preview-title {
        color: <%= settings.portalHeadingColor || '#31513d' %>;
        font-size: <%= settings.portalTitleSize === 'large' ? '1.2rem' : settings.portalTitleSize === 'compact' ? '.86rem' : '1rem' %>;
        font-style: <%= settings.portalHeadingItalic ? 'italic' : 'normal' %>;
        font-weight: <%= settings.portalHeadingWeight || '900' %>;
      }
    </style>
  </head>
  <body class="bg-[#f7f3ea] text-slate-900">
    <main class="mx-auto max-w-7xl px-4 py-8 md:px-8">
      <header class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.24em] text-[#b88b38]">Administração do Sistema</p>
          <h1 class="mt-2 text-3xl font-black md:text-5xl">Editor Gatofilia News</h1>
          <p class="mt-3 max-w-3xl text-slate-600">
            Edite a página inicial <strong>gatofilia.com.br</strong>. A Jornada continua separada em <strong>Editor Jornada Gatofilia</strong>.
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a href="/dashboard" class="rounded-2xl border border-slate-300 px-4 py-3 text-sm font-black text-slate-700">Voltar</a>
          <a href="/" target="_blank" rel="noopener" class="rounded-2xl bg-[#31513d] px-4 py-3 text-sm font-black text-white">Ver página</a>
          <a href="/academy/admin/configuracoes" class="rounded-2xl border border-[#31513d] px-4 py-3 text-sm font-black text-[#31513d]">Editor Jornada</a>
        </div>
      </header>

      <% if (saved) { %>
        <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-sm font-black text-emerald-800">
          Configurações da Gatofilia News salvas com sucesso.
        </div>
      <% } %>

      <section class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_440px] lg:items-start">
        <form method="post" action="/academy/admin/gatofilia-news" enctype="multipart/form-data" class="grid gap-6">
          <section class="rounded-[2rem] bg-white p-6 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.22em] text-[#b88b38]">Identidade</p>
                <h2 class="mt-2 text-2xl font-black">Logo e tipografia</h2>
              </div>
              <span class="rounded-full bg-[#fff4d9] px-3 py-1 text-xs font-black text-[#8c651f]">Topo da página</span>
            </div>
            <div class="mt-5 grid gap-4 md:grid-cols-3">
              <label class="grid gap-2 text-sm font-bold text-slate-700 md:col-span-2">
                Logo do cabeçalho
                <input type="hidden" name="portalLogoUrl" value="<%= settings.portalLogoUrl || '' %>" />
                <% if (settings.portalLogoUrl) { %>
                  <img src="<%= settings.portalLogoUrl %>" alt="Logo atual" class="max-h-24 w-fit rounded-2xl bg-slate-900 p-3" />
                <% } %>
                <input type="file" name="portalLogo" accept="image/*" class="rounded-2xl border border-slate-200 bg-white p-3" />
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Tamanho dos títulos
                <select name="portalTitleSize" class="rounded-2xl border border-slate-200 bg-white p-3">
                  <option value="compact" <%= settings.portalTitleSize === 'compact' ? 'selected' : '' %>>Compacto</option>
                  <option value="medium" <%= !settings.portalTitleSize || settings.portalTitleSize === 'medium' ? 'selected' : '' %>>Médio</option>
                  <option value="large" <%= settings.portalTitleSize === 'large' ? 'selected' : '' %>>Maior</option>
                </select>
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Fonte principal
                <select name="portalFontFamily" class="rounded-2xl border border-slate-200 bg-white p-3">
                  <% ['Inter', 'Lora', 'Merriweather', 'Playfair Display', 'Georgia'].forEach(function(font) { %>
                    <option value="<%= font %>" <%= settings.portalFontFamily === font ? 'selected' : '' %>><%= font %></option>
                  <% }) %>
                </select>
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Cor do texto
                <input type="color" name="portalTextColor" value="<%= settings.portalTextColor || '#1f2933' %>" class="h-[50px] rounded-2xl border border-slate-200 bg-white p-2" />
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Cor dos títulos
                <input type="color" name="portalHeadingColor" value="<%= settings.portalHeadingColor || '#171717' %>" class="h-[50px] rounded-2xl border border-slate-200 bg-white p-2" />
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Cor de destaque
                <input type="color" name="portalAccentColor" value="<%= settings.portalAccentColor || '#a97824' %>" class="h-[50px] rounded-2xl border border-slate-200 bg-white p-2" />
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Peso dos títulos
                <select name="portalHeadingWeight" class="rounded-2xl border border-slate-200 bg-white p-3">
                  <% [['600','Semi negrito'],['700','Negrito'],['800','Extra negrito'],['900','Máximo destaque']].forEach(function(item) { %>
                    <option value="<%= item[0] %>" <%= String(settings.portalHeadingWeight || '900') === item[0] ? 'selected' : '' %>><%= item[1] %></option>
                  <% }) %>
                </select>
              </label>
              <label class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white p-3 text-sm font-bold text-slate-700">
                <input type="checkbox" name="portalHeadingItalic" <%= settings.portalHeadingItalic ? 'checked' : '' %> class="h-5 w-5 accent-[#31513d]" />
                Títulos em itálico
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Troca do carrossel
                <div class="flex items-center gap-2">
                  <input type="number" min="3" max="20" name="portalCarouselSeconds" value="<%= settings.portalCarouselSeconds || 7 %>" class="w-full rounded-2xl border border-slate-200 bg-white p-3" />
                  <span class="text-xs font-black uppercase text-slate-400">seg.</span>
                </div>
              </label>
            </div>
          </section>

          <section class="rounded-[2rem] bg-white p-6 shadow-sm">
            <p class="text-xs font-black uppercase tracking-[0.22em] text-[#b88b38]">Banners</p>
            <h2 class="mt-2 text-2xl font-black">Patrocinadores</h2>
            <p class="mt-2 text-sm text-slate-500">
              Tamanhos sugeridos: Banner A 900x260px (2 colunas), Banner B 580x180px (3 colunas), Banner C 420x130px (4 colunas).
            </p>

            <div class="mt-5 grid gap-4">
              <div>
                <h3 class="mb-3 text-lg font-black">Banners A</h3>
                <div class="grid gap-4 md:grid-cols-2">
                  <% const bannersA = Array.isArray(settings.portalBannerA) ? settings.portalBannerA : [settings.portalBannerA || {}, {}]; %>
                  <% [0,1].forEach(function(index) { const banner = bannersA[index] || {}; %>
                    <details open class="rounded-3xl border border-slate-200 p-4" data-banner-editor>
                      <summary class="cursor-pointer text-lg font-black">Banner A <%= index + 1 %></summary>
                      <div class="mt-4 grid gap-3">
                        <input type="hidden" name="portalBannerAImageUrl" value="<%= banner.imageUrl || '' %>" />
                        <% if (banner.imageUrl) { %><div class="admin-upload-preview-frame"><img src="<%= banner.imageUrl %>" alt="Banner A atual" class="admin-upload-live-preview" style="object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; --banner-scale: <%= Number(banner.scale || 100) / 100 %>;" data-position-preview /></div><% } %>
                        <input type="file" name="portalBannerA<%= index %>" accept="image/*" class="rounded-2xl border border-slate-200 bg-white p-3" />
                        <div class="banner-position-controls grid gap-3 rounded-2xl bg-slate-50 p-3">
                          <p class="text-xs font-black uppercase tracking-widest text-slate-400">Enquadramento da imagem</p>
                          <label class="grid gap-2 text-sm font-bold text-slate-600">
                            <span class="banner-control-heading">Horizontal <span class="banner-control-value" data-position-x-label><%= banner.positionX ?? 50 %>%</span></span>
                            <input type="range" min="0" max="100" name="portalBannerAPositionX" value="<%= banner.positionX ?? 50 %>" data-position-x class="accent-[#31513d]" />
                          </label>
                          <label class="grid gap-2 text-sm font-bold text-slate-600">
                            <span class="banner-control-heading">Vertical <span class="banner-control-value" data-position-y-label><%= banner.positionY ?? 50 %>%</span></span>
                            <input type="range" min="0" max="100" name="portalBannerAPositionY" value="<%= banner.positionY ?? 50 %>" data-position-y class="accent-[#31513d]" />
                          </label>
                          <label class="grid gap-2 text-sm font-bold text-slate-600">
                            <span class="banner-control-heading">Escala <span class="banner-control-value" data-scale-label><%= banner.scale ?? 100 %>%</span></span>
                            <input type="range" min="100" max="200" name="portalBannerAScale" value="<%= banner.scale ?? 100 %>" data-position-scale class="accent-[#31513d]" />
                          </label>
                        </div>
                        <input name="portalBannerALinkUrl" value="<%= banner.linkUrl || '' %>" placeholder="Link ao clicar" class="rounded-2xl border border-slate-200 bg-white p-3" />
                        <input name="portalBannerAAltText" value="<%= banner.altText || 'Banner A' %>" placeholder="Texto alternativo" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      </div>
                    </details>
                  <% }) %>
                </div>
              </div>

              <div>
                <h3 class="mb-3 text-lg font-black">Banners B</h3>
                <div class="grid gap-4 md:grid-cols-3">
                <% const bannersB = settings.portalBannerB || []; %>
                <% [0,1,2].forEach(function(index) { const banner = bannersB[index] || {}; %>
                  <details class="rounded-3xl border border-slate-200 p-4" data-banner-editor>
                    <summary class="cursor-pointer text-lg font-black">Banner B <%= index + 1 %></summary>
                    <div class="mt-4 grid gap-3">
                      <input type="hidden" name="portalBannerBImageUrl" value="<%= banner.imageUrl || '' %>" />
                      <% if (banner.imageUrl) { %><div class="admin-upload-preview-frame"><img src="<%= banner.imageUrl %>" alt="Banner B atual" class="admin-upload-live-preview" style="object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; --banner-scale: <%= Number(banner.scale || 100) / 100 %>;" data-position-preview /></div><% } %>
                      <input type="file" name="portalBannerB<%= index %>" accept="image/*" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <div class="banner-position-controls grid gap-3 rounded-2xl bg-slate-50 p-3">
                        <p class="text-xs font-black uppercase tracking-widest text-slate-400">Enquadramento da imagem</p>
                        <label class="grid gap-2 text-sm font-bold text-slate-600">
                          <span class="banner-control-heading">Horizontal <span class="banner-control-value" data-position-x-label><%= banner.positionX ?? 50 %>%</span></span>
                          <input type="range" min="0" max="100" name="portalBannerBPositionX" value="<%= banner.positionX ?? 50 %>" data-position-x class="accent-[#31513d]" />
                        </label>
                        <label class="grid gap-2 text-sm font-bold text-slate-600">
                          <span class="banner-control-heading">Vertical <span class="banner-control-value" data-position-y-label><%= banner.positionY ?? 50 %>%</span></span>
                          <input type="range" min="0" max="100" name="portalBannerBPositionY" value="<%= banner.positionY ?? 50 %>" data-position-y class="accent-[#31513d]" />
                        </label>
                        <label class="grid gap-2 text-sm font-bold text-slate-600">
                          <span class="banner-control-heading">Escala <span class="banner-control-value" data-scale-label><%= banner.scale ?? 100 %>%</span></span>
                          <input type="range" min="100" max="200" name="portalBannerBScale" value="<%= banner.scale ?? 100 %>" data-position-scale class="accent-[#31513d]" />
                        </label>
                      </div>
                      <input name="portalBannerBLinkUrl" value="<%= banner.linkUrl || '' %>" placeholder="Link ao clicar" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <input type="hidden" name="portalBannerBAltText" value="<%= banner.altText || 'Banner B' %>" />
                    </div>
                  </details>
                <% }) %>
                </div>
              </div>

              <div>
                <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
                  <h3 class="text-lg font-black">Banners C</h3>
                  <button type="button" data-add-banner-c class="rounded-2xl border border-[#31513d] px-4 py-2 text-sm font-black text-[#31513d]">+ Banner C</button>
                </div>
                <div class="grid gap-4 md:grid-cols-4" data-banner-c-list>
                <% const bannersC = settings.portalBannerC && settings.portalBannerC.length ? settings.portalBannerC : [{}, {}, {}, {}]; %>
                <% bannersC.forEach(function(banner, index) { %>
                  <details class="rounded-3xl border border-slate-200 p-4" data-banner-c-card data-banner-editor>
                    <summary class="cursor-pointer text-lg font-black">Banner C <%= index + 1 %></summary>
                    <div class="mt-4 grid gap-3">
                      <input type="hidden" name="portalBannerCImageUrl" value="<%= banner.imageUrl || '' %>" />
                      <% if (banner.imageUrl) { %><div class="admin-upload-preview-frame banner-c-preview-frame"><img src="<%= banner.imageUrl %>" alt="Banner C atual" class="admin-upload-live-preview banner-c-preview" style="object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; --banner-scale: <%= Number(banner.scale || 100) / 100 %>;" data-position-preview /></div><% } %>
                      <input type="file" name="portalBannerC<%= index %>" accept="image/*" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <div class="banner-position-controls grid gap-3 rounded-2xl bg-slate-50 p-3">
                        <p class="text-xs font-black uppercase tracking-widest text-slate-400">Enquadramento da imagem</p>
                        <label class="grid gap-2 text-sm font-bold text-slate-600">
                          <span class="banner-control-heading">Horizontal <span class="banner-control-value" data-position-x-label><%= banner.positionX ?? 50 %>%</span></span>
                          <input type="range" min="0" max="100" name="portalBannerCPositionX" value="<%= banner.positionX ?? 50 %>" data-position-x class="accent-[#31513d]" />
                        </label>
                        <label class="grid gap-2 text-sm font-bold text-slate-600">
                          <span class="banner-control-heading">Vertical <span class="banner-control-value" data-position-y-label><%= banner.positionY ?? 50 %>%</span></span>
                          <input type="range" min="0" max="100" name="portalBannerCPositionY" value="<%= banner.positionY ?? 50 %>" data-position-y class="accent-[#31513d]" />
                        </label>
                        <label class="grid gap-2 text-sm font-bold text-slate-600">
                          <span class="banner-control-heading">Escala <span class="banner-control-value" data-scale-label><%= banner.scale ?? 100 %>%</span></span>
                          <input type="range" min="100" max="200" name="portalBannerCScale" value="<%= banner.scale ?? 100 %>" data-position-scale class="accent-[#31513d]" />
                        </label>
                      </div>
                      <input name="portalBannerCLinkUrl" value="<%= banner.linkUrl || '' %>" placeholder="Link ao clicar" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <input type="hidden" name="portalBannerCAltText" value="<%= banner.altText || 'Banner C' %>" />
                    </div>
                  </details>
                <% }) %>
                </div>
              </div>
            </div>
          </section>

          <section class="rounded-[2rem] bg-white p-6 shadow-sm">
            <p class="text-xs font-black uppercase tracking-[0.22em] text-[#b88b38]">Topo editorial</p>
            <div class="mt-2 flex flex-wrap items-center justify-between gap-3">
              <h2 class="text-2xl font-black">Matéria principal e destaques</h2>
              <button type="button" data-add-featured class="rounded-2xl border border-[#31513d] px-4 py-2 text-sm font-black text-[#31513d]">+ Destaque/matéria</button>
            </div>
            <p class="mt-2 text-sm text-slate-500">
              Use a posição para mandar a mesma matéria para o carrossel, destaque lateral, lista principal ou arquivo de matérias antigas.
            </p>
            <div class="mt-5 grid gap-4" data-featured-list>
              <% const featured = settings.portalFeatured && settings.portalFeatured.length ? settings.portalFeatured : [{}]; %>
              <% featured.forEach(function(item, index) { %>
                <details class="rounded-3xl border border-slate-200 p-4" data-featured-card <%= index === 0 ? 'open' : '' %>>
                  <summary class="cursor-pointer text-lg font-black">Destaque/matéria <%= index + 1 %> · <%= item.title || 'Sem título' %></summary>
                  <div class="mt-4 grid gap-3 md:grid-cols-2">
                    <input type="hidden" name="portalFeaturedImageUrl" value="<%= item.imageUrl || '' %>" />
                    <input name="portalFeaturedTitle" value="<%= item.title || '' %>" placeholder="Título" class="rounded-2xl border border-slate-200 bg-white p-3 md:col-span-2" />
                    <input name="portalFeaturedCategory" value="<%= item.category || '' %>" placeholder="Categoria" class="rounded-2xl border border-slate-200 bg-white p-3" />
                    <select name="portalFeaturedPlacement" class="rounded-2xl border border-slate-200 bg-white p-3">
                      <option value="featured" <%= (item.placement || 'featured') === 'featured' ? 'selected' : '' %>>Destaque/carrossel</option>
                      <option value="side" <%= item.placement === 'side' ? 'selected' : '' %>>Destaque lateral</option>
                      <option value="list" <%= item.placement === 'list' ? 'selected' : '' %>>Matérias em lista</option>
                      <option value="archive" <%= item.placement === 'archive' ? 'selected' : '' %>>Matérias antigas</option>
                    </select>
                    <input name="portalFeaturedSlug" value="<%= item.slug || '' %>" placeholder="Slug da página interna" class="rounded-2xl border border-slate-200 bg-white p-3" />
                    <input name="portalFeaturedVideoUrl" value="<%= item.videoUrl || '' %>" placeholder="Link de vídeo opcional" class="rounded-2xl border border-slate-200 bg-white p-3" />
                    <textarea name="portalFeaturedSubtitle" rows="2" placeholder="Resumo na home" class="rounded-2xl border border-slate-200 bg-white p-3 md:col-span-2"><%= item.subtitle || '' %></textarea>
                    <% if (item.imageUrl) { %><img src="<%= item.imageUrl %>" alt="Imagem atual" class="admin-upload-live-preview md:col-span-2" /><% } %>
                    <input type="file" name="portalFeaturedImage<%= index %>" accept="image/*" class="rounded-2xl border border-slate-200 bg-white p-3 md:col-span-2" />
                    <input name="portalFeaturedExternalUrl" value="<%= item.externalUrl || '' %>" placeholder="Link externo opcional" class="rounded-2xl border border-slate-200 bg-white p-3" />
                    <textarea name="portalFeaturedBody" rows="5" placeholder="Matéria completa" class="rounded-2xl border border-slate-200 bg-white p-3 md:col-span-2"><%= item.body || '' %></textarea>
                    <input type="hidden" name="portalFeaturedCaption" value="<%= item.caption || '' %>" />
                  </div>
                </details>
              <% }) %>
            </div>
          </section>

          <section class="rounded-[2rem] bg-white p-6 shadow-sm">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="text-xs font-black uppercase tracking-[0.22em] text-[#b88b38]">Blocos de notícias</p>
                <h2 class="mt-2 text-2xl font-black">Matérias em lista</h2>
              </div>
              <button type="button" data-add-portal-row class="rounded-2xl bg-[#31513d] px-4 py-3 text-sm font-black text-white">+ Nova matéria</button>
            </div>
            <div class="mt-5 grid gap-4" data-portal-rows>
              <% const rows = (settings.portalNewsRows && settings.portalNewsRows.length ? settings.portalNewsRows : [{ left: {}, right: {} }]); %>
              <% rows.forEach(function(row, index) { const left = row.left || {}; const right = row.right || {}; %>
                <details class="rounded-3xl border border-slate-200 p-4" data-portal-row <%= index === 0 ? 'open' : '' %>>
                  <summary class="cursor-pointer text-lg font-black">Matéria <%= index + 1 %> · <%= left.title || 'Sem título' %></summary>
                  <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,1.2fr)_minmax(260px,.8fr)]">
                    <div class="grid gap-3">
                      <input type="hidden" name="portalNewsLeftImageUrl" value="<%= left.imageUrl || '' %>" />
                      <input name="portalNewsLeftTitle" value="<%= left.title || '' %>" placeholder="Título da matéria" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <input name="portalNewsLeftCategory" value="<%= left.category || '' %>" placeholder="Categoria" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <select name="portalNewsLeftPlacement" class="rounded-2xl border border-slate-200 bg-white p-3">
                        <option value="list" <%= (left.placement || 'list') === 'list' ? 'selected' : '' %>>Matérias em lista</option>
                        <option value="featured" <%= left.placement === 'featured' ? 'selected' : '' %>>Destaque/carrossel</option>
                        <option value="side" <%= left.placement === 'side' ? 'selected' : '' %>>Destaque lateral</option>
                        <option value="archive" <%= left.placement === 'archive' ? 'selected' : '' %>>Matérias antigas</option>
                      </select>
                      <input name="portalNewsLeftSlug" value="<%= left.slug || '' %>" placeholder="Slug da página interna" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <input name="portalNewsLeftCaption" value="<%= left.caption || '' %>" placeholder="Legenda" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <% if (left.imageUrl) { %><img src="<%= left.imageUrl %>" alt="Imagem atual" class="admin-upload-live-preview" /><% } %>
                      <input type="file" name="portalNewsImage<%= index %>" accept="image/*" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <input name="portalNewsLeftVideoUrl" value="<%= left.videoUrl || '' %>" placeholder="Link de vídeo opcional" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <input name="portalNewsLeftExternalUrl" value="<%= left.externalUrl || '' %>" placeholder="Link externo opcional" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <textarea name="portalNewsLeftBody" rows="5" placeholder="Matéria completa" class="rounded-2xl border border-slate-200 bg-white p-3"><%= left.body || '' %></textarea>
                      <input type="hidden" name="portalNewsLeftSubtitle" value="<%= left.subtitle || '' %>" />
                    </div>
                    <div class="grid content-start gap-3 rounded-3xl bg-slate-50 p-4">
                      <p class="text-xs font-black uppercase tracking-widest text-slate-400">Coluna lateral</p>
                      <input name="portalNewsRightTitle" value="<%= right.title || '' %>" placeholder="Título lateral" class="rounded-2xl border border-slate-200 bg-white p-3" />
                      <textarea name="portalNewsRightText" rows="7" placeholder="Texto lateral" class="rounded-2xl border border-slate-200 bg-white p-3"><%= right.text || '' %></textarea>
                      <input name="portalNewsRightExternalUrl" value="<%= right.externalUrl || '' %>" placeholder="Link opcional" class="rounded-2xl border border-slate-200 bg-white p-3" />
                    </div>
                  </div>
                </details>
              <% }) %>
            </div>
          </section>

          <div class="sticky bottom-4 z-10 rounded-[1.5rem] border border-[#d6a84f]/30 bg-white/95 p-4 shadow-xl backdrop-blur">
            <button class="w-full rounded-2xl bg-[#31513d] px-5 py-4 text-base font-black text-white">
              Salvar Gatofilia News
            </button>
          </div>
        </form>

        <aside class="sticky top-6 rounded-[2rem] bg-white p-5 shadow-sm">
          <p class="text-xs font-black uppercase tracking-[0.22em] text-[#b88b38]">Prévia aproximada</p>
          <div class="portal-preview mt-4 overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white">
            <div class="flex items-center justify-between border-b border-slate-100 px-4 py-3">
              <% if (settings.portalLogoUrl) { %>
                <img src="<%= settings.portalLogoUrl %>" alt="Logo Gatofilia" class="max-h-12 max-w-[160px] object-contain" />
              <% } else { %>
                <strong class="text-[#31513d]">Gatofilia</strong>
              <% } %>
              <span class="text-xs font-black uppercase tracking-widest text-slate-400">News</span>
            </div>

            <div class="grid grid-cols-2 gap-2 p-3">
              <% const previewBannersA = Array.isArray(settings.portalBannerA) ? settings.portalBannerA : [settings.portalBannerA || {}, {}]; %>
              <% [0,1].forEach(function(index) { const banner = previewBannersA[index] || {}; %>
                <% if (banner.imageUrl) { %>
                  <img src="<%= banner.imageUrl %>" alt="Banner A" class="h-20 w-full rounded-xl object-cover" style="object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; transform: scale(<%= Number(banner.scale || 100) / 100 %>);" />
                <% } else { %>
                  <div class="grid h-20 place-items-center rounded-xl bg-[#f7f3ea] text-xs font-black text-slate-400">Banner A</div>
                <% } %>
              <% }) %>
            </div>

            <div class="grid gap-3 p-4 md:grid-cols-[1.4fr_1fr]">
              <% const previewFeatured = settings.portalFeatured || []; %>
              <% const mainFeature = previewFeatured[0] || {}; %>
              <article>
                <div class="aspect-[16/9] overflow-hidden rounded-2xl bg-slate-100">
                  <% if (mainFeature.imageUrl) { %><img src="<%= mainFeature.imageUrl %>" alt="" class="h-full w-full object-cover" /><% } %>
                </div>
                <p class="mt-3 text-[10px] font-black uppercase tracking-widest text-[#b88b38]"><%= mainFeature.category || 'Destaque' %></p>
                <h3 class="portal-preview-title mt-1 font-black text-[#31513d]"><%= mainFeature.title || 'Matéria principal' %></h3>
                <p class="mt-1 line-clamp-2 text-xs text-slate-500"><%= mainFeature.subtitle || 'Resumo da notícia principal.' %></p>
              </article>
              <div class="grid gap-3">
                <% [1,2].forEach(function(index) { const item = previewFeatured[index] || {}; %>
                  <article class="grid grid-cols-[74px_1fr] gap-3">
                    <div class="aspect-square overflow-hidden rounded-xl bg-slate-100">
                      <% if (item.imageUrl) { %><img src="<%= item.imageUrl %>" alt="" class="h-full w-full object-cover" /><% } %>
                    </div>
                    <div>
                      <p class="text-[9px] font-black uppercase tracking-widest text-[#b88b38]"><%= item.category || 'Notícia' %></p>
                      <h4 class="text-sm font-black leading-tight text-[#31513d]"><%= item.title || `Destaque ${index}` %></h4>
                    </div>
                  </article>
                <% }) %>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-2 border-t border-slate-100 p-4">
              <% (settings.portalBannerB || [{},{},{}]).slice(0,3).forEach(function(banner, index) { %>
                <% if (banner.imageUrl) { %>
                  <img src="<%= banner.imageUrl %>" alt="Banner B" class="h-12 w-full rounded-xl object-cover" style="object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; transform: scale(<%= Number(banner.scale || 100) / 100 %>);" />
                <% } else { %>
                  <div class="grid h-12 place-items-center rounded-xl bg-[#f7f3ea] text-[10px] font-black text-slate-400">B <%= index + 1 %></div>
                <% } %>
              <% }) %>
            </div>

            <div class="grid gap-3 border-t border-slate-100 p-4">
              <% (settings.portalNewsRows || []).slice(0,2).forEach(function(row) { const left = row.left || {}; %>
                <article class="grid grid-cols-[92px_1fr] gap-3">
                  <div class="aspect-[4/3] overflow-hidden rounded-xl bg-slate-100">
                    <% if (left.imageUrl) { %><img src="<%= left.imageUrl %>" alt="" class="h-full w-full object-cover" /><% } %>
                  </div>
                  <div>
                    <p class="text-[9px] font-black uppercase tracking-widest text-[#b88b38]"><%= left.category || 'Matéria' %></p>
                    <h4 class="text-sm font-black leading-tight text-[#31513d]"><%= left.title || 'Título da matéria' %></h4>
                    <p class="mt-1 line-clamp-2 text-xs text-slate-500"><%= left.caption || left.subtitle || '' %></p>
                  </div>
                </article>
              <% }) %>
            </div>
          </div>
        </aside>
      </section>
    </main>

    <script>
      const findBannerEditor = (element) => element?.closest("[data-banner-editor]") || element?.closest("details");

      const attachImagePreview = (scope = document) => {
        scope.querySelectorAll('input[type="file"][accept*="image"]').forEach((input) => {
          if (input.dataset.previewReady === "true") return;
          input.dataset.previewReady = "true";
          input.addEventListener("change", () => {
            const file = input.files && input.files[0];
            if (!file) return;
            const url = URL.createObjectURL(file);
            const bannerEditor = input.closest("[data-banner-editor]");
            const editor = bannerEditor || findBannerEditor(input);
            let preview = bannerEditor?.querySelector("[data-position-preview]") || input.parentElement?.querySelector(".admin-upload-live-preview");
            if (!preview) {
              preview = document.createElement("img");
              preview.className = "admin-upload-live-preview";
              if (input.name && input.name.startsWith("portalBannerC")) {
                preview.classList.add("banner-c-preview");
              }
              preview.alt = "Prévia da nova imagem selecionada";
              if (bannerEditor) {
                const frame = document.createElement("div");
                frame.className = "admin-upload-preview-frame";
                if (input.name && input.name.startsWith("portalBannerC")) {
                  frame.classList.add("banner-c-preview-frame");
                }
                preview.dataset.positionPreview = "true";
                frame.appendChild(preview);
                input.insertAdjacentElement("beforebegin", frame);
              } else {
                input.insertAdjacentElement("afterend", preview);
              }
            }
            preview.src = url;
            if (bannerEditor) applyPosition(editor || input.parentElement);
          });
        });
      };

      const applyPosition = (scope) => {
        if (!scope) return;
        const preview = scope.querySelector("[data-position-preview]");
        const x = scope.querySelector("[data-position-x]")?.value || 50;
        const y = scope.querySelector("[data-position-y]")?.value || 50;
        const scale = scope.querySelector("[data-position-scale]")?.value || 100;
        const xLabel = scope.querySelector("[data-position-x-label]");
        const yLabel = scope.querySelector("[data-position-y-label]");
        const scaleLabel = scope.querySelector("[data-scale-label]");
        if (xLabel) xLabel.textContent = `${x}%`;
        if (yLabel) yLabel.textContent = `${y}%`;
        if (scaleLabel) scaleLabel.textContent = `${scale}%`;
        if (preview) {
          preview.style.objectPosition = `${x}% ${y}%`;
          preview.style.setProperty("--banner-scale", String(Number(scale) / 100));
        }
      };

      (() => {
        document.addEventListener("input", (event) => {
          if (!event.target.matches("[data-position-x], [data-position-y], [data-position-scale]")) return;
          applyPosition(findBannerEditor(event.target));
        });
      })();

      (() => {
        attachImagePreview();
      })();

      (() => {
        const featuredList = document.querySelector("[data-featured-list]");
        const addFeatured = document.querySelector("[data-add-featured]");
        if (!featuredList || !addFeatured) return;

        const refreshFeatured = () => {
          featuredList.querySelectorAll("[data-featured-card]").forEach((card, index) => {
            const title = card.querySelector('input[name="portalFeaturedTitle"]')?.value?.trim() || "Sem título";
            const summary = card.querySelector("summary");
            const fileInput = card.querySelector('input[type="file"][name^="portalFeaturedImage"]');
            if (fileInput) fileInput.name = `portalFeaturedImage${index}`;
            if (summary) summary.textContent = `Destaque/matéria ${index + 1} · ${title}`;
          });
        };

        addFeatured.addEventListener("click", () => {
          const template = featuredList.querySelector("[data-featured-card]");
          if (!template) return;
          const clone = template.cloneNode(true);
          clone.querySelectorAll("input, textarea").forEach((field) => {
            if (field.type === "file") {
              field.value = "";
              delete field.dataset.previewReady;
              return;
            }
            field.value = "";
          });
          clone.querySelectorAll("select").forEach((field) => {
            field.value = "list";
          });
          clone.querySelectorAll(".admin-upload-preview-frame").forEach((frame) => frame.remove());
          clone.querySelectorAll("img").forEach((image) => image.remove());
          if ("open" in clone) clone.open = true;
          featuredList.appendChild(clone);
          attachImagePreview(clone);
          refreshFeatured();
        });

        featuredList.addEventListener("input", refreshFeatured);
        featuredList.addEventListener("change", refreshFeatured);
        refreshFeatured();
      })();

      (() => {
        const bannerCList = document.querySelector("[data-banner-c-list]");
        const addBannerC = document.querySelector("[data-add-banner-c]");
        if (!bannerCList || !addBannerC) return;

        const refreshBannerC = () => {
          bannerCList.querySelectorAll("[data-banner-c-card]").forEach((card, index) => {
            const summary = card.querySelector("summary");
            const fileInput = card.querySelector('input[type="file"][name^="portalBannerC"]');
            if (fileInput) fileInput.name = `portalBannerC${index}`;
            if (summary) summary.textContent = `Banner C ${index + 1}`;
          });
        };

        addBannerC.addEventListener("click", () => {
          const template = bannerCList.querySelector("[data-banner-c-card]");
          if (!template) return;
          const clone = template.cloneNode(true);
          clone.querySelectorAll("input").forEach((field) => {
            if (field.type === "file") {
              field.value = "";
              delete field.dataset.previewReady;
              return;
            }
            if (field.type === "range") {
              field.value = field.matches("[data-position-scale]") ? "100" : "50";
              return;
            }
            field.value = field.name === "portalBannerCAltText" ? "Banner C" : "";
          });
          clone.querySelectorAll(".admin-upload-preview-frame").forEach((frame) => frame.remove());
          clone.querySelectorAll("img").forEach((image) => image.remove());
          if ("open" in clone) clone.open = true;
          bannerCList.appendChild(clone);
          attachImagePreview(clone);
          applyPosition(clone);
          refreshBannerC();
        });

        refreshBannerC();
      })();

      (() => {
        const portalRows = document.querySelector("[data-portal-rows]");
        const addPortalRow = document.querySelector("[data-add-portal-row]");
        if (!portalRows || !addPortalRow) return;

        const refreshPortalRows = () => {
          portalRows.querySelectorAll("[data-portal-row]").forEach((row, index) => {
            const title = row.querySelector('input[name="portalNewsLeftTitle"]')?.value?.trim() || "Sem título";
            const summary = row.querySelector("summary");
            const fileInput = row.querySelector('input[type="file"][name^="portalNewsImage"]');
            if (fileInput) fileInput.name = `portalNewsImage${index}`;
            if (summary) summary.textContent = `Matéria ${index + 1} · ${title}`;
          });
        };

        addPortalRow.addEventListener("click", () => {
          const template = portalRows.querySelector("[data-portal-row]");
          if (!template) return;
          const clone = template.cloneNode(true);
          clone.querySelectorAll("input, textarea").forEach((field) => {
            if (field.type === "file") {
              field.value = "";
              delete field.dataset.previewReady;
              return;
            }
            field.value = "";
          });
          clone.querySelectorAll("select").forEach((field) => {
            field.value = "list";
          });
          clone.querySelectorAll("img").forEach((image) => image.remove());
          if ("open" in clone) clone.open = true;
          portalRows.appendChild(clone);
          attachImagePreview(clone);
          refreshPortalRows();
        });

        portalRows.addEventListener("input", refreshPortalRows);
        refreshPortalRows();
      })();
    </script>
  </body>
</html>

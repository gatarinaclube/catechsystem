<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .admin-upload-live-preview {
        display: block;
        width: 100%;
        object-fit: cover;
      }

      .admin-upload-live-preview {
        margin-top: 12px;
        max-height: 220px;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.35);
      }
    </style>
  </head>
  <body class="bg-[#f8faf7] text-[#1f2933]">
    <main class="mx-auto max-w-5xl px-5 py-8">
      <nav class="flex flex-wrap items-center justify-between gap-3">
        <a href="/academy/admin" class="font-black">← Admin Gatofilia</a>
        <div class="flex flex-wrap gap-3">
          <a href="/" target="_blank" rel="noopener" class="text-sm font-bold text-[#31513d]">Ver nova home</a>
          <a href="/jornada" target="_blank" rel="noopener" class="text-sm font-bold text-[#31513d]">Ver Jornada</a>
          <a href="/dashboard" class="text-sm font-bold text-[#31513d]">PetGus</a>
        </div>
      </nav>

      <section class="mt-8 rounded-[2rem] bg-white p-6 shadow-sm md:p-8">
        <div class="max-w-3xl">
          <p class="text-xs font-black uppercase tracking-[0.22em] text-[#b88b38]">Página pública</p>
          <h1 class="mt-3 text-4xl font-black">Editor Jornada Gatofilia</h1>
          <p class="mt-3 text-slate-600">
            Configure a página <strong>gatofilia.com.br/jornada</strong>, a apresentação reservada, o contador, profissionais convidados e os interessados recebidos.
          </p>
        </div>

        <% if (saved) { %>
          <div class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-bold text-emerald-800">
            Configurações salvas com sucesso.
          </div>
        <% } %>

        <div class="mt-8 grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
          <form method="post" action="/academy/admin/configuracoes" enctype="multipart/form-data" class="grid gap-5 rounded-3xl border border-slate-100 bg-slate-50 p-5">
            <label class="flex items-center gap-3 rounded-2xl bg-white p-4 text-sm font-black">
              <input type="checkbox" name="countdownEnabled" <%= settings.countdownEnabled ? "checked" : "" %> class="h-5 w-5 accent-[#31513d]" />
              Exibir contador na página pública
            </label>

            <label class="grid gap-2 text-sm font-bold text-slate-700">
              Título do contador
              <input
                name="countdownTitle"
                value="<%= settings.countdownTitle || '' %>"
                maxlength="120"
                class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                placeholder="Próxima jornada Gatofilia"
              />
            </label>

            <div class="grid gap-4 md:grid-cols-2">
              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Data de início da próxima jornada
                <input
                  type="date"
                  name="nextJourneyStartDate"
                  value="<%= settings.nextJourneyStartDate || '' %>"
                  class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                />
              </label>

              <label class="grid gap-2 text-sm font-bold text-slate-700">
                Encerramento das inscrições
                <input
                  type="date"
                  name="registrationEndsDate"
                  value="<%= settings.registrationEndsDate || '' %>"
                  class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                />
              </label>
            </div>

            <details class="rounded-3xl border border-slate-200 bg-white p-4" open>
              <summary class="cursor-pointer text-sm font-black uppercase tracking-[0.18em] text-[#31513d]">
                Apresentação reservada
              </summary>
              <div class="mt-5 grid gap-5">
                <div class="rounded-2xl bg-slate-50 p-4 text-sm text-slate-600">
                  Esses campos controlam apenas a página <strong>/apresentacao</strong>. Ela não aparece no menu, não entra no sitemap e está marcada como noindex.
                </div>

                <label class="grid gap-2 text-sm font-bold text-slate-700">
                  Vídeo de boas-vindas (URL ou upload MP4/WebM)
                  <input
                    name="presentationWelcomeVideoUrl"
                    value="<%= settings.presentationWelcomeVideoUrl || '' %>"
                    class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                    placeholder="https://..."
                  />
                  <input type="file" name="presentationWelcomeVideo" accept="video/mp4,video/webm" class="rounded-2xl border border-dashed border-slate-300 bg-white p-3 text-sm font-bold" />
                </label>

                <label class="grid gap-2 text-sm font-bold text-slate-700">
                  Imagem do ecossistema (URL ou upload PNG/JPG/WebP)
                  <input
                    name="presentationEcosystemImageUrl"
                    value="<%= settings.presentationEcosystemImageUrl || '' %>"
                    class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                    placeholder="/uploads/academy/gatofilia-ecosystem-01.png"
                  />
                  <input type="file" name="presentationEcosystemImage" accept="image/png,image/jpeg,image/webp,image/gif" class="rounded-2xl border border-dashed border-slate-300 bg-white p-3 text-sm font-bold" />
                </label>

                <label class="grid gap-2 text-sm font-bold text-slate-700">
                  Vídeo de encerramento (URL ou upload MP4/WebM)
                  <input
                    name="presentationClosingVideoUrl"
                    value="<%= settings.presentationClosingVideoUrl || '' %>"
                    class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                    placeholder="https://..."
                  />
                  <input type="file" name="presentationClosingVideo" accept="video/mp4,video/webm" class="rounded-2xl border border-dashed border-slate-300 bg-white p-3 text-sm font-bold" />
                </label>

                <div class="grid gap-4 md:grid-cols-2">
                  <label class="grid gap-2 text-sm font-bold text-slate-700">
                    Texto do PIX
                    <input
                      name="presentationPixLabel"
                      value="<%= settings.presentationPixLabel || '' %>"
                      class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                    />
                  </label>
                  <label class="grid gap-2 text-sm font-bold text-slate-700">
                    Texto do cartão
                    <input
                      name="presentationCardLabel"
                      value="<%= settings.presentationCardLabel || '' %>"
                      class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                    />
                  </label>
                </div>

                <label class="grid gap-2 text-sm font-bold text-slate-700">
                  Título da oferta
                  <input
                    name="presentationOfferTitle"
                    value="<%= settings.presentationOfferTitle || '' %>"
                    class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                  />
                </label>

                <label class="grid gap-2 text-sm font-bold text-slate-700">
                  Observação da oferta
                  <textarea
                    name="presentationOfferNote"
                    rows="3"
                    class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                  ><%= settings.presentationOfferNote || '' %></textarea>
                </label>

                <section class="rounded-3xl border border-[#d6a84f]/30 bg-[#fff9ed] p-4">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8c651f]">Especialistas convidados</p>
                      <p class="mt-1 text-sm font-bold text-slate-600">
                        Cadastre os profissionais que aparecerão na página de apresentação.
                      </p>
                    </div>
                    <button type="button" data-add-presentation-guest class="rounded-2xl bg-[#31513d] px-4 py-2 text-sm font-black text-white">
                      + Profissional
                    </button>
                  </div>

                  <div class="mt-5 grid gap-4" data-presentation-guests>
                    <% const presentationGuests = (settings.presentationGuests && settings.presentationGuests.length ? settings.presentationGuests : [{ sortOrder: 1, status: 'Convidado', name: '', education: '', story: '', specializations: [], experiences: [] }]); %>
                    <% presentationGuests.forEach(function(guest, index) { %>
                      <details class="rounded-3xl border border-slate-200 bg-white p-4" data-presentation-guest-card>
                        <summary class="flex cursor-pointer list-none flex-wrap items-center justify-between gap-3">
                          <span class="text-base font-black text-slate-800">
                            <%= guest.name || 'Novo profissional' %>
                          </span>
                          <span class="rounded-full bg-[#fff3d7] px-3 py-1 text-xs font-black uppercase tracking-[0.14em] text-[#8c651f]">
                            <%= guest.status || 'Convidado' %> · Ordem <%= guest.sortOrder || index + 1 %>
                          </span>
                        </summary>

                        <div class="mt-5 grid gap-4">
                          <div class="flex flex-wrap items-center justify-between gap-3">
                            <div class="grid gap-4 md:grid-cols-2">
                              <label class="grid gap-2 text-sm font-bold text-slate-700">
                                Ordem
                                <input
                                  name="presentationGuestSortOrder"
                                  type="number"
                                  min="1"
                                  step="1"
                                  value="<%= guest.sortOrder || index + 1 %>"
                                  class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                                />
                              </label>
                              <label class="grid gap-2 text-sm font-bold text-slate-700">
                                Status
                                <select name="presentationGuestStatus" class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]">
                                  <option value="Confirmado" <%= guest.status === 'Confirmado' ? 'selected' : '' %>>Confirmado</option>
                                  <option value="Convidado" <%= guest.status !== 'Confirmado' ? 'selected' : '' %>>Convidado</option>
                                </select>
                              </label>
                            </div>
                            <button type="button" data-remove-presentation-guest class="rounded-2xl border border-red-200 px-4 py-2 text-sm font-black text-red-700">
                              Remover
                            </button>
                          </div>

                          <div class="grid gap-4 md:grid-cols-2">
                            <label class="grid gap-2 text-sm font-bold text-slate-700">
                              Nome
                              <input
                                name="presentationGuestName"
                                value="<%= guest.name || '' %>"
                                class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                              />
                            </label>
                            <label class="grid gap-2 text-sm font-bold text-slate-700">
                              Formação
                              <input
                                name="presentationGuestEducation"
                                value="<%= guest.education || '' %>"
                                class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                              />
                            </label>
                          </div>

                          <label class="grid gap-2 text-sm font-bold text-slate-700">
                            Texto de apresentação
                            <textarea
                              name="presentationGuestStory"
                              rows="5"
                              class="rounded-2xl border border-slate-200 bg-white p-3 text-base font-semibold outline-none focus:border-[#d6a84f]"
                              placeholder="Conte uma breve história, atuação ou contribuição do profissional."
                            ><%= guest.story || (guest.specializations || []).concat(guest.experiences || []).join('\n') %></textarea>
                          </label>
                        </div>
                      </details>
                    <% }) %>
                  </div>
                </section>
              </div>
            </details>

            <div class="rounded-2xl bg-white p-4 text-sm text-slate-600">
              Deixe uma data em branco caso não queira mostrar aquele prazo específico. Se desativar o contador, nada será exibido na página pública.
            </div>

            <div class="rounded-2xl border border-[#d6a84f]/30 bg-[#fff9ed] p-4 text-sm text-slate-600">
              A edição da nova página inicial <strong>gatofilia.com.br</strong> foi separada desta tela.
              Use o atalho <strong>Editor Gatofilia News</strong> em Administração do Sistema para alterar banners, matérias, notícias e patrocinadores.
            </div>

            <button class="rounded-2xl bg-[#31513d] px-5 py-3 font-black text-white shadow-sm">
              Salvar configurações
            </button>
          </form>

          <aside class="rounded-3xl border border-[#d6a84f]/30 bg-[#111111] p-6 text-white">
            <p class="text-xs font-black uppercase tracking-[0.22em] text-[#d6a84f]">Prévia</p>
            <h2 class="mt-3 text-2xl font-black"><%= countdown.title %></h2>
            <% if (countdown.enabled) { %>
              <div class="mt-5 grid gap-3">
                <% countdown.items.forEach(function(item) { %>
                  <article class="rounded-2xl border border-[#d6a84f]/25 bg-white/5 p-4">
                    <p class="text-sm font-bold text-white/70"><%= item.isPast ? item.pastLabel : item.label %></p>
                    <div class="mt-2 flex items-end gap-2">
                      <% if (item.isPast) { %>
                        <strong class="text-3xl font-black text-[#d6a84f]">encerrado</strong>
                      <% } else if (item.isToday) { %>
                        <strong class="text-3xl font-black text-[#d6a84f]">hoje</strong>
                      <% } else { %>
                        <strong class="text-4xl font-black text-[#d6a84f]"><%= item.days %></strong>
                        <span class="pb-1 text-sm font-black uppercase tracking-widest text-white/60"><%= item.days === 1 ? "dia" : "dias" %></span>
                      <% } %>
                    </div>
                    <p class="mt-2 text-xs font-semibold text-white/45"><%= item.date %></p>
                  </article>
                <% }) %>
              </div>
            <% } else { %>
              <p class="mt-5 rounded-2xl bg-white/5 p-4 text-sm text-white/65">
                O contador está sem datas ou desativado.
              </p>
            <% } %>
          </aside>
        </div>
      </section>

      <section class="mt-8 rounded-[2rem] bg-white p-6 shadow-sm md:p-8">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="max-w-3xl">
            <p class="text-xs font-black uppercase tracking-[0.22em] text-[#b88b38]">Pré-inscrições</p>
            <h2 class="mt-3 text-3xl font-black">Interesses recebidos pela página pública</h2>
            <p class="mt-3 text-slate-600">
              As informações enviadas no formulário “Inicie sua jornada na Gatofilia” ficam registradas aqui. Os pedidos feitos pela apresentação reservada ficam em uma seção separada abaixo.
            </p>
          </div>
          <a href="/academy/admin/interesses" class="rounded-2xl border border-[#31513d] px-4 py-3 text-sm font-black text-[#31513d]">
            Ver relatório completo
          </a>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <div class="rounded-3xl bg-slate-50 p-5">
            <div class="text-xs font-black uppercase tracking-widest text-slate-400">Últimos registros</div>
            <div class="mt-2 text-3xl font-black"><%= publicLeads.length %></div>
          </div>
          <div class="rounded-3xl bg-slate-50 p-5">
            <div class="text-xs font-black uppercase tracking-widest text-slate-400">Com gatil</div>
            <div class="mt-2 text-3xl font-black"><%= publicLeads.filter(function(lead) { return lead.hasCattery === 'Sim'; }).length %></div>
          </div>
          <div class="rounded-3xl bg-slate-50 p-5">
            <div class="text-xs font-black uppercase tracking-widest text-slate-400">Pretendem iniciar</div>
            <div class="mt-2 text-3xl font-black"><%= publicLeads.filter(function(lead) { return lead.hasCattery === 'Não'; }).length %></div>
          </div>
        </div>

        <div class="mt-6 grid gap-4">
          <% if (!publicLeads.length) { %>
            <div class="rounded-3xl border border-dashed border-slate-200 bg-slate-50 p-8 text-center text-slate-500">
              Nenhuma pré-inscrição recebida até o momento.
            </div>
          <% } %>

          <% [
            { title: 'Novas', leads: newLeads, tone: 'border-[#d6a84f]/40 bg-[#fff9ed]', empty: 'Nenhuma solicitação nova.' },
            { title: 'Respondidas', leads: respondedLeads, tone: 'border-emerald-200 bg-emerald-50', empty: 'Nenhuma solicitação marcada como respondida.' },
          ].forEach(function(group) { %>
            <details class="overflow-hidden rounded-[1.5rem] border <%= group.tone %>" <%= group.title === 'Novas' ? 'open' : '' %>>
              <summary class="flex cursor-pointer items-center justify-between gap-3 px-5 py-4">
                <span class="text-lg font-black"><%= group.title %></span>
                <span class="rounded-full bg-white px-3 py-1 text-xs font-black text-slate-600"><%= group.leads.length %></span>
              </summary>
              <div class="grid gap-3 border-t border-white/70 p-4">
                <% if (!group.leads.length) { %>
                  <div class="rounded-2xl bg-white/80 p-5 text-center text-sm font-bold text-slate-500"><%= group.empty %></div>
                <% } %>

                <% group.leads.forEach(function(lead) { %>
                  <% const fullName = [lead.firstName, lead.lastName].filter(Boolean).join(' '); %>
                  <% const whatsappDigits = String(lead.whatsapp || '').replace(/\D/g, ''); %>
                  <details class="overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm">
                    <summary class="cursor-pointer px-5 py-4">
                      <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                          <div class="flex flex-wrap items-center gap-2">
                            <span class="rounded-full bg-[#f3ead8] px-3 py-1 text-[11px] font-black uppercase tracking-widest text-[#8c651f]">
                              <%= lead.hasCattery === 'Sim' ? 'Criador com gatil' : 'Futuro criador' %>
                            </span>
                            <span class="text-xs font-bold text-slate-400"><%= lead.createdAt.toLocaleString('pt-BR') %></span>
                          </div>
                          <h3 class="mt-2 text-xl font-black"><%= fullName || 'Sem nome' %></h3>
                          <p class="mt-1 text-sm font-bold text-slate-500">
                            <%= [lead.city, lead.state, lead.country].filter(Boolean).join(' / ') || 'Local não informado' %>
                          </p>
                        </div>
                        <span class="text-sm font-black text-[#31513d]">Abrir detalhes</span>
                      </div>
                    </summary>

                    <div class="grid gap-4 border-t border-slate-100 p-5 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-start">
                      <div class="grid gap-3 text-sm text-slate-600 md:grid-cols-3">
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Gatil</span>
                          <strong class="text-slate-800"><%= lead.catteryName || 'Ainda não possui' %></strong>
                        </div>
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Raça</span>
                          <strong class="text-slate-800"><%= lead.hasCattery === 'Sim' ? (lead.breed || '-') : (lead.wantsStart || '-') %></strong>
                        </div>
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Origem</span>
                          <strong class="text-slate-800"><%= lead.referralSource || '-' %></strong>
                        </div>
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Tempo de criação</span>
                          <strong class="text-slate-800"><%= lead.breedingTime || '-' %></strong>
                        </div>
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Atualizações</span>
                          <strong class="text-slate-800"><%= lead.wantsUpdates ? 'Sim' : 'Não' %></strong>
                        </div>
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Respondida em</span>
                          <strong class="text-slate-800"><%= lead.respondedAt ? lead.respondedAt.toLocaleString('pt-BR') : '-' %></strong>
                        </div>
                        <% if (lead.message) { %>
                          <div class="md:col-span-3">
                            <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Mensagem</span>
                            <p class="mt-1 whitespace-pre-line leading-7"><%= lead.message %></p>
                          </div>
                        <% } %>
                      </div>

                      <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-1">
                        <a href="mailto:<%= lead.email %>" class="rounded-2xl bg-[#31513d] px-4 py-3 text-center text-sm font-black text-white"><%= lead.email %></a>
                        <% if (whatsappDigits) { %>
                          <a href="https://wa.me/<%= whatsappDigits %>" target="_blank" rel="noopener" class="rounded-2xl border border-[#31513d] px-4 py-3 text-center text-sm font-black text-[#31513d]">
                            WhatsApp <%= lead.whatsapp %>
                          </a>
                        <% } %>
                        <% if (String(lead.status || 'NEW').toUpperCase() === 'RESPONDED') { %>
                          <form method="post" action="/academy/admin/interesses/<%= lead.id %>/nova">
                            <button class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm font-black text-slate-700">Marcar como nova</button>
                          </form>
                        <% } else { %>
                          <form method="post" action="/academy/admin/interesses/<%= lead.id %>/respondida">
                            <button class="w-full rounded-2xl bg-emerald-600 px-4 py-3 text-sm font-black text-white">Marcar respondida</button>
                          </form>
                        <% } %>
                        <form method="post" action="/academy/admin/interesses/<%= lead.id %>/excluir" onsubmit="return confirm('Excluir esta solicitação?');">
                          <button class="w-full rounded-2xl border border-red-200 px-4 py-3 text-sm font-black text-red-700">Excluir</button>
                        </form>
                      </div>
                    </div>
                  </details>
                <% }) %>
              </div>
            </details>
          <% }) %>
        </div>
      </section>

      <section class="mt-8 rounded-[2rem] bg-white p-6 shadow-sm md:p-8">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="max-w-3xl">
            <p class="text-xs font-black uppercase tracking-[0.22em] text-[#b88b38]">Apresentação reservada</p>
            <h2 class="mt-3 text-3xl font-black">Solicitações enviadas pela página /apresentacao</h2>
            <p class="mt-3 text-slate-600">
              Aqui ficam apenas os contatos que preencheram o formulário completo da apresentação de venda.
            </p>
          </div>
          <a href="/apresentacao" target="_blank" rel="noopener" class="rounded-2xl border border-[#31513d] px-4 py-3 text-sm font-black text-[#31513d]">
            Ver apresentação
          </a>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <div class="rounded-3xl bg-slate-50 p-5">
            <div class="text-xs font-black uppercase tracking-widest text-slate-400">Solicitações</div>
            <div class="mt-2 text-3xl font-black"><%= presentationLeads.length %></div>
          </div>
          <div class="rounded-3xl bg-slate-50 p-5">
            <div class="text-xs font-black uppercase tracking-widest text-slate-400">Novas</div>
            <div class="mt-2 text-3xl font-black"><%= presentationLeadGroups.newLeads.length %></div>
          </div>
          <div class="rounded-3xl bg-slate-50 p-5">
            <div class="text-xs font-black uppercase tracking-widest text-slate-400">Respondidas</div>
            <div class="mt-2 text-3xl font-black"><%= presentationLeadGroups.respondedLeads.length %></div>
          </div>
        </div>

        <div class="mt-6 grid gap-4">
          <% if (!presentationLeads.length) { %>
            <div class="rounded-3xl border border-dashed border-slate-200 bg-slate-50 p-8 text-center text-slate-500">
              Nenhuma solicitação pela apresentação até o momento.
            </div>
          <% } %>

          <% [
            { title: 'Novas', leads: presentationLeadGroups.newLeads, tone: 'border-[#d6a84f]/40 bg-[#fff9ed]', empty: 'Nenhuma solicitação nova da apresentação.' },
            { title: 'Respondidas', leads: presentationLeadGroups.respondedLeads, tone: 'border-emerald-200 bg-emerald-50', empty: 'Nenhuma solicitação da apresentação marcada como respondida.' },
          ].forEach(function(group) { %>
            <details class="overflow-hidden rounded-[1.5rem] border <%= group.tone %>" <%= group.title === 'Novas' ? 'open' : '' %>>
              <summary class="flex cursor-pointer items-center justify-between gap-3 px-5 py-4">
                <span class="text-lg font-black"><%= group.title %></span>
                <span class="rounded-full bg-white px-3 py-1 text-xs font-black text-slate-600"><%= group.leads.length %></span>
              </summary>
              <div class="grid gap-3 border-t border-white/70 p-4">
                <% if (!group.leads.length) { %>
                  <div class="rounded-2xl bg-white/80 p-5 text-center text-sm font-bold text-slate-500"><%= group.empty %></div>
                <% } %>

                <% group.leads.forEach(function(lead) { %>
                  <% const fullName = [lead.firstName, lead.lastName].filter(Boolean).join(' '); %>
                  <% const whatsappDigits = String(lead.whatsapp || '').replace(/\D/g, ''); %>
                  <details class="overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm">
                    <summary class="cursor-pointer px-5 py-4">
                      <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                          <div class="flex flex-wrap items-center gap-2">
                            <span class="rounded-full bg-[#f3ead8] px-3 py-1 text-[11px] font-black uppercase tracking-widest text-[#8c651f]">Apresentação</span>
                            <span class="text-xs font-bold text-slate-400"><%= lead.createdAt.toLocaleString('pt-BR') %></span>
                          </div>
                          <h3 class="mt-2 text-xl font-black"><%= fullName || 'Sem nome' %></h3>
                          <p class="mt-1 text-sm font-bold text-slate-500">
                            <%= [lead.city, lead.state, lead.country].filter(Boolean).join(' / ') || 'Local não informado' %>
                          </p>
                        </div>
                        <span class="text-sm font-black text-[#31513d]">Abrir detalhes</span>
                      </div>
                    </summary>

                    <div class="grid gap-4 border-t border-slate-100 p-5 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-start">
                      <div class="grid gap-3 text-sm text-slate-600 md:grid-cols-3">
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Gatil</span>
                          <strong class="text-slate-800"><%= lead.catteryName || 'Ainda não possui' %></strong>
                        </div>
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Raça</span>
                          <strong class="text-slate-800"><%= lead.hasCattery === 'Sim' ? (lead.breed || '-') : (lead.wantsStart || '-') %></strong>
                        </div>
                        <div>
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Origem</span>
                          <strong class="text-slate-800"><%= lead.referralSource || '-' %></strong>
                        </div>
                        <div class="md:col-span-3">
                          <span class="block text-xs font-black uppercase tracking-widest text-slate-400">Mensagem e dados de inscrição</span>
                          <p class="mt-1 whitespace-pre-line leading-7"><%= lead.message || '-' %></p>
                        </div>
                      </div>

                      <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-1">
                        <a href="mailto:<%= lead.email %>" class="rounded-2xl bg-[#31513d] px-4 py-3 text-center text-sm font-black text-white"><%= lead.email %></a>
                        <% if (whatsappDigits) { %>
                          <a href="https://wa.me/<%= whatsappDigits %>" target="_blank" rel="noopener" class="rounded-2xl border border-[#31513d] px-4 py-3 text-center text-sm font-black text-[#31513d]">
                            WhatsApp <%= lead.whatsapp %>
                          </a>
                        <% } %>
                        <% if (String(lead.status || 'NEW').toUpperCase() === 'RESPONDED') { %>
                          <form method="post" action="/academy/admin/interesses/<%= lead.id %>/nova">
                            <button class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm font-black text-slate-700">Marcar como nova</button>
                          </form>
                        <% } else { %>
                          <form method="post" action="/academy/admin/interesses/<%= lead.id %>/respondida">
                            <button class="w-full rounded-2xl bg-emerald-600 px-4 py-3 text-sm font-black text-white">Marcar respondida</button>
                          </form>
                        <% } %>
                        <form method="post" action="/academy/admin/interesses/<%= lead.id %>/excluir" onsubmit="return confirm('Excluir esta solicitação?');">
                          <button class="w-full rounded-2xl border border-red-200 px-4 py-3 text-sm font-black text-red-700">Excluir</button>
                        </form>
                      </div>
                    </div>
                  </details>
                <% }) %>
              </div>
            </details>
          <% }) %>
        </div>
      </section>
    </main>
    <script>
      (() => {
        document.querySelectorAll('input[type="file"][accept*="image"]').forEach((input) => {
          input.addEventListener("change", () => {
            const file = input.files && input.files[0];
            if (!file) return;
            const url = URL.createObjectURL(file);
            let preview = input.parentElement?.querySelector(".admin-upload-live-preview");
            if (!preview) {
              preview = document.createElement("img");
              preview.className = "admin-upload-live-preview";
              preview.alt = "Prévia da nova imagem selecionada";
              input.insertAdjacentElement("afterend", preview);
            }
            preview.src = url;
          });
        });
      })();

      (() => {
        const list = document.querySelector("[data-presentation-guests]");
        const addButton = document.querySelector("[data-add-presentation-guest]");
        if (!list || !addButton) return;

        const refreshGuestCards = () => {
          list.querySelectorAll("[data-presentation-guest-card]").forEach((card, index) => {
            const orderInput = card.querySelector('input[name="presentationGuestSortOrder"]');
            const nameInput = card.querySelector('input[name="presentationGuestName"]');
            const statusSelect = card.querySelector('select[name="presentationGuestStatus"]');
            const summaryName = card.querySelector("summary span:first-child");
            const summaryStatus = card.querySelector("summary span:last-child");
            if (orderInput && !orderInput.value) orderInput.value = String(index + 1);
            if (summaryName) summaryName.textContent = nameInput?.value?.trim() || "Novo profissional";
            if (summaryStatus) {
              const order = orderInput?.value || String(index + 1);
              summaryStatus.textContent = `${statusSelect?.value || "Convidado"} · Ordem ${order}`;
            }
          });
        };

        const wireRemoveButtons = () => {
          list.querySelectorAll("[data-remove-presentation-guest]").forEach((button) => {
            if (button.dataset.wired) return;
            button.dataset.wired = "1";
            button.addEventListener("click", () => {
              const cards = list.querySelectorAll("[data-presentation-guest-card]");
              const card = button.closest("[data-presentation-guest-card]");
              if (cards.length <= 1) {
                card.querySelectorAll("input, textarea").forEach((field) => {
                  field.value = "";
                });
                card.querySelectorAll("select").forEach((select) => {
                  select.value = "Convidado";
                });
                refreshGuestCards();
                return;
              }
              card.remove();
              refreshGuestCards();
            });
          });
        };

        addButton.addEventListener("click", () => {
          const template = list.querySelector("[data-presentation-guest-card]");
          if (!template) return;
          const clone = template.cloneNode(true);
          clone.querySelectorAll("input, textarea").forEach((field) => {
            field.value = "";
          });
          clone.querySelectorAll("select").forEach((select) => {
            select.value = "Convidado";
          });
          if ("open" in clone) clone.open = false;
          clone.querySelectorAll("[data-remove-presentation-guest]").forEach((button) => {
            delete button.dataset.wired;
          });
          list.appendChild(clone);
          refreshGuestCards();
          wireRemoveButtons();
        });

        list.addEventListener("input", refreshGuestCards);
        list.addEventListener("change", refreshGuestCards);
        refreshGuestCards();
        wireRemoveButtons();
      })();
    </script>
  </body>
</html>

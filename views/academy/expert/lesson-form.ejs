<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="bg-[#f8faf7] text-[#1f2933]">
    <main class="mx-auto max-w-6xl px-5 py-8">
      <nav class="flex flex-wrap items-center justify-between gap-3">
        <a href="/academy/especialista" class="text-sm font-black text-[#31513d]">← Painel do especialista</a>
        <% if (lesson && lesson.status === 'PUBLISHED') { %><a href="/academy/app/aulas/<%= lesson.slug %>" class="text-sm font-bold text-[#b9892e]">Ver aula</a><% } %>
      </nav>

      <form method="post" action="<%= lesson ? '/academy/especialista/aulas/' + lesson.id : '/academy/especialista/aulas' %>" class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
        <section class="rounded-[28px] bg-white p-6 shadow-sm">
          <div class="text-xs font-black uppercase tracking-[0.22em] text-[#b9892e]">Conteúdo do especialista</div>
          <h1 class="mt-3 text-4xl font-black"><%= lesson ? 'Editar aula' : 'Nova aula' %></h1>
          <p class="mt-2 text-slate-500">Salve como rascunho enquanto trabalha, ou envie para revisão quando estiver pronto.</p>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Título
              <input name="title" value="<%= lesson ? lesson.title : '' %>" required class="rounded-2xl border border-slate-200 p-4 text-lg font-black" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Slug
              <input name="slug" value="<%= lesson ? lesson.slug : '' %>" class="rounded-2xl border border-slate-200 p-4" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600 md:col-span-2">
              Resumo
              <textarea name="summary" rows="3" class="rounded-2xl border border-slate-200 p-4"><%= lesson ? (lesson.summary || '') : '' %></textarea>
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600 md:col-span-2">
              Conteúdo da aula
              <textarea name="richText" rows="14" class="academy-richtext rounded-2xl border border-slate-200 p-4"><%= lesson ? (lesson.richText || '') : '' %></textarea>
            </label>
            <input type="hidden" name="contentJson" value="<%= lesson ? (lesson.contentJson || '') : '' %>" />
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Imagem/capa URL
              <input name="imageUrl" value="<%= lesson ? (lesson.imageUrl || '') : '' %>" class="rounded-2xl border border-slate-200 p-4" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Vídeo embed
              <input name="videoEmbed" value="<%= lesson ? (lesson.videoEmbed || '') : '' %>" class="rounded-2xl border border-slate-200 p-4" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Meta title
              <input name="metaTitle" value="<%= lesson ? (lesson.metaTitle || '') : '' %>" class="rounded-2xl border border-slate-200 p-4" />
            </label>
            <label class="grid gap-2 text-sm font-bold text-slate-600">
              Meta description
              <input name="metaDescription" value="<%= lesson ? (lesson.metaDescription || '') : '' %>" class="rounded-2xl border border-slate-200 p-4" />
            </label>
          </div>
        </section>

        <aside class="grid content-start gap-5">
          <section class="rounded-[28px] bg-white p-5 shadow-sm">
            <h2 class="text-xl font-black">Configuração</h2>
            <div class="mt-4 grid gap-3">
              <label class="grid gap-2 text-sm font-bold text-slate-600">
                Módulo
                <select name="moduleId" required class="rounded-2xl border border-slate-200 p-3">
                  <% modules.forEach(function(module) { %>
                    <option value="<%= module.id %>" <%= lesson && lesson.moduleId === module.id ? 'selected' : '' %>><%= module.category.title %> · <%= module.title %></option>
                  <% }) %>
                </select>
              </label>
              <label class="grid gap-2 text-sm font-bold text-slate-600">
                Nível
                <select name="level" class="rounded-2xl border border-slate-200 p-3">
                  <% Object.values(levels).filter(function(level) { return level !== 'ADMIN'; }).forEach(function(level) { %>
                    <option value="<%= level %>" <%= lesson && lesson.level === level ? 'selected' : '' %>><%= levelLabels[level] || level %></option>
                  <% }) %>
                </select>
              </label>
              <div class="grid grid-cols-2 gap-3">
                <label class="grid gap-2 text-sm font-bold text-slate-600">
                  Duração
                  <input name="durationMinutes" type="number" value="<%= lesson ? (lesson.durationMinutes || '') : '' %>" class="rounded-2xl border border-slate-200 p-3" />
                </label>
                <label class="grid gap-2 text-sm font-bold text-slate-600">
                  Leitura
                  <input name="estimatedReadingMinutes" type="number" value="<%= lesson ? (lesson.estimatedReadingMinutes || '') : '' %>" class="rounded-2xl border border-slate-200 p-3" />
                </label>
              </div>
              <label class="grid gap-2 text-sm font-bold text-slate-600">
                Status
                <select name="status" class="rounded-2xl border border-slate-200 p-3">
                  <option value="DRAFT" <%= !lesson || lesson.status === 'DRAFT' ? 'selected' : '' %>>Rascunho</option>
                  <option value="REVIEW" <%= lesson && lesson.status === 'REVIEW' ? 'selected' : '' %>>Enviar para revisão</option>
                </select>
              </label>
              <button class="rounded-2xl bg-[#31513d] p-3 font-black text-white">Salvar</button>
            </div>
          </section>

          <% if (lesson) { %>
            <section class="rounded-[28px] bg-white p-5 shadow-sm">
              <h2 class="text-xl font-black">Mídia da aula</h2>
              <% if (lesson.media && lesson.media.length) { %>
                <div class="mt-4 grid gap-2">
                  <% lesson.media.forEach(function(media) { %>
                    <a href="<%= media.url %>" target="_blank" class="rounded-2xl bg-slate-50 p-3 text-sm font-bold text-[#31513d]"><%= media.title || media.url %></a>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="mt-3 text-sm text-slate-500">Nenhum arquivo enviado.</p>
              <% } %>
            </section>
          <% } %>
        </aside>
      </form>

      <% if (lesson) { %>
        <section class="mt-6 rounded-[28px] bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-black">Enviar arquivo</h2>
          <form method="post" action="/academy/especialista/aulas/<%= lesson.id %>/midia" enctype="multipart/form-data" class="mt-4 grid gap-3 md:grid-cols-2">
            <input name="title" placeholder="Título do arquivo" class="rounded-2xl border border-slate-200 p-3" />
            <input name="altText" placeholder="Texto alternativo" class="rounded-2xl border border-slate-200 p-3" />
            <select name="type" class="rounded-2xl border border-slate-200 p-3">
              <option value="">Detectar automaticamente</option>
              <option value="IMAGE">Imagem</option>
              <option value="DOCUMENT">Documento</option>
              <option value="VIDEO">Vídeo</option>
            </select>
            <input type="file" name="file" required accept="image/*,application/pdf,video/mp4,video/webm" class="rounded-2xl border border-slate-200 bg-white p-3" />
            <button class="rounded-2xl bg-[#31513d] p-3 font-black text-white md:col-span-2">Enviar e vincular</button>
          </form>
        </section>
      <% } %>
    </main>
  </body>
</html>

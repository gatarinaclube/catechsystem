<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="bg-[#f8faf7] text-[#1f2933]">
    <main class="mx-auto max-w-6xl px-5 py-8">
      <nav class="text-sm font-bold text-slate-500">
        <a href="/academy/app" class="text-[#31513d]">Área do aluno</a>
        <span class="mx-2">/</span>
        <span>Certificados</span>
      </nav>

      <section class="mt-8 rounded-[32px] border border-slate-200 bg-white p-8 text-[#1f2933] shadow-xl">
        <div class="text-xs font-black uppercase tracking-[0.22em] text-[#b9892e]">Progresso reconhecido</div>
        <h1 class="mt-3 text-4xl font-black">Certificados</h1>
        <p class="mt-3 max-w-2xl text-slate-600">Cada aula concluída pode gerar um certificado de conclusão, registrado no seu histórico Academy.</p>
      </section>

      <section class="mt-8 grid gap-4 md:grid-cols-2">
        <% if (!certificates.length) { %>
          <div class="rounded-3xl bg-white p-8 text-slate-600 shadow-sm">Nenhum certificado emitido ainda.</div>
        <% } %>
        <% certificates.forEach(function(certificate) { %>
          <article class="rounded-[28px] border border-[#d6a84f]/40 bg-white p-6 shadow-sm">
            <div class="text-xs font-black uppercase tracking-[0.2em] text-[#b9892e]"><%= certificate.certificateNumber %></div>
            <h2 class="mt-3 text-2xl font-black"><%= certificate.title %></h2>
            <% if (certificate.lesson) { %>
              <div class="mt-2 text-sm text-slate-500"><%= certificate.lesson.module.category.title %> · <%= certificate.lesson.module.title %></div>
            <% } %>
            <div class="mt-5 text-sm font-bold text-slate-600">Emitido em <%= certificate.issuedAt.toLocaleDateString('pt-BR') %></div>
            <% if (certificate.pdfUrl) { %>
              <a href="<%= certificate.pdfUrl %>" class="mt-4 inline-block rounded-full bg-[#31513d] px-5 py-3 font-black text-white">Abrir PDF</a>
            <% } %>
          </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>

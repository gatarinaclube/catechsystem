<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-[#f8faf7] text-[#111827]">
    <main class="mx-auto max-w-7xl px-5 py-8">
      <nav class="flex flex-wrap items-center justify-between gap-3">
        <a href="/academy" class="text-xl font-black">CatBreeder <span class="text-[#b9892e]">Pro</span></a>
        <div class="flex gap-3 text-sm font-bold">
          <a href="/academy/app/biblioteca">Biblioteca</a>
          <a href="/academy/app/favoritos">Favoritos</a>
          <% if (academy.isAdmin) { %><a href="/academy/admin">Admin</a><% } %>
          <a href="/dashboard">CaTech</a>
        </div>
      </nav>

      <section class="mt-10 rounded-3xl bg-[#111827] p-7 text-white">
        <div class="text-sm uppercase tracking-[0.2em] text-[#d6a84f]"><%= academy.levelLabel %></div>
        <h1 class="mt-3 text-4xl font-black">Olá, <%= user.name.split(' ')[0] %>.</h1>
        <p class="mt-3 text-white/65">Continue sua formação como criador felino responsável.</p>
        <div class="mt-6 h-3 rounded-full bg-white/10">
          <div class="h-3 rounded-full bg-[#d6a84f]" style="width:<%= dashboard.progressPercent %>%"></div>
        </div>
        <div class="mt-3 text-sm text-white/70"><%= dashboard.completedLessons %> de <%= dashboard.totalLessons %> aulas concluídas</div>
      </section>

      <section class="mt-8 grid gap-5 md:grid-cols-3">
        <div class="rounded-3xl bg-white p-6 shadow-sm"><div class="text-sm text-slate-500">Progresso</div><div class="mt-2 text-3xl font-black"><%= dashboard.progressPercent %>%</div></div>
        <div class="rounded-3xl bg-white p-6 shadow-sm"><div class="text-sm text-slate-500">Favoritos</div><div class="mt-2 text-3xl font-black"><%= dashboard.favoriteCount %></div></div>
        <div class="rounded-3xl bg-white p-6 shadow-sm"><div class="text-sm text-slate-500">Aulas</div><div class="mt-2 text-3xl font-black"><%= dashboard.totalLessons %></div></div>
      </section>

      <section class="mt-8 grid gap-5">
        <% dashboard.catalog.forEach(function(category) { %>
          <div class="rounded-3xl bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-black"><%= category.title %></h2>
            <div class="mt-5 grid gap-4 md:grid-cols-2">
              <% category.modules.forEach(function(module) { %>
                <div class="rounded-2xl border border-slate-200 p-5">
                  <div class="font-black"><%= module.title %></div>
                  <div class="mt-3 grid gap-2">
                    <% module.lessons.forEach(function(lesson) { %>
                      <a href="/academy/app/aulas/<%= lesson.slug %>" class="flex items-center justify-between rounded-xl bg-slate-50 px-4 py-3 text-sm">
                        <span><%= lesson.title %></span>
                        <span><%= lesson.completed ? '✓' : lesson.locked ? 'Bloqueada' : 'Abrir' %></span>
                      </a>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </section>
    </main>
  </body>
</html>

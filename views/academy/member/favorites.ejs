<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-[#f8faf7] text-[#1f2933]">
    <main class="mx-auto max-w-6xl px-5 py-8">
      <nav class="text-sm font-bold text-slate-500">
        <a href="/academy/app" class="text-[#31513d]">Área do aluno</a>
        <span class="mx-2">/</span>
        <span>Favoritos</span>
      </nav>
      <section class="mt-8 rounded-[28px] bg-white p-7 shadow-sm">
        <div class="text-xs font-black uppercase tracking-[0.2em] text-[#b9892e]">Consulta rápida</div>
        <h1 class="mt-3 text-4xl font-black">Favoritos</h1>
        <p class="mt-3 text-slate-600">Aulas salvas para voltar quando precisar.</p>
      </section>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <% if (!lessons.length) { %>
          <div class="rounded-3xl bg-white p-8 text-slate-600 shadow-sm">Nenhuma aula favoritada ainda.</div>
        <% } %>
        <% lessons.forEach(function(lesson) { %>
          <a href="/academy/app/aulas/<%= lesson.slug %>" class="rounded-3xl bg-white p-6 shadow-sm">
            <div class="text-xs font-black uppercase tracking-[0.2em] text-[#b9892e]"><%= lesson.module.category.title %> · <%= lesson.module.title %></div>
            <h2 class="mt-3 text-xl font-black"><%= lesson.title %></h2>
            <p class="mt-2 text-slate-600"><%= lesson.summary || '' %></p>
          </a>
        <% }) %>
      </div>
    </main>
  </body>
</html>

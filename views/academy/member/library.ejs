<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="bg-[#f8faf7] text-[#1f2933]">
    <main class="mx-auto max-w-6xl px-5 py-8">
      <nav class="text-sm font-bold text-slate-500">
        <a href="/academy/app" class="text-[#31513d]">Área do aluno</a>
        <span class="mx-2">/</span>
        <span>Biblioteca</span>
      </nav>

      <section class="mt-8 rounded-[28px] bg-white p-7 shadow-sm">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <div class="text-xs font-black uppercase tracking-[0.2em] text-[#b9892e]">Busca inteligente</div>
            <h1 class="mt-3 text-4xl font-black">Biblioteca</h1>
            <p class="mt-2 text-slate-600">Encontre rapidamente aulas, protocolos e conteúdos premium.</p>
          </div>
          <a href="/academy/app/favoritos" class="rounded-full border border-slate-200 px-5 py-3 text-sm font-black">Favoritos</a>
        </div>
        <form method="get" class="mt-6">
          <input name="q" value="<%= query %>" placeholder="Buscar por título, resumo, categoria ou módulo..." class="w-full rounded-2xl border border-slate-200 px-5 py-4" />
        </form>
      </section>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <% if (!lessons.length) { %>
          <div class="rounded-3xl bg-white p-8 text-slate-600 shadow-sm">Nenhuma aula encontrada.</div>
        <% } %>
        <% lessons.forEach(function(lesson) { %>
          <a href="/academy/app/aulas/<%= lesson.slug %>" class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
            <div class="text-xs font-black uppercase tracking-[0.2em] text-[#b9892e]"><%= lesson.categoryTitle %> · <%= lesson.moduleTitle %></div>
            <h2 class="mt-3 text-xl font-black"><%= lesson.title %></h2>
            <p class="mt-2 text-slate-600"><%= lesson.summary || '' %></p>
            <div class="mt-5 flex flex-wrap gap-2 text-xs font-bold text-slate-500">
              <% if (lesson.durationMinutes) { %><span class="rounded-full bg-slate-100 px-3 py-1"><%= lesson.durationMinutes %> min</span><% } %>
              <% if (lesson.estimatedReadingMinutes) { %><span class="rounded-full bg-slate-100 px-3 py-1"><%= lesson.estimatedReadingMinutes %> min leitura</span><% } %>
              <% if (lesson.locked) { %><span class="rounded-full bg-slate-100 px-3 py-1">Bloqueada</span><% } %>
            </div>
          </a>
        <% }) %>
      </div>
    </main>
  </body>
</html>

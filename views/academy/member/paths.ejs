<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="bg-[#f8faf7] text-[#1f2933]">
    <main class="mx-auto max-w-7xl px-5 py-8">
      <nav class="flex flex-wrap items-center justify-between gap-3">
        <a href="/academy/app" class="text-xl font-black">CatBreeder <span class="text-[#b9892e]">Pro</span></a>
        <div class="flex flex-wrap gap-3 text-sm font-bold">
          <a href="/academy/app">Dashboard</a>
          <a href="/academy/app/biblioteca">Biblioteca</a>
          <a href="/academy/app/favoritos">Favoritos</a>
          <a href="/academy/app/certificados">Certificados</a>
          <a href="/dashboard">CaTech</a>
        </div>
      </nav>

      <section class="mt-10 rounded-[32px] border border-slate-200 bg-white p-8 text-[#1f2933] shadow-xl md:p-10">
        <div class="max-w-3xl">
          <div class="text-sm uppercase tracking-[0.22em] text-[#b9892e]">Trilhas de aprendizagem</div>
          <h1 class="mt-4 text-4xl font-black md:text-5xl">Caminhos claros para evoluir como criador.</h1>
          <p class="mt-4 text-slate-600">Cada trilha agrupa módulos e aulas em uma ordem prática. Acompanhe o progresso, retome a próxima aula e veja quais conteúdos dependem do seu plano.</p>
        </div>
      </section>

      <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        <% if (!paths.length) { %>
          <div class="rounded-[28px] bg-white p-6 text-slate-500 shadow-sm">Nenhuma trilha publicada no momento.</div>
        <% } %>
        <% paths.forEach(function(path) { %>
          <article class="flex min-h-[320px] flex-col rounded-[28px] bg-white p-6 shadow-sm">
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="text-xs font-black uppercase tracking-[0.22em] text-[#b9892e]"><%= path.completed ? 'Concluída' : path.availableLessons ? 'Em evolução' : 'Bloqueada' %></div>
                <h2 class="mt-3 text-2xl font-black"><%= path.title %></h2>
              </div>
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-[#31513d]/10 text-xl font-black text-[#31513d]"><%= path.progressPercent %>%</div>
            </div>
            <p class="mt-4 line-clamp-3 text-sm text-slate-500"><%= path.description || 'Trilha CatBreeder Pro com conteúdos organizados por módulos.' %></p>
            <div class="mt-6 h-2 rounded-full bg-slate-100">
              <div class="h-2 rounded-full bg-[#d6a84f]" style="width:<%= path.progressPercent %>%"></div>
            </div>
            <div class="mt-4 grid grid-cols-3 gap-2 text-center text-sm">
              <div class="rounded-2xl bg-slate-50 p-3"><div class="font-black"><%= path.totalLessons %></div><div class="text-xs text-slate-500">aulas</div></div>
              <div class="rounded-2xl bg-slate-50 p-3"><div class="font-black"><%= path.completedLessons %></div><div class="text-xs text-slate-500">feitas</div></div>
              <div class="rounded-2xl bg-slate-50 p-3"><div class="font-black"><%= path.modules.length %></div><div class="text-xs text-slate-500">módulos</div></div>
            </div>
            <div class="mt-5 flex-1 rounded-2xl bg-[#f8faf7] p-4">
              <div class="text-xs font-black uppercase tracking-widest text-slate-400">Próximo passo</div>
              <% if (path.nextLesson) { %>
                <div class="mt-2 font-black"><%= path.nextLesson.title %></div>
                <div class="mt-1 text-sm text-slate-500"><%= path.activeModule ? path.activeModule.title : '' %></div>
              <% } else { %>
                <div class="mt-2 text-sm text-slate-500"><%= path.completed ? 'Trilha concluída.' : 'Sem aula liberada para este plano.' %></div>
              <% } %>
            </div>
            <a href="/academy/app/trilhas/<%= path.slug %>" class="mt-5 inline-flex justify-center rounded-full bg-[#31513d] px-5 py-3 text-sm font-black text-white">Abrir trilha</a>
          </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>

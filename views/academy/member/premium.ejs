<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="bg-[#f8faf7] text-[#111827]">
    <main class="mx-auto max-w-7xl px-5 py-8">
      <nav class="flex flex-wrap items-center justify-between gap-3">
        <a href="/academy/app" class="text-xl font-black">CatBreeder <span class="text-[#b9892e]">Pro</span></a>
        <div class="flex flex-wrap gap-3 text-sm font-bold">
          <a href="/academy/app">Dashboard</a>
          <a href="/academy/app/trilhas">Trilhas</a>
          <a href="/academy/app/biblioteca">Biblioteca</a>
          <a href="/academy/app/certificados">Certificados</a>
          <a href="/dashboard">CaTech</a>
        </div>
      </nav>

      <section class="mt-10 overflow-hidden rounded-[32px] bg-[#111827] text-white shadow-2xl">
        <div class="grid gap-8 p-8 lg:grid-cols-[minmax(0,1fr)_360px] lg:p-10">
          <div>
            <div class="text-sm uppercase tracking-[0.22em] text-[#d6a84f]">Premium Lab</div>
            <h1 class="mt-4 text-4xl font-black md:text-5xl"><%= hub.headline %></h1>
            <p class="mt-4 max-w-2xl text-white/65"><%= hub.summary %></p>
            <div class="mt-7 flex flex-wrap gap-3">
              <a href="/academy/app/trilhas" class="rounded-full bg-[#d6a84f] px-5 py-3 text-sm font-black text-black">Continuar trilhas</a>
              <a href="/academy/app/biblioteca" class="rounded-full border border-white/20 px-5 py-3 text-sm font-black text-white">Abrir biblioteca</a>
            </div>
          </div>
          <aside class="rounded-[28px] border border-white/10 bg-white/10 p-6">
            <div class="text-sm font-bold text-white/60">Estrutura pronta para</div>
            <div class="mt-4 grid gap-3">
              <div class="rounded-2xl bg-black/20 p-4">
                <div class="text-2xl font-black"><%= hub.features.length %></div>
                <div class="text-xs text-white/60">recursos mapeados</div>
              </div>
              <div class="rounded-2xl bg-black/20 p-4">
                <div class="text-2xl font-black">CMS</div>
                <div class="text-xs text-white/60">sem duplicar usuários</div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        <% hub.features.forEach(function(feature) { %>
          <article id="<%= feature.key %>" class="rounded-[28px] bg-white p-6 shadow-sm">
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="text-xs font-black uppercase tracking-[0.22em] text-[#b9892e]"><%= feature.eyebrow %></div>
                <h2 class="mt-3 text-2xl font-black"><%= feature.title %></h2>
              </div>
              <span class="rounded-full bg-[#31513d]/10 px-3 py-1 text-xs font-black text-[#31513d]"><%= feature.status %></span>
            </div>
            <p class="mt-4 text-sm text-slate-500"><%= feature.description %></p>
            <div class="mt-6 h-2 rounded-full bg-slate-100">
              <div class="h-2 rounded-full bg-[#d6a84f]" style="width:<%= feature.readiness %>%"></div>
            </div>
            <div class="mt-3 text-xs font-bold text-slate-400">Preparação técnica: <%= feature.readiness %>%</div>
          </article>
        <% }) %>
      </section>

      <section class="mt-8 rounded-[28px] bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-2xl font-black">Próximos marcos</h2>
            <p class="mt-1 text-sm text-slate-500">Lista de decisões para transformar os recursos planejados em produto ativo.</p>
          </div>
          <span class="rounded-full bg-[#fff7df] px-4 py-2 text-xs font-black uppercase tracking-widest text-[#8a641d]">Fase futura</span>
        </div>
        <div class="mt-5 grid gap-3">
          <% hub.nextMilestones.forEach(function(item, index) { %>
            <div class="grid gap-3 rounded-2xl border border-slate-200 p-4 md:grid-cols-[42px_minmax(0,1fr)] md:items-center">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#31513d]/10 font-black text-[#31513d]"><%= index + 1 %></div>
              <div class="font-bold"><%= item %></div>
            </div>
          <% }) %>
        </div>
      </section>
    </main>
  </body>
</html>

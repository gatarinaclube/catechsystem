<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include("../partials/seo", { seo, pageTitle }) %>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-white text-[#1f2933]">
    <main class="mx-auto max-w-6xl px-5 py-10">
      <a href="/academy" class="text-sm font-bold text-[#31513d]">← CatBreeder Pro</a>
      <h1 class="mt-10 text-5xl font-black">Conteúdos</h1>
      <div class="mt-8 grid gap-5">
        <% if (!catalog.length) { %>
          <div class="rounded-3xl border border-slate-200 p-8 text-slate-600">Conteúdos em preparação.</div>
        <% } %>
        <% catalog.forEach(function(category) { %>
          <section class="rounded-3xl border border-slate-200 p-6">
            <h2 class="text-2xl font-black"><%= category.title %></h2>
            <p class="mt-2 text-slate-600"><%= category.description || '' %></p>
            <div class="mt-5 grid gap-3 md:grid-cols-2">
              <% category.modules.forEach(function(module) { %>
                <div class="rounded-2xl bg-slate-50 p-5">
                  <div class="font-black"><%= module.title %></div>
                  <div class="mt-2 text-sm text-slate-500"><%= module.lessons.length %> aula(s)</div>
                </div>
              <% }) %>
            </div>
          </section>
        <% }) %>
      </div>
    </main>
  </body>
</html>

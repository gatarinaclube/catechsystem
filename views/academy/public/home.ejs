<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include("../partials/seo", { seo, pageTitle }) %>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="bg-[#f8faf7] text-[#1f2933]">
    <main class="min-h-screen overflow-hidden">
      <section class="relative px-5 py-8 md:px-10">
        <div class="absolute inset-0 bg-[linear-gradient(135deg,#ffffff,#f8faf7_56%,#eef5ee)]"></div>
        <div class="relative mx-auto max-w-7xl">
          <nav class="flex items-center justify-between gap-4">
            <a href="/academy" class="text-xl font-black tracking-tight">CatBreeder <span class="academy-gold">Pro</span></a>
            <div class="hidden items-center gap-6 text-sm font-bold text-slate-600 md:flex">
              <a href="/academy/sobre">Sobre</a>
              <a href="/academy/planos">Planos</a>
              <a href="/academy/conteudos">Conteúdos</a>
              <a href="/academy/faq">FAQ</a>
            </div>
            <a href="/academy/login" class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-[#31513d] shadow-sm">Entrar</a>
          </nav>

          <div class="grid min-h-[78vh] items-center gap-10 py-14 md:grid-cols-[1.1fr_.9fr]">
            <div>
              <div class="mb-5 inline-flex rounded-full border border-[#d6a84f]/35 bg-[#fff7df] px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-[#8a641d]">
                Academy Gatarina / CaTech
              </div>
              <h1 class="max-w-4xl text-5xl font-black leading-[0.95] tracking-tight md:text-7xl">
                Formação premium para criadores felinos responsáveis.
              </h1>
              <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
                Aulas, protocolos, biblioteca e trilhas práticas para profissionalizar manejo, saúde, reprodução e gestão do gatil.
              </p>
              <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                <a href="/academy/cadastro" class="rounded-full bg-[#31513d] px-6 py-3 text-center font-black text-white shadow-sm">Começar agora</a>
                <a href="/academy/conteudos" class="rounded-full border border-slate-200 bg-white px-6 py-3 text-center font-bold text-[#31513d] shadow-sm">Ver conteúdos</a>
              </div>
            </div>

            <div class="rounded-3xl border border-slate-200 bg-white/85 p-6 shadow-xl">
              <div class="rounded-2xl bg-[#f8faf7] p-5">
                <div class="text-sm uppercase tracking-[0.25em] text-[#b9892e]">Trilha em destaque</div>
                <h2 class="mt-3 text-3xl font-black">Gatil de Alta Performance</h2>
                <div class="mt-5 grid gap-3">
                  <% ["Reprodução ética", "Sanidade e prevenção", "Gestão financeira", "Documentos e processos"].forEach(function(item, index) { %>
                    <div class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white p-4">
                      <span><%= item %></span>
                      <span class="rounded-full bg-[#31513d]/10 px-3 py-1 text-xs font-black text-[#31513d]"><%= index + 1 %></span>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white px-5 py-16 text-[#1f2933] md:px-10">
        <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-3">
          <% [
            ["Método", "Aulas diretas para aplicar no manejo real do gatil."],
            ["Biblioteca", "Conteúdos consultivos para rotina, saúde e gestão."],
            ["Ecossistema", "Integrado ao CaTech System e preparado para evolução SaaS."]
          ].forEach(function(card) { %>
            <div class="rounded-3xl border border-slate-200 p-6 shadow-sm">
              <h3 class="text-xl font-black"><%= card[0] %></h3>
              <p class="mt-3 text-slate-600"><%= card[1] %></p>
            </div>
          <% }) %>
        </div>
      </section>
    </main>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Planos | CatBreeder Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="bg-[#f8faf7] text-[#111827]">
    <main class="mx-auto max-w-7xl px-5 py-10">
      <a href="/academy" class="text-sm font-bold text-[#31513d]">← CatBreeder Pro</a>
      <div class="mt-10 max-w-3xl">
        <h1 class="text-5xl font-black">Planos preparados para escalar.</h1>
        <p class="mt-4 text-slate-600">Estrutura pronta para Mercado Pago, PIX, cartão e recorrência.</p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <% const fallback = [
          { name: "Mensal", description: "Acesso essencial à academy.", priceCents: 9900, billingCycle: "MONTHLY", featured: false },
          { name: "Anual", description: "Melhor custo para evolução contínua.", priceCents: 99900, billingCycle: "YEARLY", featured: true },
          { name: "Premium", description: "Conteúdos avançados e trilhas exclusivas.", priceCents: 149900, billingCycle: "YEARLY", featured: false },
        ]; %>
        <% (plans.length ? plans : fallback).forEach(function(plan) { %>
          <div class="rounded-3xl border <%= plan.featured ? 'border-[#d6a84f] bg-[#111827] text-white' : 'border-slate-200 bg-white' %> p-7 shadow-sm">
            <div class="text-sm font-bold uppercase tracking-[0.2em] <%= plan.featured ? 'text-[#d6a84f]' : 'text-slate-500' %>"><%= plan.billingCycle === 'YEARLY' ? 'Anual' : 'Mensal' %></div>
            <h2 class="mt-3 text-3xl font-black"><%= plan.name %></h2>
            <p class="mt-3 <%= plan.featured ? 'text-white/70' : 'text-slate-600' %>"><%= plan.description || 'Plano CatBreeder Pro.' %></p>
            <div class="mt-6 text-4xl font-black">R$ <%= (Number(plan.priceCents || 0) / 100).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
            <a href="/academy/cadastro" class="mt-6 block rounded-full bg-[#d6a84f] px-5 py-3 text-center font-black text-black">Escolher plano</a>
          </div>
        <% }) %>
      </div>
    </main>
  </body>
</html>

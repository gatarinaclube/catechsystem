<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include("../partials/seo", { seo, pageTitle }) %>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="bg-[#f8faf7] text-[#111827]">
    <main class="mx-auto max-w-7xl px-5 py-10">
      <% function features(plan) { try { const parsed = JSON.parse(plan.featuresJson || '[]'); return Array.isArray(parsed) ? parsed : []; } catch (err) { return []; } } %>
      <% function cycleLabel(cycle) { return cycle === 'FREE' ? 'Gratuito' : cycle === 'YEARLY' ? 'Anual' : cycle === 'PREMIUM' ? 'Premium' : 'Mensal'; } %>
      <% function priceLabel(plan) { return Number(plan.priceCents || 0) === 0 ? 'R$ 0,00' : 'R$ ' + (Number(plan.priceCents || 0) / 100).toLocaleString('pt-BR', { minimumFractionDigits: 2 }); } %>

      <a href="/academy" class="text-sm font-bold text-[#31513d]">← CatBreeder Pro</a>
      <section class="mt-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_420px] lg:items-end">
        <div>
          <div class="text-xs font-black uppercase tracking-[0.22em] text-[#b9892e]">Assinaturas</div>
          <h1 class="mt-4 text-5xl font-black">Planos preparados para crescer com a Academy.</h1>
          <p class="mt-4 max-w-2xl text-slate-600">A estrutura já está pronta para Mercado Pago, PIX, cartão e recorrência. A ativação do acesso é feita pelo administrador até a integração de pagamento entrar em produção.</p>
        </div>
        <div class="rounded-[28px] bg-[#111827] p-6 text-white shadow-2xl">
          <div class="text-sm font-bold text-[#d6a84f]">Status do seu acesso</div>
          <div class="mt-3 text-2xl font-black"><%= academy.hasMemberAccess ? 'Acesso ativo' : 'Aguardando ativação' %></div>
          <p class="mt-2 text-sm text-white/65"><%= academy.subscription ? 'Assinatura vinculada ao seu usuário.' : 'Escolha um plano e solicite a liberação.' %></p>
        </div>
      </section>

      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        <% const fallback = [
          { name: "Gratuito", description: "Conteúdos abertos e introdutórios.", priceCents: 0, billingCycle: "FREE", featured: false, accessLevel: "VISITOR", featuresJson: '["Conteúdos abertos","Newsletter","Materiais introdutórios"]' },
          { name: "Mensal", description: "Acesso essencial à Academy.", priceCents: 9900, billingCycle: "MONTHLY", featured: false, accessLevel: "STUDENT", featuresJson: '["Aulas premium","Favoritos","Progresso do aluno"]' },
          { name: "Anual", description: "Melhor custo para evolução contínua.", priceCents: 99000, billingCycle: "YEARLY", featured: true, accessLevel: "STUDENT", featuresJson: '["Aulas premium","Biblioteca","Atualizações"]' },
          { name: "Premium", description: "Conteúdos avançados e trilhas exclusivas.", priceCents: 14900, billingCycle: "PREMIUM", featured: false, accessLevel: "PREMIUM", featuresJson: '["Conteúdo avançado","Trilhas premium","Certificados futuros"]' },
        ]; %>
        <% (plans.length ? plans : fallback).forEach(function(plan) { %>
          <div class="rounded-[28px] border <%= plan.featured ? 'border-[#d6a84f] bg-[#111827] text-white' : 'border-slate-200 bg-white' %> p-7 shadow-sm">
            <div class="text-sm font-bold uppercase tracking-[0.2em] <%= plan.featured ? 'text-[#d6a84f]' : 'text-slate-500' %>"><%= cycleLabel(plan.billingCycle) %></div>
            <h2 class="mt-3 text-3xl font-black"><%= plan.name %></h2>
            <p class="mt-3 <%= plan.featured ? 'text-white/70' : 'text-slate-600' %>"><%= plan.description || 'Plano CatBreeder Pro.' %></p>
            <div class="mt-6 text-4xl font-black"><%= priceLabel(plan) %></div>
            <div class="mt-2 text-sm <%= plan.featured ? 'text-white/60' : 'text-slate-500' %>">Acesso: <%= plan.accessLevel || 'STUDENT' %></div>
            <div class="mt-6 grid gap-2">
              <% features(plan).forEach(function(item) { %>
                <div class="rounded-2xl <%= plan.featured ? 'bg-white/10' : 'bg-slate-50' %> px-4 py-3 text-sm font-bold">✓ <%= item %></div>
              <% }) %>
            </div>
            <a href="/academy/cadastro" class="mt-6 block rounded-full bg-[#d6a84f] px-5 py-3 text-center font-black text-black">Escolher plano</a>
          </div>
        <% }) %>
      </div>
    </main>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include("../partials/seo", { seo, pageTitle }) %>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body
    class="gatofilia-public gatofilia-portal title-<%= settings.portalTitleSize || 'medium' %>"
    style="--portal-font: '<%= settings.portalFontFamily || 'Inter' %>'; --portal-text: <%= settings.portalTextColor || '#1f2933' %>; --portal-heading: <%= settings.portalHeadingColor || '#171717' %>; --portal-accent: <%= settings.portalAccentColor || '#a97824' %>; --portal-heading-weight: <%= settings.portalHeadingWeight || '900' %>; --portal-heading-style: <%= settings.portalHeadingItalic ? 'italic' : 'normal' %>;"
  >
    <header class="gatofilia-portal-header">
      <a class="gatofilia-portal-logo" href="/" aria-label="Gatofilia">
        <img src="<%= settings.portalLogoUrl || '/uploads/academy/gatofilia-main-logo-360.png' %>" alt="Gatofilia" width="360" height="180" decoding="async" />
      </a>
      <button class="gatofilia-menu-toggle" type="button" aria-controls="gatofiliaPortalMenu" aria-expanded="false">
        <span></span><span></span><span></span><strong>Menu</strong>
      </button>
      <nav id="gatofiliaPortalMenu" aria-label="Menu Gatofilia">
        <a href="/">Início</a>
        <a href="#noticias">Notícias</a>
        <a href="#materias">Matérias</a>
      </nav>
    </header>

    <main class="gatofilia-portal-main">
      <% const bannersA = Array.isArray(settings.portalBannerA) ? settings.portalBannerA : [settings.portalBannerA || {}, {}]; %>
      <section class="gatofilia-ad-grid gatofilia-ad-grid-a" aria-label="Banners A">
        <% bannersA.slice(0, 2).forEach(function(banner) { %>
          <article class="gatofilia-ad gatofilia-ad-a">
            <% if (banner.imageUrl) { %>
              <a href="<%= banner.linkUrl || '#' %>" <%= banner.linkUrl ? 'target="_blank" rel="noopener"' : '' %>>
                <img src="<%= banner.imageUrl %>" alt="<%= banner.altText || 'Banner A' %>" width="900" height="260" loading="eager" decoding="async" style="object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; --banner-scale: <%= Number(banner.scale || 100) / 100 %>;" />
              </a>
            <% } else { %>
              <div>Banner A</div>
            <% } %>
          </article>
        <% }) %>
      </section>

      <% const portalRows = settings.portalNewsRows || []; %>
      <% const rowArticles = portalRows.map(function(row) { return row.left || {}; }).filter(function(article) { return article.title || article.imageUrl || article.body || article.externalUrl; }); %>
      <% const allArticles = (settings.portalFeatured || []).concat(rowArticles); %>
      <% let featuredArticles = allArticles.filter(function(article) { return (article.placement || 'featured') === 'featured'; }); %>
      <% if (!featuredArticles.length && allArticles.length) featuredArticles = [allArticles[0]]; %>
      <% const sideArticles = allArticles.filter(function(article) { return article.placement === 'side'; }); %>
      <% const listArticles = allArticles.filter(function(article) { return article.placement === 'list'; }); %>
      <% const archiveArticles = allArticles.filter(function(article) { return article.placement === 'archive'; }); %>

      <section id="noticias" class="gatofilia-featured-news">
        <div class="gatofilia-featured-carousel" data-featured-carousel data-interval="<%= Number(settings.portalCarouselSeconds || 7) * 1000 %>">
          <% featuredArticles.forEach(function(mainArticle, index) { %>
            <a class="gatofilia-featured-main <%= index === 0 ? 'is-active' : '' %>" href="<%= articleUrl(mainArticle) %>" <%= mainArticle.externalUrl ? 'target="_blank" rel="noopener"' : '' %> data-featured-slide>
              <div class="gatofilia-news-media">
                <% if (mainArticle.videoUrl) { %>
                  <iframe src="<%= mainArticle.videoUrl %>" title="<%= mainArticle.title || 'Vídeo Gatofilia' %>" loading="lazy" allowfullscreen></iframe>
                <% } else if (mainArticle.imageUrl) { %>
                  <img src="<%= mainArticle.imageUrl %>" alt="<%= mainArticle.title || 'Matéria Gatofilia' %>" width="900" height="560" loading="lazy" decoding="async" />
                <% } else { %>
                  <div class="gatofilia-news-placeholder">Destaque</div>
                <% } %>
              </div>
              <p><%= mainArticle.category || 'Destaque' %></p>
              <h1><%= mainArticle.title || 'Gatofilia' %></h1>
              <span><%= mainArticle.subtitle || mainArticle.caption || 'Conteúdo em destaque para criadores e interessados em felinocultura.' %></span>
            </a>
          <% }) %>
          <% if (featuredArticles.length > 1) { %>
            <div class="gatofilia-carousel-dots" aria-label="Destaques">
              <% featuredArticles.forEach(function(article, index) { %>
                <button type="button" class="<%= index === 0 ? 'is-active' : '' %>" data-featured-dot aria-label="Abrir destaque <%= index + 1 %>"></button>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="gatofilia-featured-side">
          <% sideArticles.slice(0, 4).forEach(function(article) { %>
            <a href="<%= articleUrl(article) %>" <%= article.externalUrl ? 'target="_blank" rel="noopener"' : '' %>>
              <div class="gatofilia-news-media small">
                <% if (article.imageUrl) { %>
                  <img src="<%= article.imageUrl %>" alt="<%= article.title %>" width="520" height="310" loading="lazy" decoding="async" />
                <% } else { %>
                  <div class="gatofilia-news-placeholder">Notícia</div>
                <% } %>
              </div>
              <p><%= article.category || 'Gatofilia' %></p>
              <h2><%= article.title %></h2>
              <span><%= article.subtitle || article.caption || '' %></span>
            </a>
          <% }) %>
        </div>
      </section>

      <section id="patrocinadores" class="gatofilia-ad-grid gatofilia-ad-grid-b" aria-label="Banners B">
        <% (settings.portalBannerB || []).slice(0, 3).forEach(function(banner) { %>
          <article class="gatofilia-ad gatofilia-ad-b">
            <% if (banner.imageUrl) { %>
              <a href="<%= banner.linkUrl || '#' %>" <%= banner.linkUrl ? 'target="_blank" rel="noopener"' : '' %>>
                <img src="<%= banner.imageUrl %>" alt="<%= banner.altText || 'Banner B' %>" width="580" height="180" loading="lazy" decoding="async" style="object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; --banner-scale: <%= Number(banner.scale || 100) / 100 %>;" />
              </a>
            <% } else { %>
              <div>Banner B</div>
            <% } %>
          </article>
        <% }) %>
      </section>

      <section id="materias" class="gatofilia-news-layout">
        <div class="gatofilia-news-list">
          <% listArticles.forEach(function(article) { %>
            <article class="gatofilia-news-row">
              <a class="gatofilia-news-image" href="<%= articleUrl(article) %>" <%= article.externalUrl ? 'target="_blank" rel="noopener"' : '' %>>
                <% if (article.imageUrl) { %>
                  <img src="<%= article.imageUrl %>" alt="<%= article.title || 'Matéria Gatofilia' %>" width="680" height="420" loading="lazy" decoding="async" />
                <% } else { %>
                  <div class="gatofilia-news-placeholder">Matéria</div>
                <% } %>
              </a>
              <div>
                <p><%= article.category || 'Matéria' %></p>
                <a href="<%= articleUrl(article) %>" <%= article.externalUrl ? 'target="_blank" rel="noopener"' : '' %>>
                  <h2><%= article.title || 'Nova matéria Gatofilia' %></h2>
                </a>
                <span><%= article.caption || article.subtitle || '' %></span>
              </div>
            </article>
          <% }) %>
        </div>

        <aside class="gatofilia-side-text">
          <% portalRows.forEach(function(row) { %>
            <% if (row.right && (row.right.title || row.right.text)) { %>
              <article>
                <h3><%= row.right.title %></h3>
                <p><%= row.right.text %></p>
                <% if (row.right.externalUrl) { %>
                  <a href="<%= row.right.externalUrl %>" target="_blank" rel="noopener">Ler mais</a>
                <% } %>
              </article>
            <% } %>
          <% }) %>
          <% if (archiveArticles.length) { %>
            <article class="gatofilia-archive-list">
              <h3>Matérias antigas</h3>
              <ul>
                <% archiveArticles.forEach(function(article) { %>
                  <li>
                    <a href="<%= articleUrl(article) %>" <%= article.externalUrl ? 'target="_blank" rel="noopener"' : '' %>>
                      <span><%= article.category || 'Arquivo' %></span>
                      <strong><%= article.title %></strong>
                    </a>
                  </li>
                <% }) %>
              </ul>
            </article>
          <% } %>
        </aside>
      </section>

      <section class="gatofilia-ad-grid gatofilia-ad-grid-c" aria-label="Banners C">
        <% (settings.portalBannerC || []).forEach(function(banner) { %>
          <article class="gatofilia-ad gatofilia-ad-c">
            <% if (banner.imageUrl) { %>
              <a href="<%= banner.linkUrl || '#' %>" <%= banner.linkUrl ? 'target="_blank" rel="noopener"' : '' %>>
                <img src="<%= banner.imageUrl %>" alt="<%= banner.altText || 'Banner C' %>" width="420" height="130" loading="lazy" decoding="async" style="object-position: <%= banner.positionX ?? 50 %>% <%= banner.positionY ?? 50 %>%; --banner-scale: <%= Number(banner.scale || 100) / 100 %>;" />
              </a>
            <% } else { %>
              <div>Banner C</div>
            <% } %>
          </article>
        <% }) %>
      </section>
    </main>

    <footer class="gatofilia-portal-footer">
      <img src="<%= settings.portalLogoUrl || '/uploads/academy/gatofilia-main-logo-360.png' %>" alt="Gatofilia" width="260" height="140" loading="lazy" decoding="async" />
      <p>E-mail: <a href="mailto:contato@gatofilia.com.br">contato@gatofilia.com.br</a></p>
      <p>© 2026 Gatofilia. Todos os direitos reservados.</p>
    </footer>

    <script>
      (() => {
        const button = document.querySelector(".gatofilia-menu-toggle");
        const menu = document.getElementById("gatofiliaPortalMenu");
        if (!button || !menu) return;
        button.addEventListener("click", () => {
          const isOpen = menu.classList.toggle("is-open");
          button.setAttribute("aria-expanded", String(isOpen));
        });
      })();

      (() => {
        const carousel = document.querySelector("[data-featured-carousel]");
        if (!carousel) return;
        const slides = Array.from(carousel.querySelectorAll("[data-featured-slide]"));
        const dots = Array.from(carousel.querySelectorAll("[data-featured-dot]"));
        if (slides.length <= 1) return;
        const interval = Math.max(3000, Number(carousel.dataset.interval || 7000));
        let active = 0;
        const show = (index) => {
          active = index % slides.length;
          slides.forEach((slide, itemIndex) => slide.classList.toggle("is-active", itemIndex === active));
          dots.forEach((dot, itemIndex) => dot.classList.toggle("is-active", itemIndex === active));
        };
        dots.forEach((dot, index) => dot.addEventListener("click", () => show(index)));
        window.setInterval(() => show(active + 1), interval);
      })();
    </script>
  </body>
</html>

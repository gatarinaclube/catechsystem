<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <%- include("../partials/seo", { seo, pageTitle }) %>
    <link rel="stylesheet" href="/css/academy.css" />
  </head>
  <body class="gatofilia-public gatofilia-presentation-page">
    <%
      const presentationSettings = settings || {};
      const welcomeVideoUrl = presentationSettings.presentationWelcomeVideoUrl || "";
      const closingVideoUrl = presentationSettings.presentationClosingVideoUrl || "";
      const ecosystemImageUrl = presentationSettings.presentationEcosystemImageUrl || "/uploads/academy/gatofilia-ecosystem-01.png";
      const pixLabel = presentationSettings.presentationPixLabel || "PIX - R$ 2.000,00";
      const cardLabel = presentationSettings.presentationCardLabel || "Cartão - 12x R$ 200,00";
      const offerTitle = presentationSettings.presentationOfferTitle || "Exclusiva para os 10 primeiros inscritos";
      const offerNote = presentationSettings.presentationOfferNote || "Considerando os benefícios inclusos, uma parte significativa do investimento retorna em estrutura, tecnologia, associação e apoio prático.";
      const presentationGuests = Array.isArray(presentationSettings.presentationGuests) ? presentationSettings.presentationGuests : [];
      const isVideoFile = function(url) { return /\.(mp4|webm)(\?.*)?$/i.test(String(url || "")); };
    %>
    <header class="gatofilia-presentation-nav" id="gatofiliaNav">
      <a class="gatofilia-brand" href="/apresentacao" aria-label="Gatofilia">
        <img
          src="/uploads/academy/gatofilia-main-logo-360.png"
          srcset="/uploads/academy/gatofilia-main-logo-360.png 1x, /uploads/academy/gatofilia-main-logo-620.png 2x"
          width="360"
          height="360"
          decoding="async"
          alt="Gatofilia"
        />
      </a>
      <nav aria-label="Navegação da apresentação">
        <a href="#ecosistema">Ecossistema</a>
        <a href="#jornada">Jornada</a>
        <a href="#investimento">Investimento</a>
        <a href="#inscricao">Inscrição</a>
      </nav>
    </header>

    <main>
      <section class="gatofilia-presentation-hero">
        <div class="gatofilia-presentation-hero-copy reveal-on-scroll">
          <p class="gatofilia-eyebrow">Apresentação reservada</p>
          <h1>Gatofilia: um ecossistema para transformar conhecimento em resultados.</h1>
          <p>
            Uma jornada para criadores e futuros criadores que desejam construir um gatil
            com responsabilidade, planejamento, gestão e visão de excelência.
          </p>
          <div class="gatofilia-actions">
            <a class="gatofilia-button primary" href="#inscricao">Solicitar confirmação da inscrição</a>
            <a class="gatofilia-button secondary" href="#ecosistema">Entender a proposta</a>
          </div>
        </div>
        <div class="gatofilia-presentation-hero-card reveal-on-scroll">
          <span>Próxima turma</span>
          <strong>Vagas limitadas</strong>
          <p>Conteúdo, comunidade, PetGus Premium, materiais, bônus e acompanhamento em uma única jornada.</p>
        </div>
      </section>

      <section class="gatofilia-section gatofilia-welcome reveal-on-scroll">
        <div class="gatofilia-section-heading centered compact">
          <p class="gatofilia-eyebrow">Boas-vindas</p>
          <h2>Antes de decidir, veja a Gatofilia por dentro.</h2>
          <p>Conheça a Jornada Gatofilia em detalhes: nossa metodologia, os conteúdos que serão abordados, os especialistas convidados, o investimento e tudo o que você precisa para decidir se esta jornada é para você.
</p>
        </div>
        <% if (welcomeVideoUrl) { %>
          <div class="gatofilia-video-frame">
            <% if (isVideoFile(welcomeVideoUrl)) { %>
              <video src="<%= welcomeVideoUrl %>" controls preload="metadata"></video>
            <% } else { %>
              <iframe src="<%= welcomeVideoUrl %>" title="Vídeo de boas-vindas Gatofilia" loading="lazy" allowfullscreen></iframe>
            <% } %>
          </div>
        <% } else { %>
          <div class="gatofilia-video-placeholder" aria-label="Espaço reservado para vídeo de boas-vindas">
            <span>Vídeo de boas-vindas</span>
            <strong>Em breve</strong>
            <p>Apresentação da jornada, metodologia, especialistas e próximos passos.</p>
          </div>
        <% } %>
      </section>

      <section id="ecosistema" class="gatofilia-section gatofilia-ecosystem gatofilia-band-light reveal-on-scroll">
        <div class="gatofilia-section-heading centered compact">
          <p class="gatofilia-eyebrow">O que é a Gatofilia</p>
          <h2>Não é curso. Não é mentoria. Não é plataforma. É um ecossistema.</h2>
          <p>
            A Gatofilia conecta conhecimento, planejamento, gestão, comunidade e evolução contínua
            para transformar decisões melhores em resultados consistentes.
          </p>
        </div>
        <figure class="gatofilia-ecosystem-image">
          <img src="<%= ecosystemImageUrl %>" alt="Ecossistema Gatofilia" width="1536" height="1536" loading="lazy" decoding="async" />
        </figure>
      </section>

      <section id="jornada" class="gatofilia-section gatofilia-presentation-learning reveal-on-scroll">
        <div class="gatofilia-section-heading centered compact">
          <p class="gatofilia-eyebrow">O que você vai aprender</p>
          <h2>Você não aprenderá apenas a criar gatos.</h2>
          <p>Você aprenderá a construir um gatil profissional, tomar decisões com segurança e desenvolver uma criação baseada em conhecimento, planejamento e responsabilidade.</p>
        </div>
        <div class="gatofilia-presentation-modules">
          <% [
            ["Fundamentos", "História, ética, responsabilidade e estrutura de um gatil profissional."],
            ["Genética aplicada", "Pedigrees, seleção de reprodutores e planejamento genético."],
            ["Saúde felina", "Medicina preventiva, exames essenciais e protocolos sanitários."],
            ["Nutrição", "Alimentação por fase de vida, suplementação e manejo nutricional."],
            ["Reprodução", "Planejamento, gestação, parto e desenvolvimento neonatal."],
            ["Manejo e bem-estar", "Biossegurança, comportamento, socialização e rotina do gatil."],
            ["Gestão profissional", "Documentos, finanças, indicadores, clientes e processos."],
            ["Exposições e exportação", "Federações, títulos, campanhas, logística e protocolos internacionais."]
          ].forEach(function(item, index) { %>
            <article>
              <span><%= String(index + 1).padStart(2, "0") %></span>
              <h3><%= item[0] %></h3>
              <p><%= item[1] %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="gatofilia-section gatofilia-presentation-guests gatofilia-band-light reveal-on-scroll">
        <div class="gatofilia-section-heading centered compact">
          <p class="gatofilia-eyebrow">Especialistas convidados</p>
          <h2>Conhecimento ampliado por profissionais convidados.</h2>
          <p>Conheça alguns dos profissionais que contribuirão com a Jornada Gatofilia, trazendo experiência prática, conhecimento técnico e atuação reconhecida na felinocultura e medicina felina.</p>
        </div>
        <div class="gatofilia-presentation-guest-grid">
          <% if (presentationGuests.length) { %>
            <% presentationGuests.forEach(function(guest) { %>
              <article class="<%= guest.status === 'Confirmado' ? 'is-confirmed' : '' %>">
                <span><%= guest.status || 'Convidado' %></span>
                <h3><%= guest.name || 'Profissional convidado' %></h3>
                <% if (guest.education) { %>
                  <p class="gatofilia-guest-education"><%= guest.education %></p>
                <% } %>
                <% if (guest.specializations && guest.specializations.length) { %>
                  <% guest.specializations.forEach(function(item) { %>
                    <p class="gatofilia-guest-story"><%= item %></p>
                  <% }) %>
                <% } %>
                <% if (guest.experiences && guest.experiences.length) { %>
                  <% guest.experiences.forEach(function(item) { %>
                    <p class="gatofilia-guest-story"><%= item %></p>
                  <% }) %>
                <% } %>
              </article>
            <% }) %>
          <% } else { %>
            <article>
              <span>Em breve</span>
              <h3>Especialistas em confirmação</h3>
              <p>Os profissionais convidados serão apresentados nesta área assim que confirmados.</p>
            </article>
          <% } %>
        </div>
      </section>

      <section id="investimento" class="gatofilia-section gatofilia-investment reveal-on-scroll">
        <div class="gatofilia-section-heading centered compact">
          <p class="gatofilia-eyebrow">Bônus exclusivos e investimento</p>
          <h2>Você não estará adquirindo apenas uma jornada de conhecimento.</h2>
          <p>
            Ao se inscrever, você recebe PetGus Premium por 1 ano, benefícios opcionais junto à
            Gatarina/FIFe, comunidade exclusiva, materiais, lives, visita técnica e certificado oficial.
          </p>
        </div>
        <div class="gatofilia-offer-card">
          <span>Oferta de lançamento</span>
          <h3><%= offerTitle %></h3>
          <div class="gatofilia-price-grid">
            <article>
              <small>Cartão de crédito</small>
              <strong><%= cardLabel.replace(/^Cart[aã]o\\s*-\\s*/i, "") %></strong>
            </article>
            <article>
              <small>PIX à vista</small>
              <strong><%= pixLabel.replace(/^PIX\\s*-\\s*/i, "") %></strong>
            </article>
          </div>
          <p><%= offerNote %></p>
          <a class="gatofilia-button primary" href="#inscricao">Garanta sua vaga</a>
        </div>
      </section>

      <section class="gatofilia-section gatofilia-cost gatofilia-band-light reveal-on-scroll">
        <div class="gatofilia-section-heading">
          <p class="gatofilia-eyebrow">O custo de não fazer</p>
          <h2>Na felinocultura, os maiores prejuízos raramente acontecem por falta de dedicação.</h2>
          <p>Eles acontecem por falta de conhecimento.</p>
        </div>
        <div class="gatofilia-cost-grid">
          <% [
            "Um cruzamento mal planejado pode comprometer anos de seleção genética.",
            "Uma doença prevenível pode gerar sofrimento, despesas e interrupção do programa.",
            "Um erro na escolha de reprodutor pode impactar toda uma linhagem.",
            "Falhas na gestação ou no desenvolvimento neonatal podem resultar em perdas irreparáveis.",
            "Documentação incorreta pode impedir exportações ou atrasar processos internacionais.",
            "A falta de organização pode fazer informações importantes se perderem."
          ].forEach(function(item) { %>
            <article><span>•</span><p><%= item %></p></article>
          <% }) %>
        </div>
        <p class="gatofilia-section-note">Investir em conhecimento sempre custa menos do que aprender apenas com os próprios erros.</p>
      </section>

      <section id="inscricao" class="gatofilia-interest reveal-on-scroll">
        <div class="gatofilia-interest-copy">
          <p class="gatofilia-eyebrow">Próximos passos</p>
          <h2>Gostaria de participar?</h2>
          <p>Preencha os dados para solicitar a confirmação da sua inscrição. Nossa equipe entrará em contato para validar os próximos passos.</p>
        </div>

        <form method="post" action="/apresentacao/interesse" class="gatofilia-form gatofilia-interest-form" data-gatofilia-interest-form data-presentation-interest-form data-lead-status="<%= leadStatus || '' %>">
          <div class="gatofilia-form-intro">
            <span>Solicitação de inscrição</span>
            <strong class="gatofilia-form-intro-copy">Garanta sua vaga na próxima Jornada Gatofilia.</strong>
          </div>

          <label>Nome<input name="firstName" required autocomplete="given-name" /></label>
          <label>Sobrenome<input name="lastName" required autocomplete="family-name" /></label>
          <label>CPF<input name="cpf" required inputmode="numeric" autocomplete="off" placeholder="000.000.000-00" data-cpf-input /></label>
          <label>E-mail<input name="email" type="email" required autocomplete="email" /></label>
          <label>WhatsApp<input name="whatsapp" required autocomplete="tel" /></label>

          <label>País
            <input name="country" value="Brasil" list="gatofiliaCountryList" required autocomplete="country-name" data-country-input />
            <datalist id="gatofiliaCountryList"></datalist>
          </label>
          <label data-brazil-state-field>Estado
            <select name="state" required data-brazil-state-select>
              <option value="">Selecione</option>
            </select>
          </label>
          <label data-other-state-field hidden>Estado
            <input name="state" required disabled />
          </label>
          <label data-brazil-city-field>Cidade
            <select name="city" required data-brazil-city-select>
              <option value="">Selecione o estado primeiro</option>
            </select>
          </label>
          <label data-other-city-field hidden>Cidade
            <input name="city" required disabled />
          </label>

          <label data-brazil-address-field>CEP
            <input name="zipCode" required inputmode="numeric" autocomplete="postal-code" placeholder="00000-000" data-zipcode-input />
          </label>
          <label data-brazil-address-field>Bairro<input name="district" required autocomplete="address-level3" /></label>
          <label data-brazil-address-field>Rua<input name="street" required autocomplete="address-line1" /></label>
          <label>Número<input name="addressNumber" required autocomplete="address-line2" /></label>
          <label>Complemento<input name="addressComplement" autocomplete="address-line3" /></label>

          <label class="full gatofilia-cattery-question">Possui gatil?
            <select name="hasCattery" required data-has-cattery>
              <option value="">Selecione</option>
              <option value="Sim">Sim</option>
              <option value="Não">Não</option>
            </select>
          </label>
          <label class="gatofilia-conditional-field" data-cattery-only hidden>Nome do gatil<input name="catteryName" required disabled /></label>
          <label class="gatofilia-conditional-field" data-cattery-only hidden>Raça principal criada<input name="breed" required disabled /></label>
          <label class="gatofilia-conditional-field" data-cattery-only hidden>Há quanto tempo cria?<input name="breedingTime" required disabled /></label>
          <label class="full gatofilia-conditional-field" data-no-cattery-only hidden>Raça que pretende criar<input name="wantsStart" required disabled /></label>

          <label>Como conheceu a Gatofilia?
            <select name="referralSource" required>
              <option value="">Selecione</option>
              <option value="Indicação">Indicação</option>
              <option value="Pesquisa Google">Pesquisa Google</option>
              <option value="Anúncio">Anúncio</option>
              <option value="Grupo de WhatsApp">Grupo de WhatsApp</option>
            </select>
          </label>
          <label class="full gatofilia-payment-choice">Forma de pagamento
            <div>
              <label><input type="radio" name="paymentChoice" value="<%= pixLabel %>" required /> <%= pixLabel %></label>
              <label><input type="radio" name="paymentChoice" value="<%= cardLabel %>" required /> <%= cardLabel %></label>
            </div>
          </label>
          <label class="full">Mensagem
            <textarea name="message" rows="5" required placeholder="Conte sua história, necessidades ou dúvidas sobre a jornada."></textarea>
          </label>
          <label class="full gatofilia-checkbox">
            <input name="wantsUpdates" type="checkbox" value="1" checked />
            <span>Desejo receber informações sobre abertura das próximas turmas.</span>
          </label>
          <button type="submit">Garanta sua vaga</button>
          <div class="gatofilia-submit-status <%= leadStatus === 'ok' ? 'success' : (leadStatus === 'erro' ? 'error' : '') %>" data-submit-status aria-live="polite">
            <% if (leadStatus === "ok") { %>
              Formulário enviado. Nossa equipe entrará em contato.
            <% } else if (leadStatus === "erro") { %>
              Não foi possível enviar agora. Confira os campos obrigatórios.
            <% } %>
          </div>
        </form>
      </section>

      <section class="gatofilia-section gatofilia-band-light reveal-on-scroll">
        <div class="gatofilia-section-heading centered compact">
          <p class="gatofilia-eyebrow">Perguntas frequentes</p>
          <h2>Informações importantes antes de confirmar sua participação.</h2>
        </div>
        <div class="gatofilia-faq">
          <% [
            ["Preciso já possuir um gatil?", "Não. A jornada foi desenvolvida para quem deseja iniciar da forma correta e também para criadores que já possuem gatil e desejam evoluir."],
            ["A jornada é indicada para todas as raças?", "Sim. Os fundamentos de criação responsável são aplicáveis a diferentes raças felinas."],
            ["As aulas ficam gravadas?", "Sim. Todo o conteúdo ficará disponível na plataforma durante o período de acesso."],
            ["Receberei certificado?", "Sim. Ao concluir a jornada, você receberá o certificado emitido pela Gatofilia."],
            ["A jornada possui suporte?", "Sim. Além do conteúdo, os alunos terão acesso à comunidade exclusiva para troca de experiências."],
            ["As vagas são limitadas?", "Sim. Cada turma possui vagas limitadas para preservar a proximidade e qualidade da experiência."]
          ].forEach(function(item) { %>
            <details>
              <summary><%= item[0] %></summary>
              <p><%= item[1] %></p>
            </details>
          <% }) %>
        </div>
      </section>

      <section class="gatofilia-section gatofilia-closing-video reveal-on-scroll">
        <div class="gatofilia-section-heading centered compact">
          <p class="gatofilia-eyebrow">Encerramento</p>
          <h2>O próximo passo é decidir construir com conhecimento.</h2>
          <p>Cada grande gatil começou com uma decisão. Esperamos você na próxima turma da Jornada Gatofilia.</p>
        </div>
        <% if (closingVideoUrl) { %>
          <div class="gatofilia-video-frame">
            <% if (isVideoFile(closingVideoUrl)) { %>
              <video src="<%= closingVideoUrl %>" controls preload="metadata"></video>
            <% } else { %>
              <iframe src="<%= closingVideoUrl %>" title="Vídeo de encerramento Gatofilia" loading="lazy" allowfullscreen></iframe>
            <% } %>
          </div>
        <% } else { %>
          <div class="gatofilia-video-placeholder is-final" aria-label="Espaço reservado para vídeo de encerramento">
            <span>Vídeo de encerramento</span>
            <strong>Em breve</strong>
            <p>Mensagem final.</p>
          </div>
        <% } %>
      </section>
    </main>

    <footer id="contato" class="gatofilia-footer">
      <div>
        <img src="/uploads/academy/gatofilia-main-logo-360.png" width="360" height="360" decoding="async" alt="Gatofilia" />
      </div>
      <p>Desenvolvendo a próxima geração de criadores de excelência.</p>
      <p>E-mail: contato@gatofilia.com.br</p>
      <p>© 2026 Gatofilia. Todos os direitos reservados.</p>
    </footer>

    <script src="/js/academy-interest.js"></script>
    <script src="/js/academy-presentation.js"></script>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Vermifugação - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <style>
      .deworming-grid {
        display: grid;
        grid-template-columns: 220px 180px 140px 320px 220px;
        gap: 10px;
        align-items: start;
      }
      .deworming-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .deworming-row {
        padding: 12px;
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        margin-bottom: 12px;
      }
      .deworming-row.is-overdue {
        border-left: 5px solid #dc2626;
      }
      .deworming-row.is-dewormed {
        border-left: 5px solid #16a34a;
      }
      .mini-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .inline-plus {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      @media (max-width: 1300px) {
        .deworming-grid {
          grid-template-columns: 1fr;
        }
        .deworming-header {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Vermifugação</h2>
            <div class="welcome-sub">Controle administrativo de vermifugação dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% categories.forEach(function(category) { %>
          <section class="content-card" style="margin-bottom: 18px; border-left: 5px solid <%= category.color %>;">
            <div class="content-title"><%= category.label %></div>

            <div class="deworming-grid deworming-header" style="margin-top: 12px;">
              <div>Nome do Gato</div>
              <div>Mãe</div>
              <div>Data de Nascimento</div>
              <div>Histórico</div>
              <div>Próxima vermifugação</div>
            </div>

            <% if (!grouped[category.key] || !grouped[category.key].length) { %>
              <div class="empty" style="margin-top:12px;">Nenhum gato nesta categoria.</div>
            <% } else { %>
              <% grouped[category.key].forEach(function(row) { %>
                <form method="post" action="/admin/deworming/<%= row.cat.id %>" class="deworming-row is-<%= row.dewormingState %>">
                  <div class="deworming-grid">
                    <div>
                      <div class="item-title" style="color:<%= row.dewormingState === 'overdue' ? '#dc2626' : '#16a34a' %>;">
                        <%= row.displayName %>
                      </div>
                    </div>

                    <div><strong><%= row.motherName %></strong></div>
                    <div><strong><%= row.birthDateLabel %></strong></div>

                    <div class="mini-stack" data-history-box>
                      <% row.history.forEach(function(item, idx) { %>
                        <div class="inline-plus">
                          <input type="date" name="historyDates" value="<%= item.date %>" />
                          <select name="historyTypes" style="width:140px;">
                            <option value="">Tipo</option>
                            <% dewormingTypes.forEach(function(type) { %>
                              <option value="<%= type %>" <%= item.type === type ? "selected" : "" %>><%= type %></option>
                            <% }) %>
                          </select>
                          <% if (idx === row.history.length - 1) { %>
                            <button type="button" class="btn add-history">+</button>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>

                    <div class="mini-stack">
                      <div><strong><%= row.nextDeworming ? formatDate(row.nextDeworming) : "-" %></strong></div>
                      <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                  </div>
                </form>
              <% }) %>
            <% } %>
          </section>
        <% }) %>
      </main>
    </div>

    <script>
      (function () {
        document.querySelectorAll(".add-history").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-history-box]");
            const row = button.parentElement.cloneNode(true);
            row.querySelector("input").value = "";
            row.querySelector("select").value = "";
            row.querySelector("button").remove();
            box.appendChild(row);
          });
        });
      })();
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Vermifugação - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .deworming-grid {
        display: grid;
        grid-template-columns: 260px 140px 320px 220px;
        gap: 10px;
        align-items: start;
      }
      .cat-subline {
        margin-top: 4px;
        font-size: 11px;
        line-height: 1.35;
        color: var(--text-muted);
      }
      .deworming-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .deworming-row {
        padding: 12px;
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        margin-bottom: 12px;
      }
      .deworming-row.is-overdue {
        border-left: 5px solid #dc2626;
      }
      .deworming-row.is-dewormed {
        border-left: 5px solid #16a34a;
      }
      .mini-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .inline-plus {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .history-date-display,
      .history-type-display {
        padding: 8px 10px;
        border: 1px solid var(--border-soft);
        border-radius: 8px;
        background: #f8fafc;
        font-size: 13px;
      }
      .history-date-display {
        flex: 1 1 auto;
        min-width: 0;
      }
      .history-type-display {
        flex: 0 0 140px;
      }
      .delete-history-date {
        min-width: 38px;
        padding-left: 0;
        padding-right: 0;
      }
      @media (max-width: 1300px) {
        .deworming-grid {
          grid-template-columns: 1fr;
        }
        .deworming-header {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Vermifugação</h2>
            <div class="welcome-sub">Controle administrativo de vermifugação dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% categories.forEach(function(category) { %>
          <% const items = grouped[category.key] || []; %>
          <details class="content-card module-panel module-accordion" style="border-left: 5px solid <%= category.color %>;">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= category.label %></span>
              </div>
              <span class="module-accordion-count"><%= items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <div class="deworming-grid deworming-header">
                <div>Nome do Gato</div>
                <div>Data de Nascimento</div>
                <div>Histórico</div>
                <div>Próxima vermifugação</div>
              </div>

              <% if (!items.length) { %>
                <div class="empty" style="margin-top:12px;">Nenhum gato nesta categoria.</div>
              <% } else { %>
                <% items.forEach(function(row) { %>
                <form method="post" action="/admin/deworming/<%= row.cat.id %>" class="deworming-row is-<%= row.dewormingState %>">
                  <div class="deworming-grid">
                    <div>
                      <div class="item-title" style="color:<%= row.dewormingState === 'overdue' ? '#dc2626' : '#16a34a' %>;">
                        <%= row.displayName %>
                      </div>
                      <div class="cat-subline">Mãe: <%= row.motherName %></div>
                    </div>

                    <div><strong><%= row.birthDateLabel %></strong></div>

                    <div class="mini-stack" data-history-box>
                      <% row.history.forEach(function(item) { %>
                        <div class="inline-plus" data-history-row>
                          <% if (item.date && item.type) { %>
                            <input type="hidden" name="historyDates" value="<%= item.date %>" />
                            <input type="hidden" name="historyTypes" value="<%= item.type %>" />
                            <span class="history-date-display"><%= formatDate(item.date) %></span>
                            <span class="history-type-display"><%= item.type %></span>
                            <button type="button" class="btn delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
                          <% } else { %>
                            <input type="date" name="historyDates" value="<%= item.date || '' %>" />
                            <select name="historyTypes" style="width:140px;">
                              <option value="">Tipo</option>
                              <% dewormingTypes.forEach(function(type) { %>
                                <option value="<%= type %>" <%= item.type === type ? "selected" : "" %>><%= type %></option>
                              <% }) %>
                            </select>
                          <% } %>
                        </div>
                      <% }) %>
                      <div class="history-add-row">
                        <button type="button" class="btn add-history">+</button>
                      </div>
                    </div>

                    <div class="mini-stack">
                      <div><strong><%= row.nextDeworming ? formatDate(row.nextDeworming) : "-" %></strong></div>
                    </div>
                  </div>
                </form>
                <% }) %>
              <% } %>
            </div>
          </details>
        <% }) %>
      </main>
    </div>

    <script>
      (function () {
        const dewormingTypes = <%- JSON.stringify(dewormingTypes) %>;

        function formatDisplayDate(value) {
          if (!value) return "";
          const parts = value.split("-");
          if (parts.length !== 3) return value;
          return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        function dewormingTypeOptions() {
          return [
            '<option value="">Tipo</option>',
            ...dewormingTypes.map((type) => `<option value="${type}">${type}</option>`),
          ].join("");
        }

        async function autosave(form) {
          if (!form) return;
          if (form.dataset.submitting === "true") {
            form.dataset.pendingSave = "true";
            return;
          }

          form.dataset.submitting = "true";
          form.dataset.pendingSave = "false";

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(form)),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "X-Autosave": "true",
              },
            });

            if (!response.ok) {
              throw new Error("Erro ao salvar vermifugação");
            }
          } catch (error) {
            console.error(error);
          } finally {
            form.dataset.submitting = "false";
            if (form.dataset.pendingSave === "true") {
              autosave(form);
            }
          }
        }

        document.querySelectorAll(".add-history").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-history-box]");
            const row = document.createElement("div");
            row.className = "inline-plus";
            row.dataset.historyRow = "";
            row.innerHTML = `<input type="date" name="historyDates" value="" /><select name="historyTypes" style="width:140px;">${dewormingTypeOptions()}</select>`;
            box.insertBefore(row, button.closest(".history-add-row"));
            bindHistoryRow(row);
          });
        });

        function bindDelete(button) {
          button.addEventListener("click", () => {
            const row = button.closest("[data-history-row]");
            const form = button.closest("form");
            row.remove();

            autosave(form);
          });
        }

        function bindHistoryRow(row) {
          const input = row.querySelector('input[type="date"]');
          const select = row.querySelector("select");

          function maybeFreeze() {
            if (!input?.value || !select?.value) return;
            row.innerHTML = `
              <input type="hidden" name="historyDates" value="${input.value}" />
              <input type="hidden" name="historyTypes" value="${select.value}" />
              <span class="history-date-display">${formatDisplayDate(input.value)}</span>
              <span class="history-type-display">${select.value}</span>
              <button type="button" class="btn delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
            `;
            bindDelete(row.querySelector(".delete-history-date"));
            autosave(row.closest("form"));
          }

          if (input) input.addEventListener("change", maybeFreeze);
          if (select) select.addEventListener("change", maybeFreeze);

          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) bindDelete(deleteButton);
        }

        document.querySelectorAll("[data-history-row]").forEach(bindHistoryRow);
      })();
    </script>
  </body>
</html>

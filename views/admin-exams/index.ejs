<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Exames - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .exam-table-wrap {
        overflow-x: auto;
        border: 1px solid var(--border-soft);
        border-radius: 8px;
        background: #fff;
      }
      .exam-table {
        width: max-content;
        min-width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 13px;
      }
      .exam-table th,
      .exam-table td {
        border-right: 1px solid var(--border-soft);
        border-bottom: 1px solid var(--border-soft);
        padding: 8px;
        vertical-align: top;
      }
      .exam-table th {
        background: #f8fafc;
        color: var(--text-muted);
        font-size: 11px;
        letter-spacing: .04em;
        text-transform: uppercase;
        text-align: left;
        white-space: nowrap;
      }
      .exam-table tr.is-urgent td:first-child {
        border-left: 5px solid #dc2626;
      }
      .exam-cat-cell {
        min-width: 220px;
        max-width: 260px;
      }
      .exam-date-cell {
        min-width: 130px;
      }
      .exam-genetic-cell {
        min-width: 230px;
      }
      .exam-hcm-cell {
        min-width: 270px;
      }
      .exam-next-cell {
        min-width: 150px;
      }
      .exam-mini-title {
        display: block;
        color: var(--text-muted);
        font-size: 11px;
        margin-bottom: 4px;
      }
      .exam-upload {
        display: none;
        gap: 6px;
      }
      .exam-upload.is-visible {
        display: grid;
      }
      .exam-file-link {
        font-size: 12px;
      }
      .exam-row input,
      .exam-row select {
        max-width: 100%;
        min-width: 0;
      }
      .exam-row select,
      .exam-row input[type="date"] {
        height: 34px;
        padding: 6px 8px;
      }
      .exam-row .mini-stack {
        gap: 6px;
      }
      .inline-plus.exam-eco-row {
        align-items: start;
        flex-wrap: wrap;
      }
      .exam-print-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      @media (max-width: 760px) {
        .exam-table {
          font-size: 12px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Exames</h2>
            <div class="welcome-sub">Controle de exames dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <section class="content-card" style="margin-bottom:18px;">
          <div class="history-section-head" style="margin-bottom:12px;">
            <div>
              <div class="content-title">Imprimir exames</div>
              <div class="content-sub">Selecione o gato e escolha quais exames deseja baixar para impressão.</div>
            </div>
          </div>
          <div class="grid-2" style="align-items:end;">
            <div class="field">
              <label class="field-label" for="printCatId">Gato</label>
              <select id="printCatId">
                <option value="">Selecione...</option>
                <% (printCats || []).forEach(function(cat) { %>
                  <option value="<%= cat.id %>"><%= cat.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="exam-print-actions">
              <% if (activeExams && activeExams.genetic && activeExams.genetic.length) { %>
                <% activeExams.genetic.forEach(function(exam) { %>
                  <a class="btn" href="#" data-print-type="<%= exam.key %>"><%= exam.label %></a>
                <% }) %>
              <% } %>
              <% if (activeExams && activeExams.hcm) { %>
                <a class="btn" href="#" data-print-type="hcm-latest">Último HCM</a>
                <a class="btn" href="#" data-print-type="hcm-all">Todos HCM</a>
              <% } %>
              <% if (activeExams && ((activeExams.genetic && activeExams.genetic.length) || activeExams.hcm)) { %>
                <a class="btn btn-primary" href="#" data-print-type="all">Todos</a>
              <% } %>
            </div>
          </div>
        </section>

        <% categories.forEach(function(category) { %>
          <% const items = grouped[category.key] || []; %>
          <details class="content-card module-panel module-accordion" style="border-left: 5px solid <%= category.color %>;">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= category.label %></span>
              </div>
              <span class="module-accordion-count"><%= items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <% if (!items.length) { %>
                <div class="empty" style="margin-top:12px;">Nenhum gato nesta categoria.</div>
              <% } else { %>
                <div class="exam-table-wrap">
                  <table class="exam-table">
                    <thead>
                      <tr>
                        <th>Nome do gato</th>
                        <th>Data de nascimento</th>
                        <% const firstExamSet = items[0] && items[0].activeExams ? items[0].activeExams : activeExams; %>
                        <% (firstExamSet.genetic || []).forEach(function(exam) { %>
                          <th><%= exam.label %></th>
                        <% }) %>
                        <% if (firstExamSet.hcm) { %>
                          <th>HCM - Doppler</th>
                          <th>Próximo HCM</th>
                        <% } %>
                      </tr>
                    </thead>
                    <tbody>
                      <% items.forEach(function(row) { %>
                        <tr class="exam-row <%= row.urgent ? 'is-urgent' : '' %>" data-form-id="exam-form-<%= row.cat.id %>">
                          <td class="exam-cat-cell">
                            <form id="exam-form-<%= row.cat.id %>" method="post" action="/admin/exams/<%= row.cat.id %>" enctype="multipart/form-data"></form>
                            <div class="item-title" style="color:<%= row.urgent ? '#dc2626' : 'inherit' %>;"><%= row.displayName %></div>
                            <span class="status-pill <%= row.urgent ? 'is-red' : 'is-blue' %>">
                              <%= row.urgent ? 'Atenção' : 'Acompanhamento' %>
                            </span>
                          </td>
                          <td class="exam-date-cell"><strong><%= row.birthDateLabel %></strong></td>
                          <% row.geneticExams.forEach(function(exam) { %>
                            <td class="exam-genetic-cell">
                              <div class="mini-stack">
                                <% if (exam.inheritedNn && !exam.file) { %>
                                  <span class="status-pill is-green">Antecedente OK</span>
                                <% } %>
                                <select form="exam-form-<%= row.cat.id %>" name="<%= exam.key %>Source" data-source-toggle="<%= exam.key %>">
                                  <option value="">Selecione</option>
                                  <% sourceOptions.forEach(function(option) { %>
                                    <option value="<%= option %>" <%= exam.source === option ? "selected" : "" %>><%= option %></option>
                                  <% }) %>
                                </select>
                                <select form="exam-form-<%= row.cat.id %>" name="<%= exam.key %>Result">
                                  <option value="">Resultado</option>
                                  <% exam.results.forEach(function(option) { %>
                                    <option value="<%= option %>" <%= exam.result === option ? "selected" : "" %>><%= option %></option>
                                  <% }) %>
                                </select>
                                <div class="exam-upload" data-upload-box="<%= exam.key %>">
                                  <% if (exam.file) { %>
                                    <a class="exam-file-link" href="<%= exam.file %>" target="_blank">Arquivo atual</a>
                                  <% } %>
                                  <input form="exam-form-<%= row.cat.id %>" type="file" name="<%= exam.key %>Doc" accept=".pdf,image/*" />
                                </div>
                              </div>
                            </td>
                          <% }) %>
                          <% if (row.activeExams && row.activeExams.hcm) { %>
                            <td class="exam-hcm-cell">
                              <div class="mini-stack" data-eco-box>
                                <% row.ecoHistory.forEach(function(item, index) { %>
                                  <div class="inline-plus exam-eco-row" data-eco-row>
                                    <% if (item.date) { %>
                                      <input form="exam-form-<%= row.cat.id %>" type="hidden" name="ecoDates" value="<%= item.date %>" />
                                      <input form="exam-form-<%= row.cat.id %>" type="hidden" name="ecoFiles" value="<%= item.file || '' %>" />
                                      <span class="history-date-display"><%= formatDate(item.date) %></span>
                                      <% if (item.file) { %>
                                        <a class="exam-file-link" href="<%= item.file %>" target="_blank">Arquivo</a>
                                      <% } %>
                                      <input form="exam-form-<%= row.cat.id %>" type="file" name="hcmDoc_<%= index %>" accept=".pdf,image/*" />
                                      <button type="button" class="btn delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
                                    <% } else { %>
                                      <input form="exam-form-<%= row.cat.id %>" type="date" name="ecoDates" value="" />
                                      <input form="exam-form-<%= row.cat.id %>" type="hidden" name="ecoFiles" value="" />
                                    <% } %>
                                  </div>
                                <% }) %>
                                <div class="history-add-row">
                                  <button type="button" class="btn add-eco">+</button>
                                </div>
                              </div>
                            </td>
                            <td class="exam-next-cell">
                              <strong><%= row.nextEco ? formatDate(row.nextEco) : (row.isFounder ? 'Último válido' : '-') %></strong>
                            </td>
                          <% } %>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>
          </details>
        <% }) %>
        <section class="content-card" style="margin-top:18px;">
          <div class="content-title">Legenda</div>
          <div class="grid-4" style="margin-top:12px;">
            <div><strong>NN:</strong> Negativo e não portador</div>
            <div><strong>NK:</strong> Portador de PKDef</div>
            <div><strong>KK:</strong> Positivo para PKDef</div>
            <div><strong>ND:</strong> Portador de PKD</div>
            <div><strong>DD:</strong> Positivo para PKD</div>
            <div><strong>NP:</strong> Portador de PRA</div>
            <div><strong>PP:</strong> Positivo para PRA</div>
            <div><strong>NH:</strong> Portador de HCM</div>
            <div><strong>HH:</strong> Positivo para HCM</div>
          </div>
        </section>
      </main>
    </div>

    <script>
      (function () {
        const printCatSelect = document.getElementById("printCatId");
        document.querySelectorAll("[data-print-type]").forEach((button) => {
          button.addEventListener("click", (event) => {
            const catId = printCatSelect?.value || "";
            if (!catId) {
              event.preventDefault();
              alert("Selecione um gato para imprimir os exames.");
              return;
            }
            button.href = `/admin/exams/print?catId=${encodeURIComponent(catId)}&type=${encodeURIComponent(button.dataset.printType)}`;
          });
        });

        function formatDisplayDate(value) {
          if (!value) return "";
          const parts = value.split("-");
          if (parts.length !== 3) return value;
          return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        function getExamRow(element) {
          return element?.closest?.(".exam-row") || null;
        }

        function getForm(element) {
          const row = getExamRow(element);
          const formId = row?.dataset.formId || element?.getAttribute?.("form") || "";
          return formId ? document.getElementById(formId) : element?.closest?.("form");
        }

        async function autosave(form, row) {
          if (!form) return;
          reindexEcoRows(row || document.querySelector(`[data-form-id="${form.id}"]`));
          if (form.dataset.submitting === "true") {
            form.dataset.pendingSave = "true";
            return;
          }

          form.dataset.submitting = "true";
          form.dataset.pendingSave = "false";

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new FormData(form),
              credentials: "same-origin",
              headers: {
                "X-Autosave": "true",
              },
            });

            if (!response.ok) {
              throw new Error("Erro ao salvar exames");
            }
          } catch (error) {
            console.error(error);
          } finally {
            form.dataset.submitting = "false";
            if (form.dataset.pendingSave === "true") {
              autosave(form, row);
            }
          }
        }

        document.querySelectorAll(".add-eco").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-eco-box]");
            const row = document.createElement("div");
            row.className = "inline-plus exam-eco-row";
            row.dataset.ecoRow = "";
            row.innerHTML = '<input type="date" name="ecoDates" value="" /><input type="hidden" name="ecoFiles" value="" />';
            const form = getForm(button);
            row.querySelectorAll("input").forEach((input) => {
              if (form?.id) input.setAttribute("form", form.id);
            });
            box.insertBefore(row, button.closest(".history-add-row"));
            bindEcoRow(row);
            reindexEcoRows(getExamRow(button));
          });
        });

        function reindexEcoRows(rowScope) {
          if (!rowScope) return;
          rowScope.querySelectorAll("[data-eco-row]").forEach((row, index) => {
            const fileInput = row.querySelector('input[type="file"]');
            if (fileInput) fileInput.name = `hcmDoc_${index}`;
          });
        }

        function bindDelete(button) {
          button.addEventListener("click", () => {
            const row = button.closest("[data-eco-row]");
            const examRow = getExamRow(button);
            const form = getForm(button);
            row.remove();

            reindexEcoRows(examRow);
            autosave(form, examRow);
          });
        }

        function bindEcoRow(row) {
          const input = row.querySelector('input[type="date"]');
          if (input) {
            input.addEventListener("change", () => {
              if (!input.value) return;
              row.innerHTML = `
                <input type="hidden" name="ecoDates" value="${input.value}" />
                <input type="hidden" name="ecoFiles" value="" />
                <span class="history-date-display">${formatDisplayDate(input.value)}</span>
                <input type="file" accept=".pdf,image/*" />
                <button type="button" class="btn delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
              `;
              const examRow = getExamRow(row);
              const form = getForm(row);
              row.querySelectorAll("input").forEach((newInput) => {
                if (form?.id && !newInput.getAttribute("form")) newInput.setAttribute("form", form.id);
              });
              reindexEcoRows(examRow);
              bindFileInputs(row);
              bindDelete(row.querySelector(".delete-history-date"));
              autosave(form, examRow);
            });
          }

          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) bindDelete(deleteButton);
          bindFileInputs(row);
        }

        function syncExamUploads(row) {
          row.querySelectorAll("[data-source-toggle]").forEach((select) => {
            const box = row.querySelector(`[data-upload-box="${select.dataset.sourceToggle}"]`);
            if (!box) return;
            box.classList.toggle("is-visible", select.value === "Próprio");
          });
        }

        function bindFileInputs(scope) {
          scope.querySelectorAll('input[type="file"]').forEach((input) => {
            if (input.dataset.boundFile === "true") return;
            input.dataset.boundFile = "true";
            input.addEventListener("change", () => autosave(getForm(input), getExamRow(input)));
          });
        }

        document.querySelectorAll("[data-eco-row]").forEach(bindEcoRow);
        document.querySelectorAll(".exam-row select").forEach((field) => {
          field.addEventListener("change", () => {
            const row = getExamRow(field);
            const form = getForm(field);
            syncExamUploads(row);
            autosave(form, row);
          });
        });
        document.querySelectorAll(".exam-row").forEach((row) => {
          syncExamUploads(row);
          reindexEcoRows(row);
          bindFileInputs(row);
        });
      })();
    </script>
  </body>
</html>

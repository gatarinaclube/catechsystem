<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Exames - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <style>
      .exam-grid {
        display: grid;
        grid-template-columns: 220px 140px 220px 220px 240px 190px;
        gap: 10px;
        align-items: start;
      }
      .exam-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .exam-row {
        padding: 12px;
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        margin-bottom: 12px;
      }
      .exam-row.is-urgent {
        border-left: 5px solid #dc2626;
      }
      .mini-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .inline-plus {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      @media (max-width: 1300px) {
        .exam-grid {
          grid-template-columns: 1fr;
        }
        .exam-header {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Exames</h2>
            <div class="welcome-sub">Controle de exames dos reprodutores e fundadores do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% categories.forEach(function(category) { %>
          <section class="content-card" style="margin-bottom: 18px; border-left: 5px solid <%= category.color %>;">
            <div class="content-title"><%= category.label %></div>

            <div class="exam-grid exam-header" style="margin-top: 12px;">
              <div>Nome do Gato</div>
              <div>Data de Nascimento</div>
              <div>PKDef</div>
              <div>PRA-bf</div>
              <div>Ecocardiodoppler</div>
              <div>Próximo Eco</div>
            </div>

            <% if (!grouped[category.key] || !grouped[category.key].length) { %>
              <div class="empty" style="margin-top:12px;">Nenhum gato nesta categoria.</div>
            <% } else { %>
              <% grouped[category.key].forEach(function(row) { %>
                <form method="post" action="/admin/exams/<%= row.cat.id %>" class="exam-row <%= row.urgent ? 'is-urgent' : '' %>">
                  <div class="exam-grid">
                    <div>
                      <div class="item-title" style="color:<%= row.urgent ? '#dc2626' : 'inherit' %>;">
                        <%= row.displayName %>
                      </div>
                    </div>

                    <div><strong><%= row.birthDateLabel %></strong></div>

                    <div class="mini-stack">
                      <select name="pkdefSource">
                        <option value="">Selecione</option>
                        <% sourceOptions.forEach(function(option) { %>
                          <option value="<%= option %>" <%= row.pkdefSource === option ? "selected" : "" %>><%= option %></option>
                        <% }) %>
                      </select>
                      <select name="pkdefResult">
                        <option value="">Resultado</option>
                        <% pkdefResults.forEach(function(option) { %>
                          <option value="<%= option %>" <%= row.pkdefResult === option ? "selected" : "" %>><%= option %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="mini-stack">
                      <select name="prabfSource">
                        <option value="">Selecione</option>
                        <% sourceOptions.forEach(function(option) { %>
                          <option value="<%= option %>" <%= row.prabfSource === option ? "selected" : "" %>><%= option %></option>
                        <% }) %>
                      </select>
                      <select name="prabfResult">
                        <option value="">Resultado</option>
                        <% prabfResults.forEach(function(option) { %>
                          <option value="<%= option %>" <%= row.prabfResult === option ? "selected" : "" %>><%= option %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="mini-stack" data-eco-box>
                      <% row.ecoHistory.forEach(function(item, idx) { %>
                        <div class="inline-plus">
                          <input type="date" name="ecoDates" value="<%= item.date %>" />
                          <% if (idx === row.ecoHistory.length - 1) { %>
                            <button type="button" class="btn add-eco">+</button>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>

                    <div class="mini-stack">
                      <div><strong><%= row.nextEco ? formatDate(row.nextEco) : "-" %></strong></div>
                      <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                  </div>
                </form>
              <% }) %>
            <% } %>
          </section>
        <% }) %>
      </main>
    </div>

    <script>
      (function () {
        document.querySelectorAll(".add-eco").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-eco-box]");
            const row = button.parentElement.cloneNode(true);
            row.querySelector("input").value = "";
            row.querySelector("button").remove();
            box.appendChild(row);
          });
        });
      })();
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Exames - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .exam-table-wrap {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: auto;
        overflow-y: visible;
        border: 1px solid var(--border-soft);
        border-radius: 8px;
        background: #fff;
      }
      .shell > .main {
        min-width: 0;
        max-width: calc(100vw - 300px);
      }
      .main .content-card,
      .module-accordion,
      .module-accordion-body {
        min-width: 0;
        max-width: 100%;
        box-sizing: border-box;
      }
      .exam-table-shell {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow: hidden;
      }
      .exam-table {
        width: max-content;
        min-width: 100%;
        max-width: none;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 13px;
      }
      .exam-scrollbar {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        height: 18px;
        margin-top: 8px;
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        background: #f8fafc;
        position: sticky;
        bottom: 0;
        z-index: 3;
      }
      .exam-scrollbar-inner {
        height: 1px;
        min-width: 100%;
      }
      .exam-table th,
      .exam-table td {
        border-right: 1px solid var(--border-soft);
        border-bottom: 1px solid var(--border-soft);
        padding: 8px;
        vertical-align: top;
      }
      .exam-table tbody tr + tr td {
        border-top: 3px solid #cbd5e1;
      }
      .exam-table th {
        background: #f8fafc;
        color: var(--text-muted);
        font-size: 11px;
        letter-spacing: .04em;
        text-transform: uppercase;
        text-align: left;
        white-space: nowrap;
      }
      .exam-table tr.is-urgent td:first-child {
        border-left: 5px solid #dc2626;
      }
      .exam-cat-cell {
        min-width: 220px;
        max-width: 260px;
      }
      .exam-genetic-cell {
        min-width: 230px;
      }
      .exam-hcm-cell {
        min-width: 270px;
      }
      .exam-next-cell {
        min-width: 150px;
      }
      .exam-mini-title {
        display: block;
        color: var(--text-muted);
        font-size: 11px;
        margin-bottom: 4px;
      }
      .exam-upload {
        display: none;
        gap: 6px;
      }
      .exam-upload.is-visible {
        display: grid;
      }
      .exam-upload.is-forced-visible {
        display: grid;
      }
      .exam-current-doc {
        display: flex;
        align-items: center;
        gap: 8px;
        min-height: 34px;
      }
      .exam-current-doc.is-hidden {
        display: none;
      }
      .exam-file-link {
        font-size: 12px;
      }
      .exam-upload-button {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        min-height: 34px;
        overflow: hidden;
        cursor: pointer;
        white-space: nowrap;
      }
      .exam-upload-button input[type="file"] {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        cursor: pointer;
      }
      .exam-row input,
      .exam-row select {
        max-width: 100%;
        min-width: 0;
      }
      .exam-row select,
      .exam-row input[type="date"] {
        height: 34px;
        padding: 6px 8px;
      }
      .exam-genetic-controls {
        display: grid;
        grid-template-columns: minmax(120px, 1fr) 74px;
        gap: 6px;
        align-items: center;
      }
      .exam-row .mini-stack {
        gap: 6px;
      }
      .inline-plus.exam-eco-row {
        align-items: start;
        flex-wrap: wrap;
      }
      .exam-delete-date {
        width: 34px;
        height: 34px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #b91c1c;
        border-color: #fecaca;
        background: #fff5f5;
        font-size: 16px;
        line-height: 1;
      }
      .exam-print-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .exam-filter-card {
        margin-bottom: 18px;
      }
      .exam-filter-grid {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) minmax(190px, 260px);
        gap: 12px;
        align-items: end;
      }
      .exam-save-status {
        display: block;
        min-height: 16px;
        margin-top: 6px;
        font-size: 11px;
        color: var(--text-muted);
      }
      .exam-save-status.is-ok {
        color: #15803d;
      }
      .exam-save-status.is-error {
        color: #b91c1c;
      }
      @media (max-width: 760px) {
        .shell > .main {
          max-width: 100vw;
        }
        .exam-table {
          font-size: 12px;
        }
        .exam-filter-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Exames</h2>
            <div class="welcome-sub">Controle de exames dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <section class="content-card" style="margin-bottom:18px;">
          <div class="history-section-head" style="margin-bottom:12px;">
            <div>
              <div class="content-title">Imprimir exames</div>
              <div class="content-sub">Selecione o gato e escolha quais exames deseja baixar para impressão.</div>
            </div>
          </div>
          <div class="grid-2" style="align-items:end;">
            <div class="field">
              <label class="field-label" for="printCatSearch">Gato</label>
              <input id="printCatSearch" list="printCatOptions" type="search" placeholder="Digite parte do nome do gato..." autocomplete="off" />
              <datalist id="printCatOptions">
                <% (printCats || []).forEach(function(cat) { %>
                  <option value="<%= cat.label %>" data-id="<%= cat.id %>"></option>
                <% }) %>
              </datalist>
            </div>
            <div class="exam-print-actions">
              <% if (activeExams && activeExams.genetic && activeExams.genetic.length) { %>
                <% activeExams.genetic.forEach(function(exam) { %>
                  <a class="btn" href="#" data-print-type="<%= exam.key %>"><%= exam.label %></a>
                <% }) %>
              <% } %>
              <% if (activeExams && activeExams.hcm) { %>
                <a class="btn" href="#" data-print-type="hcm-latest">Último HCM</a>
                <a class="btn" href="#" data-print-type="hcm-all">Todos HCM</a>
              <% } %>
              <% if (activeExams && ((activeExams.genetic && activeExams.genetic.length) || activeExams.hcm)) { %>
                <a class="btn btn-primary" href="#" data-print-type="all">Todos</a>
              <% } %>
            </div>
          </div>
        </section>

        <section class="content-card exam-filter-card">
          <div class="exam-filter-grid">
            <div class="field">
              <label class="field-label" for="examSearch">Buscar gato</label>
              <input id="examSearch" type="search" placeholder="Digite parte do nome do gato..." autocomplete="off" />
            </div>
            <div class="field">
              <label class="field-label" for="examStatusFilter">Status</label>
              <select id="examStatusFilter">
                <option value="">Todos</option>
                <option value="valid">Exames Válidos</option>
                <option value="pending">Exames Pendentes</option>
              </select>
            </div>
          </div>
        </section>

        <% categories.forEach(function(category) { %>
          <% const items = grouped[category.key] || []; %>
          <details class="content-card module-panel module-accordion" style="border-left: 5px solid <%= category.color %>;">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= category.label %></span>
              </div>
              <span class="module-accordion-count"><%= items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <% if (!items.length) { %>
                <div class="empty" style="margin-top:12px;">Nenhum gato nesta categoria.</div>
              <% } else { %>
                <% items.forEach(function(row) { %>
                  <form id="exam-form-<%= row.cat.id %>" method="post" action="/admin/exams/<%= row.cat.id %>" enctype="multipart/form-data"></form>
                <% }) %>
                <div class="exam-table-shell">
                  <div class="exam-table-wrap" data-exam-table-wrap>
                    <table class="exam-table">
                      <thead>
                        <tr>
                          <th>Nome do gato</th>
                          <% const firstExamSet = items[0] && items[0].activeExams ? items[0].activeExams : activeExams; %>
                          <% (firstExamSet.genetic || []).forEach(function(exam) { %>
                            <th><%= exam.label %></th>
                          <% }) %>
                          <% if (firstExamSet.hcm) { %>
                            <th>HCM - Doppler</th>
                            <th>Próximo HCM</th>
                          <% } %>
                        </tr>
                      </thead>
                      <tbody>
                        <% items.forEach(function(row) { %>
                          <tr
                            class="exam-row <%= row.urgent ? 'is-urgent' : '' %>"
                            data-form-id="exam-form-<%= row.cat.id %>"
                            data-search="<%= String(row.displayName || '').toLowerCase() %>"
                            data-status="<%= row.urgent ? 'pending' : 'valid' %>"
                          >
                            <td class="exam-cat-cell">
                              <div class="item-title" style="color:<%= row.urgent ? '#dc2626' : 'inherit' %>;"><%= row.displayName %></div>
                              <div class="content-sub" style="font-size:11px; margin:2px 0 6px;">
                                Nasc.: <%= row.birthDateLabel %>
                              </div>
                              <span class="status-pill <%= row.urgent ? 'is-red' : 'is-blue' %>">
                                <%= row.statusLabel || (row.urgent ? 'Exame Pendente' : 'Exames Válidos') %>
                              </span>
                              <span class="exam-save-status" data-save-status></span>
                            </td>
                            <% row.geneticExams.forEach(function(exam) { %>
                              <td class="exam-genetic-cell">
                                <div class="mini-stack">
                                  <% if (exam.inheritedNn && !exam.file) { %>
                                    <span class="status-pill is-green">Antecedente OK</span>
                                  <% } %>
                                  <div class="exam-genetic-controls">
                                    <% const lockInheritedSource = exam.inheritedNn && exam.source === 'Antecedente'; %>
                                    <select
                                      form="exam-form-<%= row.cat.id %>"
                                      name="<%= exam.key %>Source"
                                      data-source-toggle="<%= exam.key %>"
                                      <%= lockInheritedSource ? 'disabled' : '' %>
                                    >
                                      <option value="">Status</option>
                                      <% sourceOptions.forEach(function(option) { %>
                                        <option value="<%= option %>" <%= exam.source === option ? "selected" : "" %>><%= option %></option>
                                      <% }) %>
                                    </select>
                                    <% if (lockInheritedSource) { %>
                                      <input form="exam-form-<%= row.cat.id %>" type="hidden" name="<%= exam.key %>Source" value="Antecedente" />
                                    <% } %>
                                    <select form="exam-form-<%= row.cat.id %>" name="<%= exam.key %>Result">
                                      <option value="">Resultado</option>
                                      <% exam.results.forEach(function(option) { %>
                                        <option value="<%= option %>" <%= exam.result === option ? "selected" : "" %>><%= option %></option>
                                      <% }) %>
                                    </select>
                                  </div>
                                  <% if (exam.file) { %>
                                    <div class="exam-current-doc" data-current-doc="<%= exam.key %>">
                                      <a class="exam-file-link" href="<%= exam.file %>" target="_blank">Arquivo atual</a>
                                      <button type="button" class="btn exam-delete-date" data-delete-genetic-doc="<%= exam.key %>" title="Excluir arquivo" aria-label="Excluir arquivo">&#128465;&#65039;</button>
                                    </div>
                                  <% } %>
                                  <input form="exam-form-<%= row.cat.id %>" type="hidden" name="<%= exam.key %>DeleteDoc" value="" data-delete-doc-input="<%= exam.key %>" />
                                  <div class="exam-upload <%= exam.file ? '' : 'is-forced-visible' %>" data-upload-box="<%= exam.key %>" data-has-file="<%= exam.file ? 'true' : 'false' %>">
                                    <label class="btn exam-upload-button">
                                      Anexar exame
                                      <input form="exam-form-<%= row.cat.id %>" type="file" name="<%= exam.key %>Doc" accept=".pdf,image/*" />
                                    </label>
                                  </div>
                                </div>
                              </td>
                            <% }) %>
                            <% if (row.activeExams && row.activeExams.hcm) { %>
                              <td class="exam-hcm-cell">
                                <div class="mini-stack" data-eco-box>
                                  <% const lastEcoIndex = row.ecoHistory.reduce(function(lastIndex, item, currentIndex) { return item.date ? currentIndex : lastIndex; }, -1); %>
                                  <% row.ecoHistory.forEach(function(item, index) { %>
                                    <div class="inline-plus exam-eco-row" data-eco-row>
                                      <% if (item.date) { %>
                                        <input form="exam-form-<%= row.cat.id %>" type="hidden" name="ecoDates" value="<%= item.date %>" />
                                        <input form="exam-form-<%= row.cat.id %>" type="hidden" name="ecoFiles" value="<%= item.file || '' %>" />
                                        <span class="history-date-display"><%= formatDate(item.date) %></span>
                                        <% if (item.file) { %>
                                          <a class="exam-file-link" href="<%= item.file %>" target="_blank">Arquivo</a>
                                        <% } else { %>
                                          <label class="btn exam-upload-button">
                                            Anexar exame
                                            <input form="exam-form-<%= row.cat.id %>" type="file" name="hcmDoc_<%= index %>" accept=".pdf,image/*" />
                                          </label>
                                        <% } %>
                                        <% if (index === lastEcoIndex) { %>
                                          <button type="button" class="btn exam-delete-date delete-history-date" title="Excluir esta data" aria-label="Excluir esta data">&#128465;&#65039;</button>
                                        <% } %>
                                      <% } else { %>
                                        <input form="exam-form-<%= row.cat.id %>" type="text" data-eco-date-input inputmode="numeric" maxlength="10" placeholder="dd/mm/aaaa" value="" />
                                        <input form="exam-form-<%= row.cat.id %>" type="hidden" name="ecoFiles" value="" />
                                      <% } %>
                                    </div>
                                  <% }) %>
                                  <div class="history-add-row">
                                    <button type="button" class="btn add-eco">+</button>
                                  </div>
                                </div>
                              </td>
                              <td class="exam-next-cell">
                                <strong><%= row.nextEco ? formatDate(row.nextEco) : (row.isFounder ? 'Último válido' : '-') %></strong>
                              </td>
                            <% } %>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                  <div class="exam-scrollbar" data-exam-scrollbar aria-label="Rolagem horizontal da tabela de exames">
                    <div class="exam-scrollbar-inner" data-exam-scrollbar-inner></div>
                  </div>
                </div>
              <% } %>
            </div>
          </details>
        <% }) %>
        <section class="content-card" style="margin-top:18px;">
          <div class="content-title">Legenda</div>
          <div class="grid-4" style="margin-top:12px;">
            <div><strong>NN:</strong> Negativo e não portador</div>
            <div><strong>NK:</strong> Portador de PKDef</div>
            <div><strong>KK:</strong> Positivo para PKDef</div>
            <div><strong>ND:</strong> Portador de PKD</div>
            <div><strong>DD:</strong> Positivo para PKD</div>
            <div><strong>NP:</strong> Portador de PRA</div>
            <div><strong>PP:</strong> Positivo para PRA</div>
            <div><strong>NH:</strong> Portador de HCM</div>
            <div><strong>HH:</strong> Positivo para HCM</div>
          </div>
        </section>
      </main>
    </div>

    <script>
      (function () {
        const printCatSearch = document.getElementById("printCatSearch");
        const printCatOptions = Array.from(document.querySelectorAll("#printCatOptions option"));
        function selectedPrintCatId() {
          const value = String(printCatSearch?.value || "").trim();
          const exact = printCatOptions.find((option) => option.value === value);
          if (exact) return exact.dataset.id || "";
          const partialMatches = printCatOptions.filter((option) => (
            normalizeSearch(option.value).includes(normalizeSearch(value))
          ));
          return partialMatches.length === 1 ? partialMatches[0].dataset.id || "" : "";
        }
        document.querySelectorAll("[data-print-type]").forEach((button) => {
          button.addEventListener("click", (event) => {
            const catId = selectedPrintCatId();
            if (!catId) {
              event.preventDefault();
              alert("Digite e selecione um gato da lista para imprimir os exames.");
              return;
            }
            button.href = `/admin/exams/print?catId=${encodeURIComponent(catId)}&type=${encodeURIComponent(button.dataset.printType)}`;
          });
        });

        function normalizeSearch(value) {
          return String(value || "")
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .toLowerCase()
            .trim();
        }

        function formatDisplayDate(value) {
          if (!value) return "";
          const parts = value.split("-");
          if (parts.length !== 3) return value;
          return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        function syncExamScrollbars(scope = document) {
          scope.querySelectorAll(".exam-table-shell").forEach((shell) => {
            const tableWrap = shell.querySelector("[data-exam-table-wrap]");
            const bottomScrollbar = shell.querySelector("[data-exam-scrollbar]");
            const bottomScrollbarInner = shell.querySelector("[data-exam-scrollbar-inner]");
            const table = shell.querySelector(".exam-table");
            if (!tableWrap || !bottomScrollbar || !bottomScrollbarInner) return;

            const tableWidth = table ? table.scrollWidth : 0;
            const scrollWidth = Math.max(tableWidth, tableWrap.scrollWidth, tableWrap.clientWidth);
            bottomScrollbarInner.style.width = `${scrollWidth}px`;
            bottomScrollbar.style.display = scrollWidth > tableWrap.clientWidth ? "block" : "none";
            bottomScrollbar.scrollLeft = tableWrap.scrollLeft;
          });
        }

        function maskBrazilianDate(value) {
          const digits = String(value || "").replace(/\D/g, "").slice(0, 8);
          if (digits.length <= 2) return digits;
          if (digits.length <= 4) return `${digits.slice(0, 2)}/${digits.slice(2)}`;
          return `${digits.slice(0, 2)}/${digits.slice(2, 4)}/${digits.slice(4)}`;
        }

        function parseCompleteBrazilianDate(value) {
          const match = String(value || "").match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
          if (!match) return null;
          const [, dayRaw, monthRaw, yearRaw] = match;
          const day = Number(dayRaw);
          const month = Number(monthRaw);
          const year = Number(yearRaw);
          if (year < 1900 || year > 2100) return null;
          const parsed = new Date(year, month - 1, day);
          if (
            Number.isNaN(parsed.getTime()) ||
            parsed.getFullYear() !== year ||
            parsed.getMonth() !== month - 1 ||
            parsed.getDate() !== day
          ) {
            return null;
          }
          return `${yearRaw}-${monthRaw}-${dayRaw}`;
        }

        function getExamRow(element) {
          return element?.closest?.(".exam-row") || null;
        }

        function getForm(element) {
          const row = getExamRow(element);
          const formId = row?.dataset.formId || element?.getAttribute?.("form") || "";
          return formId ? document.getElementById(formId) : element?.closest?.("form");
        }

        function buildRowFormData(form, row) {
          if (!row) return new FormData(form);
          const data = new FormData();
          row.querySelectorAll("input, select, textarea").forEach((field) => {
            if (!field.name || field.disabled) return;
            if ((field.type === "checkbox" || field.type === "radio") && !field.checked) return;
            if (field.type === "file") {
              Array.from(field.files || []).forEach((file) => data.append(field.name, file));
              return;
            }
            data.append(field.name, field.value || "");
          });
          return data;
        }

        function setSaveStatus(row, message, className = "") {
          const status = row?.querySelector("[data-save-status]");
          if (!status) return;
          status.textContent = message || "";
          status.className = `exam-save-status ${className}`.trim();
        }

        async function autosave(form, row, options = {}) {
          if (!form) return;
          reindexEcoRows(row || document.querySelector(`[data-form-id="${form.id}"]`));
          if (form.dataset.submitting === "true") {
            form.dataset.pendingSave = "true";
            return;
          }

          form.dataset.submitting = "true";
          form.dataset.pendingSave = "false";
          if (options.showStatus) setSaveStatus(row, "Salvando...");

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: buildRowFormData(form, row || document.querySelector(`[data-form-id="${form.id}"]`)),
              credentials: "same-origin",
              headers: {
                "X-Autosave": "true",
              },
            });

            if (!response.ok) {
              throw new Error("Erro ao salvar exames");
            }
            if (options.showStatus) {
              setSaveStatus(row, "Salvo", "is-ok");
              window.setTimeout(() => setSaveStatus(row, ""), 2500);
            }
            if (options.reloadOnSuccess) {
              window.setTimeout(() => window.location.reload(), 500);
            }
          } catch (error) {
            console.error(error);
            if (options.showStatus) setSaveStatus(row, "Erro ao salvar", "is-error");
          } finally {
            form.dataset.submitting = "false";
            if (form.dataset.pendingSave === "true") {
              autosave(form, row);
            }
          }
        }

        document.querySelectorAll(".add-eco").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-eco-box]");
            const row = document.createElement("div");
            row.className = "inline-plus exam-eco-row";
            row.dataset.ecoRow = "";
            row.innerHTML = `
              <input type="text" data-eco-date-input inputmode="numeric" maxlength="10" placeholder="dd/mm/aaaa" value="" />
              <input type="hidden" name="ecoFiles" value="" />
              <button type="button" class="btn exam-delete-date delete-history-date" title="Excluir esta data" aria-label="Excluir esta data">&#128465;&#65039;</button>
            `;
            const form = getForm(button);
            row.querySelectorAll("input").forEach((input) => {
              if (form?.id) input.setAttribute("form", form.id);
            });
            box.insertBefore(row, button.closest(".history-add-row"));
            bindEcoRow(row);
            reindexEcoRows(getExamRow(button));
            syncExamScrollbars(button.closest(".exam-table-shell") || document);
          });
        });

        function reindexEcoRows(rowScope) {
          if (!rowScope) return;
          rowScope.querySelectorAll("[data-eco-row]").forEach((row, index) => {
            const fileInput = row.querySelector('input[type="file"]');
            if (fileInput) fileInput.name = `hcmDoc_${index}`;
          });
        }

        function bindDelete(button) {
          if (!button || button.dataset.boundDelete === "true") return;
          button.dataset.boundDelete = "true";
          button.addEventListener("click", () => {
            const row = button.closest("[data-eco-row]");
            const examRow = getExamRow(button);
            const form = getForm(button);
            row.remove();

            reindexEcoRows(examRow);
            autosave(form, examRow);
            syncExamScrollbars(button.closest(".exam-table-shell") || document);
          });
        }

        function bindEcoRow(row) {
          const input = row.querySelector("[data-eco-date-input]");
          if (input) {
            const commitDate = () => {
              const isoDate = parseCompleteBrazilianDate(input.value);
              if (!isoDate || row.dataset.dateCommitted === isoDate) return;
              row.dataset.dateCommitted = isoDate;
              row.innerHTML = `
                <input type="hidden" name="ecoDates" value="${isoDate}" />
                <input type="hidden" name="ecoFiles" value="" />
                <span class="history-date-display">${formatDisplayDate(isoDate)}</span>
                <label class="btn exam-upload-button">
                  Anexar exame
                  <input type="file" accept=".pdf,image/*" />
                </label>
                <button type="button" class="btn exam-delete-date delete-history-date" title="Excluir esta data" aria-label="Excluir esta data">&#128465;&#65039;</button>
              `;
              const examRow = getExamRow(row);
              const form = getForm(row);
              row.querySelectorAll("input").forEach((newInput) => {
                if (form?.id && !newInput.getAttribute("form")) newInput.setAttribute("form", form.id);
              });
              reindexEcoRows(examRow);
              bindFileInputs(row);
              bindDelete(row.querySelector(".delete-history-date"));
              autosave(form, examRow);
              syncExamScrollbars(row.closest(".exam-table-shell") || document);
            };

            input.addEventListener("input", () => {
              input.value = maskBrazilianDate(input.value);
              if (input.value.length === 10) {
                commitDate();
              }
            });
            input.addEventListener("blur", commitDate);
          }

          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) bindDelete(deleteButton);
          bindFileInputs(row);
        }

        function syncExamUploads(row) {
          row.querySelectorAll("[data-source-toggle]").forEach((select) => {
            const box = row.querySelector(`[data-upload-box="${select.dataset.sourceToggle}"]`);
            if (!box) return;
            const deleteInput = row.querySelector(`[data-delete-doc-input="${select.dataset.sourceToggle}"]`);
            const hasFile = box.dataset.hasFile === "true" && deleteInput?.value !== "1";
            box.classList.toggle("is-visible", select.value === "Próprio" && !hasFile);
          });
        }

        function bindFileInputs(scope) {
          scope.querySelectorAll('input[type="file"]').forEach((input) => {
            if (input.dataset.boundFile === "true") return;
            input.dataset.boundFile = "true";
            input.addEventListener("change", () => autosave(getForm(input), getExamRow(input), {
              showStatus: true,
              reloadOnSuccess: true,
            }));
          });
        }

        document.querySelectorAll("[data-eco-row]").forEach(bindEcoRow);
        document.querySelectorAll(".exam-row select").forEach((field) => {
          field.addEventListener("change", () => {
            const row = getExamRow(field);
            const form = getForm(field);
            syncExamUploads(row);
            autosave(form, row);
          });
        });
        document.querySelectorAll(".exam-row").forEach((row) => {
          syncExamUploads(row);
          reindexEcoRows(row);
          bindFileInputs(row);
        });
        const examSearch = document.getElementById("examSearch");
        const examStatusFilter = document.getElementById("examStatusFilter");
        function applyExamFilters() {
          const query = normalizeSearch(examSearch?.value);
          const status = examStatusFilter?.value || "";
          document.querySelectorAll(".exam-row").forEach((row) => {
            const matchesName = !query || normalizeSearch(row.dataset.search).includes(query);
            const matchesStatus = !status || row.dataset.status === status;
            row.style.display = matchesName && matchesStatus ? "" : "none";
          });
          syncExamScrollbars();
        }
        examSearch?.addEventListener("input", applyExamFilters);
        examStatusFilter?.addEventListener("change", applyExamFilters);
        document.querySelectorAll("[data-delete-genetic-doc]").forEach((button) => {
          button.addEventListener("click", () => {
            const key = button.dataset.deleteGeneticDoc;
            const row = getExamRow(button);
            const deleteInput = row?.querySelector(`[data-delete-doc-input="${key}"]`);
            const currentDoc = row?.querySelector(`[data-current-doc="${key}"]`);
            const uploadBox = row?.querySelector(`[data-upload-box="${key}"]`);
            if (deleteInput) deleteInput.value = "1";
            currentDoc?.classList.add("is-hidden");
            uploadBox?.classList.add("is-forced-visible");
            uploadBox?.classList.add("is-visible");
            autosave(getForm(button), row, { showStatus: true });
          });
        });

        document.querySelectorAll(".exam-table-shell").forEach((shell) => {
          const tableWrap = shell.querySelector("[data-exam-table-wrap]");
          const bottomScrollbar = shell.querySelector("[data-exam-scrollbar]");
          if (!tableWrap || !bottomScrollbar) return;
          let syncingFromTable = false;
          let syncingFromBar = false;

          tableWrap.addEventListener("scroll", () => {
            if (syncingFromBar) return;
            syncingFromTable = true;
            bottomScrollbar.scrollLeft = tableWrap.scrollLeft;
            syncingFromTable = false;
          });

          bottomScrollbar.addEventListener("scroll", () => {
            if (syncingFromTable) return;
            syncingFromBar = true;
            tableWrap.scrollLeft = bottomScrollbar.scrollLeft;
            syncingFromBar = false;
          });

          requestAnimationFrame(() => syncExamScrollbars(shell));
        });
        document.querySelectorAll("details.module-accordion").forEach((details) => {
          details.addEventListener("toggle", () => {
            requestAnimationFrame(() => syncExamScrollbars(details));
          });
        });
        window.addEventListener("resize", () => syncExamScrollbars());
        requestAnimationFrame(() => syncExamScrollbars());
      })();
    </script>
  </body>
</html>

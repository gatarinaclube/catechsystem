<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Histórico - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Histórico</h2>
            <div class="welcome-sub">Centralize o histórico completo dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card module-panel">
          <form method="get" action="/admin/history" class="admin-filter-form">
            <div class="field" style="min-width:360px; flex:1;">
              <label class="field-label" for="historySearch">Buscar por nome ou microchip</label>
              <input
                id="historySearch"
                type="text"
                name="q"
                placeholder="Digite parte do nome ou microchip"
                value="<%= query || '' %>"
              />
            </div>
            <button type="submit" class="btn btn-primary">Buscar</button>
            <a href="/admin/history" class="btn">Limpar</a>
          </form>
        </div>

        <% categories.forEach(function(category) { %>
          <% const items = grouped[category.key] || []; %>
          <details class="content-card module-panel module-list-card module-accordion" style="border-left: 5px solid <%= category.color %>;">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= category.label %></span>
              </div>
              <span class="module-accordion-count"><%= items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <% if (!items.length) { %>
                <div class="empty">Nenhum gato nesta categoria.</div>
              <% } else { %>
                <ul class="list">
                  <% items.forEach(function(cat) { %>
                    <li class="item">
                      <div>
                        <a class="item-link" href="/admin/history/<%= cat.id %>">
                          <%= cat.displayName %> - <%= cat.birthDateLabel %> - <%= cat.microchipLabel %>
                        </a>
                      </div>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            </div>
          </details>
        <% }) %>
      </main>
    </div>
  </body>
</html>

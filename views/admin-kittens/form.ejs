<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title><%= formTitle %> - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .kitten-property-grid {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) repeat(3, 160px);
        gap: 18px clamp(18px, 3vw, 48px);
        align-items: start;
        margin-top: 12px;
      }
      .kitten-property-grid select {
        width: 100%;
      }
      .owner-nested-field {
        margin-top: 10px;
      }
      .registered-owner-row {
        display: grid;
        grid-template-columns: minmax(180px, 240px) minmax(240px, 1fr);
        gap: 16px;
        margin-top: 12px;
        align-items: start;
      }
      .new-owner-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px 16px;
        margin-top: 12px;
      }
      .cep-lookup-row {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .cep-lookup-row input {
        min-width: 0;
        flex: 1;
      }
      .cep-lookup-button {
        flex: 0 0 40px;
        width: 40px;
        height: 38px;
        padding: 0;
        font-size: 16px;
      }
      @media (max-width: 1000px) {
        .kitten-property-grid,
        .registered-owner-row,
        .new-owner-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title"><%= formTitle %></h2>
            <div class="welcome-sub">Cadastro administrativo de filhotes.</div>
          </div>
          <div class="actions">
            <% if (historyPath) { %>
              <a href="<%= historyPath %>" class="btn">Histórico</a>
            <% } %>
            <a href="<%= cancelPath %>" class="btn">Voltar</a>
          </div>
        </div>

        <% if (error) { %>
          <div class="content-card" style="border-left:4px solid #b91c1c; margin-bottom:18px;">
            <div class="content-sub"><%= error %></div>
          </div>
        <% } %>

        <form method="post" action="<%= formAction %>">
          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Informações dos Filhotes</div>

            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="kittenNumber">N do Filhote</label>
                <input id="kittenNumber" name="kittenNumber" type="text" maxlength="4" value="<%= kitten?.kittenNumber || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="name">Nome do Filhote</label>
                <input id="name" name="name" type="text" maxlength="21" value="<%= kitten?.name || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="gender">Sexo</label>
                <select id="gender" name="gender">
                  <option value="">Selecione...</option>
                  <option value="M" <%= kitten?.gender === "M" ? "selected" : "" %>>Macho</option>
                  <option value="F" <%= kitten?.gender === "F" ? "selected" : "" %>>Fêmea</option>
                </select>
              </div>
            </div>

            <div class="grid-4" style="margin-top:12px; display:grid; grid-template-columns:repeat(4, minmax(0,1fr)); gap:16px;">
              <div class="field">
                <label class="field-label" for="microchip">Microchip</label>
                <input id="microchip" name="microchip" type="text" value="<%= kitten?.microchip || '' %>" placeholder="000.000.000.000.000" />
              </div>
              <div class="field">
                <label class="field-label" for="birthDate">Data de Nascimento</label>
                <input id="birthDate" name="birthDate" type="date" value="<%= kitten?.birthDate ? new Date(kitten.birthDate).toISOString().slice(0,10) : '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="motherId">Nome da Mãe</label>
                <select id="motherId" name="motherId">
                  <option value="">Selecione...</option>
                  <% females.forEach(function(cat) { %>
                    <option value="<%= cat.id %>" <%= String(kitten?.motherId || '') === String(cat.id) ? "selected" : "" %>><%= cat.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="fatherId">Nome do Pai</label>
                <select id="fatherId" name="fatherId">
                  <option value="">Selecione...</option>
                  <% males.forEach(function(cat) { %>
                    <option value="<%= cat.id %>" <%= String(kitten?.fatherId || '') === String(cat.id) ? "selected" : "" %>><%= cat.name %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="grid-4" style="margin-top:12px; display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:16px;">
              <div class="field">
                <label class="field-label" for="pedigreeType">Tipo de Registro</label>
                <select id="pedigreeType" name="pedigreeType">
                  <option value="">Selecione...</option>
                  <option value="LO" <%= kitten?.pedigreeType === "LO" ? "selected" : "" %>>LO</option>
                  <option value="RX" <%= kitten?.pedigreeType === "RX" ? "selected" : "" %>>RX</option>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="pedigreeNumber">N de Registro</label>
                <input id="pedigreeNumber" name="pedigreeNumber" type="text" maxlength="6" value="<%= kitten?.pedigreeNumber || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="breed">Raça</label>
                <select id="breed" name="breed">
                  <option value="">Selecione...</option>
                  <% breeds.forEach(function(breed) { %>
                    <option value="<%= breed %>" <%= kitten?.breed === breed ? "selected" : "" %>><%= breed %></option>
                  <% }) %>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="emsCode">Cor e EMS</label>
                <select id="emsCode" name="emsCode">
                  <option value="<%= kitten?.emsCode || '' %>"><%= kitten?.emsCode || 'Selecione a raça primeiro...' %></option>
                </select>
              </div>
            </div>

            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="breedingStatus">Reprodução</label>
                <select id="breedingStatus" name="breedingStatus">
                  <option value="FOR_BREEDING" <%= kitten?.neutered === true ? "" : "selected" %>>For Breeding</option>
                  <option value="NOT_FOR_BREEDING" <%= kitten?.neutered === true ? "selected" : "" %>>Not For Breeding</option>
                </select>
              </div>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Informações de Propriedade</div>
            <% const hasNewOwnerInfo = Boolean(kitten?.newOwnerInfoJson || kitten?.newOwnerInfo); %>
            <% const isOtherOwner = hasNewOwnerInfo || (kitten?.currentOwnerId && kitten?.currentOwnerId !== kitten?.ownerId); %>
            <% const newOwnerInfo = kitten?.newOwnerInfo || {}; %>
            <div class="kitten-property-grid">
              <div class="field">
                <label class="field-label" for="currentOwnerMode">Proprietário</label>
                <select id="currentOwnerMode" name="currentOwnerMode">
                  <option value="ME" <%= isOtherOwner ? "" : "selected" %>>Eu Mesmo</option>
                  <option value="OTHER" <%= isOtherOwner ? "selected" : "" %>>Outro</option>
                </select>
                <div class="field owner-nested-field" id="registeredOwnerModeField">
                  <label class="field-label" for="registeredOwnerMode">Pessoa cadastrada?</label>
                  <select id="registeredOwnerMode" name="registeredOwnerMode">
                    <option value="YES" <%= hasNewOwnerInfo ? "" : "selected" %>>SIM</option>
                    <option value="NO" <%= hasNewOwnerInfo ? "selected" : "" %>>NÃO</option>
                  </select>
                </div>
              </div>
              <div class="field">
                <label class="field-label" for="kittenAvailabilityStatus">Status</label>
                <select id="kittenAvailabilityStatus" name="kittenAvailabilityStatus">
                  <% kittenStatusOptions.forEach(function(option) { %>
                    <option value="<%= option.value %>" <%= (kitten?.kittenAvailabilityStatus || 'UNAVAILABLE') === option.value ? "selected" : "" %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="registered-owner-row" id="currentOwnerField">
              <div class="field">
                <label class="field-label" for="currentOwnerId">Pessoa cadastrada</label>
                <select id="currentOwnerId" name="currentOwnerId">
                  <option value="">Selecione...</option>
                  <% users.forEach(function(item) { %>
                    <option value="<%= item.id %>" <%= String(kitten?.currentOwnerId || '') === String(item.id) ? "selected" : "" %>><%= item.name %></option>
                  <% }) %>
                </select>
                <a href="#" id="ownerInfoLink" style="display:inline-block; margin-top:8px;">informações</a>
              </div>
              <div id="ownerInfoBox" class="content-card" style="display:none; padding:12px;"></div>
            </div>
            <div class="new-owner-grid" id="newOwnerFields">
              <div class="field">
                <label class="field-label" for="newOwnerName">Nome Completo</label>
                <input id="newOwnerName" name="newOwnerName" type="text" value="<%= newOwnerInfo.name || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerDocument">CPF/RG/Passaporte</label>
                <input id="newOwnerDocument" name="newOwnerDocument" type="text" value="<%= newOwnerInfo.document || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerCep">CEP</label>
                <div class="cep-lookup-row">
                  <input id="newOwnerCep" name="newOwnerCep" type="text" value="<%= newOwnerInfo.cep || '' %>" />
                  <button type="button" class="btn cep-lookup-button" id="cepLookupButton" title="Buscar CEP" aria-label="Buscar CEP">&#128269;</button>
                </div>
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerCity">Cidade</label>
                <input id="newOwnerCity" name="newOwnerCity" type="text" value="<%= newOwnerInfo.city || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerStreet">Rua</label>
                <input id="newOwnerStreet" name="newOwnerStreet" type="text" value="<%= newOwnerInfo.street || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerNumber">Número</label>
                <input id="newOwnerNumber" name="newOwnerNumber" type="text" value="<%= newOwnerInfo.number || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerNeighborhood">Bairro</label>
                <input id="newOwnerNeighborhood" name="newOwnerNeighborhood" type="text" value="<%= newOwnerInfo.neighborhood || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerState">UF</label>
                <input id="newOwnerState" name="newOwnerState" type="text" maxlength="2" value="<%= newOwnerInfo.state || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerCountry">País</label>
                <input id="newOwnerCountry" name="newOwnerCountry" type="text" value="<%= newOwnerInfo.country || 'Brasil' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerPhone">Telefone/Whatsapp</label>
                <input id="newOwnerPhone" name="newOwnerPhone" type="text" value="<%= newOwnerInfo.phone || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="newOwnerEmail">E-mail</label>
                <input id="newOwnerEmail" name="newOwnerEmail" type="email" value="<%= newOwnerInfo.email || '' %>" />
              </div>
            </div>
          </div>

          <div class="content-card">
            <div class="content-title">Histórico</div>
            <div class="field" style="margin-top:12px;">
              <label class="field-label" for="historyNotes">Histórico</label>
              <textarea id="historyNotes" name="historyNotes" rows="5"><%= kitten?.historyNotes || '' %></textarea>
            </div>
            <div class="form-actions" style="margin-top:24px; text-align:right;">
              <button type="submit" class="btn btn-primary">Salvar</button>
              <a href="<%= cancelPath %>" class="btn">Cancelar</a>
            </div>
          </div>
        </form>
      </main>
    </div>

    <script src="/js/ems-data.js"></script>
    <script>
      const users = <%- JSON.stringify(users) %>;
      const currentOwnerMode = document.getElementById("currentOwnerMode");
      const registeredOwnerModeField = document.getElementById("registeredOwnerModeField");
      const registeredOwnerMode = document.getElementById("registeredOwnerMode");
      const currentOwnerField = document.getElementById("currentOwnerField");
      const currentOwnerSelect = document.getElementById("currentOwnerId");
      const ownerInfoLink = document.getElementById("ownerInfoLink");
      const ownerInfoBox = document.getElementById("ownerInfoBox");
      const newOwnerFields = document.getElementById("newOwnerFields");
      const newOwnerCep = document.getElementById("newOwnerCep");
      const cepLookupButton = document.getElementById("cepLookupButton");
      const newOwnerCity = document.getElementById("newOwnerCity");
      const newOwnerStreet = document.getElementById("newOwnerStreet");
      const newOwnerNeighborhood = document.getElementById("newOwnerNeighborhood");
      const newOwnerState = document.getElementById("newOwnerState");
      const newOwnerCountry = document.getElementById("newOwnerCountry");
      const microchipInput = document.getElementById("microchip");
      const breedSelect = document.getElementById("breed");
      const emsSelect = document.getElementById("emsCode");

      function formatMicrochip() {
        let digits = microchipInput.value.replace(/\D/g, "").slice(0, 15);
        microchipInput.value = (digits.match(/.{1,3}/g) || []).join(".");
      }

      function toggleOwnerField() {
        const isOther = currentOwnerMode.value === "OTHER";
        const isRegistered = registeredOwnerMode.value === "YES";

        registeredOwnerModeField.style.display = isOther ? "block" : "none";
        currentOwnerField.style.display = isOther && isRegistered ? "grid" : "none";
        newOwnerFields.style.display = isOther && !isRegistered ? "grid" : "none";

        if (!isOther || !isRegistered) {
          ownerInfoBox.style.display = "none";
        }
      }

      function renderOwnerInfo(event) {
        event.preventDefault();
        const selected = users.find((item) => String(item.id) === currentOwnerSelect.value);
        if (!selected) {
          ownerInfoBox.style.display = "none";
          return;
        }
        ownerInfoBox.style.display = "block";
        ownerInfoBox.innerHTML = `
          <strong>${selected.name}</strong><br>
          E-mail: ${selected.email || "-"}<br>
          Telefone: ${selected.phones || "-"}<br>
          Cidade: ${selected.city || "-"} / ${selected.state || "-"}
        `;
      }

      async function lookupCep() {
        const cep = newOwnerCep.value.replace(/\D/g, "");
        if (cep.length !== 8) return;

        try {
          const response = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
          if (!response.ok) return;
          const data = await response.json();
          if (data.erro) return;

          if (!newOwnerStreet.value) newOwnerStreet.value = data.logradouro || "";
          if (!newOwnerNeighborhood.value) newOwnerNeighborhood.value = data.bairro || "";
          if (!newOwnerCity.value) newOwnerCity.value = data.localidade || "";
          if (!newOwnerState.value) newOwnerState.value = data.uf || "";
          if (!newOwnerCountry.value) newOwnerCountry.value = "Brasil";
        } catch (error) {
          console.error(error);
        }
      }

      function bindBreedToEms() {
        const emsList = window.EMS_BY_BREED[breedSelect.value] || [];
        const currentValue = "<%= kitten?.emsCode || '' %>";
        emsSelect.innerHTML = "";
        if (!emsList.length) {
          const option = document.createElement("option");
          option.value = "";
          option.textContent = "Nenhum código disponível";
          emsSelect.appendChild(option);
          return;
        }
        emsList.forEach((ems) => {
          const option = document.createElement("option");
          option.value = ems;
          option.textContent = ems;
          if (ems === currentValue) option.selected = true;
          emsSelect.appendChild(option);
        });
      }

      currentOwnerMode.addEventListener("change", toggleOwnerField);
      registeredOwnerMode.addEventListener("change", toggleOwnerField);
      ownerInfoLink.addEventListener("click", renderOwnerInfo);
      newOwnerCep.addEventListener("blur", lookupCep);
      cepLookupButton.addEventListener("click", lookupCep);
      microchipInput.addEventListener("input", formatMicrochip);
      breedSelect.addEventListener("change", bindBreedToEms);

      toggleOwnerField();
      formatMicrochip();
      bindBreedToEms();
    </script>
  </body>
</html>

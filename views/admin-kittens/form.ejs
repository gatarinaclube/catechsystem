<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title><%= formTitle %> - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .kitten-property-grid {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) repeat(3, 160px);
        gap: 18px clamp(18px, 3vw, 48px);
        align-items: start;
        margin-top: 12px;
      }
      .kitten-property-grid select {
        width: 100%;
      }
      .owner-nested-field {
        margin-top: 10px;
      }
      .registered-owner-row {
        display: grid;
        grid-template-columns: minmax(180px, 240px) minmax(240px, 1fr);
        gap: 16px;
        margin-top: 12px;
        align-items: start;
      }
      .new-owner-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px 16px;
        margin-top: 12px;
      }
      .cep-lookup-row {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .cep-lookup-row input {
        min-width: 0;
        flex: 1;
      }
      .cep-lookup-button {
        flex: 0 0 40px;
        width: 40px;
        height: 38px;
        padding: 0;
        font-size: 16px;
      }
      @media (max-width: 1000px) {
        .kitten-property-grid,
        .registered-owner-row,
        .new-owner-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title"><%= formTitle %></h2>
            <div class="welcome-sub">Cadastro administrativo de filhotes.</div>
          </div>
          <div class="actions">
            <% if (historyPath) { %>
              <a href="<%= historyPath %>" class="btn">Histórico</a>
            <% } %>
            <a href="<%= cancelPath %>" class="btn">Voltar</a>
          </div>
        </div>

        <% if (error) { %>
          <div class="content-card" style="border-left:4px solid #b91c1c; margin-bottom:18px;">
            <div class="content-sub"><%= error %></div>
          </div>
        <% } %>

        <% if (success) { %>
          <div class="content-card" style="border-left:4px solid #16a34a; margin-bottom:18px; background:#f0fdf4;">
            <div class="content-title" style="color:#166534;">Cadastro salvo com sucesso.</div>
            <div class="content-sub">As informações do filhote foram atualizadas.</div>
          </div>
        <% } %>

        <% if (microchipRequiredNotice) { %>
          <div class="content-card" style="border-left:4px solid #f59e0b; margin-bottom:18px;">
            <div class="content-title">Microchip obrigatório</div>
            <div class="content-sub" style="margin-top:6px;"><%= microchipRequiredNotice %></div>
          </div>
        <% } %>

        <form method="post" action="<%= formAction %>" enctype="multipart/form-data">
          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Informações dos Filhotes</div>

            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="kittenNumber">N do Filhote</label>
                <input id="kittenNumber" name="kittenNumber" type="text" maxlength="4" value="<%= kitten?.kittenNumber || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="name">Nome do Filhote</label>
                <input id="name" name="name" type="text" maxlength="21" value="<%= kitten?.name || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="gender">Sexo</label>
                <select id="gender" name="gender">
                  <option value="">Selecione...</option>
                  <option value="M" <%= kitten?.gender === "M" ? "selected" : "" %>>Macho</option>
                  <option value="F" <%= kitten?.gender === "F" ? "selected" : "" %>>Fêmea</option>
                </select>
              </div>
            </div>

            <div class="grid-4" style="margin-top:12px; display:grid; grid-template-columns:repeat(4, minmax(0,1fr)); gap:16px;">
              <div class="field">
                <label class="field-label" for="microchip">Microchip</label>
                <input id="microchip" name="microchip" type="text" value="<%= kitten?.microchip || '' %>" placeholder="000.000.000.000.000" <%= microchipRequiredNotice ? "required" : "" %> />
                <div class="section-note" style="margin-top:6px;">
                  Filhotes cadastrados por ninhada podem ficar sem microchip até completar 4 meses.
                </div>
              </div>
              <div class="field">
                <label class="field-label" for="birthDate">Data de Nascimento</label>
                <input id="birthDate" name="birthDate" type="date" value="<%= kitten?.birthDate ? new Date(kitten.birthDate).toISOString().slice(0,10) : '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="motherId">Nome da Mãe</label>
                <select id="motherId" name="motherId">
                  <option value="">Selecione...</option>
                  <% females.forEach(function(cat) { %>
                    <option value="<%= cat.id %>" <%= String(kitten?.motherId || '') === String(cat.id) ? "selected" : "" %>><%= cat.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="fatherId">Nome do Pai</label>
                <select id="fatherId" name="fatherId">
                  <option value="">Selecione...</option>
                  <% males.forEach(function(cat) { %>
                    <option value="<%= cat.id %>" <%= String(kitten?.fatherId || '') === String(cat.id) ? "selected" : "" %>><%= cat.name %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="grid-4" style="margin-top:12px; display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:16px;">
              <div class="field">
                <label class="field-label" for="pedigreeType">Tipo de Registro</label>
                <select id="pedigreeType" name="pedigreeType">
                  <option value="">Selecione...</option>
                  <option value="LO" <%= kitten?.pedigreeType === "LO" ? "selected" : "" %>>LO</option>
                  <option value="RX" <%= kitten?.pedigreeType === "RX" ? "selected" : "" %>>RX</option>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="pedigreeNumber">N de Registro</label>
                <input id="pedigreeNumber" name="pedigreeNumber" type="text" maxlength="6" value="<%= kitten?.pedigreeNumber || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="breed">Raça</label>
                <select id="breed" name="breed">
                  <option value="">Selecione...</option>
                  <% breeds.forEach(function(breed) { %>
                    <option value="<%= breed %>" <%= kitten?.breed === breed ? "selected" : "" %>><%= breed %></option>
                  <% }) %>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="emsCode">Cor e EMS</label>
                <select id="emsCode" name="emsCode">
                  <option value="<%= kitten?.emsCode || '' %>"><%= kitten?.emsCode || 'Selecione a raça primeiro...' %></option>
                </select>
              </div>
            </div>

            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="breedingStatus">Reprodução</label>
                <select id="breedingStatus" name="breedingStatus">
                  <option value="FOR_BREEDING" <%= kitten?.neutered === true ? "" : "selected" %>>For Breeding</option>
                  <option value="NOT_FOR_BREEDING" <%= kitten?.neutered === true ? "selected" : "" %>>Not For Breeding</option>
                </select>
              </div>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Informações de Propriedade</div>
            <% const selectedOwnerClient = ownerClients.find(function(client) { return String(kitten?.currentOwnerClientId || '') === String(client.id); }); %>
            <% const ownerLockedBySale = kitten?.ownershipSource === 'SALE'; %>
            <% const ownerInfo = kitten?.newOwnerInfo || {}; %>
            <div class="grid-2" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="ownerClientSearch">Cliente proprietário</label>
                <input
                  id="ownerClientSearch"
                  list="ownerClientOptions"
                  value="<%= selectedOwnerClient ? selectedOwnerClient.label : '' %>"
                  placeholder="Digite o nome, CPF ou CNPJ do cliente"
                  autocomplete="off"
                  <%= ownerLockedBySale ? "readonly" : "" %>
                />
                <input type="hidden" id="currentOwnerClientId" name="currentOwnerClientId" value="<%= kitten?.currentOwnerClientId || '' %>" />
                <datalist id="ownerClientOptions">
                  <% ownerClients.forEach(function(client) { %>
                    <option value="<%= client.label %>" data-id="<%= client.id %>"></option>
                  <% }) %>
                </datalist>
                <% if (ownerLockedBySale) { %>
                  <div class="section-note" style="margin-top:8px;">
                    Proprietário vinculado por venda. Para alterar, edite a venda relacionada.
                  </div>
                <% } %>
              </div>
              <div class="field">
                <label class="field-label" for="kittenAvailabilityStatus">Status</label>
                <select id="kittenAvailabilityStatus" name="kittenAvailabilityStatus">
                  <% kittenStatusOptions.forEach(function(option) { %>
                    <option value="<%= option.value %>" <%= (kitten?.kittenAvailabilityStatus || 'UNAVAILABLE') === option.value ? "selected" : "" %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="grid-2" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="ownerContractLink">Link de acesso ao contrato</label>
                <input
                  id="ownerContractLink"
                  name="ownerContractLink"
                  type="url"
                  value="<%= ownerInfo.contractLink || '' %>"
                  placeholder="https://..."
                />
                <div class="section-note" style="margin-top:6px;">
                  Use este campo para colar o link de assinatura eletrônica ou acesso externo ao contrato.
                  <% if (ownerInfo.contractLink) { %>
                    <br><a href="<%= ownerInfo.contractLink %>" target="_blank" rel="noopener noreferrer">Abrir link atual</a>
                  <% } %>
                </div>
              </div>
              <div class="field">
                <label class="field-label" for="ownerContractFile">Anexar contrato</label>
                <input id="ownerContractFile" name="ownerContractFile" type="file" accept="application/pdf,image/jpeg,image/png,image/webp" />
                <% if (ownerInfo.contractFile?.path) { %>
                  <div class="section-note" style="margin-top:6px;">
                    Contrato atual:
                    <a href="<%= ownerInfo.contractFile.path %>" target="_blank" rel="noopener noreferrer">
                      <%= ownerInfo.contractFile.originalName || 'Abrir arquivo' %>
                    </a>
                  </div>
                <% } %>
              </div>
            </div>
            <div id="deathCauseBlock" class="grid-2" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="deathCause">Causa do óbito</label>
                <select id="deathCause" name="deathCause">
                  <option value="">Selecione...</option>
                  <% deathCauseOptions.forEach(function(option) { %>
                    <option value="<%= option %>" <%= kitten?.deathCause === option ? "selected" : "" %>><%= option %></option>
                  <% }) %>
                </select>
              </div>
              <div class="field" id="deathCauseDescriptionBlock">
                <label class="field-label" for="deathCauseDescription">Descrição da causa</label>
                <input id="deathCauseDescription" name="deathCauseDescription" value="<%= kitten?.deathCauseDescription || '' %>" placeholder="Descreva a causa do óbito" />
              </div>
            </div>
            <div id="ownerClientInfoBox" class="content-card" style="display:none; padding:12px; margin-top:12px;"></div>
          </div>

          <div class="content-card">
            <div class="content-title">Histórico</div>
            <div class="field" style="margin-top:12px;">
              <label class="field-label" for="historyNotes">Histórico</label>
              <textarea id="historyNotes" name="historyNotes" rows="5"><%= kitten?.historyNotes || '' %></textarea>
            </div>
            <div class="form-actions" style="margin-top:24px; text-align:right;">
              <button type="submit" class="btn btn-primary">Salvar</button>
              <a href="<%= cancelPath %>" class="btn">Cancelar</a>
            </div>
          </div>
        </form>
      </main>
    </div>

    <script src="/js/ems-data.js"></script>
    <script>
      const ownerClients = <%- JSON.stringify(ownerClients || []) %>;
      const ownerClientSearch = document.getElementById("ownerClientSearch");
      const currentOwnerClientId = document.getElementById("currentOwnerClientId");
      const ownerClientInfoBox = document.getElementById("ownerClientInfoBox");
      const microchipInput = document.getElementById("microchip");
      const breedSelect = document.getElementById("breed");
      const emsSelect = document.getElementById("emsCode");
      const kittenAvailabilityStatus = document.getElementById("kittenAvailabilityStatus");
      const deathCauseBlock = document.getElementById("deathCauseBlock");
      const deathCauseSelect = document.getElementById("deathCause");
      const deathCauseDescriptionBlock = document.getElementById("deathCauseDescriptionBlock");
      const deathCauseDescription = document.getElementById("deathCauseDescription");

      function formatMicrochip() {
        let digits = microchipInput.value.replace(/\D/g, "").slice(0, 15);
        microchipInput.value = (digits.match(/.{1,3}/g) || []).join(".");
      }

      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function renderOwnerClientInfo() {
        const selected = ownerClients.find((item) => String(item.id) === currentOwnerClientId.value);
        if (!selected) {
          ownerClientInfoBox.style.display = "none";
          return;
        }
        ownerClientInfoBox.style.display = "block";
        ownerClientInfoBox.innerHTML = `
          <strong>${escapeHtml(selected.fullName)}</strong><br>
          Documento: ${escapeHtml(selected.document || "-")}<br>
          E-mail: ${escapeHtml(selected.email || "-")}<br>
          Telefone: ${escapeHtml(selected.phone || "-")}<br>
          Cidade: ${escapeHtml(selected.city || "-")} / ${escapeHtml(selected.state || "-")}
        `;
      }

      function syncOwnerClientId() {
        const selected = ownerClients.find((item) => item.label === ownerClientSearch.value);
        currentOwnerClientId.value = selected ? selected.id : "";
        renderOwnerClientInfo();
      }

      function bindBreedToEms() {
        const emsList = window.EMS_BY_BREED[breedSelect.value] || [];
        const currentValue = "<%= kitten?.emsCode || '' %>";
        emsSelect.innerHTML = "";
        if (!emsList.length) {
          const option = document.createElement("option");
          option.value = "";
          option.textContent = "Nenhum código disponível";
          emsSelect.appendChild(option);
          return;
        }
        emsList.forEach((ems) => {
          const option = document.createElement("option");
          option.value = ems;
          option.textContent = ems;
          if (ems === currentValue) option.selected = true;
          emsSelect.appendChild(option);
        });
      }

      function toggleDeathCause() {
        const isDeceased = kittenAvailabilityStatus.value === "DECEASED";
        const needsDescription = ["Outro", "Causa Desconhecida"].includes(deathCauseSelect.value);
        deathCauseBlock.style.display = isDeceased ? "grid" : "none";
        deathCauseSelect.required = isDeceased;
        deathCauseDescriptionBlock.style.display = isDeceased && needsDescription ? "block" : "none";
        deathCauseDescription.required = isDeceased && needsDescription;
        if (!isDeceased) {
          deathCauseSelect.value = "";
          deathCauseDescription.value = "";
        }
      }

      ownerClientSearch.addEventListener("input", syncOwnerClientId);
      ownerClientSearch.addEventListener("change", syncOwnerClientId);
      microchipInput.addEventListener("input", formatMicrochip);
      breedSelect.addEventListener("change", bindBreedToEms);
      kittenAvailabilityStatus.addEventListener("change", toggleDeathCause);
      deathCauseSelect.addEventListener("change", toggleDeathCause);

      renderOwnerClientInfo();
      formatMicrochip();
      bindBreedToEms();
      toggleDeathCause();
    </script>
  </body>
</html>

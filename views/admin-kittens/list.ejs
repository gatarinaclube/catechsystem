<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Filhotes - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .kitten-list-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
      }
      .kitten-list-main {
        min-width: 0;
      }
      .kitten-list-main .item-link {
        color: #4b5563;
      }
      .kitten-list-actions {
        display: flex;
        align-items: center;
      }
      .kitten-quick-field {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin: 0;
      }
      .kitten-quick-field .field-label {
        margin: 0;
        font-size: 10px;
        white-space: nowrap;
      }
      .kitten-status-select {
        min-width: 160px;
        height: 36px;
        padding: 0 10px;
        font-size: 13px;
      }
      @media (max-width: 900px) {
        .kitten-list-item {
          align-items: stretch;
          flex-direction: column;
        }
        .kitten-list-actions {
          justify-content: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Filhotes</h2>
            <div class="welcome-sub">Lista administrativa dos filhotes cadastrados.</div>
          </div>
          <div class="actions">
            <a href="/admin/kittens/new" class="btn btn-primary">+ Novo Filhote</a>
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card module-panel">
          <form method="get" action="/admin/kittens" class="admin-filter-form">
            <input type="hidden" name="ownerId" id="kittensOwnerId" value="<%= selectedOwnerId || '' %>" />
            <div class="field" style="min-width:320px; flex:1;">
              <label class="field-label" for="kittensOwnerSearch">Filtrar por usuário</label>
              <input
                id="kittensOwnerSearch"
                list="kittensOwnersList"
                type="text"
                placeholder="Digite o nome do usuário"
                value="<%= selectedOwnerId ? ((users.find((u) => u.id === selectedOwnerId) || {}).name || '') : '' %>"
              />
              <datalist id="kittensOwnersList">
                <% users.forEach(function(item) { %>
                  <option value="<%= item.name %>"><%= item.email %></option>
                <% }) %>
              </datalist>
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/admin/kittens" class="btn">Limpar</a>
          </form>
        </div>

        <% const kittenGroups = [
          { title: "Disponíveis", items: groupedKittens.available || [], color: "#16a34a" },
          { title: "Reservados", items: groupedKittens.reserved || [], color: "#f59e0b" },
          { title: "Indisponíveis", items: groupedKittens.unavailable || [], color: "#64748b" },
          { title: "Padreadores/Matrizes", items: groupedKittens.breeders || [], color: "#7c3aed" },
          { title: "Entregues/Vendidos", items: groupedKittens.deliveredSold || [], color: "#6b7280" },
          { title: "Óbito", items: groupedKittens.deceased || [], color: "#374151" },
        ]; %>

        <% if (!kittenGroups.some(function(group) { return group.items.length; })) { %>
          <div class="content-card module-list-card">
            <div class="empty">Nenhum filhote cadastrado.</div>
          </div>
        <% } else { %>
          <% kittenGroups.forEach(function(group) { %>
            <details class="content-card module-panel module-accordion" open style="border-left: 5px solid <%= group.color %>;">
              <summary>
                <div class="module-accordion-summary">
                  <span class="module-accordion-icon">⌄</span>
                  <span class="module-accordion-title"><%= group.title %></span>
                </div>
                <span class="module-accordion-count"><%= group.items.length %></span>
              </summary>
              <div class="module-accordion-body module-list-card">
                <% if (!group.items.length) { %>
                  <div class="empty">Nenhum filhote nesta divisão.</div>
                <% } else { %>
                  <ul class="list">
                    <% group.items.forEach(function(kitten) { %>
                      <li class="item" style="border-left: 4px solid <%= kitten.deceased ? '#6b7280' : kitten.gender === 'F' ? '#db2777' : '#2563eb' %>;">
                        <div class="kitten-list-item">
                          <div class="kitten-list-main">
                            <a class="item-link" href="/admin/kittens/<%= kitten.id %>"><%= kitten.label %></a>
                          </div>
                          <form method="post" action="/admin/kittens/<%= kitten.id %>/quick-status" class="kitten-list-actions" data-quick-kitten-status>
                            <div class="kitten-quick-field">
                              <span class="field-label">Status:</span>
                              <select class="kitten-status-select" name="kittenAvailabilityStatus">
                                <% kittenStatusOptions.forEach(function(option) { %>
                                  <option value="<%= option.value %>" <%= kitten.kittenAvailabilityStatus === option.value ? "selected" : "" %>><%= option.label %></option>
                                <% }) %>
                              </select>
                            </div>
                          </form>
                        </div>
                      </li>
                    <% }) %>
                  </ul>
                <% } %>
              </div>
            </details>
          <% }) %>
        <% } %>
      </main>
    </div>
    <script>
      (function () {
        const searchInput = document.getElementById("kittensOwnerSearch");
        const hiddenInput = document.getElementById("kittensOwnerId");
        const users = <%- JSON.stringify(users) %>;

        function syncOwnerId() {
          const match = users.find((item) => item.name === searchInput.value);
          hiddenInput.value = match ? match.id : "";
        }

        searchInput.addEventListener("input", syncOwnerId);
        searchInput.addEventListener("change", syncOwnerId);

        document.querySelectorAll("[data-quick-kitten-status]").forEach((form) => {
          form.querySelectorAll("select").forEach((select) => {
            select.addEventListener("change", async () => {
              try {
                const response = await fetch(form.action, {
                  method: "POST",
                  body: new URLSearchParams(new FormData(form)),
                  credentials: "same-origin",
                  headers: {
                    "Content-Type": "application/x-www-form-urlencoded",
                    "X-Autosave": "true",
                  },
                });

                if (!response.ok) {
                  throw new Error("Erro ao atualizar filhote");
                }

                window.location.reload();
              } catch (error) {
                console.error(error);
              }
            });
          });
        });
      })();
    </script>
  </body>
</html>

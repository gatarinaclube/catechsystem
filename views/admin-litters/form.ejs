<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title><%= formTitle %> - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .litter-kitten-grid {
        display: grid;
        grid-template-columns: 90px minmax(150px, 22ch) 110px 190px 160px;
        column-gap: clamp(20px, 3vw, 56px);
        row-gap: 12px;
        align-items: start;
        width: 100%;
        justify-content: space-between;
      }
      .litter-kitten-grid input,
      .litter-kitten-grid select {
        width: 100%;
        min-width: 0;
      }
      .litter-kitten-field {
        min-width: 0;
      }
      .litter-kitten-field .field-label {
        margin-bottom: 4px;
        white-space: nowrap;
      }
      .litter-kitten-history {
        justify-self: end;
        align-self: end;
      }
      .litter-kitten-history .btn {
        min-width: 130px;
        text-align: center;
      }
      .litter-kitten-deceased {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 38px;
        color: var(--text-muted);
      }
      .litter-kitten-deceased input {
        width: auto;
        min-width: 0;
      }
      .litter-breeding-role {
        margin-top: 6px;
      }
      .litter-breeding-role select {
        width: 100%;
      }
      .litter-breeding-role:empty {
        display: none;
      }
      .litter-kitten-row-2 {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: 130px minmax(220px, 320px) 150px 140px;
        column-gap: clamp(20px, 3vw, 56px);
        row-gap: 12px;
        align-items: start;
        justify-content: space-between;
      }
      .admin-litter-kitten-row {
        display: block;
        width: 100%;
        box-sizing: border-box;
        padding: 14px;
        border: 1px solid var(--border-soft);
        border-radius: 12px;
        margin-bottom: 14px;
        background: #ffffff;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04);
      }
      .admin-litter-kitten-row.is-deceased {
        background: #e5e7eb;
      }
      @media (max-width: 1200px) {
        .litter-kitten-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .litter-kitten-row-2 {
          grid-column: 1 / -1;
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .litter-kitten-history {
          justify-self: stretch;
        }
      }
      @media (max-width: 700px) {
        .litter-kitten-grid,
        .litter-kitten-row-2 {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title"><%= formTitle %></h2>
            <div class="welcome-sub">Cadastro administrativo da ninhada e dos filhotes.</div>
          </div>
          <div class="actions">
            <a href="<%= cancelPath %>" class="btn">Voltar</a>
          </div>
        </div>

        <% if (error) { %>
          <div class="content-card" style="border-left:4px solid #b91c1c; margin-bottom:18px;">
            <div class="content-sub"><%= error %></div>
          </div>
        <% } %>

        <form method="post" action="<%= formAction %>">
          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Informações da Ninhada</div>
            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="litterNumber">N da ninhada</label>
                <input id="litterNumber" name="litterNumber" type="text" maxlength="3" value="<%= litter?.litterNumber || '' %>" placeholder="000" />
              </div>
              <div class="field">
                <label class="field-label" for="femaleCatId">Nome da Mãe</label>
                <select id="femaleCatId" name="femaleCatId">
                  <option value="">Selecione...</option>
                  <% females.forEach(function(cat) { %>
                    <option value="<%= cat.id %>" <%= String(litter?.femaleCatId || '') === String(cat.id) || litter?.femaleName === cat.name ? "selected" : "" %>><%= cat.name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="maleCatId">Nome do Pai</label>
                <select id="maleCatId" name="maleCatId">
                  <option value="">Selecione...</option>
                  <% males.forEach(function(cat) { %>
                    <option value="<%= cat.id %>" <%= String(litter?.maleCatId || '') === String(cat.id) || litter?.maleName === cat.name ? "selected" : "" %>><%= cat.name %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="litterBirthDate">Data de Nascimento</label>
                <input id="litterBirthDate" name="litterBirthDate" type="date" value="<%= litter?.litterBirthDate ? new Date(litter.litterBirthDate).toISOString().slice(0,10) : '' %>" />
              </div>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Informações dos Filhotes</div>
            <div class="grid-4" style="margin-top:12px; display:grid; grid-template-columns:repeat(4, minmax(0,1fr)); gap:16px;">
              <div class="field">
                <label class="field-label" for="femaleCount">Qtde de Fêmeas</label>
                <input id="femaleCount" name="femaleCount" type="number" min="0" max="99" value="<%= litter?.femaleCount ?? '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="maleCount">Qtde de Machos</label>
                <input id="maleCount" name="maleCount" type="number" min="0" max="99" value="<%= litter?.maleCount ?? '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="litterCountDisplay">Qtde de Filhotes</label>
                <input id="litterCountDisplay" type="number" readonly value="<%= litter?.litterCount ?? 0 %>" />
              </div>
              <div class="field">
                <label class="field-label" for="deadCount">Óbitos</label>
                <input id="deadCount" name="deadCount" type="number" min="0" value="<%= litter?.deadCount ?? 0 %>" />
              </div>
            </div>

            <div id="kittenRows" style="margin-top:16px;"></div>
          </div>

          <div class="content-card" id="deadStatsCard" style="margin-bottom:18px;">
            <div class="content-title">Estatísticas</div>
            <div id="deadStatsBlock" style="margin-top:12px;">
              <div class="grid-3">
                <div class="field">
                  <label class="field-label" for="deadAtBirthCount">Qtde mortes no parto</label>
                  <input id="deadAtBirthCount" name="deadAtBirthCount" type="number" min="0" value="<%= litter?.deadAtBirthCount ?? 0 %>" />
                </div>
                <div class="field">
                  <label class="field-label" for="deadAfterBirthCount">Qtde mortes pós parto</label>
                  <input id="deadAfterBirthCount" name="deadAfterBirthCount" type="number" min="0" value="<%= litter?.deadAfterBirthCount ?? 0 %>" />
                </div>
              </div>

              <div id="deadAtBirthDetails" class="grid-3" style="margin-top:12px;">
                <div class="field">
                  <label class="field-label" for="deadAtBirthMaleCount">Machos mortos no parto</label>
                  <input id="deadAtBirthMaleCount" name="deadAtBirthMaleCount" type="number" min="0" value="<%= litter?.deadAtBirthMaleCount ?? 0 %>" />
                </div>
                <div class="field">
                  <label class="field-label" for="deadAtBirthFemaleCount">Fêmeas mortas no parto</label>
                  <input id="deadAtBirthFemaleCount" name="deadAtBirthFemaleCount" type="number" min="0" value="<%= litter?.deadAtBirthFemaleCount ?? 0 %>" />
                </div>
              </div>

              <div id="deadAfterBirthDetails" class="grid-3" style="margin-top:12px;">
                <div class="field">
                  <label class="field-label" for="deadAfterBirthMaleCount">Machos mortos pós parto</label>
                  <input id="deadAfterBirthMaleCount" name="deadAfterBirthMaleCount" type="number" min="0" value="<%= litter?.deadAfterBirthMaleCount ?? 0 %>" />
                </div>
                <div class="field">
                  <label class="field-label" for="deadAfterBirthFemaleCount">Fêmeas mortas pós parto</label>
                  <input id="deadAfterBirthFemaleCount" name="deadAfterBirthFemaleCount" type="number" min="0" value="<%= litter?.deadAfterBirthFemaleCount ?? 0 %>" />
                </div>
              </div>
            </div>

            <div class="field" style="margin-top:12px;">
              <label class="field-label" for="historyNotes">Histórico</label>
              <textarea id="historyNotes" name="historyNotes" rows="5"><%= litter?.historyNotes || '' %></textarea>
            </div>
          </div>

          <div class="form-actions" style="text-align:right;">
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a href="<%= cancelPath %>" class="btn">Cancelar</a>
          </div>
        </form>
      </main>
    </div>

    <script src="/js/ems-data.js"></script>
    <script>
      const breeds = <%- JSON.stringify(breeds) %>;
      const kittens = <%- JSON.stringify(kittens.map((kitten) => ({
        ...kitten,
        kittenCatId: kitten.kittenCatId || null,
      }))) %>;
      const kittenNameMaxLength = <%- JSON.stringify(kittenNameMaxLength || 30) %>;
      const femaleCountInput = document.getElementById("femaleCount");
      const maleCountInput = document.getElementById("maleCount");
      const litterCountDisplay = document.getElementById("litterCountDisplay");
      const kittenRows = document.getElementById("kittenRows");
      const deadCountInput = document.getElementById("deadCount");
      const deadStatsBlock = document.getElementById("deadStatsBlock");
      const deadAtBirthCountInput = document.getElementById("deadAtBirthCount");
      const deadAtBirthDetails = document.getElementById("deadAtBirthDetails");
      const deadAfterBirthCountInput = document.getElementById("deadAfterBirthCount");
      const deadAfterBirthDetails = document.getElementById("deadAfterBirthDetails");

      function bindBreedToEms(select, emsSelect, currentValue) {
        const emsList = window.EMS_BY_BREED[select.value] || [];
        emsSelect.innerHTML = "";

        if (!emsList.length) {
          const opt = document.createElement("option");
          opt.value = "";
          opt.textContent = "Nenhum código disponível";
          emsSelect.appendChild(opt);
          return;
        }

        emsList.forEach((ems) => {
          const opt = document.createElement("option");
          opt.value = ems;
          opt.textContent = ems;
          if (currentValue === ems) opt.selected = true;
          emsSelect.appendChild(opt);
        });
      }

      function formatMicrochipInput(input) {
        let digits = input.value.replace(/\D/g, "").slice(0, 15);
        const groups = digits.match(/.{1,3}/g) || [];
        input.value = groups.join(".");
      }

      function updateDeadBlocks() {
        const hasDeadKittens = Number(deadCountInput.value || 0) > 0;
        deadStatsBlock.style.display = hasDeadKittens ? "block" : "none";
        deadAtBirthDetails.style.display = Number(deadAtBirthCountInput.value || 0) > 0 ? "grid" : "none";
        deadAfterBirthDetails.style.display = Number(deadAfterBirthCountInput.value || 0) > 0 ? "grid" : "none";
      }

      function renderKittenRows() {
        const femaleCount = Number(femaleCountInput.value || 0);
        const maleCount = Number(maleCountInput.value || 0);
        const total = femaleCount + maleCount;
        litterCountDisplay.value = total;
        kittenRows.innerHTML = "";

        for (let i = 0; i < total; i += 1) {
          const kitten = kittens[i] || {};
          const row = document.createElement("div");
          row.className = "admin-litter-kitten-row" + (kitten.deceased ? " is-deceased" : "");
          row.innerHTML = `
            <input type="hidden" name="kitten_id_${i}" value="${kitten.id || ""}">
            <input type="hidden" name="kitten_cat_id_${i}" value="${kitten.kittenCatId || ""}">
            <div class="litter-kitten-grid">
              <div class="litter-kitten-field">
                <label class="field-label">N do Filhote</label>
                <input name="kitten_number_${i}" maxlength="4" value="${kitten.kittenNumber || ""}" />
              </div>
              <div class="litter-kitten-field">
                <label class="field-label">Nome do Filhote</label>
                <input name="kitten_name_${i}" maxlength="${kittenNameMaxLength}" value="${kitten.name || ""}" />
              </div>
              <div class="litter-kitten-field">
                <label class="field-label">Sexo</label>
                <select name="kitten_sex_${i}">
                  <option value="">Selecione...</option>
                  <option value="M" ${kitten.sex === "M" ? "selected" : ""}>Macho</option>
                  <option value="F" ${kitten.sex === "F" ? "selected" : ""}>Fêmea</option>
                </select>
              </div>
              <div class="litter-kitten-field">
                <label class="field-label">Microchip</label>
                <input name="kitten_microchip_${i}" class="kitten-microchip" maxlength="19" inputmode="numeric" value="${kitten.microchip || ""}" />
              </div>
              <div class="litter-kitten-field">
                <label class="field-label">Reprodução?</label>
                <select name="kitten_breeding_${i}">
                  <option value="FOR_BREEDING" ${kitten.breeding === "FOR_BREEDING" ? "selected" : ""}>For Breeding</option>
                  <option value="NOT_FOR_BREEDING" ${kitten.breeding === "NOT_FOR_BREEDING" ? "selected" : ""}>Not For Breeding</option>
                </select>
              </div>
              <div class="litter-kitten-row-2">
                <div class="litter-kitten-field">
                  <label class="field-label">Raça</label>
                  <select name="kitten_breed_${i}" data-kit-breed="${i}">
                    <option value="">Raça...</option>
                    ${breeds.map((breed) => `<option value="${breed}" ${kitten.breed === breed ? "selected" : ""}>${breed}</option>`).join("")}
                  </select>
                </div>
                <div class="litter-kitten-field">
                  <label class="field-label">Cor e EMS</label>
                  <select name="kitten_ems_${i}" data-kit-ems="${i}">
                    <option value="${kitten.emsEyes || ""}">${kitten.emsEyes || "EMS..."}</option>
                  </select>
                </div>
                <div class="litter-kitten-field">
                  <label class="field-label">&nbsp;</label>
                  <label class="litter-kitten-deceased">
                    <input type="checkbox" name="kitten_deceased_${i}" ${kitten.deceased ? "checked" : ""}>
                    Óbito
                  </label>
                  <div class="litter-breeding-role" data-breeding-role-box="${i}" style="display:none;">
                    <select name="kitten_breeding_role_${i}" data-breeding-role="${i}">
                      <option value="">Selecione...</option>
                    </select>
                  </div>
                </div>
                <div class="litter-kitten-history">
                  ${kitten.kittenCatId ? `<a href="/admin/history/${kitten.kittenCatId}" class="btn">Histórico</a>` : `<span style="font-size:12px; color:var(--text-muted);">Histórico será criado ao salvar</span>`}
                </div>
              </div>
            </div>
          `;
          kittenRows.appendChild(row);
        }

        document.querySelectorAll("[data-kit-breed]").forEach((select) => {
          const idx = select.dataset.kitBreed;
          const emsSelect = document.querySelector(`[data-kit-ems="${idx}"]`);
          const kitten = kittens[idx] || {};
          bindBreedToEms(select, emsSelect, kitten.emsEyes || "");
          select.addEventListener("change", () => bindBreedToEms(select, emsSelect, ""));
        });

        document.querySelectorAll(".kitten-microchip").forEach((input) => {
          input.addEventListener("input", () => formatMicrochipInput(input));
          formatMicrochipInput(input);
        });

        document.querySelectorAll('select[name^="kitten_breeding_"]:not([name^="kitten_breeding_role_"])').forEach((select) => {
          const index = select.name.replace("kitten_breeding_", "");
          const sexSelect = document.querySelector(`[name="kitten_sex_${index}"]`);
          const roleBox = document.querySelector(`[data-breeding-role-box="${index}"]`);
          const roleSelect = document.querySelector(`[data-breeding-role="${index}"]`);
          const kitten = kittens[index] || {};

          function updateBreedingRole() {
            const sex = sexSelect.value;
            const isForBreeding = select.value === "FOR_BREEDING";
            roleBox.style.display = isForBreeding ? "block" : "none";
            roleSelect.innerHTML = '<option value="">Selecione...</option>';

            if (!isForBreeding) {
              roleSelect.value = "";
              return;
            }

            if (sex === "F") {
              roleSelect.innerHTML += '<option value="NEW_DAM">Nova Matriz</option>';
            } else if (sex === "M") {
              roleSelect.innerHTML += '<option value="NEW_SIRE">Novo Padreador</option>';
            }

            if (kitten.breedingRole) {
              roleSelect.value = kitten.breedingRole;
            }
          }

          select.addEventListener("change", updateBreedingRole);
          sexSelect.addEventListener("change", updateBreedingRole);
          updateBreedingRole();
        });

        document.querySelectorAll('input[type="checkbox"][name^="kitten_deceased_"]').forEach((checkbox) => {
          checkbox.addEventListener("change", () => {
            checkbox.closest(".admin-litter-kitten-row").classList.toggle("is-deceased", checkbox.checked);
          });
        });
      }

      femaleCountInput.addEventListener("input", renderKittenRows);
      maleCountInput.addEventListener("input", renderKittenRows);
      deadCountInput.addEventListener("input", updateDeadBlocks);
      deadAtBirthCountInput.addEventListener("input", updateDeadBlocks);
      deadAfterBirthCountInput.addEventListener("input", updateDeadBlocks);

      renderKittenRows();
      updateDeadBlocks();
    </script>
  </body>
</html>

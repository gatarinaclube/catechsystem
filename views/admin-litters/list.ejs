<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Ninhadas - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Ninhadas</h2>
            <div class="welcome-sub">Lista administrativa de ninhadas cadastradas.</div>
          </div>
          <div class="actions">
            <a href="/admin/litters/new" class="btn btn-primary">+ Nova Ninhada</a>
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card" style="margin-bottom: 18px;">
          <form method="get" action="/admin/litters" style="display:flex; gap:10px; align-items:end; flex-wrap:wrap;">
            <input type="hidden" name="ownerId" id="littersOwnerId" value="<%= selectedOwnerId || '' %>" />
            <div class="field" style="min-width:320px; flex:1;">
              <label class="field-label" for="littersOwnerSearch">Filtrar por usuário</label>
              <input
                id="littersOwnerSearch"
                list="littersOwnersList"
                type="text"
                placeholder="Digite o nome do usuário"
                value="<%= selectedOwnerId ? ((users.find((u) => u.id === selectedOwnerId) || {}).name || '') : '' %>"
              />
              <datalist id="littersOwnersList">
                <% users.forEach(function(item) { %>
                  <option value="<%= item.name %>" data-id="<%= item.id %>"><%= item.email %></option>
                <% }) %>
              </datalist>
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/admin/litters" class="btn">Limpar</a>
          </form>
        </div>

        <div class="content-card">
          <% if (!litters.length) { %>
            <div class="empty">Nenhuma ninhada cadastrada.</div>
          <% } else { %>
            <ul class="list">
              <% litters.forEach(function(litter) { %>
                <li class="item">
                  <div>
                    <a class="item-link" href="/admin/litters/<%= litter.id %>"><%= litter.label %></a>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </main>
    </div>
    <script>
      (function () {
        const searchInput = document.getElementById("littersOwnerSearch");
        const hiddenInput = document.getElementById("littersOwnerId");
        const users = <%- JSON.stringify(users) %>;

        function syncOwnerId() {
          const match = users.find((item) => item.name === searchInput.value);
          hiddenInput.value = match ? match.id : "";
        }

        searchInput.addEventListener("input", syncOwnerId);
        searchInput.addEventListener("change", syncOwnerId);
      })();
    </script>
  </body>
</html>

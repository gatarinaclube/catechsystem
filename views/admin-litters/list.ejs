<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Ninhadas - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Ninhadas</h2>
            <div class="welcome-sub">Lista administrativa de ninhadas cadastradas.</div>
          </div>
          <div class="actions">
            <a href="/admin/litters/new" class="btn btn-primary">+ Nova Ninhada</a>
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card">
          <% if (!litters.length) { %>
            <div class="empty">Nenhuma ninhada cadastrada.</div>
          <% } else { %>
            <ul class="list">
              <% litters.forEach(function(litter) { %>
                <li class="item">
                  <div>
                    <a class="item-link" href="/admin/litters/<%= litter.id %>"><%= litter.label %></a>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>

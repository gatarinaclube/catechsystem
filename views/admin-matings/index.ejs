<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Acasalamentos - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .mating-table {
        display: grid;
        grid-template-columns:
          minmax(0, 1.25fr)
          minmax(0, 0.85fr)
          minmax(0, 1fr)
          minmax(0, 0.7fr)
          minmax(130px, 0.62fr)
          minmax(190px, 1.08fr);
        gap: 10px;
        align-items: start;
        min-width: 0;
      }
      .mating-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .mating-row {
        padding: 12px;
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        margin-bottom: 12px;
      }
      .parent-line {
        margin-top: 4px;
        font-size: 11px;
        line-height: 1.35;
        color: var(--text-muted);
      }
      .birth-line {
        margin-top: 4px;
        font-size: 11px;
        line-height: 1.35;
        color: var(--text-muted);
      }
      .parent-line span {
        display: block;
      }
      .origin-button {
        margin-top: 4px;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--accent);
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
      }
      .origin-dialog {
        width: min(920px, calc(100vw - 32px));
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        padding: 20px;
        color: var(--text-main);
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
      }
      .origin-dialog::backdrop {
        background: rgba(15, 23, 42, 0.38);
      }
      .origin-dialog-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
      }
      .origin-dialog-title {
        font-size: 16px;
        font-weight: 700;
      }
      .pedigree-tree,
      .pedigree-tree ul {
        list-style: none;
        margin: 0;
        padding-left: 22px;
        position: relative;
      }
      .pedigree-tree {
        padding-left: 0;
      }
      .pedigree-tree ul {
        margin-top: 10px;
        border-left: 2px solid #dbeafe;
      }
      .pedigree-tree li {
        margin: 10px 0;
        line-height: 1.35;
        position: relative;
      }
      .pedigree-tree ul > li::before {
        content: "";
        position: absolute;
        left: -22px;
        top: 20px;
        width: 18px;
        height: 2px;
        background: #dbeafe;
      }
      .pedigree-node {
        display: inline-grid;
        gap: 2px;
        min-width: 190px;
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        background: #ffffff;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.06);
      }
      .pedigree-node.is-root {
        border-color: #86efac;
        background: #f0fdf4;
      }
      .pedigree-node.is-father {
        border-color: #93c5fd;
        background: #eff6ff;
      }
      .pedigree-node.is-mother {
        border-color: #f9a8d4;
        background: #fdf2f8;
      }
      .pedigree-label {
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .pedigree-name {
        color: #111827;
        font-weight: 700;
        font-size: 14px;
      }
      .mating-date-field .field-label {
        display: block;
        margin-bottom: 4px;
      }
      .mating-male-field {
        margin-top: 8px;
      }
      .mating-male-field .field-label {
        display: block;
        margin-bottom: 4px;
      }
      .mating-dpp {
        padding-left: 14px;
      }
      .mini-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .inline-plus {
        display: flex;
        gap: 8px;
        align-items: center;
        min-width: 0;
      }
      .mating-table input,
      .mating-table select {
        width: 100%;
        min-width: 0;
      }
      .inline-plus select,
      .inline-plus input {
        flex: 1 1 auto;
      }
      .history-date-display {
        flex: 1 1 auto;
        min-width: 0;
        padding: 8px 10px;
        border: 1px solid var(--border-soft);
        border-radius: 8px;
        background: #f8fafc;
        font-size: 13px;
      }
      .delete-history-date {
        min-width: 38px;
        padding-left: 0;
        padding-right: 0;
      }
      @media (max-width: 900px) {
        .mating-table {
          grid-template-columns: 1fr;
        }
        .mating-header {
          display: none;
        }
        .origin-dialog {
          padding: 14px;
        }
        .pedigree-tree,
        .pedigree-tree ul {
          padding-left: 14px;
        }
        .pedigree-tree ul > li::before {
          left: -14px;
          width: 11px;
        }
        .pedigree-node {
          min-width: min(210px, 72vw);
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Acasalamentos</h2>
            <div class="welcome-sub">Planejamento reprodutivo das fêmeas cadastradas.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card module-panel">
          <form method="get" action="/admin/matings" class="admin-filter-form">
            <div class="field" style="min-width:320px; flex:1;">
              <label class="field-label" for="matingsOwnerSearch">Filtrar por usuário</label>
              <input type="hidden" name="ownerId" id="matingsOwnerId" value="<%= selectedOwnerId || '' %>" />
              <input
                id="matingsOwnerSearch"
                list="matingsOwnersList"
                type="text"
                placeholder="Digite o nome do usuário"
                value="<%= selectedOwnerId ? ((users.find((u) => u.id === selectedOwnerId) || {}).name || '') : '' %>"
              />
              <datalist id="matingsOwnersList">
                <% users.forEach(function(item) { %>
                  <option value="<%= item.name %>"><%= item.email %></option>
                <% }) %>
              </datalist>
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/admin/matings" class="btn">Limpar</a>
          </form>
        </div>

        <% function escapeHtml(value) {
          return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
        } %>
        <% function pedigreeNodeClass(label) {
          const normalized = String(label || "").toLowerCase();
          if (normalized.includes("pai")) return "is-father";
          if (normalized.includes("mãe") || normalized.includes("mae")) return "is-mother";
          return "is-root";
        } %>
        <% function renderPedigreeNode(node, label, level) {
          if (!node) {
            return "";
          }

          const fatherBranch = node.father
            ? renderPedigreeNode(node.father, "Pai", level - 1)
            : node.fatherName
              ? `<li><div class="pedigree-node is-father"><span class="pedigree-label">Pai</span><span class="pedigree-name">${escapeHtml(node.fatherName)}</span></div></li>`
              : "";
          const motherBranch = node.mother
            ? renderPedigreeNode(node.mother, "Mãe", level - 1)
            : node.motherName
              ? `<li><div class="pedigree-node is-mother"><span class="pedigree-label">Mãe</span><span class="pedigree-name">${escapeHtml(node.motherName)}</span></div></li>`
              : "";
          const children = level > 1 && (fatherBranch || motherBranch)
            ? `<ul>${fatherBranch}${motherBranch}</ul>`
            : "";
          return `<li><div class="pedigree-node ${pedigreeNodeClass(label)}"><span class="pedigree-label">${escapeHtml(label)}</span><span class="pedigree-name">${escapeHtml(node.name)}</span></div>${children}</li>`;
        } %>

        <% groups.forEach(function(group) { %>
          <% const items = grouped[group.key] || []; %>
          <details class="content-card module-panel module-accordion">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= group.label %></span>
              </div>
              <span class="module-accordion-count"><%= items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <div class="mating-table mating-header">
                <div>Fêmea</div>
                <div>Status</div>
                <div>Últimas Ninhadas</div>
                <div>Próxima Cruza</div>
                <div>Data Cruza</div>
                <div>DPP</div>
              </div>

              <% if (!items.length) { %>
                <div class="empty" style="margin-top:12px;">Nenhum registro nesta divisão.</div>
              <% } else { %>
                <% items.forEach(function(row) { %>
                <form method="post" action="/admin/matings/<%= row.female.id %>" class="mating-row">
                  <input type="hidden" name="ownerId" value="<%= selectedOwnerId || '' %>" />
                  <div class="mating-table">
                    <div>
                      <div class="item-title"><%= row.femaleDisplayName %></div>
                      <div class="birth-line">Nascimento: <%= row.birthDateLabel %></div>
                      <div class="parent-line">
                        <span>Pai: <%= row.fatherName %></span>
                        <span>Mãe: <%= row.motherName %></span>
                      </div>
                      <button type="button" class="origin-button" data-open-origin="origin-<%= row.female.id %>">Origem</button>
                      <dialog class="origin-dialog" id="origin-<%= row.female.id %>">
                        <div class="origin-dialog-header">
                          <div class="origin-dialog-title">Origem - <%= row.femaleDisplayName %></div>
                          <button type="button" class="btn" data-close-origin>Fechar</button>
                        </div>
                        <ul class="pedigree-tree">
                          <%- renderPedigreeNode(row.pedigree, "Gata", 5) %>
                        </ul>
                      </dialog>
                    </div>

                    <div class="mini-stack">
                      <select name="status">
                        <% groups.forEach(function(statusItem) { %>
                          <option value="<%= statusItem.key %>" <%= row.status === statusItem.key ? "selected" : "" %>><%= statusItem.label %></option>
                        <% }) %>
                      </select>
                      <div class="mating-male-field">
                        <label class="field-label">Macho</label>
                        <select name="maleCatId">
                          <option value="">Selecione...</option>
                          <% row.maleOptions.forEach(function(male) { %>
                            <option value="<%= male.id %>" <%= String(row.plan?.maleCatId || '') === String(male.id) ? "selected" : "" %>><%= male.name %></option>
                          <% }) %>
                        </select>
                      </div>
                    </div>

                    <div class="mini-stack" data-history-box>
                      <% const historyList = row.litterHistory.length ? row.litterHistory : [""]; %>
                      <% historyList.forEach(function(value) { %>
                        <div class="inline-plus" data-history-row>
                          <% if (value) { %>
                            <input type="hidden" name="litterHistoryDates" value="<%= formatDateInput(value) %>" />
                            <span class="history-date-display"><%= formatDate(value) %></span>
                            <button type="button" class="btn delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
                          <% } else { %>
                            <input type="date" name="litterHistoryDates" value="" />
                          <% } %>
                        </div>
                      <% }) %>
                      <div class="history-add-row">
                        <button type="button" class="btn add-history-date">+</button>
                      </div>
                    </div>

                    <div>
                      <strong><%= row.nextCrossDate ? formatDate(row.nextCrossDate) : "-" %></strong>
                    </div>

                    <div class="mini-stack">
                      <div class="mating-date-field">
                        <label class="field-label">1º dia</label>
                        <input type="date" name="matingStartDate" value="<%= row.plan?.matingStartDate ? formatDateInput(row.plan.matingStartDate) : '' %>" />
                      </div>
                      <div class="mating-date-field">
                        <label class="field-label">2º dia</label>
                        <input type="date" name="matingEndDate" value="<%= row.plan?.matingEndDate ? formatDateInput(row.plan.matingEndDate) : '' %>" />
                      </div>
                    </div>

                    <div class="mini-stack mating-dpp">
                      <div><strong><%= row.dppDate ? formatDate(row.dppDate) : "-" %></strong></div>
                      <div><%= row.gestationDays !== null ? row.gestationDays + " dias de gestação" : "-" %></div>
                    </div>
                  </div>
                </form>
                <% }) %>
              <% } %>
            </div>
          </details>
        <% }) %>
      </main>
    </div>

    <script>
      (function () {
        const users = <%- JSON.stringify(users) %>;
        const ownerSearch = document.getElementById("matingsOwnerSearch");
        const ownerId = document.getElementById("matingsOwnerId");

        function syncOwnerId() {
          const match = users.find((item) => item.name === ownerSearch.value);
          ownerId.value = match ? match.id : "";
        }

        ownerSearch.addEventListener("input", syncOwnerId);
        ownerSearch.addEventListener("change", syncOwnerId);

        async function autosave(form) {
          if (!form) return;
          if (form.dataset.submitting === "true") {
            form.dataset.pendingSave = "true";
            return;
          }

          form.dataset.submitting = "true";
          form.dataset.pendingSave = "false";

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(form)),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
              },
            });

            if (!response.ok) {
              throw new Error("Erro ao salvar");
            }
          } catch (error) {
            console.error(error);
          } finally {
            form.dataset.submitting = "false";
            if (form.dataset.pendingSave === "true") {
              autosave(form);
            }
          }
        }

        document.querySelectorAll("[data-open-origin]").forEach((button) => {
          button.addEventListener("click", () => {
            document.getElementById(button.dataset.openOrigin)?.showModal();
          });
        });

        document.querySelectorAll("[data-close-origin]").forEach((button) => {
          button.addEventListener("click", () => {
            button.closest("dialog")?.close();
          });
        });

        document.querySelectorAll(".add-history-date").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-history-box]");
            const row = document.createElement("div");
            row.className = "inline-plus";
            row.dataset.historyRow = "";
            row.innerHTML = '<input type="date" name="litterHistoryDates" value="" />';
            box.insertBefore(row, button.closest(".history-add-row"));
            bindHistoryRow(row);
          });
        });

        function formatDisplayDate(value) {
          if (!value) return "";
          const parts = value.split("-");
          if (parts.length !== 3) return value;
          return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        function addDeleteHandler(button) {
          button.addEventListener("click", () => {
            const row = button.closest("[data-history-row]");
            const form = button.closest("form");
            row.remove();

            autosave(form);
          });
        }

        function bindHistoryRow(row) {
          const input = row.querySelector('input[type="date"]');
          if (input) {
            input.addEventListener("change", () => {
              if (!input.value) return;
              row.innerHTML = `
                <input type="hidden" name="litterHistoryDates" value="${input.value}" />
                <span class="history-date-display">${formatDisplayDate(input.value)}</span>
                <button type="button" class="btn delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
              `;
              addDeleteHandler(row.querySelector(".delete-history-date"));
              autosave(row.closest("form"));
            });
          }

          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) addDeleteHandler(deleteButton);
        }

        document.querySelectorAll("[data-history-row]").forEach(bindHistoryRow);
        document.querySelectorAll(".mating-row select, .mating-row input[type='date']").forEach((field) => {
          field.addEventListener("change", () => autosave(field.closest("form")));
        });
      })();
    </script>
  </body>
</html>

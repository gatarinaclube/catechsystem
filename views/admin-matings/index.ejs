<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Acasalamentos - PetGus</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .shell {
        max-width: 100vw;
      }
      .main {
        min-width: 0;
        max-width: calc(100vw - 260px);
        overflow: hidden;
      }
      .module-panel {
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
      }
      .mating-table {
        display: grid;
        grid-template-columns:
          220px
          138px
          170px
          196px
          125px
          112px
          112px
          94px
          86px;
        align-items: stretch;
        min-width: 1237px;
      }
      .mating-header {
        font-size: 12px;
        font-weight: 600;
        color: #111827;
        background: #e5e7eb;
        border-top: 1px solid #94a3b8;
        border-left: 1px solid #94a3b8;
        position: sticky;
        top: 0;
        z-index: 2;
      }
      .mating-header > div {
        padding: 7px 8px;
        border-right: 1px solid #94a3b8;
        border-bottom: 1px solid #94a3b8;
        text-align: center;
      }
      .mating-row {
        display: block;
        margin: 0;
        border: 0;
        border-radius: 0;
        background: #ffffff;
      }
      .mating-row[data-status="CONFIRMADO"] .mating-table > div {
        border-left-color: #16a34a;
      }
      .mating-row[data-status="NAO_CONFIRMADO"] .mating-table > div {
        border-left-color: #f97316;
      }
      .mating-row[data-status="PARA_ACASALAR"] .mating-table > div {
        border-left-color: #2563eb;
      }
      .mating-row[data-status="PAUSA_REPRODUTIVA"] .mating-table > div {
        border-left-color: #7c3aed;
      }
      .mating-row[data-status="COM_PROBLEMA"] .mating-table > div {
        border-left-color: #dc2626;
      }
      .mating-row[data-status="EM_DESENVOLVIMENTO"] .mating-table > div {
        border-left-color: #64748b;
      }
      .mating-row.is-supplementing {
        background: #ecfdf5;
      }
      .mating-row .mating-table {
        border-left: 1px solid #cbd5e1;
      }
      .mating-row .mating-table > div {
        min-height: 40px;
        padding: 5px 7px;
        border-right: 1px solid #cbd5e1;
        border-bottom: 1px solid #cbd5e1;
        border-left: 3px solid transparent;
        background: rgba(255, 255, 255, 0.78);
      }
      .mating-row.is-supplementing .mating-table > div {
        background: rgba(236, 253, 245, 0.88);
      }
      .mating-sheet-shell {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        margin-top: 14px;
        overflow: hidden;
      }
      .mating-sheet-wrap {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: auto;
        overflow-y: visible;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        background: #f8fafc;
      }
      .mating-scrollbar {
        width: 100%;
        max-width: 100%;
        height: 18px;
        margin-top: 8px;
        overflow-x: auto;
        overflow-y: hidden;
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        background: #f8fafc;
        position: sticky;
        bottom: 0;
        z-index: 3;
      }
      .mating-scrollbar-inner {
        height: 1px;
        min-width: 100%;
      }
      .mating-status-divider {
        display: grid;
        grid-template-columns: 220px 1fr;
        align-items: center;
        min-width: 1237px;
        border-left: 1px solid #94a3b8;
        border-right: 1px solid #94a3b8;
        border-bottom: 1px solid #94a3b8;
        color: #ffffff;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .mating-status-divider span {
        padding: 6px 10px;
      }
      .mating-status-divider small {
        justify-self: end;
        padding: 6px 10px;
        font-size: 11px;
        opacity: 0.86;
      }
      .mating-section-scrollbar {
        height: 12px;
        min-width: 1237px;
        overflow-x: auto;
        overflow-y: hidden;
        border-left: 1px solid #94a3b8;
        border-right: 1px solid #94a3b8;
        border-bottom: 1px solid rgba(148, 163, 184, 0.72);
        background: rgba(241, 245, 249, 0.96);
      }
      .mating-section-scrollbar-inner {
        height: 1px;
        min-width: 100%;
      }
      .mating-status-divider[data-status="CONFIRMADO"] {
        background: #15803d;
      }
      .mating-status-divider[data-status="NAO_CONFIRMADO"] {
        background: #ea580c;
      }
      .mating-status-divider[data-status="PARA_ACASALAR"] {
        background: #2563eb;
      }
      .mating-status-divider[data-status="PAUSA_REPRODUTIVA"] {
        background: #7c3aed;
      }
      .mating-status-divider[data-status="COM_PROBLEMA"] {
        background: #dc2626;
      }
      .mating-status-divider[data-status="EM_DESENVOLVIMENTO"] {
        background: #475569;
      }
      .mating-female-cell {
        position: sticky;
        left: 0;
        z-index: 1;
        box-shadow: 8px 0 14px rgba(15, 23, 42, 0.08);
      }
      .mating-row .mating-female-cell {
        background: #f8fafc;
      }
      .mating-row.is-supplementing .mating-female-cell {
        background: #dcfce7;
      }
      .mating-header .mating-female-cell {
        z-index: 3;
        background: #d1d5db;
      }
      .supplement-list {
        display: grid;
        gap: 10px;
        margin-top: 14px;
        max-width: 100%;
      }
      .supplement-item {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        padding: 12px 14px;
        border: 1px solid var(--border-soft);
        border-radius: 12px;
        background: #f8fafc;
        min-width: 0;
        flex-wrap: wrap;
      }
      .supplement-item-main {
        display: grid;
        gap: 4px;
      }
      .supplement-item-sub {
        color: var(--text-muted);
        font-size: 12px;
      }
      .origin-button {
        margin-top: 4px;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--accent);
        font-size: 11px;
        font-weight: 600;
        cursor: pointer;
      }
      .origin-dialog {
        width: min(920px, calc(100vw - 32px));
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        padding: 20px;
        color: var(--text-main);
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
      }
      .origin-dialog::backdrop {
        background: rgba(15, 23, 42, 0.38);
      }
      .origin-dialog-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
      }
      .origin-dialog-title {
        font-size: 16px;
        font-weight: 700;
      }
      .pedigree-map {
        display: flex;
        flex-direction: column;
        gap: 28px;
        min-width: 780px;
        overflow-x: auto;
        padding: 4px 2px 10px;
      }
      .pedigree-generation {
        display: grid;
        gap: 12px;
        position: relative;
      }
      .pedigree-generation:not(:first-child)::before {
        content: "";
        position: absolute;
        top: -15px;
        left: 4%;
        right: 4%;
        height: 2px;
        background: #c7d2fe;
      }
      .pedigree-slot {
        display: flex;
        justify-content: center;
        position: relative;
      }
      .pedigree-generation:not(:first-child) .pedigree-slot::before {
        content: "";
        position: absolute;
        top: -15px;
        left: 50%;
        width: 2px;
        height: 15px;
        background: #c7d2fe;
      }
      .pedigree-node {
        display: grid;
        gap: 2px;
        width: 100%;
        min-width: 150px;
        padding: 10px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        background: #ffffff;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.06);
      }
      .pedigree-node.is-root {
        border-color: #86efac;
        background: #f0fdf4;
      }
      .pedigree-node.is-father {
        border-color: #93c5fd;
        background: #eff6ff;
      }
      .pedigree-node.is-mother {
        border-color: #f9a8d4;
        background: #fdf2f8;
      }
      .pedigree-node.is-empty {
        border-style: dashed;
        border-color: #cbd5e1;
        background: #f8fafc;
        color: #94a3b8;
      }
      .pedigree-generation-label {
        margin-bottom: -18px;
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .pedigree-label {
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .pedigree-name {
        color: #111827;
        font-weight: 700;
        font-size: 14px;
      }
      .mating-date-field .field-label {
        display: block;
        margin-bottom: 4px;
      }
      .mating-male-field {
        margin-top: 0;
      }
      .mating-male-field .field-label {
        display: block;
        margin-bottom: 4px;
      }
      .mating-dpp {
        padding-left: 0;
      }
      .mating-table input,
      .mating-table select {
        width: 100%;
        min-width: 0;
      }
      .mating-table select,
      .mating-table input[type="text"] {
        min-height: 27px;
        border-radius: 7px;
        font-size: 12px;
        padding: 4px 7px;
      }
      .mating-status-select {
        color: #ffffff;
        border: 0;
        font-weight: 800;
      }
      .mating-status-select[data-status="CONFIRMADO"] {
        background: #16a34a;
      }
      .mating-status-select[data-status="NAO_CONFIRMADO"] {
        background: #f97316;
      }
      .mating-status-select[data-status="PARA_ACASALAR"] {
        background: #2563eb;
      }
      .mating-status-select[data-status="PAUSA_REPRODUTIVA"] {
        background: #7c3aed;
      }
      .mating-status-select[data-status="COM_PROBLEMA"] {
        background: #dc2626;
      }
      .mating-status-select[data-status="EM_DESENVOLVIMENTO"] {
        background: #64748b;
      }
      .mating-female-details summary {
        cursor: pointer;
        list-style: none;
      }
      .mating-female-details summary::-webkit-details-marker {
        display: none;
      }
      .mating-female-more {
        display: grid;
        gap: 4px;
        margin-top: 6px;
      }
      .mating-female-cell .item-title {
        font-size: 13px;
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .mating-history-compact {
        display: grid;
        gap: 3px;
        align-content: start;
      }
      .mating-history-main,
      .inline-plus {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: nowrap;
        white-space: nowrap;
      }
      .mating-history-main {
        min-width: 0;
      }
      .mating-history-date-input,
      .mating-date-field input[type="text"] {
        width: 86px;
        min-width: 86px;
        text-align: center;
      }
      .history-date-display {
        display: inline-block;
        min-width: 74px;
        font-size: 12px;
        line-height: 1;
        white-space: nowrap;
      }
      .mating-icon-button,
      .mating-table .mating-icon-button,
      .delete-history-date,
      .mating-table .delete-history-date,
      .add-history-date,
      .mating-table .add-history-date {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        min-height: 22px;
        padding: 0;
        border-radius: 999px;
        font-size: 11px;
        line-height: 1;
      }
      .mating-history-more {
        margin: 0 0 2px;
      }
      .mating-history-more summary {
        cursor: pointer;
        color: var(--accent);
        font-size: 11px;
        font-weight: 800;
      }
      .mating-history-more[open] summary {
        margin-bottom: 3px;
      }
      .mating-next-date,
      .mating-dpp strong,
      [data-gestation-days] {
        display: inline-block;
        padding-top: 2px;
        font-size: 13px;
        line-height: 1.2;
      }
      .mating-next-date.is-ready {
        color: #16a34a;
      }
      .mating-next-date.is-danger {
        color: #dc2626;
      }
      .mating-search-grid {
        display: grid;
        grid-template-columns: minmax(240px, 1fr) auto;
        gap: 12px;
        align-items: end;
        max-width: 100%;
      }
      .mating-list {
        display: flex;
        flex-direction: column;
        min-width: 1237px;
      }
      .record-list {
        max-width: 100%;
      }
      .record-row {
        min-width: 0;
        flex-wrap: wrap;
      }
      .record-main {
        min-width: 0;
      }
      .mating-row.search-match {
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.28);
      }
      .mating-save-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 0;
      }
      .mating-save-status {
        color: var(--text-muted);
        font-size: 12px;
        font-weight: 800;
      }
      .mating-save-status.is-success {
        color: #16a34a;
      }
      .mating-save-status.is-error {
        color: #dc2626;
      }
      .mating-excess-warning {
        margin-top: 4px;
        color: #dc2626;
        font-size: 12px;
        font-weight: 900;
      }
      @media (max-width: 900px) {
        .main {
          max-width: 100vw;
        }
        .origin-dialog {
          padding: 14px;
        }
        .pedigree-map {
          min-width: 680px;
        }
        .pedigree-node {
          min-width: 130px;
          padding: 9px 10px;
        }
        .mating-search-grid {
          grid-template-columns: 1fr;
        }
        .mating-table {
          min-width: 1116px;
          grid-template-columns:
            190px
            120px
            155px
            178px
            115px
            98px
            98px
            90px
            85px;
        }
        .mating-status-divider {
          min-width: 1116px;
          grid-template-columns: 190px 1fr;
        }
        .mating-section-scrollbar {
          min-width: 1116px;
        }
        .mating-list {
          min-width: 1116px;
        }
        .mating-history-date-input,
        .mating-date-field input[type="text"] {
          width: 82px;
          min-width: 82px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Acasalamentos</h2>
            <div class="welcome-sub">Planejamento reprodutivo das fêmeas cadastradas.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% if (users && users.length) { %>
        <div class="content-card module-panel">
          <form method="get" action="/admin/matings" class="admin-filter-form">
            <div class="field" style="min-width:320px; flex:1;">
              <label class="field-label" for="matingsOwnerSearch">Filtrar por usuário</label>
              <input type="hidden" name="ownerId" id="matingsOwnerId" value="<%= selectedOwnerId || '' %>" />
              <input
                id="matingsOwnerSearch"
                list="matingsOwnersList"
                type="text"
                placeholder="Digite o nome do usuário"
                value="<%= selectedOwnerId ? ((users.find((u) => u.id === selectedOwnerId) || {}).name || '') : '' %>"
              />
              <datalist id="matingsOwnersList">
                <% users.forEach(function(item) { %>
                  <option value="<%= item.name %>"><%= item.email %></option>
                <% }) %>
              </datalist>
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/admin/matings" class="btn">Limpar</a>
          </form>
        </div>
        <% } %>

        <div class="content-card module-panel">
          <div class="mating-search-grid">
            <div class="field">
              <label class="field-label" for="matingCatSearch">Pesquisar gato</label>
              <input id="matingCatSearch" type="search" placeholder="Digite o nome do gato..." autocomplete="off" />
              <div class="section-note">Ao pesquisar, os gatos encontrados sobem para visualização e edição.</div>
            </div>
            <button class="btn" type="button" id="clearMatingSearch">Limpar</button>
          </div>
        </div>

        <div class="content-card module-panel">
          <div class="history-section-head">
            <div>
              <div class="content-title">Próximas ações</div>
              <div class="content-sub">Cruzas liberadas ou DPP próximas para acompanhamento.</div>
            </div>
            <span class="status-pill is-purple"><%= nextActions.length %></span>
          </div>
          <% if (!nextActions.length) { %>
            <div class="empty" style="margin-top:12px;">Nenhuma ação urgente para acasalamentos.</div>
          <% } else { %>
            <div class="record-list" style="margin-top:12px;">
              <% nextActions.forEach(function(action) { %>
                <div class="record-row">
                  <div class="record-main">
                    <div class="record-title"><%= action.title %></div>
                    <div class="record-sub"><%= action.sub %></div>
                  </div>
                  <div class="record-meta">
                    <span class="status-pill <%= action.color %>"><%= action.badge %></span>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <% function escapeHtml(value) {
          return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
        } %>
        <% function pedigreeNodeClass(slot) {
          if (!slot || !slot.name) return "is-empty";
          if (slot.side === "father") return "is-father";
          if (slot.side === "mother") return "is-mother";
          return "is-root";
        } %>
        <% function pedigreeGenerationLabel(index) {
          return ["Gato", "Pais", "Avós", "Bisavós", "Tataravós"][index] || `${index + 1}ª geração`;
        } %>
        <% function pedigreeSlotLabel(index, side) {
          if (index === 0) return "Gato";
          if (index === 1) return side === "father" ? "Pai" : "Mãe";
          if (index === 2) return side === "father" ? "Avô" : "Avó";
          if (index === 3) return side === "father" ? "Bisavô" : "Bisavó";
          if (index === 4) return side === "father" ? "Tataravô" : "Tataravó";
          return side === "father" ? "Ancestral" : "Ancestral";
        } %>
        <% function buildPedigreeGenerations(root, maxGenerations) {
          if (!root) return [];
          const generations = [[{ node: root, name: root.name || "-", side: "root" }]];

          for (let index = 1; index < maxGenerations; index += 1) {
            const previous = generations[index - 1];
            const next = [];

            previous.forEach(function(slot) {
              const source = slot.node || null;
              next.push({
                node: source?.father || null,
                name: source?.father?.name || source?.fatherName || "",
                side: "father",
              });
              next.push({
                node: source?.mother || null,
                name: source?.mother?.name || source?.motherName || "",
                side: "mother",
              });
            });

            generations.push(next);
          }

          return generations;
        } %>
        <% function renderPedigreeMap(root, maxGenerations) {
          const generations = buildPedigreeGenerations(root, maxGenerations);
          return generations.map(function(generation, index) {
            const columns = Math.max(1, generation.length);
            const cards = generation.map(function(slot) {
              const nodeClass = pedigreeNodeClass(slot);
              const label = slot.name ? pedigreeSlotLabel(index, slot.side) : "Não informado";
              const name = slot.name || "-";
              return `<div class="pedigree-slot"><div class="pedigree-node ${nodeClass}"><span class="pedigree-label">${escapeHtml(label)}</span><span class="pedigree-name">${escapeHtml(name)}</span></div></div>`;
            }).join("");

            return `<div class="pedigree-generation-label">${escapeHtml(pedigreeGenerationLabel(index))}</div><div class="pedigree-generation" style="grid-template-columns: repeat(${columns}, minmax(150px, 1fr));">${cards}</div>`;
          }).join("");
        } %>

        <% const totalMatingRows = groups.reduce(function(total, group) { return total + ((grouped[group.key] || []).length); }, 0); %>
        <section class="content-card module-panel">
          <div class="history-section-head">
            <div>
              <div class="content-title">Planejamento de Acasalamentos</div>
              <div class="content-sub">Tabela geral das fêmeas, organizada por status reprodutivo.</div>
            </div>
            <span class="status-pill is-purple"><%= totalMatingRows %></span>
          </div>

          <% if (!totalMatingRows) { %>
            <div class="empty" style="margin-top:12px;">Nenhuma fêmea disponível para planejamento.</div>
          <% } else { %>
            <div class="mating-sheet-shell">
              <div class="mating-sheet-wrap" data-mating-sheet-wrap>
                <div class="mating-table mating-header">
                  <div class="mating-female-cell">Fêmea</div>
                  <div>Status</div>
                  <div>Macho</div>
                  <div>Última Ninhada</div>
                  <div>Próxima Cruza</div>
                  <div>Cruza 1º dia</div>
                  <div>Cruza 2º dia</div>
                  <div>DPP</div>
                  <div>Gestação</div>
                </div>
                <div class="mating-list">
                <% groups.forEach(function(group, groupIndex) { %>
                  <% const items = grouped[group.key] || []; %>
                  <div class="mating-status-divider" data-status="<%= group.key %>" data-status-divider="<%= group.key %>" data-group-index="<%= groupIndex %>">
                    <span><%= group.label %></span>
                    <small data-status-count="<%= group.key %>"><%= items.length %></small>
                  </div>
                  <% items.forEach(function(row, index) { %>
                    <% const globalOrder = (groupIndex * 1000) + index; %>
                    <% const nextDateValue = row.nextCrossDate ? new Date(row.nextCrossDate) : null; %>
                    <% const todayValue = new Date(); todayValue.setHours(0, 0, 0, 0); %>
                    <% const nextDateClass = row.excessLitterWarning ? "is-danger" : (nextDateValue && nextDateValue <= todayValue ? "is-ready" : ""); %>
                    <% const historyList = row.litterHistory.length ? row.litterHistory : [""]; %>
                    <% const latestHistory = historyList[historyList.length - 1]; %>
                    <form
                      method="post"
                      action="/admin/matings/<%= row.female.id %>"
                      class="mating-row <%= row.supplement?.active ? 'is-supplementing' : '' %>"
                      data-mating-row
                      data-status="<%= row.status %>"
                      data-original-order="<%= globalOrder %>"
                      data-search="<%= String(row.femaleDisplayName || '').toLowerCase() %>"
                    >
                      <input type="hidden" name="ownerId" value="<%= selectedOwnerId || '' %>" />
                      <div class="mating-table">
                        <div class="mating-female-cell">
                          <details class="mating-female-details">
                            <summary>
                              <div class="item-title">
                                <%= row.female.name || row.femaleDisplayName %>
                              </div>
                            </summary>
                            <div class="mating-female-more">
                              <div class="birth-line">Nascimento: <%= row.birthDateLabel %></div>
                              <% if (row.supplement?.active) { %>
                                <div class="birth-line">
                                  <%= row.supplement.phase %> · início <%= formatDate(row.supplement.startDate) %> ·
                                  <%= row.supplement.endOpen ? "até lançar a data de cruza" : "fim " + formatDate(row.supplement.endDate) %>
                                </div>
                              <% } %>
                              <div class="parent-line">
                                <span>Pai: <%= row.fatherName %></span>
                                <span>Mãe: <%= row.motherName %></span>
                              </div>
                              <button type="button" class="origin-button" data-open-origin="origin-<%= row.female.id %>">Origem</button>
                            </div>
                          </details>
                          <dialog class="origin-dialog" id="origin-<%= row.female.id %>">
                            <div class="origin-dialog-header">
                              <div class="origin-dialog-title">Origem - <%= row.femaleDisplayName %></div>
                              <button type="button" class="btn" data-close-origin>Fechar</button>
                            </div>
                            <div class="pedigree-map">
                              <%- renderPedigreeMap(row.pedigree, 5) %>
                            </div>
                          </dialog>
                        </div>

                        <div class="mini-stack">
                          <select name="status" class="mating-status-select" data-status-select data-status="<%= row.status %>" aria-label="Status de acasalamento">
                            <% groups.forEach(function(statusItem) { %>
                              <option value="<%= statusItem.key %>" <%= row.status === statusItem.key ? "selected" : "" %>><%= statusItem.label %></option>
                            <% }) %>
                          </select>
                          <span class="mating-save-status" data-save-status></span>
                        </div>

                        <div class="mating-male-field">
                          <select name="maleCatId" aria-label="Macho">
                            <option value="">Selecione...</option>
                            <% row.maleOptions.forEach(function(male) { %>
                              <option value="<%= male.id %>" <%= String(row.plan?.maleCatId || '') === String(male.id) ? "selected" : "" %>><%= male.name %></option>
                            <% }) %>
                          </select>
                        </div>

                        <div class="mating-history-compact" data-history-box>
                          <% if (historyList.filter(Boolean).length > 1) { %>
                            <details class="mating-history-more">
                              <summary>Ver mais datas</summary>
                              <% historyList.slice(0, -1).forEach(function(value) { %>
                                <div class="inline-plus" data-history-row>
                                  <% if (value) { %>
                                    <input type="hidden" name="litterHistoryDates" value="<%= formatDateInput(value) %>" />
                                    <span class="history-date-display"><%= formatDate(value) %></span>
                                    <button type="button" class="btn mating-icon-button delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
                                  <% } %>
                                </div>
                              <% }) %>
                            </details>
                          <% } %>
                          <div class="mating-history-main">
                            <% if (latestHistory) { %>
                              <div class="inline-plus" data-history-row>
                                <input type="hidden" name="litterHistoryDates" value="<%= formatDateInput(latestHistory) %>" />
                                <span class="history-date-display"><%= formatDate(latestHistory) %></span>
                                <button type="button" class="btn mating-icon-button delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
                              </div>
                            <% } else { %>
                              <div class="inline-plus" data-history-row>
                                <input class="mating-history-date-input" type="text" data-history-date-input inputmode="numeric" maxlength="10" placeholder="dd/mm/aaaa" value="" />
                              </div>
                            <% } %>
                            <button type="button" class="btn mating-icon-button add-history-date" title="Adicionar ninhada" aria-label="Adicionar ninhada">+</button>
                          </div>

                          <% if (historyList.filter(Boolean).length <= 1 && latestHistory) { %>
                            <% historyList.slice(0, -1).forEach(function(value) { %>
                              <% if (value) { %>
                                <div class="inline-plus" data-history-row hidden>
                                  <input type="hidden" name="litterHistoryDates" value="<%= formatDateInput(value) %>" />
                                </div>
                              <% } %>
                            <% }) %>
                          <% } else { %>
                            <% historyList.slice(1).forEach(function(value) { %>
                              <% if (value) { %>
                                <div class="inline-plus" data-history-row hidden>
                                  <input type="hidden" name="litterHistoryDates" value="<%= formatDateInput(value) %>" />
                                </div>
                              <% } %>
                            <% }) %>
                          <% } %>
                        </div>

                        <div>
                          <strong class="mating-next-date <%= nextDateClass %>" data-next-cross><%= row.nextCrossDate ? formatDate(row.nextCrossDate) : "-" %></strong>
                          <div class="mating-excess-warning" data-excess-litter-warning <%= row.excessLitterWarning ? "" : "hidden" %>>Excesso de Ninhada</div>
                        </div>

                        <div class="mating-date-field">
                          <input type="hidden" name="matingStartDate" value="<%= row.plan?.matingStartDate ? formatDateInput(row.plan.matingStartDate) : '' %>" data-mating-date-value />
                          <input type="text" data-mating-date-display inputmode="numeric" maxlength="10" placeholder="dd/mm/aaaa" value="<%= row.plan?.matingStartDate ? formatDate(row.plan.matingStartDate) : '' %>" />
                        </div>

                        <div class="mating-date-field">
                          <input type="hidden" name="matingEndDate" value="<%= row.plan?.matingEndDate ? formatDateInput(row.plan.matingEndDate) : '' %>" data-mating-date-value />
                          <input type="text" data-mating-date-display inputmode="numeric" maxlength="10" placeholder="dd/mm/aaaa" value="<%= row.plan?.matingEndDate ? formatDate(row.plan.matingEndDate) : '' %>" />
                        </div>

                        <div class="mini-stack mating-dpp">
                          <strong data-dpp-date><%= row.dppDate ? formatDate(row.dppDate) : "-" %></strong>
                        </div>

                        <div data-gestation-days><%= row.gestationDays !== null ? row.gestationDays + " dias" : "-" %></div>
                      </div>
                    </form>
                  <% }) %>
                  <div class="mating-section-scrollbar" data-mating-scrollbar data-section-scrollbar data-status-scrollbar="<%= group.key %>" aria-label="Rolagem horizontal da seção <%= group.label %>">
                    <div class="mating-section-scrollbar-inner" data-mating-scrollbar-inner></div>
                  </div>
                <% }) %>
                </div>
              </div>
              <div class="mating-scrollbar" data-mating-scrollbar aria-label="Rolagem horizontal da tabela de acasalamentos">
                <div class="mating-scrollbar-inner" data-mating-scrollbar-inner></div>
              </div>
            </div>
          <% } %>
        </section>

        <% if (supplementRows && supplementRows.length) { %>
          <section class="content-card module-panel">
            <div class="history-section-head">
              <div>
                <div class="content-title">Gatas em suplementação</div>
                <div class="content-sub">Matrizes dentro do período configurado em Configurações.</div>
              </div>
              <span class="status-pill is-green"><%= supplementRows.length %></span>
            </div>
            <div class="supplement-list">
              <% supplementRows.forEach(function(row) { %>
                <div class="supplement-item">
                  <div class="supplement-item-main">
                    <strong><%= row.femaleDisplayName %></strong>
                    <span class="supplement-item-sub">
                      <%= row.supplement.phase %> · início <%= formatDate(row.supplement.startDate) %> ·
                      <%= row.supplement.endOpen ? "mantém até informar a data de cruza" : "fim " + formatDate(row.supplement.endDate) %>
                    </span>
                    <span class="supplement-item-sub"><%= row.supplement.summary %></span>
                  </div>
                  <span class="status-pill is-green">Suplementação</span>
                </div>
              <% }) %>
            </div>
          </section>
        <% } %>
      </main>
    </div>

    <script>
      (function () {
        const users = <%- JSON.stringify(users) %>;
        const statusGroups = <%- JSON.stringify(groups) %>;
        const statusOrder = new Map(statusGroups.map((group, index) => [group.key, index]));
        const ownerSearch = document.getElementById("matingsOwnerSearch");
        const ownerId = document.getElementById("matingsOwnerId");

        function syncOwnerId() {
          if (!ownerSearch || !ownerId) return;
          const match = users.find((item) => item.name === ownerSearch.value);
          ownerId.value = match ? match.id : "";
        }

        ownerSearch?.addEventListener("input", syncOwnerId);
        ownerSearch?.addEventListener("change", syncOwnerId);

        async function autosave(form) {
          if (!form) return;
          if (form.dataset.submitting === "true") {
            form.dataset.pendingSave = "true";
            return;
          }

          form.dataset.submitting = "true";
          form.dataset.pendingSave = "false";

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(form)),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "Accept": "application/json",
              },
            });

            if (!response.ok) {
              throw new Error("Erro ao salvar");
            }

            const data = await response.json();
            applyMatingSaveResponse(form, data);
            setSaveStatus(form.querySelector("[data-save-status]"), "Salvo.", "success");
          } catch (error) {
            console.error(error);
            setSaveStatus(form.querySelector("[data-save-status]"), "Erro.", "error");
          } finally {
            form.dataset.submitting = "false";
            if (form.dataset.pendingSave === "true") {
              autosave(form);
            }
          }
        }

        function setSaveStatus(element, text, type = "") {
          if (!element) return;
          element.textContent = text || "";
          element.classList.toggle("is-success", type === "success");
          element.classList.toggle("is-error", type === "error");
        }

        function updateStatusCounters() {
          const counts = {};
          document.querySelectorAll("[data-mating-row]").forEach((row) => {
            counts[row.dataset.status] = (counts[row.dataset.status] || 0) + 1;
          });

          document.querySelectorAll("[data-status-count]").forEach((counter) => {
            counter.textContent = counts[counter.dataset.statusCount] || 0;
          });
        }

        function rowOrder(row) {
          const groupIndex = statusOrder.get(row.dataset.status) ?? statusGroups.length;
          const original = Number(row.dataset.originalOrder || 0);
          return groupIndex * 10000 + original;
        }

        function reorderMatingRows() {
          document.querySelectorAll("[data-status-divider]").forEach((divider) => {
            const groupIndex = statusOrder.get(divider.dataset.statusDivider) ?? statusGroups.length;
            divider.style.order = String(groupIndex * 10000 - 1);
          });

          document.querySelectorAll("[data-mating-row]").forEach((row) => {
            row.style.order = String(rowOrder(row));
          });

          document.querySelectorAll("[data-status-scrollbar]").forEach((scrollbar) => {
            const groupIndex = statusOrder.get(scrollbar.dataset.statusScrollbar) ?? statusGroups.length;
            scrollbar.style.order = String(groupIndex * 10000 + 9999);
          });

          updateStatusCounters();
        }

        function updateNextCrossColor(form, hasExcessWarning) {
          const nextCross = form.querySelector("[data-next-cross]");
          if (!nextCross) return;
          nextCross.classList.toggle("is-danger", Boolean(hasExcessWarning));
          if (hasExcessWarning) {
            nextCross.classList.remove("is-ready");
            return;
          }

          const match = String(nextCross.textContent || "").match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
          if (!match) {
            nextCross.classList.remove("is-ready");
            return;
          }

          const date = new Date(Number(match[3]), Number(match[2]) - 1, Number(match[1]));
          const today = new Date();
          today.setHours(0, 0, 0, 0);
          nextCross.classList.toggle("is-ready", date <= today);
        }

        function applyMatingSaveResponse(form, data) {
          if (!form || !data) return;
          if (data.status) {
            form.dataset.status = data.status;
            const select = form.querySelector("[data-status-select]");
            if (select) select.dataset.status = data.status;
          }

          const nextCross = form.querySelector("[data-next-cross]");
          const dppDate = form.querySelector("[data-dpp-date]");
          const gestation = form.querySelector("[data-gestation-days]");
          const excessWarning = form.querySelector("[data-excess-litter-warning]");
          if (nextCross) nextCross.textContent = data.nextCrossLabel || "-";
          if (excessWarning) excessWarning.hidden = !data.excessLitterWarning;
          if (dppDate) dppDate.textContent = data.dppLabel || "-";
          if (gestation) gestation.textContent = data.gestationLabel || "-";

          form.classList.toggle("is-supplementing", Boolean(data.supplementActive));
          updateNextCrossColor(form, data.excessLitterWarning);
          reorderMatingRows();
        }

        function maskBrazilianDate(value) {
          const digits = String(value || "").replace(/\D/g, "").slice(0, 8);
          if (digits.length <= 2) return digits;
          if (digits.length <= 4) return `${digits.slice(0, 2)}/${digits.slice(2)}`;
          return `${digits.slice(0, 2)}/${digits.slice(2, 4)}/${digits.slice(4)}`;
        }

        function parseCompleteBrazilianDate(value) {
          const match = String(value || "").match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
          if (!match) return "";

          const day = Number(match[1]);
          const month = Number(match[2]);
          const year = Number(match[3]);
          const parsed = new Date(year, month - 1, day);
          if (parsed.getFullYear() !== year || parsed.getMonth() !== month - 1 || parsed.getDate() !== day) {
            return "";
          }

          return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
        }

        async function manualUpdate(form) {
          if (!form) return;
          const button = form.querySelector(".mating-update-button");
          const status = form.querySelector("[data-save-status]");
          setSaveStatus(status, "Salvando...");
          if (button) button.disabled = true;

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(form)),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "Accept": "application/json",
                "X-Manual-Update": "true",
              },
            });
            if (!response.ok) throw new Error("Não foi possível salvar.");
            const data = await response.json();

            const statusPill = form.querySelector("[data-mating-status-pill]");
            if (statusPill) statusPill.textContent = data.statusLabel || "Atualizado";
            const nextCross = form.querySelector("[data-next-cross]");
            const dppDate = form.querySelector("[data-dpp-date]");
            const gestation = form.querySelector("[data-gestation-days]");
            if (nextCross) nextCross.textContent = data.nextCrossLabel || "-";
            const excessWarning = form.querySelector("[data-excess-litter-warning]");
            if (excessWarning) excessWarning.hidden = !data.excessLitterWarning;
            if (dppDate) dppDate.textContent = data.dppLabel || "-";
            if (gestation) gestation.textContent = data.gestationLabel || "-";

            form.classList.toggle("is-supplementing", Boolean(data.supplementActive));
            setSaveStatus(status, "Salvo.", "success");
          } catch (error) {
            console.error(error);
            setSaveStatus(status, error.message || "Erro ao salvar.", "error");
          } finally {
            if (button) button.disabled = false;
          }
        }

        document.querySelectorAll("[data-open-origin]").forEach((button) => {
          button.addEventListener("click", () => {
            document.getElementById(button.dataset.openOrigin)?.showModal();
          });
        });

        document.querySelectorAll("[data-close-origin]").forEach((button) => {
          button.addEventListener("click", () => {
            button.closest("dialog")?.close();
          });
        });

        document.querySelectorAll(".add-history-date").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-history-box]");
            const main = button.closest(".mating-history-main") || box;
            const row = document.createElement("div");
            row.className = "inline-plus";
            row.dataset.historyRow = "";
            row.innerHTML = '<input class="mating-history-date-input" type="text" data-history-date-input inputmode="numeric" maxlength="10" placeholder="dd/mm/aaaa" value="" />';
            main.insertBefore(row, button);
            bindHistoryRow(row);
            row.querySelector("input")?.focus();
          });
        });

        function formatDisplayDate(value) {
          if (!value) return "";
          const parts = value.split("-");
          if (parts.length !== 3) return value;
          return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        function addDeleteHandler(button) {
          button.addEventListener("click", () => {
            const row = button.closest("[data-history-row]");
            const form = button.closest("form");
            row.remove();

            autosave(form);
          });
        }

        function bindMatingDateField(input) {
          const hidden = input.parentElement?.querySelector("[data-mating-date-value]");
          if (!hidden) return;

          function commitDate(allowEmpty = false) {
            const value = input.value.trim();
            if (!value) {
              if (!allowEmpty || !hidden.value) return false;
              hidden.value = "";
              autosave(input.closest("form"));
              return true;
            }

            const isoDate = parseCompleteBrazilianDate(value);
            if (!isoDate) return false;
            if (hidden.value !== isoDate) {
              hidden.value = isoDate;
              autosave(input.closest("form"));
            }
            return true;
          }

          input.addEventListener("input", () => {
            input.value = maskBrazilianDate(input.value);
            if (input.value.length === 10) commitDate(false);
          });

          input.addEventListener("blur", () => {
            if (commitDate(true)) return;
            input.value = hidden.value ? formatDisplayDate(hidden.value) : "";
          });
        }

        function bindHistoryRow(row) {
          const input = row.querySelector("[data-history-date-input]");
          if (input) {
            function commitHistoryDate() {
              const isoDate = parseCompleteBrazilianDate(input.value);
              if (!isoDate) return false;
              row.innerHTML = `
                <input type="hidden" name="litterHistoryDates" value="${isoDate}" />
                <span class="history-date-display">${formatDisplayDate(isoDate)}</span>
                <button type="button" class="btn mating-icon-button delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
              `;
              addDeleteHandler(row.querySelector(".delete-history-date"));
              autosave(row.closest("form"));
              return true;
            }

            input.addEventListener("input", () => {
              input.value = maskBrazilianDate(input.value);
              if (input.value.length === 10) commitHistoryDate();
            });

            input.addEventListener("blur", () => {
              if (!input.value.trim()) return;
              if (!commitHistoryDate()) input.value = "";
            });
          }

          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) addDeleteHandler(deleteButton);
        }

        document.querySelectorAll("[data-history-row]").forEach(bindHistoryRow);
        document.querySelectorAll("[data-mating-date-display]").forEach(bindMatingDateField);
        document.querySelectorAll(".mating-row select").forEach((field) => {
          field.addEventListener("change", () => {
            if (field.matches("[data-status-select]")) {
              field.dataset.status = field.value;
              field.closest("[data-mating-row]").dataset.status = field.value;
              reorderMatingRows();
            }
            autosave(field.closest("form"));
          });
        });

        const matingSearch = document.getElementById("matingCatSearch");
        const clearMatingSearch = document.getElementById("clearMatingSearch");
        const matingRows = Array.from(document.querySelectorAll("[data-mating-row]"));

        function normalizeSearch(value) {
          return String(value || "")
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .toLowerCase()
            .trim();
        }

        function applyMatingSearch() {
          const query = normalizeSearch(matingSearch?.value);
          let firstMatch = null;

          matingRows.forEach((row) => {
            const matched = Boolean(query) && normalizeSearch(row.dataset.search).includes(query);
            row.classList.toggle("search-match", matched);
            row.style.order = matched ? "-1" : String(rowOrder(row));
            if (matched && !firstMatch) firstMatch = row;
          });

          if (query && firstMatch) {
            firstMatch.scrollIntoView({ behavior: "smooth", block: "center" });
          }
        }

        matingSearch?.addEventListener("input", applyMatingSearch);
        clearMatingSearch?.addEventListener("click", () => {
          if (matingSearch) matingSearch.value = "";
          matingRows.forEach((row) => {
            row.classList.remove("search-match");
            row.style.order = String(rowOrder(row));
          });
          matingSearch?.focus();
        });

        document.querySelectorAll("[data-status-select]").forEach((select) => {
          select.dataset.status = select.value;
        });
        reorderMatingRows();

        document.querySelectorAll("[data-mating-sheet-wrap]").forEach((wrap) => {
          const shell = wrap.closest(".mating-sheet-shell");
          const scrollbars = Array.from(shell?.querySelectorAll("[data-mating-scrollbar]") || []);
          const table = wrap.querySelector(".mating-table");
          if (!scrollbars.length || !table) return;

          function refreshMatingScrollbar() {
            const scrollWidth = Math.max(table.scrollWidth, wrap.scrollWidth, wrap.clientWidth);
            scrollbars.forEach((scrollbar) => {
              const inner = scrollbar.querySelector("[data-mating-scrollbar-inner]");
              if (inner) inner.style.width = `${scrollWidth}px`;
              scrollbar.style.display = scrollWidth > wrap.clientWidth ? "block" : "none";
              scrollbar.scrollLeft = wrap.scrollLeft;
            });
          }

          let syncingFromTable = false;
          let syncingFromBar = false;
          wrap.addEventListener("scroll", () => {
            if (syncingFromBar) return;
            syncingFromTable = true;
            scrollbars.forEach((scrollbar) => {
              scrollbar.scrollLeft = wrap.scrollLeft;
            });
            syncingFromTable = false;
          });

          scrollbars.forEach((scrollbar) => {
            scrollbar.addEventListener("scroll", () => {
              if (syncingFromTable) return;
              syncingFromBar = true;
              wrap.scrollLeft = scrollbar.scrollLeft;
              scrollbars.forEach((otherScrollbar) => {
                if (otherScrollbar !== scrollbar) otherScrollbar.scrollLeft = scrollbar.scrollLeft;
              });
              syncingFromBar = false;
            });
          });

          requestAnimationFrame(refreshMatingScrollbar);
          window.addEventListener("resize", refreshMatingScrollbar);
          window.addEventListener("load", refreshMatingScrollbar);

          if ("ResizeObserver" in window) {
            const resizeObserver = new ResizeObserver(refreshMatingScrollbar);
            resizeObserver.observe(wrap);
            resizeObserver.observe(table);
          }
        });
      })();
    </script>
  </body>
</html>

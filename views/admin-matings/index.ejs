<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Acasalamentos - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .mating-table {
        display: grid;
        grid-template-columns:
          minmax(0, 1.25fr)
          minmax(0, 1fr)
          minmax(0, 0.85fr)
          minmax(0, 1fr)
          minmax(0, 0.7fr)
          minmax(0, 1.05fr)
          minmax(0, 0.8fr);
        gap: 10px;
        align-items: start;
        min-width: 0;
      }
      .mating-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .mating-row {
        padding: 12px;
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        margin-bottom: 12px;
      }
      .parent-line {
        margin-top: 4px;
        font-size: 11px;
        line-height: 1.35;
        color: var(--text-muted);
      }
      .parent-line span {
        display: block;
      }
      .mini-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .inline-plus {
        display: flex;
        gap: 8px;
        align-items: center;
        min-width: 0;
      }
      .mating-table input,
      .mating-table select {
        width: 100%;
        min-width: 0;
      }
      .inline-plus select,
      .inline-plus input {
        flex: 1 1 auto;
      }
      @media (max-width: 900px) {
        .mating-table {
          grid-template-columns: 1fr;
        }
        .mating-header {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Acasalamentos</h2>
            <div class="welcome-sub">Planejamento reprodutivo das fêmeas cadastradas.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card module-panel">
          <form method="get" action="/admin/matings" class="admin-filter-form">
            <div class="field" style="min-width:320px; flex:1;">
              <label class="field-label" for="matingsOwnerSearch">Filtrar por usuário</label>
              <input type="hidden" name="ownerId" id="matingsOwnerId" value="<%= selectedOwnerId || '' %>" />
              <input
                id="matingsOwnerSearch"
                list="matingsOwnersList"
                type="text"
                placeholder="Digite o nome do usuário"
                value="<%= selectedOwnerId ? ((users.find((u) => u.id === selectedOwnerId) || {}).name || '') : '' %>"
              />
              <datalist id="matingsOwnersList">
                <% users.forEach(function(item) { %>
                  <option value="<%= item.name %>"><%= item.email %></option>
                <% }) %>
              </datalist>
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/admin/matings" class="btn">Limpar</a>
          </form>
        </div>

        <% groups.forEach(function(group) { %>
          <% const items = grouped[group.key] || []; %>
          <details class="content-card module-panel module-accordion">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= group.label %></span>
              </div>
              <span class="module-accordion-count"><%= items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <div class="mating-table mating-header">
                <div>Fêmea</div>
                <div>Consanguinidade</div>
                <div>Macho</div>
                <div>Histórico</div>
                <div>Próxima Cruza</div>
                <div>Data Cruza</div>
                <div>DPP</div>
              </div>

              <% if (!items.length) { %>
                <div class="empty" style="margin-top:12px;">Nenhum registro nesta divisão.</div>
              <% } else { %>
                <% items.forEach(function(row) { %>
                <form method="post" action="/admin/matings/<%= row.female.id %>" class="mating-row">
                  <input type="hidden" name="ownerId" value="<%= selectedOwnerId || '' %>" />
                  <div class="mating-table">
                    <div>
                      <div class="item-title"><%= row.femaleDisplayName %></div>
                      <div class="parent-line">
                        <span>Pai: <%= row.fatherName %></span>
                        <span>Mãe: <%= row.motherName %></span>
                      </div>
                    </div>

                    <div class="mini-stack" data-consanguinity-box>
                      <% const consList = row.consanguinity.length ? row.consanguinity : [""]; %>
                      <% consList.forEach(function(value, idx) { %>
                        <div class="inline-plus">
                          <select name="consanguinityIds">
                            <option value="">Sem consanguinidade</option>
                            <% row.allMaleOptions.forEach(function(male) { %>
                              <option value="<%= male.id %>" <%= String(value) === String(male.id) ? "selected" : "" %>><%= male.name %></option>
                            <% }) %>
                          </select>
                          <% if (idx === consList.length - 1) { %>
                            <button type="button" class="btn add-consanguinity">+</button>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>

                    <div>
                      <select name="maleCatId">
                        <option value="">Selecione...</option>
                        <% row.maleOptions.forEach(function(male) { %>
                          <option value="<%= male.id %>" <%= String(row.plan?.maleCatId || '') === String(male.id) ? "selected" : "" %>><%= male.name %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="mini-stack" data-history-box>
                      <% const historyList = row.litterHistory.length ? row.litterHistory : [""]; %>
                      <% historyList.forEach(function(value, idx) { %>
                        <div class="inline-plus">
                          <input type="date" name="litterHistoryDates" value="<%= formatDateInput(value) %>" />
                          <% if (idx === historyList.length - 1) { %>
                            <button type="button" class="btn add-history-date">+</button>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>

                    <div>
                      <strong><%= row.nextCrossDate ? formatDate(row.nextCrossDate) : "-" %></strong>
                    </div>

                    <div class="mini-stack">
                      <input type="date" name="matingStartDate" value="<%= row.plan?.matingStartDate ? formatDateInput(row.plan.matingStartDate) : '' %>" />
                      <input type="date" name="matingEndDate" value="<%= row.plan?.matingEndDate ? formatDateInput(row.plan.matingEndDate) : '' %>" />
                      <select name="status">
                        <% groups.forEach(function(statusItem) { %>
                          <option value="<%= statusItem.key %>" <%= (row.plan?.status || "PARA_ACASALAR") === statusItem.key ? "selected" : "" %>><%= statusItem.label %></option>
                        <% }) %>
                      </select>
                      <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>

                    <div class="mini-stack">
                      <div><strong><%= row.dppDate ? formatDate(row.dppDate) : "-" %></strong></div>
                      <div><%= row.gestationDays !== null ? row.gestationDays + " dias de gestação" : "-" %></div>
                    </div>
                  </div>
                </form>
                <% }) %>
              <% } %>
            </div>
          </details>
        <% }) %>
      </main>
    </div>

    <script>
      (function () {
        const users = <%- JSON.stringify(users) %>;
        const ownerSearch = document.getElementById("matingsOwnerSearch");
        const ownerId = document.getElementById("matingsOwnerId");

        function syncOwnerId() {
          const match = users.find((item) => item.name === ownerSearch.value);
          ownerId.value = match ? match.id : "";
        }

        ownerSearch.addEventListener("input", syncOwnerId);
        ownerSearch.addEventListener("change", syncOwnerId);

        document.querySelectorAll(".add-consanguinity").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-consanguinity-box]");
            const row = button.parentElement.cloneNode(true);
            row.querySelector("select").value = "";
            row.querySelector("button").remove();
            box.appendChild(row);
          });
        });

        document.querySelectorAll(".add-history-date").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-history-box]");
            const row = button.parentElement.cloneNode(true);
            row.querySelector("input").value = "";
            row.querySelector("button").remove();
            box.appendChild(row);
          });
        });
      })();
    </script>
  </body>
</html>

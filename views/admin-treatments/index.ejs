<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Tratamento - PetGus</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Tratamento</h2>
            <div class="welcome-sub">Registro de medicações e tratamentos no histórico dos animais.</div>
          </div>
          <div class="actions">
            <button class="btn btn-primary" type="button" data-open-medications>Cadastrar Medicação</button>
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card message message-success">Tratamento salvo.</div>
        <% } %>
        <% if (error) { %>
          <div class="content-card message message-error"><%= error %></div>
        <% } %>

        <datalist id="medicationOptions">
          <% medications.forEach(function(medication) { %>
            <option value="<%= medication.name %>" data-id="<%= medication.id %>"></option>
          <% }) %>
        </datalist>

        <details class="content-card medication-manager" id="medicationManager">
          <summary class="dashboard-panel-summary">
            <div>
              <div class="content-title title-with-help">
                Medicações cadastradas
                <button class="help-info-button" type="button" data-help-title="Medicações cadastradas" data-help-text="Cadastre as medicações antes de lançar tratamentos. Se uma medicação já estiver em uso, ela pode ser editada para atualizar o nome nos registros, mas não deve ser excluída.">i</button>
              </div>
              <div class="content-sub">Cadastre, edite ou exclua medicações ainda não utilizadas.</div>
            </div>
            <span class="dashboard-panel-icon">+</span>
          </summary>

          <div class="medication-manager-body">
            <form method="post" action="/admin/treatments/medications" class="form-grid medication-form">
              <div class="field">
                <label class="field-label" for="medName">Nome da medicação</label>
                <input id="medName" name="name" required />
              </div>
              <div class="field">
                <label class="field-label" for="medDescription">Observação</label>
                <input id="medDescription" name="description" />
              </div>
              <div class="form-actions">
                <button class="btn btn-primary" type="submit">Salvar medicação</button>
              </div>
            </form>

            <% if (!medications.length) { %>
              <div class="empty" style="margin-top:12px;">Nenhuma medicação cadastrada.</div>
            <% } else { %>
              <div class="record-list" style="margin-top:14px;">
                <% medications.forEach(function(medication) { %>
                  <details class="record-row medication-row">
                    <summary class="medication-row-summary">
                      <div class="record-main">
                        <div class="record-title"><%= medication.name %></div>
                        <div class="record-sub">
                          <%= medication.description || 'Sem observação.' %>
                          <% if (medication.usageCount) { %> · Em uso: <%= medication.usageCount %><% } %>
                        </div>
                      </div>
                      <span class="status-pill <%= medication.usageCount ? 'is-yellow' : 'is-blue' %>">Editar</span>
                    </summary>
                    <form method="post" action="/admin/treatments/medications/<%= medication.id %>/update" class="form-grid medication-edit-form">
                      <div class="field">
                        <label class="field-label">Nome</label>
                        <input name="name" value="<%= medication.name %>" required />
                      </div>
                      <div class="field">
                        <label class="field-label">Observação</label>
                        <input name="description" value="<%= medication.description || '' %>" />
                      </div>
                      <div class="form-actions">
                        <button class="btn btn-primary" type="submit">Salvar edição</button>
                      </div>
                    </form>
                    <form method="post" action="/admin/treatments/medications/<%= medication.id %>/delete" onsubmit="return confirm('Excluir esta medicação?');">
                      <button class="btn btn-danger" type="submit" <%= medication.usageCount ? 'disabled title="Medicação em uso não pode ser excluída"' : '' %>>Excluir</button>
                    </form>
                  </details>
                <% }) %>
              </div>
            <% } %>
          </div>
        </details>

        <div class="treatment-layout treatment-layout-single">
          <section class="content-card">
            <div class="history-section-head" style="margin-bottom:12px;">
              <div>
                <div class="content-title title-with-help">
                  Novo tratamento
                  <button class="help-info-button" type="button" data-help-title="Novo tratamento" data-help-text="Selecione um ou mais animais, escolha uma ou mais medicações cadastradas, informe dose, frequência, horários, via, início e fim. Ao salvar, o tratamento também entra no histórico do animal.">i</button>
                </div>
                <div class="content-sub">Selecione um ou mais animais. Filhotes entregues não aparecem para novos lançamentos.</div>
              </div>
            </div>

            <form method="post" action="/admin/treatments" class="treatment-form">
              <div class="field treatment-full">
                <label class="field-label" for="catIds">Animais</label>
                <select id="catIds" name="catIds" multiple size="9" required>
                  <% cats.forEach(function(cat) { %>
                    <option value="<%= cat.id %>"><%= cat.categoryLabel %> - <%= cat.name %><%= cat.microchip ? ' - ' + cat.microchip : '' %></option>
                  <% }) %>
                </select>
              </div>

              <div class="treatment-full treatment-medications" id="treatmentMedications">
                <div class="treatment-medication-block" data-medication-block data-index="0">
                  <div class="treatment-medication-head">
                    <div>
                      <div class="content-title">Medicação 1</div>
                      <div class="content-sub">Dados desta medicação para os animais selecionados.</div>
                    </div>
                    <button class="btn treatment-remove-medication" type="button" data-remove-medication hidden>Remover</button>
                  </div>

                  <div class="treatment-form treatment-medication-grid">
                    <div class="field">
                      <label class="field-label" for="treatments-0-medicationName">Medicação</label>
                      <input id="treatments-0-medicationName" class="medication-picker" name="treatments[0][medicationName]" list="medicationOptions" placeholder="Digite ou selecione..." autocomplete="off" required />
                      <input class="medication-id" type="hidden" name="treatments[0][medicationId]" />
                    </div>

                    <div class="field">
                      <label class="field-label" for="treatments-0-dosageAmount">Dose</label>
                      <input id="treatments-0-dosageAmount" name="treatments[0][dosageAmount]" inputmode="decimal" placeholder="Quantidade" />
                    </div>

                    <div class="field">
                      <label class="field-label" for="treatments-0-dosageUnit">Unidade</label>
                      <select id="treatments-0-dosageUnit" name="treatments[0][dosageUnit]">
                        <option value="">Selecione...</option>
                        <% dosageUnits.forEach(function(unit) { %>
                          <option value="<%= unit %>"><%= unit %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="field">
                      <label class="field-label" for="treatments-0-durationDays">Tempo de tratamento em dias</label>
                      <input id="treatments-0-durationDays" class="duration-days" name="treatments[0][durationDays]" type="number" min="1" step="1" placeholder="Ex.: 5" />
                    </div>

                    <div class="field">
                      <label class="field-label" for="treatments-0-frequency">Frequência</label>
                      <select id="treatments-0-frequency" class="frequency-select" name="treatments[0][frequency]">
                        <option value="">Selecione...</option>
                        <% frequencies.forEach(function(frequency) { %>
                          <option value="<%= frequency %>"><%= frequency %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="field">
                      <label class="field-label" for="treatments-0-administrationRoute">Via de administração</label>
                      <select id="treatments-0-administrationRoute" name="treatments[0][administrationRoute]">
                        <option value="">Selecione...</option>
                        <% routes.forEach(function(route) { %>
                          <option value="<%= route %>"><%= route %></option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="field">
                      <label class="field-label" for="treatments-0-startDate">Data de início</label>
                      <input id="treatments-0-startDate" class="start-date" name="treatments[0][startDate]" type="date" value="<%= form.startDate %>" required />
                    </div>

                    <div class="field">
                      <label class="field-label" for="treatments-0-endDate">Data final</label>
                      <input id="treatments-0-endDate" class="end-date" name="treatments[0][endDate]" type="date" />
                    </div>

                    <div class="field treatment-full treatment-times-field">
                      <label class="field-label">Horários</label>
                      <div class="schedule-times" data-schedule-name="treatments[0][scheduleTimes]"></div>
                    </div>

                    <div class="field treatment-full">
                      <label class="field-label" for="treatments-0-notes">Observações</label>
                      <textarea id="treatments-0-notes" name="treatments[0][notes]" rows="3" placeholder="Reação, evolução clínica, orientação veterinária ou observações importantes"></textarea>
                    </div>
                  </div>
                </div>
              </div>

              <div class="form-actions treatment-full treatment-add-actions">
                <button class="btn" type="button" id="addTreatmentMedication">+ Incluir outra medicação</button>
              </div>

              <div class="form-actions treatment-full">
                <button class="btn btn-primary" type="submit">Salvar tratamento</button>
              </div>
            </form>
          </section>
        </div>

        <section class="content-card module-list-card" style="margin-top:18px;">
          <div class="history-section-head" style="margin-bottom:12px;">
              <div>
              <div class="content-title title-with-help">
                Tratamentos Ativos
                <button class="help-info-button" type="button" data-help-title="Tratamentos Ativos" data-help-text="Lista todos os tratamentos em andamento hoje. Um tratamento fica ativo quando a data de início já chegou e a data final ainda não passou, ou quando não possui data final.">i</button>
              </div>
              <div class="content-sub">Gatos com tratamento em andamento neste momento.</div>
            </div>
            <span class="status-pill is-yellow"><%= activeTreatments.length %></span>
          </div>

          <%- include('./_treatment-list', {
            treatments: activeTreatments,
            emptyText: 'Nenhum tratamento ativo no momento.',
            dosageUnits,
            frequencies,
            routes
          }) %>
        </section>

        <details class="content-card module-list-card treatment-finished-panel" style="margin-top:18px;">
          <summary class="dashboard-panel-summary">
            <div>
              <div class="content-title title-with-help">
                Tratamentos recentes finalizados
                <button class="help-info-button" type="button" data-help-title="Tratamentos recentes finalizados" data-help-text="Mostra os últimos 10 tratamentos que já passaram da data final. Fica retraído para manter a tela limpa, mas ainda permite consulta e edição quando necessário.">i</button>
              </div>
              <div class="content-sub">Últimos 10 tratamentos já encerrados.</div>
            </div>
            <span class="status-pill is-blue"><%= recentFinishedTreatments.length %></span>
          </summary>
          <div class="treatment-finished-body">
            <%- include('./_treatment-list', {
              treatments: recentFinishedTreatments,
              emptyText: 'Nenhum tratamento finalizado encontrado.',
              dosageUnits,
              frequencies,
              routes
            }) %>
          </div>
        </details>
      </main>
    </div>
    <script>
      const frequencyDefaults = {
        "1xdia": ["Manhã"],
        "12/12h": ["08:00", "20:00"],
        "8/8h": ["08:00", "16:00", "00:00"],
        "6/6h": ["08:00", "14:00", "20:00", "02:00"],
        "4/4h": ["08:00", "12:00", "16:00", "20:00", "00:00", "04:00"],
        "2/2h": ["08:00", "10:00", "12:00", "14:00", "16:00", "18:00", "20:00", "22:00", "00:00", "02:00", "04:00", "06:00"],
      };
      const frequencyHours = {
        "12/12h": 12,
        "8/8h": 8,
        "6/6h": 6,
        "4/4h": 4,
        "2/2h": 2,
      };

      function addHoursToTime(value, hours) {
        const [hour, minute] = String(value || "08:00").split(":").map(Number);
        const total = (((hour || 0) * 60 + (minute || 0) + hours * 60) % 1440 + 1440) % 1440;
        return `${String(Math.floor(total / 60)).padStart(2, "0")}:${String(total % 60).padStart(2, "0")}`;
      }

      function recalculateTimes(target, frequencyValue) {
        const step = frequencyHours[frequencyValue];
        if (!step) return;
        const inputs = Array.from(target.querySelectorAll("input[type='time']"));
        if (!inputs.length) return;
        const first = inputs[0].value || "08:00";
        inputs.forEach((input, index) => {
          input.value = addHoursToTime(first, step * index);
        });
      }

      function addDays(dateText, days) {
        const parts = String(dateText || "").split("-").map(Number);
        if (!parts[0] || !parts[1] || !parts[2]) return "";
        const date = new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]));
        date.setUTCDate(date.getUTCDate() + days);
        return date.toISOString().slice(0, 10);
      }

      function syncEndDate(form) {
        const start = form.querySelector(".start-date, #startDate");
        const duration = form.querySelector(".duration-days, #durationDays");
        const end = form.querySelector(".end-date, #endDate");
        const days = Number(duration && duration.value ? duration.value : 0);
        if (start && end && days > 0) end.value = addDays(start.value, days - 1);
      }

      function renderSchedule(form, keepExisting = false, forceDefaults = false) {
        const frequency = form.querySelector(".frequency-select, #frequency");
        const target = form.querySelector(".schedule-times, #scheduleTimes");
        if (!frequency || !target) return;
        const scheduleName = target.dataset.scheduleName || "scheduleTimes";

        const existing = keepExisting && target.dataset.times
          ? JSON.parse(target.dataset.times || "[]")
          : forceDefaults
            ? []
            : Array.from(target.querySelectorAll("input, select")).map((input) => input.value).filter(Boolean);
        const values = existing.length ? existing : (frequencyDefaults[frequency.value] || []);
        target.innerHTML = "";

        values.forEach((value, index) => {
          const label = document.createElement("label");
          label.className = "schedule-time";
          if (frequency.value === "1xdia") {
            label.innerHTML = `
              <span>Período</span>
              <select name="${scheduleName}">
                ${["Manhã", "Tarde", "Noite"].map((period) => `<option value="${period}" ${value === period ? "selected" : ""}>${period}</option>`).join("")}
              </select>
            `;
          } else {
            label.innerHTML = `<span>${index + 1}º horário</span><input type="time" name="${scheduleName}" value="${value}" ${index > 0 ? "readonly" : ""}>`;
          }
          target.appendChild(label);
        });

        const firstInput = target.querySelector("input[type='time']");
        if (firstInput) {
          firstInput.addEventListener("change", () => recalculateTimes(target, frequency.value));
        }
      }

      function setupMedicationPicker(input) {
        const field = input.closest(".field") || input.parentElement;
        const hidden = field ? field.querySelector(".medication-id") : null;
        const options = Array.from(document.querySelectorAll("#medicationOptions option"));
        if (!input || !hidden) return;

        function syncMedicationId() {
          const selected = options.find((option) => option.value === input.value);
          hidden.value = selected ? selected.dataset.id || "" : "";
          input.setCustomValidity(selected ? "" : "Selecione uma medicação cadastrada.");
        }

        input.addEventListener("input", syncMedicationId);
        input.addEventListener("change", syncMedicationId);
        syncMedicationId();
      }

      function setupTreatmentForm(form) {
        form.querySelectorAll(".medication-picker").forEach(setupMedicationPicker);
        form.querySelectorAll(".frequency-select, #frequency").forEach((frequency) => {
          const scope = frequency.closest("[data-medication-block], .treatment-edit-form, form") || form;
          renderSchedule(scope, true);
          frequency.addEventListener("change", () => renderSchedule(scope, false, true));
        });
        form.querySelectorAll(".duration-days, #durationDays").forEach((duration) => {
          const scope = duration.closest("[data-medication-block], .treatment-edit-form, form") || form;
          duration.addEventListener("input", () => syncEndDate(scope));
        });
        form.querySelectorAll(".start-date, #startDate").forEach((start) => {
          const scope = start.closest("[data-medication-block], .treatment-edit-form, form") || form;
          start.addEventListener("change", () => syncEndDate(scope));
        });
      }

      function resetMedicationBlock(block) {
        block.querySelectorAll("input, select, textarea").forEach((field) => {
          if (field.type === "hidden" || field.type === "text" || field.type === "number" || field.type === "date" || field.tagName === "TEXTAREA") {
            field.value = field.classList.contains("start-date") ? "<%= form.startDate %>" : "";
          } else if (field.tagName === "SELECT") {
            field.selectedIndex = 0;
          }
          field.setCustomValidity("");
        });
        block.querySelectorAll(".schedule-times").forEach((target) => {
          target.innerHTML = "";
          target.dataset.times = "";
        });
      }

      function reindexMedicationBlocks() {
        const blocks = Array.from(document.querySelectorAll("[data-medication-block]"));
        blocks.forEach((block, index) => {
          block.dataset.index = String(index);
          const title = block.querySelector(".content-title");
          if (title) title.textContent = `Medicação ${index + 1}`;
          block.querySelector("[data-remove-medication]")?.toggleAttribute("hidden", blocks.length === 1);

          block.querySelectorAll("[name]").forEach((field) => {
            field.name = field.name.replace(/treatments\[\d+\]/, `treatments[${index}]`);
          });
          block.querySelectorAll("[id]").forEach((field) => {
            field.id = field.id.replace(/treatments-\d+-/, `treatments-${index}-`);
          });
          block.querySelectorAll("label[for]").forEach((label) => {
            label.htmlFor = label.htmlFor.replace(/treatments-\d+-/, `treatments-${index}-`);
          });
          block.querySelectorAll(".schedule-times").forEach((target) => {
            target.dataset.scheduleName = `treatments[${index}][scheduleTimes]`;
          });
        });
      }

      document.getElementById("addTreatmentMedication")?.addEventListener("click", () => {
        const container = document.getElementById("treatmentMedications");
        const source = container?.querySelector("[data-medication-block]");
        if (!container || !source) return;
        const clone = source.cloneNode(true);
        resetMedicationBlock(clone);
        container.appendChild(clone);
        reindexMedicationBlocks();
        setupTreatmentForm(clone);
        clone.scrollIntoView({ behavior: "smooth", block: "center" });
        clone.querySelector(".medication-picker")?.focus();
      });

      document.getElementById("treatmentMedications")?.addEventListener("click", (event) => {
        const button = event.target.closest("[data-remove-medication]");
        if (!button) return;
        const block = button.closest("[data-medication-block]");
        if (block && document.querySelectorAll("[data-medication-block]").length > 1) {
          block.remove();
          reindexMedicationBlocks();
        }
      });

      document.querySelector("[data-open-medications]")?.addEventListener("click", () => {
        const panel = document.getElementById("medicationManager");
        if (panel) {
          panel.open = true;
          panel.scrollIntoView({ behavior: "smooth", block: "start" });
          panel.querySelector("input[name='name']")?.focus();
        }
      });

      reindexMedicationBlocks();
      document.querySelectorAll("form.treatment-form").forEach(setupTreatmentForm);
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Tratamento - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Tratamento</h2>
            <div class="welcome-sub">Registro de medicações e tratamentos no histórico dos animais.</div>
          </div>
          <div class="actions">
            <button class="btn btn-primary" type="button" data-open-medications>Cadastrar Medicação</button>
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card message message-success">Tratamento salvo.</div>
        <% } %>
        <% if (error) { %>
          <div class="content-card message message-error"><%= error %></div>
        <% } %>

        <details class="content-card medication-manager" id="medicationManager">
          <summary class="dashboard-panel-summary">
            <div>
              <div class="content-title">Medicações cadastradas</div>
              <div class="content-sub">Cadastre, edite ou exclua medicações ainda não utilizadas.</div>
            </div>
            <span class="dashboard-panel-icon">+</span>
          </summary>

          <div class="medication-manager-body">
            <form method="post" action="/admin/treatments/medications" class="form-grid medication-form">
              <div class="field">
                <label class="field-label" for="medName">Nome da medicação</label>
                <input id="medName" name="name" required />
              </div>
              <div class="field">
                <label class="field-label" for="medDescription">Observação</label>
                <input id="medDescription" name="description" />
              </div>
              <div class="form-actions">
                <button class="btn btn-primary" type="submit">Salvar medicação</button>
              </div>
            </form>

            <% if (!medications.length) { %>
              <div class="empty" style="margin-top:12px;">Nenhuma medicação cadastrada.</div>
            <% } else { %>
              <div class="record-list" style="margin-top:14px;">
                <% medications.forEach(function(medication) { %>
                  <details class="record-row medication-row">
                    <summary class="medication-row-summary">
                      <div class="record-main">
                        <div class="record-title"><%= medication.name %></div>
                        <div class="record-sub">
                          <%= medication.description || 'Sem observação.' %>
                          <% if (medication.usageCount) { %> · Em uso: <%= medication.usageCount %><% } %>
                        </div>
                      </div>
                      <span class="status-pill <%= medication.usageCount ? 'is-yellow' : 'is-blue' %>">Editar</span>
                    </summary>
                    <form method="post" action="/admin/treatments/medications/<%= medication.id %>/update" class="form-grid medication-edit-form">
                      <div class="field">
                        <label class="field-label">Nome</label>
                        <input name="name" value="<%= medication.name %>" required />
                      </div>
                      <div class="field">
                        <label class="field-label">Observação</label>
                        <input name="description" value="<%= medication.description || '' %>" />
                      </div>
                      <div class="form-actions">
                        <button class="btn btn-primary" type="submit">Salvar edição</button>
                      </div>
                    </form>
                    <form method="post" action="/admin/treatments/medications/<%= medication.id %>/delete" onsubmit="return confirm('Excluir esta medicação?');">
                      <button class="btn btn-danger" type="submit" <%= medication.usageCount ? 'disabled title="Medicação em uso não pode ser excluída"' : '' %>>Excluir</button>
                    </form>
                  </details>
                <% }) %>
              </div>
            <% } %>
          </div>
        </details>

        <div class="treatment-layout treatment-layout-single">
          <section class="content-card">
            <div class="history-section-head" style="margin-bottom:12px;">
              <div>
                <div class="content-title">Novo tratamento</div>
                <div class="content-sub">Selecione um ou mais animais. Filhotes entregues não aparecem para novos lançamentos.</div>
              </div>
            </div>

            <form method="post" action="/admin/treatments" class="treatment-form">
              <div class="field treatment-full">
                <label class="field-label" for="catIds">Animais</label>
                <select id="catIds" name="catIds" multiple size="9" required>
                  <% cats.forEach(function(cat) { %>
                    <option value="<%= cat.id %>"><%= cat.categoryLabel %> - <%= cat.name %><%= cat.microchip ? ' - ' + cat.microchip : '' %></option>
                  <% }) %>
                </select>
              </div>

              <div class="field">
                <label class="field-label" for="medicationSearch">Buscar medicação</label>
                <input id="medicationSearch" class="medication-search" type="search" placeholder="Digite parte do nome" autocomplete="off" />
              </div>

              <div class="field">
                <label class="field-label" for="medicationId">Medicação</label>
                <select id="medicationId" name="medicationId" required>
                  <option value="">Selecione...</option>
                  <% medications.forEach(function(medication) { %>
                    <option value="<%= medication.id %>"><%= medication.name %></option>
                  <% }) %>
                </select>
              </div>

              <div class="field">
                <label class="field-label" for="dosageAmount">Dose</label>
                <input id="dosageAmount" name="dosageAmount" inputmode="decimal" placeholder="Quantidade" />
              </div>

              <div class="field">
                <label class="field-label" for="dosageUnit">Unidade</label>
                <select id="dosageUnit" name="dosageUnit">
                  <option value="">Selecione...</option>
                  <% dosageUnits.forEach(function(unit) { %>
                    <option value="<%= unit %>"><%= unit %></option>
                  <% }) %>
                </select>
              </div>

              <div class="field">
                <label class="field-label" for="durationDays">Tempo de tratamento em dias</label>
                <input id="durationDays" name="durationDays" type="number" min="1" step="1" placeholder="Ex.: 5" />
              </div>

              <div class="field">
                <label class="field-label" for="frequency">Frequência</label>
                <select id="frequency" name="frequency">
                  <option value="">Selecione...</option>
                  <% frequencies.forEach(function(frequency) { %>
                    <option value="<%= frequency %>"><%= frequency %></option>
                  <% }) %>
                </select>
              </div>

              <div class="field treatment-full treatment-times-field">
                <label class="field-label">Horários</label>
                <div id="scheduleTimes" class="schedule-times"></div>
              </div>

              <div class="field">
                <label class="field-label" for="administrationRoute">Via de administração</label>
                <select id="administrationRoute" name="administrationRoute">
                  <option value="">Selecione...</option>
                  <% routes.forEach(function(route) { %>
                    <option value="<%= route %>"><%= route %></option>
                  <% }) %>
                </select>
              </div>

              <div class="field">
                <label class="field-label" for="startDate">Data de início</label>
                <input id="startDate" name="startDate" type="date" value="<%= form.startDate %>" required />
              </div>

              <div class="field">
                <label class="field-label" for="endDate">Data final</label>
                <input id="endDate" name="endDate" type="date" />
              </div>

              <div class="field treatment-full">
                <label class="field-label" for="notes">Observações</label>
                <textarea id="notes" name="notes" rows="3" placeholder="Reação, evolução clínica, orientação veterinária ou observações importantes"></textarea>
              </div>

              <div class="form-actions treatment-full">
                <button class="btn btn-primary" type="submit">Salvar tratamento</button>
              </div>
            </form>
          </section>
        </div>

        <section class="content-card module-list-card" style="margin-top:18px;">
          <div class="history-section-head" style="margin-bottom:12px;">
            <div>
              <div class="content-title">Tratamentos recentes</div>
              <div class="content-sub">Todos estes registros também constam no histórico individual do animal.</div>
            </div>
            <span class="status-pill is-yellow"><%= treatments.length %></span>
          </div>

          <% if (!treatments.length) { %>
            <div class="empty">Nenhum tratamento registrado.</div>
          <% } else { %>
            <div class="record-list">
              <% treatments.forEach(function(treatment) { %>
                <details class="record-row treatment-edit-row">
                  <summary class="medication-row-summary">
                    <div class="record-main">
                      <div class="record-title"><%= treatment.catName %></div>
                      <div class="record-sub">
                        <strong><%= treatment.medicationName %></strong>
                        <% if (treatment.dosage) { %> · Dose: <%= treatment.dosage %><% } %>
                        <% if (treatment.duration) { %> · Tempo: <%= treatment.duration %><% } %>
                      </div>
                      <div class="record-sub">
                        Início: <%= treatment.startDateLabel %>
                        <% if (treatment.endDate) { %> · Final: <%= treatment.endDateLabel %><% } %>
                        <% if (treatment.administrationTime) { %> · Horário: <%= treatment.administrationTime %><% } %>
                        <% if (treatment.administrationRoute) { %> · Via: <%= treatment.administrationRoute %><% } %>
                      </div>
                      <% if (treatment.notes) { %>
                        <div class="record-sub"><%= treatment.notes %></div>
                      <% } %>
                    </div>
                    <span class="status-pill is-blue">Editar</span>
                  </summary>

                  <form method="post" action="/admin/treatments/<%= treatment.id %>/update" class="treatment-form treatment-edit-form">
                    <div class="field">
                      <label class="field-label">Buscar medicação</label>
                      <input class="medication-search" type="search" placeholder="Digite parte do nome" autocomplete="off" />
                    </div>
                    <div class="field">
                      <label class="field-label">Medicação</label>
                      <select name="medicationId" class="medication-select" required>
                        <option value="">Selecione...</option>
                        <% medications.forEach(function(medication) { %>
                          <option value="<%= medication.id %>" <%= treatment.medicationId === medication.id ? 'selected' : '' %>><%= medication.name %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="field">
                      <label class="field-label">Dose</label>
                      <input name="dosageAmount" inputmode="decimal" value="<%= treatment.dosageParts.amount || '' %>" />
                    </div>
                    <div class="field">
                      <label class="field-label">Unidade</label>
                      <select name="dosageUnit">
                        <option value="">Selecione...</option>
                        <% dosageUnits.forEach(function(unit) { %>
                          <option value="<%= unit %>" <%= treatment.dosageParts.unit === unit ? 'selected' : '' %>><%= unit %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="field">
                      <label class="field-label">Tempo de tratamento em dias</label>
                      <input class="duration-days" name="durationDays" type="number" min="1" step="1" value="<%= treatment.durationDays || '' %>" />
                    </div>
                    <div class="field">
                      <label class="field-label">Frequência</label>
                      <select name="frequency" class="frequency-select">
                        <option value="">Selecione...</option>
                        <% frequencies.forEach(function(frequency) { %>
                          <option value="<%= frequency %>" <%= treatment.administrationParts.frequency === frequency ? 'selected' : '' %>><%= frequency %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="field treatment-full treatment-times-field">
                      <label class="field-label">Horários</label>
                      <div class="schedule-times" data-times='<%- JSON.stringify(treatment.administrationParts.times || []) %>'></div>
                    </div>
                    <div class="field">
                      <label class="field-label">Via de administração</label>
                      <select name="administrationRoute">
                        <option value="">Selecione...</option>
                        <% routes.forEach(function(route) { %>
                          <option value="<%= route %>" <%= treatment.administrationRoute === route ? 'selected' : '' %>><%= route %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="field">
                      <label class="field-label">Data de início</label>
                      <input class="start-date" name="startDate" type="date" value="<%= treatment.startDateInput %>" required />
                    </div>
                    <div class="field">
                      <label class="field-label">Data final</label>
                      <input class="end-date" name="endDate" type="date" value="<%= treatment.endDateInput %>" />
                    </div>
                    <div class="field treatment-full">
                      <label class="field-label">Observações</label>
                      <textarea name="notes" rows="3"><%= treatment.notes || '' %></textarea>
                    </div>
                    <div class="form-actions treatment-full">
                      <button class="btn btn-primary" type="submit">Salvar edição</button>
                      <a class="btn" href="/admin/history/<%= treatment.catId %>#tratamentos">Ver histórico</a>
                    </div>
                  </form>
                  <form method="post" action="/admin/treatments/<%= treatment.id %>/delete" onsubmit="return confirm('Excluir este tratamento? Ele também será removido do histórico deste animal.');">
                    <button class="btn btn-danger" type="submit">Excluir tratamento</button>
                  </form>
                </details>
              <% }) %>
            </div>
          <% } %>
        </section>
      </main>
    </div>
    <script>
      const frequencyDefaults = {
        "1xdia": ["Manhã"],
        "12/12h": ["08:00", "20:00"],
        "8/8h": ["08:00", "16:00", "00:00"],
        "6/6h": ["08:00", "14:00", "20:00", "02:00"],
        "4/4h": ["08:00", "12:00", "16:00", "20:00", "00:00", "04:00"],
        "2/2h": ["08:00", "10:00", "12:00", "14:00", "16:00", "18:00", "20:00", "22:00", "00:00", "02:00", "04:00", "06:00"],
      };
      const frequencyHours = {
        "12/12h": 12,
        "8/8h": 8,
        "6/6h": 6,
        "4/4h": 4,
        "2/2h": 2,
      };

      function addHoursToTime(value, hours) {
        const [hour, minute] = String(value || "08:00").split(":").map(Number);
        const total = (((hour || 0) * 60 + (minute || 0) + hours * 60) % 1440 + 1440) % 1440;
        return `${String(Math.floor(total / 60)).padStart(2, "0")}:${String(total % 60).padStart(2, "0")}`;
      }

      function recalculateTimes(target, frequencyValue) {
        const step = frequencyHours[frequencyValue];
        if (!step) return;
        const inputs = Array.from(target.querySelectorAll("input[type='time']"));
        if (!inputs.length) return;
        const first = inputs[0].value || "08:00";
        inputs.forEach((input, index) => {
          input.value = addHoursToTime(first, step * index);
        });
      }

      function addDays(dateText, days) {
        const parts = String(dateText || "").split("-").map(Number);
        if (!parts[0] || !parts[1] || !parts[2]) return "";
        const date = new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]));
        date.setUTCDate(date.getUTCDate() + days);
        return date.toISOString().slice(0, 10);
      }

      function syncEndDate(form) {
        const start = form.querySelector(".start-date, #startDate");
        const duration = form.querySelector(".duration-days, #durationDays");
        const end = form.querySelector(".end-date, #endDate");
        const days = Number(duration && duration.value ? duration.value : 0);
        if (start && end && days > 0) end.value = addDays(start.value, days - 1);
      }

      function renderSchedule(form, keepExisting = false) {
        const frequency = form.querySelector(".frequency-select, #frequency");
        const target = form.querySelector(".schedule-times, #scheduleTimes");
        if (!frequency || !target) return;

        const existing = keepExisting && target.dataset.times
          ? JSON.parse(target.dataset.times || "[]")
          : Array.from(target.querySelectorAll("input")).map((input) => input.value).filter(Boolean);
        const values = existing.length ? existing : (frequencyDefaults[frequency.value] || []);
        target.innerHTML = "";

        values.forEach((value, index) => {
          const label = document.createElement("label");
          label.className = "schedule-time";
          if (frequency.value === "1xdia") {
            label.innerHTML = `
              <span>Período</span>
              <select name="scheduleTimes">
                ${["Manhã", "Tarde", "Noite"].map((period) => `<option value="${period}" ${value === period ? "selected" : ""}>${period}</option>`).join("")}
              </select>
            `;
          } else {
            label.innerHTML = `<span>${index + 1}º horário</span><input type="time" name="scheduleTimes" value="${value}">`;
          }
          target.appendChild(label);
        });

        const firstInput = target.querySelector("input[type='time']");
        if (firstInput) {
          firstInput.addEventListener("change", () => recalculateTimes(target, frequency.value));
        }
      }

      function setupMedicationFilter(scope) {
        const search = scope.querySelector(".medication-search");
        const select = scope.querySelector(".medication-select, #medicationId");
        if (!search || !select) return;

        const options = Array.from(select.options).map((option) => ({
          value: option.value,
          text: option.text,
          selected: option.selected,
        }));

        search.addEventListener("input", () => {
          const term = search.value.trim().toLocaleLowerCase("pt-BR");
          const current = select.value;
          select.innerHTML = "";
          options
            .filter((option) => !term || option.text.toLocaleLowerCase("pt-BR").includes(term) || !option.value)
            .forEach((option) => {
              const next = new Option(option.text, option.value);
              next.selected = option.value === current;
              select.add(next);
            });
        });
      }

      function setupTreatmentForm(form) {
        setupMedicationFilter(form);
        const frequency = form.querySelector(".frequency-select, #frequency");
        const duration = form.querySelector(".duration-days, #durationDays");
        const start = form.querySelector(".start-date, #startDate");
        if (frequency) {
          renderSchedule(form, true);
          frequency.addEventListener("change", () => renderSchedule(form));
        }
        if (duration) duration.addEventListener("input", () => syncEndDate(form));
        if (start) start.addEventListener("change", () => syncEndDate(form));
      }

      document.querySelector("[data-open-medications]")?.addEventListener("click", () => {
        const panel = document.getElementById("medicationManager");
        if (panel) {
          panel.open = true;
          panel.scrollIntoView({ behavior: "smooth", block: "start" });
          panel.querySelector("input[name='name']")?.focus();
        }
      });

      document.querySelectorAll(".treatment-form").forEach(setupTreatmentForm);
    </script>
  </body>
</html>

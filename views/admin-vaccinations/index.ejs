<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Vacinação - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .vaccination-grid {
        display: grid;
        grid-template-columns: 260px 220px 300px 220px;
        gap: 10px;
        align-items: start;
      }
      .vaccination-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .vaccination-row {
        padding: 12px;
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        margin-bottom: 12px;
      }
      .vaccination-row.is-overdue {
        border-left: 5px solid #dc2626;
      }
      .vaccination-row.is-upcoming {
        border-left: 5px solid #f59e0b;
      }
      .vaccination-row.is-vaccinated {
        border-left: 5px solid #16a34a;
      }
      .vaccination-cat-list {
        display: grid;
        gap: 10px;
        margin-top: 12px;
      }
      .vaccination-cat-card {
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        background: #fff;
        overflow: hidden;
      }
      .vaccination-cat-card > summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        cursor: pointer;
        list-style: none;
      }
      .vaccination-cat-card > summary::-webkit-details-marker {
        display: none;
      }
      .vaccination-cat-card.is-overdue {
        border-left: 5px solid #dc2626;
      }
      .vaccination-cat-card.is-upcoming {
        border-left: 5px solid #f59e0b;
      }
      .vaccination-cat-card.is-vaccinated {
        border-left: 5px solid #16a34a;
      }
      .vaccination-cat-summary-main {
        min-width: 0;
      }
      .vaccination-cat-summary-main strong {
        display: block;
        color: var(--text-main);
        font-size: 14px;
      }
      .vaccination-cat-summary-main span {
        display: block;
        margin-top: 3px;
        color: var(--text-muted);
        font-size: 12px;
      }
      .vaccination-cat-summary-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }
      .vaccination-cat-card .vaccination-row {
        border: 0;
        border-top: 1px solid var(--border-soft);
        border-radius: 0;
        margin-bottom: 0;
      }
      .vaccination-cat-card[open] > summary .module-accordion-icon {
        transform: rotate(180deg);
      }
      @media (max-width: 1300px) {
        .vaccination-grid {
          grid-template-columns: 1fr;
        }
        .vaccination-header {
          display: none;
        }
        .vaccination-cat-card > summary {
          align-items: flex-start;
          flex-direction: column;
        }
        .vaccination-cat-summary-meta {
          justify-content: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Vacinação</h2>
            <div class="welcome-sub">Controle vacinal administrativo dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card module-panel">
          <div class="history-section-head">
            <div>
              <div class="content-title">Próximas ações</div>
              <div class="content-sub">Vacinas vencidas ou próximas nos próximos 15 dias.</div>
            </div>
            <span class="status-pill is-blue"><%= nextActions.length %></span>
          </div>
          <% if (!nextActions.length) { %>
            <div class="empty" style="margin-top:12px;">Nenhuma vacinação urgente no momento.</div>
          <% } else { %>
            <div class="record-list" style="margin-top:12px;">
              <% nextActions.forEach(function(action) { %>
                <div class="record-row">
                  <div class="record-main">
                    <div class="record-title"><%= action.title %></div>
                    <div class="record-sub"><%= action.sub %></div>
                  </div>
                  <div class="record-meta">
                    <span class="status-pill <%= action.color %>"><%= action.badge %></span>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <% categories.forEach(function(category) { %>
          <% const items = grouped[category.key] || []; %>
          <details class="content-card module-panel module-accordion" style="border-left: 5px solid <%= category.color %>;">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= category.label %></span>
              </div>
              <span class="module-accordion-count"><%= items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <% if (!items.length) { %>
                <div class="empty" style="margin-top:12px;">Nenhum gato nesta categoria.</div>
              <% } else { %>
                <div class="vaccination-cat-list">
                  <% items.forEach(function(row) { %>
                    <details class="vaccination-cat-card is-<%= row.vaccinationState %>">
                      <summary>
                        <div class="vaccination-cat-summary-main">
                          <strong><%= row.displayName %></strong>
                        </div>
                        <div class="vaccination-cat-summary-meta">
                          <span class="status-pill <%= row.vaccinationState === 'overdue' ? 'is-red' : row.vaccinationState === 'upcoming' ? 'is-yellow' : 'is-green' %>">
                            <%= row.vaccinationState === 'overdue' ? 'Vencida' : row.vaccinationState === 'upcoming' ? 'Próxima' : 'Em dia' %>
                          </span>
                          <span class="module-accordion-icon">⌄</span>
                        </div>
                      </summary>
                      <form method="post" action="/admin/vaccinations/<%= row.cat.id %>" class="vaccination-row is-<%= row.vaccinationState %>">
                        <div class="vaccination-grid">
                          <div>
                            <div class="item-title" style="color:<%= row.vaccinationState === 'overdue' ? '#dc2626' : row.vaccinationState === 'upcoming' ? '#f59e0b' : '#16a34a' %>;">
                              <%= row.displayName %>
                            </div>
                            <div class="cat-subline">Nascimento: <%= row.birthDateLabel %></div>
                            <div class="cat-subline">Mãe: <%= row.motherName %></div>
                            <div style="margin-top:8px;">
                              <span class="status-pill <%= row.vaccinationState === 'overdue' ? 'is-red' : row.vaccinationState === 'upcoming' ? 'is-yellow' : 'is-green' %>">
                                <%= row.vaccinationState === 'overdue' ? 'Vencida' : row.vaccinationState === 'upcoming' ? 'Próxima' : 'Em dia' %>
                              </span>
                            </div>
                          </div>

                          <div class="mini-stack" data-antirabic-box>
                            <div class="content-sub">Histórico Antirrábica</div>
                            <% const lastAntirabicIndex = row.antirabicHistory.reduce(function(last, item, index) { return item.date ? index : last; }, -1); %>
                            <% row.antirabicHistory.forEach(function(item, index) { %>
                              <div class="inline-plus" data-antirabic-row>
                                <input type="date" name="antirabicDates" value="<%= item.date || '' %>" />
                                <% if (item.date && index === lastAntirabicIndex) { %>
                                  <button type="button" class="btn delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
                                <% } %>
                              </div>
                            <% }) %>
                            <div class="history-add-row">
                              <button type="button" class="btn add-antirabic">+</button>
                            </div>
                          </div>

                          <div class="mini-stack" data-feline-box>
                            <div class="content-sub">Histórico Feline</div>
                            <% const lastFelineIndex = row.felineHistory.reduce(function(last, item, index) { return (item.date || item.type) ? index : last; }, -1); %>
                            <% row.felineHistory.forEach(function(item, index) { %>
                              <div class="inline-plus" data-feline-row>
                                <input type="date" name="felineDates" value="<%= item.date || '' %>" />
                                <select name="felineTypes" style="width:120px;">
                                  <option value="">Tipo</option>
                                  <% felineTypes.forEach(function(type) { %>
                                    <option value="<%= type %>" <%= item.type === type ? "selected" : "" %>><%= type %></option>
                                  <% }) %>
                                </select>
                                <% if ((item.date || item.type) && index === lastFelineIndex) { %>
                                  <button type="button" class="btn delete-history-date" title="Remover data" aria-label="Remover data">&#128465;</button>
                                <% } %>
                              </div>
                            <% }) %>
                            <div class="history-add-row">
                              <button type="button" class="btn add-feline">+</button>
                            </div>
                          </div>

                          <div class="mini-stack">
                            <div class="content-sub">Próxima vacinação</div>
                            <div>Antirrábica: <strong><%= row.nextAntirabic ? formatDate(row.nextAntirabic) : "-" %></strong></div>
                            <div>Feline: <strong><%= row.nextFeline ? formatDate(row.nextFeline) : "-" %></strong></div>
                          </div>
                        </div>
                      </form>
                    </details>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </details>
        <% }) %>
      </main>
    </div>

    <script>
      (function () {
        const felineTypes = <%- JSON.stringify(felineTypes) %>;

        function isCompleteDate(value) {
          if (!/^\d{4}-\d{2}-\d{2}$/.test(String(value || ""))) return false;
          const [year, month, day] = value.split("-").map(Number);
          if (year < 1900 || year > 2200) return false;
          const parsed = new Date(Date.UTC(year, month - 1, day));
          return parsed.getUTCFullYear() === year &&
            parsed.getUTCMonth() === month - 1 &&
            parsed.getUTCDate() === day;
        }

        function felineTypeOptions() {
          return [
            '<option value="">Tipo</option>',
            ...felineTypes.map((type) => `<option value="${type}">${type}</option>`),
          ].join("");
        }

        async function autosave(form) {
          if (!form) return;
          if (form.dataset.submitting === "true") {
            form.dataset.pendingSave = "true";
            return;
          }

          form.dataset.submitting = "true";
          form.dataset.pendingSave = "false";

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(form)),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "X-Autosave": "true",
              },
            });

            if (!response.ok) {
              throw new Error("Erro ao salvar vacinação");
            }
          } catch (error) {
            console.error(error);
          } finally {
            form.dataset.submitting = "false";
            if (form.dataset.pendingSave === "true") {
              autosave(form);
            }
          }
        }

        document.querySelectorAll(".add-antirabic").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-antirabic-box]");
            const row = document.createElement("div");
            row.className = "inline-plus";
            row.dataset.antirabicRow = "";
            row.innerHTML = '<input type="date" name="antirabicDates" value="" />';
            box.insertBefore(row, button.closest(".history-add-row"));
            bindAntirabicRow(row);
          });
        });

        document.querySelectorAll(".add-feline").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-feline-box]");
            const row = document.createElement("div");
            row.className = "inline-plus";
            row.dataset.felineRow = "";
            row.innerHTML = `<input type="date" name="felineDates" value="" /><select name="felineTypes" style="width:120px;">${felineTypeOptions()}</select>`;
            box.insertBefore(row, button.closest(".history-add-row"));
            bindFelineRow(row);
          });
        });

        function removeHistoryRow(row) {
          row.remove();
        }

        function bindDelete(button) {
          button.addEventListener("click", () => {
            const form = button.closest("form");
            const antirabicBox = button.closest("[data-antirabic-box]");
            const felineBox = button.closest("[data-feline-box]");
            removeHistoryRow(button.closest(".inline-plus"));
            if (antirabicBox) refreshAntirabicDeleteButton(antirabicBox);
            if (felineBox) refreshFelineDeleteButton(felineBox);
            autosave(form);
          });
        }

        function deleteButtonHtml() {
          return '<button type="button" class="btn delete-history-date" title="Remover última vacina" aria-label="Remover última vacina">&#128465;</button>';
        }

        function resetDeleteButton(row) {
          row.querySelector(".delete-history-date")?.remove();
        }

        function ensureDeleteButton(row) {
          if (!row.querySelector(".delete-history-date")) {
            row.insertAdjacentHTML("beforeend", deleteButtonHtml());
            bindDelete(row.querySelector(".delete-history-date"));
          }
        }

        function refreshAntirabicDeleteButton(box) {
          const rows = Array.from(box.querySelectorAll("[data-antirabic-row]"));
          rows.forEach(resetDeleteButton);
          const savedRows = rows.filter((row) => isCompleteDate(row.querySelector('input[type="date"]')?.value));
          const last = savedRows[savedRows.length - 1];
          if (last) ensureDeleteButton(last);
        }

        function refreshFelineDeleteButton(box) {
          const rows = Array.from(box.querySelectorAll("[data-feline-row]"));
          rows.forEach(resetDeleteButton);
          const savedRows = rows.filter((row) => {
            const input = row.querySelector('input[type="date"]');
            const select = row.querySelector("select");
            return isCompleteDate(input?.value) && Boolean(select?.value);
          });
          const last = savedRows[savedRows.length - 1];
          if (last) ensureDeleteButton(last);
        }

        function bindAntirabicRow(row) {
          const input = row.querySelector('input[type="date"]');
          if (input) {
            input.addEventListener("change", () => {
              if (!isCompleteDate(input.value)) return;
              refreshAntirabicDeleteButton(row.closest("[data-antirabic-box]"));
              autosave(row.closest("form"));
            });
          }

          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) bindDelete(deleteButton);
        }

        function bindFelineRow(row) {
          const input = row.querySelector('input[type="date"]');
          const select = row.querySelector("select");

          function maybeSave() {
            if (!isCompleteDate(input?.value) || !select?.value) return;
            refreshFelineDeleteButton(row.closest("[data-feline-box]"));
            autosave(row.closest("form"));
          }

          if (input) input.addEventListener("change", maybeSave);
          if (select) select.addEventListener("change", maybeSave);

          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) bindDelete(deleteButton);
        }

        document.querySelectorAll("[data-antirabic-row]").forEach(bindAntirabicRow);
        document.querySelectorAll("[data-feline-row]").forEach(bindFelineRow);
        document.querySelectorAll("[data-antirabic-box]").forEach(refreshAntirabicDeleteButton);
        document.querySelectorAll("[data-feline-box]").forEach(refreshFelineDeleteButton);
      })();
    </script>
  </body>
</html>

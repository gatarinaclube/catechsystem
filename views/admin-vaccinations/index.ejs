<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Vacinação - PetGus</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .shell {
        max-width: 100vw;
      }

      .main {
        min-width: 0;
        max-width: calc(100vw - 260px);
        overflow: hidden;
      }

      .module-panel {
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
      }

      .vaccination-search-card {
        margin-bottom: 18px;
      }

      .vaccination-search-grid {
        display: grid;
        grid-template-columns: minmax(240px, 1fr) auto;
        gap: 12px;
        align-items: end;
      }

      .vaccination-sheet-shell {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        margin-top: 14px;
        overflow: hidden;
      }

      .vaccination-sheet-wrap {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: auto;
        overflow-y: visible;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        background: #f8fafc;
      }

      .vaccination-table {
        display: flex;
        min-width: 1230px;
        flex-direction: column;
      }

      .vaccination-grid-row {
        display: grid;
        grid-template-columns: 240px 240px 330px 220px 200px;
        min-width: 1230px;
      }

      .vaccination-head-cell,
      .vaccination-cell {
        border-right: 1px solid #cbd5e1;
        border-bottom: 1px solid #cbd5e1;
        min-width: 0;
      }

      .vaccination-head-cell:last-child,
      .vaccination-cell:last-child {
        border-right: 0;
      }

      .vaccination-head-cell {
        background: #e2e8f0;
        color: #0f172a;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0.03em;
        padding: 8px 10px;
        text-transform: uppercase;
        white-space: nowrap;
      }

      .vaccination-cell {
        background: #fff;
        padding: 5px 7px;
        font-size: 12px;
      }

      .vaccination-data-row.is-overdue .vaccination-cell {
        background: #fff7f7;
      }

      .vaccination-data-row.is-upcoming .vaccination-cell {
        background: #fffbeb;
      }

      .vaccination-data-row.is-vaccinated .vaccination-cell {
        background: #f7fff8;
      }

      .vaccination-data-row.search-match .vaccination-cell {
        box-shadow: inset 0 0 0 2px rgba(245, 158, 11, 0.36);
      }

      .vaccination-section-row {
        min-width: 1230px;
        border-bottom: 1px solid #94a3b8;
        color: #fff;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0.04em;
        padding: 7px 10px;
        text-transform: uppercase;
      }

      .vaccination-section-scrollbar {
        height: 12px;
        min-width: 1230px;
        overflow-x: auto;
        overflow-y: hidden;
        border-bottom: 1px solid rgba(148, 163, 184, 0.72);
        background: rgba(241, 245, 249, 0.96);
      }

      .vaccination-section-scrollbar-inner {
        height: 1px;
        min-width: 100%;
      }

      .vaccination-scrollbar {
        width: 100%;
        max-width: 100%;
        height: 18px;
        margin-top: 8px;
        overflow-x: auto;
        overflow-y: hidden;
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        background: #f8fafc;
        position: sticky;
        bottom: 0;
        z-index: 3;
      }

      .vaccination-scrollbar-inner {
        height: 1px;
        min-width: 100%;
      }

      .vaccination-cat-cell {
        position: sticky;
        left: 0;
        z-index: 2;
        border-right: 2px solid #94a3b8;
      }

      .vaccination-cat-details {
        margin: 0;
      }

      .vaccination-cat-details > summary {
        cursor: pointer;
        list-style: none;
      }

      .vaccination-cat-details > summary::-webkit-details-marker {
        display: none;
      }

      .vaccination-cat-name {
        display: block;
        color: #0f172a;
        font-size: 12px;
        font-weight: 900;
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .vaccination-data-row.is-overdue .vaccination-cat-name {
        color: #dc2626;
      }

      .vaccination-cat-extra {
        display: grid;
        gap: 2px;
        margin-top: 8px;
        color: #475569;
        font-size: 11px;
        line-height: 1.35;
      }

      .vaccination-history-box {
        display: grid;
        gap: 3px;
      }

      .vaccination-history-more {
        margin: 0;
      }

      .vaccination-history-more > summary {
        color: #b45309;
        cursor: pointer;
        font-size: 10px;
        font-weight: 900;
        list-style: none;
        margin-bottom: 2px;
        text-transform: uppercase;
      }

      .vaccination-history-more > summary::-webkit-details-marker {
        display: none;
      }

      .vaccination-history-rows {
        display: grid;
        gap: 4px;
        margin-bottom: 4px;
      }

      .vaccination-history-line {
        display: flex;
        align-items: center;
        gap: 4px;
        min-width: 0;
        white-space: nowrap;
      }

      .vaccination-date-display,
      .vaccination-type-select {
        height: 27px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        background: #fff;
        color: #0f172a;
        font-size: 12px;
        font-weight: 800;
        padding: 4px 6px;
      }

      .vaccination-date-display {
        width: 118px;
        text-align: center;
      }

      .vaccination-type-select {
        width: 118px;
      }

      .vaccination-icon-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border: 1px solid #cbd5e1;
        border-radius: 999px;
        background: #fff;
        color: #475569;
        cursor: pointer;
        font-size: 12px;
        font-weight: 900;
        line-height: 1;
        padding: 0;
      }

      .vaccination-icon-button:hover {
        border-color: #f59e0b;
        color: #b45309;
      }

      .vaccination-icon-button.is-danger:hover {
        border-color: #dc2626;
        color: #dc2626;
      }

      .vaccination-next-date {
        display: inline-block;
        color: #15803d;
        font-size: 13px;
        font-weight: 900;
        line-height: 1.25;
        white-space: nowrap;
      }

      .vaccination-next-date.is-danger {
        color: #dc2626;
      }

      .vaccination-save-status {
        display: inline-block;
        min-height: 14px;
        color: #64748b;
        font-size: 10px;
        font-weight: 900;
        line-height: 1.2;
        margin-top: 3px;
        text-transform: uppercase;
      }

      .vaccination-save-status.is-success {
        color: #16a34a;
      }

      .vaccination-save-status.is-error {
        color: #dc2626;
      }

      @media (max-width: 900px) {
        .main {
          max-width: 100vw;
        }
      }

      @media (max-width: 700px) {
        .vaccination-search-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <%
      function isoDate(value) {
        const text = String(value || "");
        if (/^\d{4}-\d{2}-\d{2}$/.test(text)) return text;
        const parsed = new Date(value);
        if (Number.isNaN(parsed.getTime())) return "";
        const year = parsed.getFullYear();
        const month = String(parsed.getMonth() + 1).padStart(2, "0");
        const day = String(parsed.getDate()).padStart(2, "0");
        return `${year}-${month}-${day}`;
      }

      function visibleDate(value) {
        const iso = isoDate(value);
        return iso ? formatDate(iso) : "";
      }

      function isOverdue(value) {
        const iso = isoDate(value);
        if (!iso) return false;
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const parsed = new Date(`${iso}T00:00:00`);
        return parsed < today;
      }

      function filledAntirabic(history) {
        const filled = (history || []).filter(function(item) { return item && item.date; });
        return filled.length ? filled : [{ date: "" }];
      }

      function filledFeline(history) {
        const filled = (history || []).filter(function(item) { return item && (item.date || item.type); });
        return filled.length ? filled : [{ date: "", type: "" }];
      }

      function renderAntirabicLine(item, includeAddButton) {
    %>
        <div class="vaccination-history-line" data-antirabic-row>
          <input type="hidden" name="antirabicDates" value="<%= isoDate(item.date) %>" data-vaccine-date-value />
          <input
            class="vaccination-date-display"
            type="text"
            inputmode="numeric"
            placeholder="dd/mm/aaaa"
            value="<%= visibleDate(item.date) %>"
            data-vaccine-date-display
          />
          <% if (includeAddButton) { %>
            <button type="button" class="vaccination-icon-button add-antirabic" title="Adicionar antirrábica" aria-label="Adicionar antirrábica">+</button>
          <% } %>
        </div>
    <%
      }

      function renderFelineLine(item, includeAddButton) {
    %>
        <div class="vaccination-history-line" data-feline-row>
          <input type="hidden" name="felineDates" value="<%= isoDate(item.date) %>" data-vaccine-date-value />
          <input
            class="vaccination-date-display"
            type="text"
            inputmode="numeric"
            placeholder="dd/mm/aaaa"
            value="<%= visibleDate(item.date) %>"
            data-vaccine-date-display
          />
          <select name="felineTypes" class="vaccination-type-select">
            <option value="">Tipo</option>
            <% felineTypes.forEach(function(type) { %>
              <option value="<%= type %>" <%= item.type === type ? "selected" : "" %>><%= type %></option>
            <% }) %>
          </select>
          <% if (includeAddButton) { %>
            <button type="button" class="vaccination-icon-button add-feline" title="Adicionar feline" aria-label="Adicionar feline">+</button>
          <% } %>
        </div>
    <%
      }
    %>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Vacinação</h2>
            <div class="welcome-sub">Controle vacinal administrativo dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card vaccination-search-card">
          <div class="vaccination-search-grid">
            <div class="field">
              <label class="field-label" for="vaccinationSearch">Pesquisar gato</label>
              <input id="vaccinationSearch" type="search" placeholder="Digite o nome do gato..." autocomplete="off" />
              <div class="section-note">Ao pesquisar, o gato encontrado é destacado e levado para visualização.</div>
            </div>
            <button class="btn" type="button" id="clearVaccinationSearch">Limpar</button>
          </div>
        </div>

        <div class="content-card module-panel">
          <div class="history-section-head">
            <div>
              <div class="content-title">Próximas ações</div>
              <div class="content-sub">Vacinas vencidas ou próximas nos próximos 15 dias.</div>
            </div>
            <span class="status-pill is-blue"><%= nextActions.length %></span>
          </div>
          <% if (!nextActions.length) { %>
            <div class="empty" style="margin-top:12px;">Nenhuma vacinação urgente no momento.</div>
          <% } else { %>
            <div class="record-list" style="margin-top:12px;">
              <% nextActions.forEach(function(action) { %>
                <div class="record-row">
                  <div class="record-main">
                    <div class="record-title"><%= action.title %></div>
                    <div class="record-sub"><%= action.sub %></div>
                  </div>
                  <div class="record-meta">
                    <span class="status-pill <%= action.color %>"><%= action.badge %></span>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="content-card module-panel">
          <div class="history-section-head">
            <div>
              <div class="content-title">Planilha de vacinação</div>
              <div class="content-sub">Histórico, próximas doses e salvamento automático.</div>
            </div>
          </div>

          <div class="vaccination-sheet-shell">
            <div class="vaccination-sheet-wrap" data-vaccination-sheet-wrap>
              <div class="vaccination-table">
                <div class="vaccination-grid-row">
                  <div class="vaccination-head-cell vaccination-cat-cell">Gato</div>
                  <div class="vaccination-head-cell">Histórico antirrábica</div>
                  <div class="vaccination-head-cell">Histórico feline</div>
                  <div class="vaccination-head-cell">Próxima antirrábica</div>
                  <div class="vaccination-head-cell">Próxima feline</div>
                </div>

                <% categories.forEach(function(category) { %>
                  <% const items = grouped[category.key] || []; %>
                  <div class="vaccination-section-row" style="background:<%= category.color %>;">
                    <%= category.label %> · <%= items.length %>
                  </div>
                  <% if (!items.length) { %>
                    <div class="vaccination-grid-row">
                      <div class="vaccination-cell vaccination-cat-cell">Nenhum gato nesta categoria.</div>
                      <div class="vaccination-cell"></div>
                      <div class="vaccination-cell"></div>
                      <div class="vaccination-cell"></div>
                      <div class="vaccination-cell"></div>
                    </div>
                  <% } else { %>
                    <% items.forEach(function(row, index) { %>
                      <% const antiHistory = filledAntirabic(row.antirabicHistory); %>
                      <% const antiPrior = antiHistory.slice(0, -1); %>
                      <% const antiLast = antiHistory[antiHistory.length - 1] || { date: "" }; %>
                      <% const felineHistory = filledFeline(row.felineHistory); %>
                      <% const felinePrior = felineHistory.slice(0, -1); %>
                      <% const felineLast = felineHistory[felineHistory.length - 1] || { date: "", type: "" }; %>
                      <form
                        method="post"
                        action="/admin/vaccinations/<%= row.cat.id %>"
                        class="vaccination-grid-row vaccination-data-row is-<%= row.vaccinationState %>"
                        data-vaccination-row
                        data-original-order="<%= index %>"
                        data-search="<%= String(row.cleanName || row.displayName || '').toLowerCase() %>"
                      >
                        <div class="vaccination-cell vaccination-cat-cell">
                          <details class="vaccination-cat-details">
                            <summary>
                              <span class="vaccination-cat-name"><%= row.cleanName || row.displayName %></span>
                            </summary>
                            <div class="vaccination-cat-extra">
                              <span>Nascimento: <%= row.birthDateLabel %></span>
                              <span>Mãe: <%= row.motherName %></span>
                              <span data-vaccination-summary><%= row.vaccinationSummary || "Em dia" %></span>
                            </div>
                          </details>
                        </div>

                        <div class="vaccination-cell">
                          <div class="vaccination-history-box" data-antirabic-box>
                            <% if (antiPrior.length) { %>
                              <details class="vaccination-history-more">
                                <summary>Ver mais datas</summary>
                                <div class="vaccination-history-rows">
                                  <% antiPrior.forEach(function(item) { renderAntirabicLine(item, false); }) %>
                                </div>
                              </details>
                            <% } %>
                            <% renderAntirabicLine(antiLast, true); %>
                            <span class="vaccination-save-status" data-save-status></span>
                          </div>
                        </div>

                        <div class="vaccination-cell">
                          <div class="vaccination-history-box" data-feline-box>
                            <% if (felinePrior.length) { %>
                              <details class="vaccination-history-more">
                                <summary>Ver mais datas</summary>
                                <div class="vaccination-history-rows">
                                  <% felinePrior.forEach(function(item) { renderFelineLine(item, false); }) %>
                                </div>
                              </details>
                            <% } %>
                            <% renderFelineLine(felineLast, true); %>
                            <span class="vaccination-save-status" data-save-status></span>
                          </div>
                        </div>

                        <div class="vaccination-cell">
                          <strong
                            class="vaccination-next-date <%= isOverdue(row.nextAntirabic) ? 'is-danger' : '' %>"
                            data-next-antirabic
                          ><%= row.nextAntirabic ? formatDate(row.nextAntirabic) : "-" %></strong>
                        </div>

                        <div class="vaccination-cell">
                          <strong
                            class="vaccination-next-date <%= isOverdue(row.nextFeline) ? 'is-danger' : '' %>"
                            data-next-feline
                          ><%= row.nextFeline ? formatDate(row.nextFeline) : "-" %></strong>
                        </div>
                      </form>
                    <% }) %>
                  <% } %>
                  <div class="vaccination-section-scrollbar" data-vaccination-scrollbar>
                    <div class="vaccination-section-scrollbar-inner" data-vaccination-scrollbar-inner></div>
                  </div>
                <% }) %>
              </div>
            </div>
            <div class="vaccination-scrollbar" data-vaccination-scrollbar>
              <div class="vaccination-scrollbar-inner" data-vaccination-scrollbar-inner></div>
            </div>
          </div>
        </div>
      </main>
    </div>

    <script>
      (function () {
        const felineTypes = <%- JSON.stringify(felineTypes) %>;

        function normalizeSearch(value) {
          return String(value || "")
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "")
            .toLowerCase()
            .trim();
        }

        function maskBrazilianDate(value) {
          const digits = String(value || "").replace(/\D/g, "").slice(0, 8);
          if (digits.length <= 2) return digits;
          if (digits.length <= 4) return `${digits.slice(0, 2)}/${digits.slice(2)}`;
          return `${digits.slice(0, 2)}/${digits.slice(2, 4)}/${digits.slice(4)}`;
        }

        function displayToIso(value) {
          const match = String(value || "").match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
          if (!match) return "";
          const day = Number(match[1]);
          const month = Number(match[2]);
          const year = Number(match[3]);
          if (year < 1900 || year > 2200) return "";
          const parsed = new Date(Date.UTC(year, month - 1, day));
          if (
            parsed.getUTCFullYear() !== year ||
            parsed.getUTCMonth() !== month - 1 ||
            parsed.getUTCDate() !== day
          ) {
            return "";
          }
          return `${year}-${String(month).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
        }

        function isCompleteDisplayDate(value) {
          return Boolean(displayToIso(value));
        }

        function isCompleteIsoDate(value) {
          return /^\d{4}-\d{2}-\d{2}$/.test(String(value || ""));
        }

        function isDisplayDatePast(value) {
          const iso = displayToIso(value);
          if (!iso) return false;
          const today = new Date();
          today.setHours(0, 0, 0, 0);
          return new Date(`${iso}T00:00:00`) < today;
        }

        function felineTypeOptions() {
          return [
            '<option value="">Tipo</option>',
            ...felineTypes.map((type) => `<option value="${type}">${type}</option>`),
          ].join("");
        }

        function setStatusText(form, text, type = "") {
          const statuses = form?.querySelectorAll("[data-save-status]") || [];
          statuses.forEach((statusElement) => {
            statusElement.textContent = text || "";
            statusElement.classList.toggle("is-success", type === "success");
            statusElement.classList.toggle("is-error", type === "error");
          });
        }

        function applyRowState(row, state) {
          if (!row) return;
          row.classList.remove("is-overdue", "is-upcoming", "is-vaccinated");
          row.classList.add(`is-${state || "vaccinated"}`);
        }

        function applyNextDate(element, label, overdue) {
          if (!element) return;
          element.textContent = label || "-";
          element.classList.toggle("is-danger", Boolean(overdue));
        }

        async function autosave(form) {
          if (!form) return;
          if (form.dataset.submitting === "true") {
            form.dataset.pendingSave = "true";
            return;
          }

          form.dataset.submitting = "true";
          form.dataset.pendingSave = "false";
          setStatusText(form, "Salvando...");

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(form)),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "Accept": "application/json",
                "X-Autosave": "true",
              },
            });

            if (!response.ok) throw new Error("Erro ao salvar vacinação");
            const data = await response.json();
            applyRowState(form, data.vaccinationState);
            form.querySelectorAll("[data-vaccination-summary]").forEach((item) => {
              item.textContent = data.vaccinationSummary || data.stateLabel || "Em dia";
            });
            applyNextDate(form.querySelector("[data-next-antirabic]"), data.nextAntirabicLabel, data.nextAntirabicOverdue);
            applyNextDate(form.querySelector("[data-next-feline]"), data.nextFelineLabel, data.nextFelineOverdue);
            setStatusText(form, "Salvo.", "success");
          } catch (error) {
            console.error(error);
            setStatusText(form, error.message || "Erro ao salvar.", "error");
          } finally {
            form.dataset.submitting = "false";
            if (form.dataset.pendingSave === "true") {
              autosave(form);
            }
          }
        }

        function deleteButtonHtml() {
          return '<button type="button" class="vaccination-icon-button is-danger delete-history-date" title="Remover última vacina" aria-label="Remover última vacina">&#128465;</button>';
        }

        function bindDelete(button) {
          button.addEventListener("click", () => {
            const form = button.closest("form");
            const antirabicBox = button.closest("[data-antirabic-box]");
            const felineBox = button.closest("[data-feline-box]");
            button.closest(".vaccination-history-line")?.remove();
            if (antirabicBox) refreshAntirabicDeleteButton(antirabicBox);
            if (felineBox) refreshFelineDeleteButton(felineBox);
            autosave(form);
          });
        }

        function resetDeleteButton(row) {
          row.querySelector(".delete-history-date")?.remove();
        }

        function ensureDeleteButton(row) {
          if (!row || row.querySelector(".delete-history-date")) return;
          row.insertAdjacentHTML("beforeend", deleteButtonHtml());
          bindDelete(row.querySelector(".delete-history-date"));
        }

        function ensureTrailingAddButton(box, rowSelector, buttonClass, label, bindFunction) {
          if (!box) return;
          const rows = Array.from(box.querySelectorAll(rowSelector));
          rows.forEach((row) => row.querySelector(`.${buttonClass}`)?.remove());
          const last = rows[rows.length - 1];
          if (!last) return;
          last.insertAdjacentHTML(
            "beforeend",
            `<button type="button" class="vaccination-icon-button ${buttonClass}" title="${label}" aria-label="${label}">+</button>`
          );
          bindFunction(last.querySelector(`.${buttonClass}`));
        }

        function refreshAntirabicDeleteButton(box) {
          const rows = Array.from(box.querySelectorAll("[data-antirabic-row]"));
          rows.forEach(resetDeleteButton);
          const savedRows = rows.filter((row) => isCompleteIsoDate(row.querySelector("[data-vaccine-date-value]")?.value));
          ensureTrailingAddButton(box, "[data-antirabic-row]", "add-antirabic", "Adicionar antirrábica", bindAddAntirabic);
          ensureDeleteButton(savedRows[savedRows.length - 1]);
        }

        function refreshFelineDeleteButton(box) {
          const rows = Array.from(box.querySelectorAll("[data-feline-row]"));
          rows.forEach(resetDeleteButton);
          const savedRows = rows.filter((row) => {
            const date = row.querySelector("[data-vaccine-date-value]")?.value;
            const type = row.querySelector("select")?.value;
            return isCompleteIsoDate(date) && Boolean(type);
          });
          ensureTrailingAddButton(box, "[data-feline-row]", "add-feline", "Adicionar feline", bindAddFeline);
          ensureDeleteButton(savedRows[savedRows.length - 1]);
        }

        function bindDateField(row, options = {}) {
          const display = row.querySelector("[data-vaccine-date-display]");
          const hidden = row.querySelector("[data-vaccine-date-value]");
          if (!display || !hidden) return;

          let lastSaved = hidden.value || "";

          function commitIfComplete() {
            const iso = displayToIso(display.value);
            if (!iso) return false;
            hidden.value = iso;
            if (iso !== lastSaved || options.forceSave?.()) {
              lastSaved = iso;
              return true;
            }
            return false;
          }

          display.addEventListener("input", () => {
            const masked = maskBrazilianDate(display.value);
            display.value = masked;
            if (!isCompleteDisplayDate(masked)) return;
            if (!commitIfComplete()) return;
            options.onComplete?.();
          });

          display.addEventListener("blur", () => {
            const masked = maskBrazilianDate(display.value);
            display.value = masked;
            if (!isCompleteDisplayDate(masked)) return;
            if (!commitIfComplete()) return;
            options.onComplete?.();
          });
        }

        function antirabicLineHtml(includeAddButton = false) {
          return `
            <div class="vaccination-history-line" data-antirabic-row>
              <input type="hidden" name="antirabicDates" value="" data-vaccine-date-value />
              <input class="vaccination-date-display" type="text" inputmode="numeric" placeholder="dd/mm/aaaa" value="" data-vaccine-date-display />
              ${includeAddButton ? '<button type="button" class="vaccination-icon-button add-antirabic" title="Adicionar antirrábica" aria-label="Adicionar antirrábica">+</button>' : ''}
            </div>
          `;
        }

        function felineLineHtml(includeAddButton = false) {
          return `
            <div class="vaccination-history-line" data-feline-row>
              <input type="hidden" name="felineDates" value="" data-vaccine-date-value />
              <input class="vaccination-date-display" type="text" inputmode="numeric" placeholder="dd/mm/aaaa" value="" data-vaccine-date-display />
              <select name="felineTypes" class="vaccination-type-select">${felineTypeOptions()}</select>
              ${includeAddButton ? '<button type="button" class="vaccination-icon-button add-feline" title="Adicionar feline" aria-label="Adicionar feline">+</button>' : ''}
            </div>
          `;
        }

        function bindAntirabicRow(row) {
          bindDateField(row, {
            onComplete: () => {
              const box = row.closest("[data-antirabic-box]");
              refreshAntirabicDeleteButton(box);
              autosave(row.closest("form"));
            },
          });
          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) bindDelete(deleteButton);
        }

        function bindFelineRow(row) {
          const select = row.querySelector("select");
          const maybeSave = () => {
            const date = row.querySelector("[data-vaccine-date-value]")?.value;
            if (!isCompleteIsoDate(date) || !select?.value) return;
            const box = row.closest("[data-feline-box]");
            refreshFelineDeleteButton(box);
            autosave(row.closest("form"));
          };

          bindDateField(row, { onComplete: maybeSave });
          if (select) select.addEventListener("change", maybeSave);
          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) bindDelete(deleteButton);
        }

        function bindAddAntirabic(button) {
          if (!button) return;
          button.addEventListener("click", () => {
            const box = button.closest("[data-antirabic-box]");
            const currentLine = button.closest(".vaccination-history-line");
            button.remove();
            currentLine.insertAdjacentHTML("afterend", antirabicLineHtml(true));
            const newLine = currentLine.nextElementSibling;
            bindAntirabicRow(newLine);
            newLine.querySelector("[data-vaccine-date-display]")?.focus();
            refreshAntirabicDeleteButton(box);
          });
        }

        function bindAddFeline(button) {
          if (!button) return;
          button.addEventListener("click", () => {
            const box = button.closest("[data-feline-box]");
            const currentLine = button.closest(".vaccination-history-line");
            button.remove();
            currentLine.insertAdjacentHTML("afterend", felineLineHtml(true));
            const newLine = currentLine.nextElementSibling;
            bindFelineRow(newLine);
            newLine.querySelector("[data-vaccine-date-display]")?.focus();
            refreshFelineDeleteButton(box);
          });
        }

        document.querySelectorAll("[data-antirabic-row]").forEach(bindAntirabicRow);
        document.querySelectorAll("[data-feline-row]").forEach(bindFelineRow);
        document.querySelectorAll("[data-antirabic-box]").forEach(refreshAntirabicDeleteButton);
        document.querySelectorAll("[data-feline-box]").forEach(refreshFelineDeleteButton);

        const searchInput = document.getElementById("vaccinationSearch");
        const clearSearch = document.getElementById("clearVaccinationSearch");
        const rows = Array.from(document.querySelectorAll("[data-vaccination-row]"));

        function applySearch() {
          const query = normalizeSearch(searchInput?.value);
          let firstMatch = null;

          rows.forEach((row) => {
            const searchable = normalizeSearch(row.dataset.search);
            const matched = Boolean(query) && searchable.includes(query);
            row.classList.toggle("search-match", matched);
            if (matched && !firstMatch) firstMatch = row;
          });

          if (query && firstMatch) {
            firstMatch.scrollIntoView({ behavior: "smooth", block: "center" });
          }
        }

        searchInput?.addEventListener("input", applySearch);
        clearSearch?.addEventListener("click", () => {
          if (searchInput) searchInput.value = "";
          rows.forEach((row) => row.classList.remove("search-match"));
          searchInput?.focus();
        });

        document.querySelectorAll("[data-vaccination-sheet-wrap]").forEach((wrap) => {
          const shell = wrap.closest(".vaccination-sheet-shell");
          const scrollbars = Array.from(shell?.querySelectorAll("[data-vaccination-scrollbar]") || []);
          const table = wrap.querySelector(".vaccination-table");
          if (!scrollbars.length || !table) return;

          function refreshVaccinationScrollbar() {
            const scrollWidth = Math.max(table.scrollWidth, wrap.scrollWidth, wrap.clientWidth);
            scrollbars.forEach((scrollbar) => {
              const inner = scrollbar.querySelector("[data-vaccination-scrollbar-inner]");
              if (inner) inner.style.width = `${scrollWidth}px`;
              scrollbar.style.display = scrollWidth > wrap.clientWidth ? "block" : "none";
              scrollbar.scrollLeft = wrap.scrollLeft;
            });
          }

          let syncingFromTable = false;
          let syncingFromBar = false;

          wrap.addEventListener("scroll", () => {
            if (syncingFromBar) return;
            syncingFromTable = true;
            scrollbars.forEach((scrollbar) => {
              scrollbar.scrollLeft = wrap.scrollLeft;
            });
            syncingFromTable = false;
          });

          scrollbars.forEach((scrollbar) => {
            scrollbar.addEventListener("scroll", () => {
              if (syncingFromTable) return;
              syncingFromBar = true;
              wrap.scrollLeft = scrollbar.scrollLeft;
              scrollbars.forEach((other) => {
                if (other !== scrollbar) other.scrollLeft = scrollbar.scrollLeft;
              });
              syncingFromBar = false;
            });
          });

          requestAnimationFrame(refreshVaccinationScrollbar);
          window.addEventListener("resize", refreshVaccinationScrollbar);
          window.addEventListener("load", refreshVaccinationScrollbar);
          if ("ResizeObserver" in window) {
            const observer = new ResizeObserver(refreshVaccinationScrollbar);
            observer.observe(wrap);
            observer.observe(table);
          }
        });
      })();
    </script>
  </body>
</html>

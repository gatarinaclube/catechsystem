<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Pesagem - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <style>
      .weighing-grid {
        display: grid;
        grid-template-columns: 220px 180px 140px 340px 220px;
        gap: 10px;
        align-items: start;
      }
      .weighing-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .weighing-row {
        padding: 12px;
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        margin-bottom: 12px;
      }
      .mini-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .inline-plus {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .history-box {
        border-radius: 12px;
        background: rgba(148, 163, 184, 0.08);
        padding: 10px;
      }
      @media (max-width: 1300px) {
        .weighing-grid {
          grid-template-columns: 1fr;
        }
        .weighing-header {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Pesagem</h2>
            <div class="welcome-sub">Acompanhamento de pesagem dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% categories.forEach(function(category) { %>
          <section class="content-card" style="margin-bottom: 18px; border-left: 5px solid <%= category.color %>;">
            <div class="content-title"><%= category.label %></div>

            <div class="weighing-grid weighing-header" style="margin-top: 12px;">
              <div>Nome do Gato</div>
              <div>Mãe</div>
              <div>Data de Nascimento</div>
              <div>Peso</div>
              <div>Histórico</div>
            </div>

            <% if (!grouped[category.key] || !grouped[category.key].length) { %>
              <div class="empty" style="margin-top:12px;">Nenhum gato nesta categoria.</div>
            <% } else { %>
              <% grouped[category.key].forEach(function(row) { %>
                <form method="post" action="/admin/weighing/<%= row.cat.id %>" class="weighing-row">
                  <div class="weighing-grid">
                    <div>
                      <div class="item-title"><%= row.displayName %></div>
                    </div>

                    <div><strong><%= row.motherName %></strong></div>
                    <div><strong><%= row.birthDateLabel %></strong></div>

                    <div class="mini-stack" data-history-box>
                      <% row.history.forEach(function(item, idx) { %>
                        <div class="inline-plus">
                          <input type="date" name="historyDates" value="<%= item.date %>" />
                          <input
                            type="text"
                            name="historyWeights"
                            value="<%= item.weight || '' %>"
                            placeholder="0,000 kg"
                            style="width:110px;"
                          />
                          <% if (idx === row.history.length - 1) { %>
                            <button type="button" class="btn add-history">+</button>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>

                    <div class="mini-stack history-box">
                      <div>G/P: <strong><%= formatWeight(row.stats.gp) %></strong></div>
                      <div>G/P*: <strong><%= formatWeight(row.stats.gpStar) %></strong></div>
                      <button type="submit" class="btn btn-primary">Salvar</button>
                    </div>
                  </div>
                </form>
              <% }) %>
            <% } %>
          </section>
        <% }) %>
      </main>
    </div>

    <script>
      (function () {
        document.querySelectorAll(".add-history").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-history-box]");
            const row = button.parentElement.cloneNode(true);
            row.querySelectorAll("input").forEach((input) => {
              input.value = "";
            });
            row.querySelector("button").remove();
            box.appendChild(row);
          });
        });
      })();
    </script>
  </body>
</html>

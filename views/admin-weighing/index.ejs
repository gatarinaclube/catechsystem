<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Pesagem - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .weighing-grid {
        display: grid;
        grid-template-columns: 260px 140px 300px 260px 220px;
        gap: 10px;
        align-items: start;
      }
      .cat-subline {
        margin-top: 4px;
        font-size: 11px;
        line-height: 1.35;
        color: var(--text-muted);
      }
      .weighing-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .weighing-row {
        padding: 12px;
        border: 1px solid var(--border-soft);
        border-radius: 14px;
        margin-bottom: 12px;
      }
      .mini-stack {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .inline-plus {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      .history-date-display,
      .history-weight-display {
        padding: 8px 10px;
        border: 1px solid var(--border-soft);
        border-radius: 8px;
        background: #f8fafc;
        font-size: 13px;
      }
      .history-date-display {
        flex: 1 1 auto;
        min-width: 0;
      }
      .history-weight-display {
        flex: 0 0 110px;
      }
      .delete-history-date {
        min-width: 38px;
        padding-left: 0;
        padding-right: 0;
      }
      .history-box {
        border-radius: 12px;
        background: rgba(148, 163, 184, 0.08);
        padding: 10px;
      }
      .weighing-settings {
        border-radius: 12px;
        background: rgba(124, 58, 237, 0.07);
        padding: 10px;
      }
      .weighing-toggle {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-main);
        font-weight: 600;
      }
      .weighing-toggle input {
        width: auto;
      }
      .weighing-options {
        display: none;
        margin-top: 8px;
      }
      .weighing-options.is-visible {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .weighing-message {
        font-size: 12px;
        color: var(--text-muted);
        line-height: 1.35;
      }
      @media (max-width: 1300px) {
        .weighing-grid {
          grid-template-columns: 1fr;
        }
        .weighing-header {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Pesagem</h2>
            <div class="welcome-sub">Acompanhamento de pesagem dos gatos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% categories.forEach(function(category) { %>
          <% const items = grouped[category.key] || []; %>
          <details class="content-card module-panel module-accordion" style="border-left: 5px solid <%= category.color %>;">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= category.label %></span>
              </div>
              <span class="module-accordion-count"><%= items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <div class="weighing-grid weighing-header">
                <div>Nome do Gato</div>
                <div>Data de Nascimento</div>
                <div>Peso</div>
                <div>Controle</div>
                <div>Histórico</div>
              </div>

              <% if (!items.length) { %>
                <div class="empty" style="margin-top:12px;">Nenhum gato nesta categoria.</div>
              <% } else { %>
                <% items.forEach(function(row) { %>
                <form method="post" action="/admin/weighing/<%= row.cat.id %>" class="weighing-row">
                  <div class="weighing-grid">
                    <div>
                      <div class="item-title"><%= row.displayName %></div>
                      <div class="cat-subline">Mãe: <%= row.motherName %></div>
                    </div>

                    <div><strong><%= row.birthDateLabel %></strong></div>

                    <div class="mini-stack" data-history-box>
                      <% const historyRows = row.history && row.history.length ? row.history : [{ date: "", weight: "" }]; %>
                      <% historyRows.forEach(function(item) { %>
                        <div class="inline-plus" data-history-row>
                          <% if (item.date && item.weight) { %>
                            <input type="hidden" name="historyDates" value="<%= item.date %>" />
                            <input type="hidden" name="historyWeights" value="<%= item.weight || '' %>" />
                            <span class="history-date-display"><%= formatDate(item.date) %></span>
                            <span class="history-weight-display"><%= item.weight || '-' %></span>
                            <button type="button" class="btn delete-history-date" title="Remover pesagem" aria-label="Remover pesagem">&#128465;</button>
                          <% } else { %>
                            <input type="date" name="historyDates" value="<%= item.date %>" />
                            <input
                              type="text"
                              name="historyWeights"
                              value="<%= item.weight || '' %>"
                              placeholder="0,000 kg"
                              style="width:110px;"
                            />
                          <% } %>
                        </div>
                      <% }) %>
                      <div class="history-add-row">
                        <button type="button" class="btn add-history">+</button>
                      </div>
                    </div>

                    <div class="weighing-settings" data-weighing-settings>
                      <label class="weighing-toggle">
                        <input type="checkbox" name="shouldWeigh" data-should-weigh <%= row.shouldWeigh ? "checked" : "" %> />
                        Pesar
                      </label>
                      <div class="weighing-options <%= row.shouldWeigh ? 'is-visible' : '' %>" data-weighing-options>
                        <select name="weighingFrequency" data-weighing-frequency>
                          <option value="">Periodicidade</option>
                          <% weighingFrequencies.forEach(function(option) { %>
                            <option value="<%= option.value %>" <%= row.weighingFrequency === option.value ? "selected" : "" %>><%= option.label %></option>
                          <% }) %>
                        </select>
                        <select name="weighingPeriod" data-weighing-period>
                          <option value="">Período</option>
                          <% weighingPeriods.forEach(function(option) { %>
                            <option value="<%= option %>" <%= row.weighingPeriod === option ? "selected" : "" %>><%= option %></option>
                          <% }) %>
                        </select>
                        <div class="weighing-message" data-weighing-message></div>
                      </div>
                    </div>

                    <div class="mini-stack history-box">
                      <div>G/P: <strong><%= formatWeight(row.stats.gp) %></strong></div>
                      <div>G/P*: <strong><%= formatWeight(row.stats.gpStar) %></strong></div>
                    </div>
                  </div>
                </form>
                <% }) %>
              <% } %>
            </div>
          </details>
        <% }) %>
      </main>
    </div>

    <script>
      (function () {
        function formatDisplayDate(value) {
          if (!value) return "";
          const parts = value.split("-");
          if (parts.length !== 3) return value;
          return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        async function autosave(form) {
          if (!form) return;
          if (form.dataset.submitting === "true") {
            form.dataset.pendingSave = "true";
            return;
          }

          form.dataset.submitting = "true";
          form.dataset.pendingSave = "false";

          try {
            const response = await fetch(form.action, {
              method: "POST",
              body: new URLSearchParams(new FormData(form)),
              credentials: "same-origin",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
                "X-Autosave": "true",
              },
            });

            if (!response.ok) {
              throw new Error("Erro ao salvar pesagem");
            }
          } catch (error) {
            console.error(error);
          } finally {
            form.dataset.submitting = "false";
            if (form.dataset.pendingSave === "true") {
              autosave(form);
            }
          }
        }

        document.querySelectorAll(".add-history").forEach((button) => {
          button.addEventListener("click", () => {
            const box = button.closest("[data-history-box]");
            const row = document.createElement("div");
            row.className = "inline-plus";
            row.dataset.historyRow = "";
            row.innerHTML = '<input type="date" name="historyDates" value="" /><input type="text" name="historyWeights" value="" placeholder="0,000 kg" style="width:110px;" />';
            box.insertBefore(row, button.closest(".history-add-row"));
            bindHistoryRow(row);
          });
        });

        function bindDelete(button) {
          button.addEventListener("click", () => {
            const row = button.closest("[data-history-row]");
            const form = button.closest("form");
            row.remove();

            autosave(form);
          });
        }

        function bindHistoryRow(row) {
          const dateInput = row.querySelector('input[name="historyDates"][type="date"]');
          const weightInput = row.querySelector('input[name="historyWeights"][type="text"]');

          function maybeFreeze() {
            if (!dateInput?.value || !weightInput?.value) return;
            row.innerHTML = `
              <input type="hidden" name="historyDates" value="${dateInput.value}" />
              <input type="hidden" name="historyWeights" value="${weightInput.value}" />
              <span class="history-date-display">${formatDisplayDate(dateInput.value)}</span>
              <span class="history-weight-display">${weightInput.value}</span>
              <button type="button" class="btn delete-history-date" title="Remover pesagem" aria-label="Remover pesagem">&#128465;</button>
            `;
            bindDelete(row.querySelector(".delete-history-date"));
            autosave(row.closest("form"));
          }

          if (dateInput) dateInput.addEventListener("change", maybeFreeze);
          if (weightInput) weightInput.addEventListener("change", maybeFreeze);

          const deleteButton = row.querySelector(".delete-history-date");
          if (deleteButton) bindDelete(deleteButton);
        }

        function updateWeighingSettings(box) {
          const checkbox = box.querySelector("[data-should-weigh]");
          const options = box.querySelector("[data-weighing-options]");
          const frequency = box.querySelector("[data-weighing-frequency]");
          const period = box.querySelector("[data-weighing-period]");
          const message = box.querySelector("[data-weighing-message]");

          options.classList.toggle("is-visible", checkbox.checked);

          if (!checkbox.checked) {
            frequency.value = "";
            period.value = "";
            message.textContent = "";
            period.style.display = "none";
            return;
          }

          period.style.display = frequency.value === "ONCE_DAILY" ? "block" : "none";

          if (frequency.value === "ONCE_DAILY") {
            message.textContent = period.value
              ? `Pesar no período da ${period.value.toLowerCase()}.`
              : "Selecione o período para fazer a pesagem.";
          } else if (frequency.value === "TWICE_DAILY") {
            period.value = "";
            message.textContent = "Pesar de manhã e no fim do dia/noite.";
          } else if (frequency.value === "THREE_DAILY") {
            period.value = "";
            message.textContent = "Pesar de manhã cedo, início da tarde e fim da tarde ou noite.";
          } else {
            period.value = "";
            message.textContent = "";
          }
        }

        document.querySelectorAll("[data-weighing-settings]").forEach((box) => {
          const checkbox = box.querySelector("[data-should-weigh]");
          const frequency = box.querySelector("[data-weighing-frequency]");
          const period = box.querySelector("[data-weighing-period]");

          checkbox.addEventListener("change", () => {
            updateWeighingSettings(box);
            autosave(box.closest("form"));
          });
          frequency.addEventListener("change", () => {
            updateWeighingSettings(box);
            autosave(box.closest("form"));
          });
          period.addEventListener("change", () => {
            updateWeighingSettings(box);
            autosave(box.closest("form"));
          });
          updateWeighingSettings(box);
        });

        document.querySelectorAll("[data-history-row]").forEach(bindHistoryRow);
      })();
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Contas - Administrativo</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <link rel="stylesheet" href="/css/quick-finance.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Contas</h2>
            <div class="welcome-sub">Saldo, entradas, saídas e capital social.</div>
          </div>
          <div class="actions">
            <a href="/administrativo" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card message message-success">Conta atualizada.</div>
        <% } %>

        <% if (!accounts.length) { %>
          <div class="content-card empty">Nenhuma conta cadastrada em Despesas.</div>
        <% } else { %>
          <div class="account-grid">
            <% accounts.forEach(function(account, index) { %>
              <div class="account-card">
                <div class="account-head">
                  <div class="account-title">
                    <h3 class="content-title"><%= account.accountName %></h3>
                    <% if (account.capitalSocialEnabled) { %>
                      <div class="content-sub">Capital social: <%= account.capitalSocialLabel %></div>
                    <% } %>
                  </div>
                  <button
                    class="account-settings-button"
                    type="button"
                    title="Configurações"
                    data-target="account-settings-<%= index %>"
                  >⚙</button>
                </div>

                <div class="account-metrics">
                  <div class="account-metric is-balance">
                    <span>Saldo da conta</span>
                    <strong><%= account.balanceLabel %></strong>
                  </div>
                  <div class="account-metric is-income">
                    <span>Entradas no mês</span>
                    <strong><%= account.monthIncomeLabel %></strong>
                  </div>
                  <div class="account-metric is-expense">
                    <span>Saídas no mês</span>
                    <strong><%= account.monthExpenseLabel %></strong>
                  </div>
                </div>

                <div id="account-settings-<%= index %>" class="account-settings">
                  <form method="post" action="/administrativo/contas" class="account-form">
                    <input type="hidden" name="accountName" value="<%= account.accountName %>" />
                    <div class="field">
                      <label class="field-label">Saldo inicial</label>
                      <input class="money-input" name="initialBalance" inputmode="decimal" value="<%= account.initialBalance %>" />
                    </div>
                    <div class="field">
                      <label class="field-label">Capital social</label>
                      <div class="capital-row">
                        <label class="paid-toggle" title="Capital social">
                          <input
                            class="capital-toggle"
                            type="checkbox"
                            name="capitalSocialEnabled"
                            value="YES"
                            data-target="capital-extra-<%= index %>"
                            <%= account.capitalSocialEnabled ? 'checked' : '' %>
                          />
                          <span></span>
                        </label>
                        <input
                          id="capital-extra-<%= index %>"
                          class="money-input capital-extra <%= account.capitalSocialEnabled ? 'is-visible' : '' %>"
                          name="capitalSocial"
                          inputmode="decimal"
                          value="<%= account.capitalSocial %>"
                        />
                      </div>
                    </div>
                    <button class="btn btn-primary" type="submit">Salvar</button>
                  </form>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="content-card transfer-card">
            <div class="content-title">Transferência entre contas</div>
            <div class="content-sub">Registre movimentações internas sem criar receita ou despesa.</div>
            <form method="post" action="/administrativo/contas/transferencias" class="transfer-grid" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="fromAccount">Conta de saída</label>
                <select id="fromAccount" name="fromAccount" required>
                  <option value="">Selecione...</option>
                  <% accounts.forEach(function(account) { %>
                    <option value="<%= account.accountName %>"><%= account.accountName %></option>
                  <% }) %>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="toAccount">Conta de entrada</label>
                <select id="toAccount" name="toAccount" required>
                  <option value="">Selecione...</option>
                  <% accounts.forEach(function(account) { %>
                    <option value="<%= account.accountName %>"><%= account.accountName %></option>
                  <% }) %>
                </select>
              </div>
              <div class="field">
                <label class="field-label" for="transferAmount">Valor</label>
                <input id="transferAmount" class="money-input" name="transferAmount" inputmode="decimal" placeholder="0,00" required />
              </div>
              <div class="field">
                <label class="field-label" for="transferDate">Data</label>
                <input id="transferDate" name="transferDate" type="date" required />
              </div>
              <div class="field">
                <label class="field-label" for="transferNote">Observação</label>
                <input id="transferNote" name="transferNote" />
              </div>
              <button class="btn btn-primary" type="submit">Registrar transferência</button>
            </form>
            <details class="transfer-history">
              <summary>Ver Transferências realizadas</summary>
              <% if (!transfers.length) { %>
                <div class="empty">Nenhuma transferência registrada.</div>
              <% } else { %>
                <div class="transfer-list">
                  <% transfers.forEach(function(transfer) { %>
                    <div class="transfer-item">
                      <div class="transfer-item-head">
                        <div>
                          <div class="transfer-title">
                            <%= transfer.fromAccount %> → <%= transfer.toAccount %>
                          </div>
                          <div class="transfer-sub">
                            <%= transfer.transferDateLabel %>
                            <% if (transfer.note) { %>
                              · <%= transfer.note %>
                            <% } %>
                          </div>
                        </div>
                        <span class="status-pill is-blue"><%= transfer.amountLabel %></span>
                      </div>
                      <details>
                        <summary>Editar transferência</summary>
                        <form method="post" action="/administrativo/contas/transferencias/<%= transfer.id %>/update" class="transfer-edit-grid" style="margin-top:12px;">
                          <div class="field">
                            <label class="field-label">Saída</label>
                            <select name="fromAccount" required>
                              <% accounts.forEach(function(account) { %>
                                <option value="<%= account.accountName %>" <%= transfer.fromAccount === account.accountName ? 'selected' : '' %>><%= account.accountName %></option>
                              <% }) %>
                            </select>
                          </div>
                          <div class="field">
                            <label class="field-label">Entrada</label>
                            <select name="toAccount" required>
                              <% accounts.forEach(function(account) { %>
                                <option value="<%= account.accountName %>" <%= transfer.toAccount === account.accountName ? 'selected' : '' %>><%= account.accountName %></option>
                              <% }) %>
                            </select>
                          </div>
                          <div class="field">
                            <label class="field-label">Valor</label>
                            <input class="money-input" name="transferAmount" inputmode="decimal" value="<%= transfer.amount %>" required />
                          </div>
                          <div class="field">
                            <label class="field-label">Data</label>
                            <input name="transferDate" type="date" value="<%= transfer.transferDateInput %>" required />
                          </div>
                          <div class="field">
                            <label class="field-label">Observação</label>
                            <input name="transferNote" value="<%= transfer.note || '' %>" />
                          </div>
                          <div class="transfer-actions">
                            <button class="btn btn-primary" type="submit">Salvar</button>
                          </div>
                        </form>
                        <form method="post" action="/administrativo/contas/transferencias/<%= transfer.id %>/delete" onsubmit="return confirm('Excluir esta transferência?');" class="transfer-actions" style="margin-top:8px;">
                          <button class="btn" type="submit">Excluir transferência</button>
                        </form>
                      </details>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </details>
          </div>
        <% } %>
      </main>
    </div>
    <script>
      function formatMoneyInput(input) {
        const digits = String(input.value || "").replace(/\D/g, "");
        if (!digits) {
          input.value = "";
          return;
        }
        const cents = Number.parseInt(digits, 10);
        input.value = (cents / 100).toLocaleString("pt-BR", {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        });
      }

      document.querySelectorAll(".money-input").forEach((input) => {
        input.addEventListener("input", () => formatMoneyInput(input));
        input.addEventListener("blur", () => formatMoneyInput(input));
        formatMoneyInput(input);
      });

      document.querySelectorAll(".capital-toggle").forEach((toggle) => {
        const target = document.getElementById(toggle.dataset.target);
        function refresh() {
          target?.classList.toggle("is-visible", toggle.checked);
        }
        toggle.addEventListener("change", refresh);
        refresh();
      });

      document.querySelectorAll(".account-settings-button").forEach((button) => {
        button.addEventListener("click", () => {
          document.getElementById(button.dataset.target)?.classList.toggle("is-visible");
        });
      });
    </script>
  </body>
</html>

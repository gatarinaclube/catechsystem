<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Contas a Pagar - Administrativo</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .supplier-lookup-status {
        min-height: 18px;
        margin-top: 6px;
        font-size: 0.82rem;
      }

      .supplier-lookup-status.is-success {
        color: #047857;
      }

      .supplier-lookup-status.is-error {
        color: #b91c1c;
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Contas a Pagar</h2>
            <div class="welcome-sub">Agende contas fixas e variáveis antes de lançar a despesa paga.</div>
          </div>
          <div class="actions">
            <a href="/administrativo" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %><div class="content-card message message-success">Conta a pagar atualizada.</div><% } %>
        <% if (error) { %><div class="content-card message message-error"><%= error %></div><% } %>

        <div class="content-card">
          <div class="content-title">Nova conta</div>
          <form method="post" action="/administrativo/contas-a-pagar" class="supplier-form" style="margin-top:12px;">
            <%- include('./payables-form-fields', { payable: form || {}, suppliers, categories, paymentMethods, prefix: 'new' }) %>
            <div class="form-actions">
              <button class="btn btn-primary" type="submit">Cadastrar conta</button>
            </div>
          </form>
        </div>

        <div class="content-card module-list-card">
          <div class="history-section-head" style="margin-bottom:12px;">
            <div>
              <div class="content-title">Contas cadastradas</div>
              <div class="content-sub">Efetivar pagamento cria automaticamente o lançamento em Despesas.</div>
            </div>
            <span class="status-pill is-purple"><%= payables.length %></span>
          </div>

          <% if (!payables.length) { %>
            <div class="empty">Nenhuma conta a pagar cadastrada.</div>
          <% } else { %>
            <div class="record-list">
              <% payables.forEach(function(payable) { %>
                <details class="record-row supplier-row">
                  <summary class="supplier-summary">
                    <span>
                      <strong><%= payable.supplier %> · <%= payable.amountLabel %></strong>
                      <small>
                        <%= payable.category %> · Vencimento <%= payable.dueDateLabel %>
                        <% if (payable.isFixed) { %> · Fixa mensal<% } %>
                        <% if (payable.status === 'PAID') { %> · Pago em <%= payable.paidAtLabel %><% } %>
                      </small>
                    </span>
                    <span style="display:flex; align-items:center; gap:8px;">
                      <span class="status-pill <%= payable.status === 'PAID' ? 'is-green' : 'is-yellow' %>">
                        <%= payable.status === 'PAID' ? 'Pago' : 'Pendente' %>
                      </span>
                      <form method="post" action="/administrativo/contas-a-pagar/<%= payable.id %>/delete" onsubmit="event.stopPropagation(); return confirm('Excluir esta conta a pagar?');" onclick="event.stopPropagation();">
                        <button class="record-delete-button" type="submit" title="Excluir conta a pagar" aria-label="Excluir conta a pagar" onclick="event.stopPropagation();">🗑</button>
                      </form>
                    </span>
                  </summary>

                  <div class="supplier-edit">
                    <% if (payable.status === 'PENDING') { %>
                      <form method="post" action="/administrativo/contas-a-pagar/<%= payable.id %>/update" class="supplier-form">
                        <%- include('./payables-form-fields', { payable, suppliers, categories, paymentMethods, prefix: 'payable-' + payable.id }) %>
                        <% if (payable.recurringGroupId) { %>
                          <label class="checkbox-line">
                            <input type="checkbox" name="applyFuture" value="YES" />
                            Aplicar alterações nas próximas contas fixas ainda pendentes
                          </label>
                        <% } %>
                        <div class="form-actions">
                          <button class="btn btn-primary" type="submit">Salvar alterações</button>
                        </div>
                      </form>

                      <form method="post" action="/administrativo/contas-a-pagar/<%= payable.id %>/pagar" class="form-grid" style="margin-top:14px;">
                        <div class="field">
                          <label class="field-label">Data de pagamento</label>
                          <input name="paidAt" type="date" value="<%= payable.dueDateInput %>" required />
                        </div>
                        <div class="field">
                          <label class="field-label">Conta de pagamento</label>
                          <select name="paymentMethod" required>
                            <option value="">Selecione...</option>
                            <% paymentMethods.forEach(function(item) { %>
                              <option value="<%= item %>" <%= payable.paymentMethod === item ? 'selected' : '' %>><%= item %></option>
                            <% }) %>
                          </select>
                        </div>
                        <div class="form-actions">
                          <button class="btn btn-primary" type="submit">Efetivar pagamento</button>
                        </div>
                      </form>

                      <% if (payable.isFixed) { %>
                        <form method="post" action="/administrativo/contas-a-pagar/<%= payable.id %>/suspender-futuras" onsubmit="return confirm('Suspender as próximas contas fixas relacionadas a esta conta? As anteriores serão mantidas.');" class="supplier-delete">
                          <button class="btn" type="submit">Suspender futuras contas fixas</button>
                        </form>
                      <% } %>

                      <form method="post" action="/administrativo/contas-a-pagar/<%= payable.id %>/delete" onsubmit="return confirm('Excluir esta conta a pagar?');" class="supplier-delete">
                        <button class="btn btn-danger" type="submit">Excluir</button>
                      </form>
                    <% } else { %>
                      <div class="content-sub">Despesa lançada automaticamente. Código da despesa: <%= payable.expenseEntryId || '-' %>.</div>
                    <% } %>
                  </div>
                </details>
              <% }) %>
            </div>
          <% } %>
        </div>
      </main>
    </div>

    <script>
      const registeredSuppliers = <%- JSON.stringify((suppliers || []).map(function(supplier) {
        return {
          commercialName: supplier.commercialName || "",
          tradeName: supplier.tradeName || "",
          cnpj: supplier.cnpj || "",
          defaultCategory: supplier.defaultCategory || ""
        };
      })) %>;

      function onlyDigits(value) {
        return String(value || "").replace(/\D/g, "");
      }

      function formatCnpj(value) {
        const cnpj = onlyDigits(value);
        if (cnpj.length !== 14) return value || "";
        return `${cnpj.slice(0, 2)}.${cnpj.slice(2, 5)}.${cnpj.slice(5, 8)}/${cnpj.slice(8, 12)}-${cnpj.slice(12)}`;
      }

      function findSupplierByCnpj(cnpj) {
        const normalized = onlyDigits(cnpj);
        return registeredSuppliers.find((supplier) => onlyDigits(supplier.cnpj) === normalized);
      }

      function findSupplierByName(name) {
        const normalized = String(name || "").trim().toLowerCase();
        return registeredSuppliers.find((supplier) => (
          String(supplier.commercialName || "").trim().toLowerCase() === normalized
          || String(supplier.tradeName || "").trim().toLowerCase() === normalized
        ));
      }

      function setSupplierLookupStatus(form, message, type) {
        const status = form.querySelector("[data-supplier-lookup-status]");
        if (!status) return;
        status.textContent = message || "";
        status.classList.toggle("is-error", type === "error");
        status.classList.toggle("is-success", type === "success");
      }

      document.querySelectorAll(".supplier-form").forEach((form) => {
        const supplier = form.querySelector('[name="supplier"]');
        const category = form.querySelector('[name="category"]');
        let cnpjLookupTimer = null;
        let lastLookedUpCnpj = "";

        function refreshCategoryFromSupplier() {
          const selected = findSupplierByName(supplier.value);
          if (selected?.defaultCategory && category) {
            category.value = selected.defaultCategory;
          }
        }

        async function lookupSupplierByCnpj() {
          const typedSupplier = String(supplier.value || "").trim();
          const cnpj = onlyDigits(typedSupplier);
          if (cnpj.length !== 14 || /[A-Za-zÀ-ÿ]/.test(typedSupplier)) return;
          if (cnpj === lastLookedUpCnpj) return;
          lastLookedUpCnpj = cnpj;

          const registered = findSupplierByCnpj(cnpj);
          if (registered) {
            supplier.value = registered.commercialName;
            if (registered.defaultCategory && category) {
              category.value = registered.defaultCategory;
            }
            setSupplierLookupStatus(form, "Fornecedor cadastrado encontrado pelo CNPJ.", "success");
            return;
          }

          setSupplierLookupStatus(form, "Buscando dados do CNPJ...", "");
          try {
            const response = await fetch(`https://brasilapi.com.br/api/cnpj/v1/${cnpj}`);
            if (!response.ok) throw new Error("Consulta indisponível");
            const data = await response.json();
            const name = data.razao_social || data.nome_fantasia || "";
            supplier.value = name ? `${name} - CNPJ ${formatCnpj(cnpj)}` : `CNPJ ${formatCnpj(cnpj)}`;
            setSupplierLookupStatus(form, "Fornecedor identificado pelo CNPJ sem criar cadastro fixo.", "success");
          } catch {
            supplier.value = `CNPJ ${formatCnpj(cnpj)}`;
            setSupplierLookupStatus(form, "Não foi possível buscar a empresa. A conta será salva apenas com o CNPJ.", "error");
          }
        }

        supplier?.addEventListener("change", refreshCategoryFromSupplier);
        supplier?.addEventListener("blur", lookupSupplierByCnpj);
        supplier?.addEventListener("input", () => {
          refreshCategoryFromSupplier();
          const cnpj = onlyDigits(supplier.value);
          if (cnpj.length !== 14) {
            setSupplierLookupStatus(form, "", "");
            lastLookedUpCnpj = "";
            return;
          }
          window.clearTimeout(cnpjLookupTimer);
          cnpjLookupTimer = window.setTimeout(lookupSupplierByCnpj, 350);
        });
      });
    </script>
  </body>
</html>

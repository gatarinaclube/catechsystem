<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Escolher pagamento - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body class="auth-body">
    <div class="auth-card" style="max-width:720px;">
      <div class="auth-logo">CaTech System</div>
      <h1 class="auth-title">Escolha a contratação</h1>
      <div class="auth-subtitle">
        Plano <strong><%= plan.title %></strong>. Selecione como deseja efetuar o pagamento.
      </div>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <form method="post" action="/billing/pay" class="auth-form">
        <div style="display:grid; gap:10px;">
          <% billingOptions.forEach(function(option, index) { %>
            <label style="display:grid; grid-template-columns:22px 1fr; gap:10px; align-items:start; border:1px solid var(--border-soft); border-radius:10px; padding:12px; cursor:pointer;">
              <input type="radio" name="billingMode" value="<%= option.mode %>" <%= index === 0 ? 'checked' : '' %> />
              <span>
                <strong style="display:block;"><%= option.title %></strong>
                <span style="display:block; color:var(--accent-hover); font-weight:700; margin-top:2px;"><%= option.subtitle %></span>
                <span style="display:block; color:var(--text-muted); font-size:12px; margin-top:4px;"><%= option.detail %></span>
              </span>
            </label>
          <% }) %>
        </div>

        <button type="submit" class="auth-button">Ir para pagamento</button>
      </form>

      <div class="auth-footer">
        <a href="/dashboard">Voltar ao painel</a>
      </div>
    </div>
  </body>
</html>

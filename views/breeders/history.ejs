<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Histórico - <%= cat.name %> - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Histórico do Gato</h2>
            <div class="welcome-sub"><%= cat.displayName %></div>
          </div>
          <div class="actions">
            <a href="/breeders/<%= cat.id %>" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card">
          <div class="content-title">Linha do tempo do cadastro</div>
          <ul class="list" style="margin-top: 12px;">
            <% timeline.forEach(function(item) { %>
              <li class="item">
                <div>
                  <div class="item-title"><%= item.label %></div>
                  <div class="item-sub"><%= item.value %></div>
                </div>
              </li>
            <% }) %>
          </ul>
        </div>
      </main>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Reprodutores - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Reprodutores</h2>
            <div class="welcome-sub">
              Gerencie padreadores, matrizes, fundadores e novos reprodutores.
            </div>
          </div>
          <div class="actions">
            <a href="/breeders/new" class="btn btn-primary">+ Novo Padreador/Matriz</a>
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card" style="margin-bottom: 18px;">
          <form method="get" action="/breeders" style="display:flex; gap:10px; align-items:end; flex-wrap:wrap;">
            <input type="hidden" name="ownerId" id="breedersOwnerId" value="<%= selectedOwnerId || '' %>" />
            <div class="field" style="min-width:320px; flex:1;">
              <label class="field-label" for="breedersOwnerSearch">Filtrar por usuário</label>
              <input
                id="breedersOwnerSearch"
                list="breedersOwnersList"
                type="text"
                placeholder="Digite o nome do usuário"
                value="<%= selectedOwnerId ? ((users.find((u) => u.id === selectedOwnerId) || {}).name || '') : '' %>"
              />
              <datalist id="breedersOwnersList">
                <% users.forEach(function(item) { %>
                  <option value="<%= item.name %>" data-id="<%= item.id %>"><%= item.email %></option>
                <% }) %>
              </datalist>
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/breeders" class="btn">Limpar</a>
          </form>
        </div>

        <section class="content-card" style="margin-bottom: 18px; border-left: 5px solid #2563eb;">
          <div class="content-title">Padreadores</div>
          <% if (!groups.sires.length) { %>
            <div class="empty">Nenhum registro nesta categoria.</div>
          <% } else { %>
            <ul class="list">
              <% groups.sires.forEach(function(cat) { %>
                <li class="item">
                  <div>
                    <a class="item-link" href="/breeders/<%= cat.id %>"><%= cat.displayName %></a>
                    <div class="item-sub">Idade: <%= cat.ageLabel %></div>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>

        <section class="content-card" style="margin-bottom: 18px; border-left: 5px solid #db2777;">
          <div class="content-title">Matrizes</div>
          <% if (!groups.dams.length) { %>
            <div class="empty">Nenhum registro nesta categoria.</div>
          <% } else { %>
            <ul class="list">
              <% groups.dams.forEach(function(cat) { %>
                <li class="item">
                  <div>
                    <a class="item-link" href="/breeders/<%= cat.id %>"><%= cat.displayName %></a>
                    <div class="item-sub">Idade: <%= cat.ageLabel %></div>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>

        <section class="content-card" style="margin-bottom: 18px; border-left: 5px solid #6b7280;">
          <div class="content-title">Fundadores</div>
          <% if (!groups.founders.length) { %>
            <div class="empty">Nenhum registro nesta categoria.</div>
          <% } else { %>
            <ul class="list">
              <% groups.founders.forEach(function(cat) { %>
                <li class="item">
                  <div>
                    <a class="item-link" href="/breeders/<%= cat.id %>"><%= cat.displayName %></a>
                    <div class="item-sub">Idade: <%= cat.ageLabel %></div>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>

        <section class="content-card" style="border-left: 5px solid #16a34a;">
          <div class="content-title">Novos</div>
          <% if (!groups.new.length) { %>
            <div class="empty">Nenhum registro nesta categoria.</div>
          <% } else { %>
            <ul class="list">
              <% groups.new.forEach(function(cat) { %>
                <li class="item">
                  <div>
                    <a class="item-link" href="/breeders/<%= cat.id %>"><%= cat.displayName %></a>
                    <div class="item-sub">Idade: <%= cat.ageLabel %></div>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>
      </main>
    </div>
    <script>
      (function () {
        const searchInput = document.getElementById("breedersOwnerSearch");
        const hiddenInput = document.getElementById("breedersOwnerId");
        const users = <%- JSON.stringify(users) %>;

        function syncOwnerId() {
          const match = users.find((item) => item.name === searchInput.value);
          hiddenInput.value = match ? match.id : "";
        }

        searchInput.addEventListener("input", syncOwnerId);
        searchInput.addEventListener("change", syncOwnerId);
      })();
    </script>
  </body>
</html>

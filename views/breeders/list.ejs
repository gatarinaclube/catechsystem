<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Reprodutores - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Reprodutores</h2>
            <div class="welcome-sub">
              Gerencie padreadores, matrizes, fundadores e novos reprodutores.
            </div>
          </div>
          <div class="actions">
            <a href="/breeders/new" class="btn btn-primary">+ Novo Padreador/Matriz</a>
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card module-panel">
          <form method="get" action="/breeders" class="admin-filter-form">
            <input type="hidden" name="ownerId" id="breedersOwnerId" value="<%= selectedOwnerId || '' %>" />
            <div class="field" style="min-width:320px; flex:1;">
              <label class="field-label" for="breedersOwnerSearch">Filtrar por usuário</label>
              <input
                id="breedersOwnerSearch"
                list="breedersOwnersList"
                type="text"
                placeholder="Digite o nome do usuário"
                value="<%= selectedOwnerId ? ((users.find((u) => u.id === selectedOwnerId) || {}).name || '') : '' %>"
              />
              <datalist id="breedersOwnersList">
                <% users.forEach(function(item) { %>
                  <option value="<%= item.name %>" data-id="<%= item.id %>"><%= item.email %></option>
                <% }) %>
              </datalist>
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/breeders" class="btn">Limpar</a>
          </form>
        </div>

        <% const sections = [
          { key: 'sires', title: 'Padreadores', color: '#2563eb', items: groups.sires },
          { key: 'dams', title: 'Matrizes', color: '#db2777', items: groups.dams },
          { key: 'founders', title: 'Fundadores', color: '#6b7280', items: groups.founders },
          { key: 'new', title: 'Novos', color: '#16a34a', items: groups.new },
        ]; %>
        <% sections.forEach(function(section) { %>
          <details class="content-card module-panel module-list-card module-accordion" style="border-left: 5px solid <%= section.color %>;">
            <summary>
              <div class="module-accordion-summary">
                <span class="module-accordion-icon">⌄</span>
                <span class="module-accordion-title"><%= section.title %></span>
              </div>
              <span class="module-accordion-count"><%= section.items.length %></span>
            </summary>
            <div class="module-accordion-body">
              <% if (!section.items.length) { %>
                <div class="empty">Nenhum registro nesta categoria.</div>
              <% } else { %>
                <div class="record-list">
                  <% section.items.forEach(function(cat) { %>
                    <a class="record-row" href="/breeders/<%= cat.id %>" style="text-decoration:none; border-left:4px solid <%= section.color %>;">
                      <div class="record-main">
                        <div class="record-title"><%= cat.displayName %></div>
                        <div class="record-sub">Idade: <%= cat.ageLabel %></div>
                      </div>
                      <div class="record-meta">
                        <span class="status-pill" style="color:<%= section.color %>;"><%= section.title %></span>
                      </div>
                    </a>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </details>
        <% }) %>
      </main>
    </div>
    <script>
      (function () {
        const searchInput = document.getElementById("breedersOwnerSearch");
        const hiddenInput = document.getElementById("breedersOwnerId");
        const users = <%- JSON.stringify(users) %>;

        function syncOwnerId() {
          const match = users.find((item) => item.name === searchInput.value);
          hiddenInput.value = match ? match.id : "";
        }

        searchInput.addEventListener("input", syncOwnerId);
        searchInput.addEventListener("change", syncOwnerId);
      })();
    </script>
  </body>
</html>

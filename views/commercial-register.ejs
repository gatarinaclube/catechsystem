<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Teste grátis - CaTech System</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body class="public-site-body">
    <main class="commercial-register-page">
      <section class="commercial-register-card">
        <a class="commercial-back-link" href="/">← Voltar</a>
        <span class="public-eyebrow">Plano <%= plan.title %></span>
        <h1>Iniciar teste Premium por 7 dias</h1>
        <p>
          Seu acesso começa liberado como Premium. Após 7 dias, caso nenhum plano seja ativado,
          o login será bloqueado automaticamente.
        </p>

        <% if (typeof error !== "undefined" && error) { %>
          <div class="auth-error"><%= error %></div>
        <% } %>

        <form method="post" action="/planos/<%= plan.slug %>/cadastro" class="commercial-register-form">
          <div class="field">
            <label class="field-label" for="name">Nome completo</label>
            <input id="name" name="name" type="text" required />
          </div>

          <div class="grid-3">
            <div class="field">
              <label class="field-label" for="email">E-mail</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div class="field">
              <label class="field-label" for="phones">Telefone</label>
              <input id="phones" name="phones" type="text" />
            </div>
            <div class="field">
              <label class="field-label" for="cpf">CPF/CNPJ</label>
              <input id="cpf" name="cpf" type="text" required />
            </div>
          </div>

          <div class="grid-2">
            <div class="field">
              <label class="field-label" for="password">Senha</label>
              <input id="password" name="password" type="password" minlength="6" required />
            </div>
            <div class="field">
              <label class="field-label" for="confirmPassword">Confirmar senha</label>
              <input id="confirmPassword" name="confirmPassword" type="password" minlength="6" required />
            </div>
          </div>

          <button class="auth-button" type="submit">Começar teste gratuito</button>
        </form>

        <div class="auth-footer">
          Já possui acesso? <a href="/login">Entrar</a>
        </div>

        <div style="margin-top:22px; padding-top:18px; border-top:1px solid var(--border-soft);">
          <h2 style="margin:0; font-size:18px;">Já tenho cadastro</h2>
          <p style="font-size:13px; color:var(--text-muted); line-height:1.5;">
            Use esta opção se você já se cadastrou como associado, está aguardando aprovação
            ou possui restrição, mas deseja contratar apenas o sistema. Este caminho não libera
            novo teste gratuito.
          </p>

          <form method="post" action="/planos/<%= plan.slug %>/comprar" class="commercial-register-form">
            <div style="display:grid; gap:8px;">
              <% billingOptions.forEach(function(option, index) { %>
                <label style="display:grid; grid-template-columns:22px 1fr; gap:10px; align-items:start; border:1px solid var(--border-soft); border-radius:10px; padding:10px; cursor:pointer;">
                  <input type="radio" name="billingMode" value="<%= option.mode %>" <%= index === 0 ? 'checked' : '' %> />
                  <span>
                    <strong style="display:block;"><%= option.title %></strong>
                    <span style="display:block; color:var(--accent-hover); font-weight:700; margin-top:2px;"><%= option.subtitle %></span>
                    <span style="display:block; color:var(--text-muted); font-size:12px; margin-top:4px;"><%= option.detail %></span>
                  </span>
                </label>
              <% }) %>
            </div>

            <div class="grid-2">
              <div class="field">
                <label class="field-label" for="existingEmail">E-mail já cadastrado</label>
                <input id="existingEmail" name="existingEmail" type="email" required />
              </div>
              <div class="field">
                <label class="field-label" for="existingPassword">Senha</label>
                <input id="existingPassword" name="existingPassword" type="password" required />
              </div>
            </div>
            <div class="grid-2">
              <div class="field">
                <label class="field-label" for="existingCpf">CPF/CNPJ</label>
                <input id="existingCpf" name="existingCpf" type="text" />
                <small style="font-size:11px; color:var(--text-muted);">
                  Obrigatório se ainda não estiver preenchido no cadastro.
                </small>
              </div>
              <div class="field">
                <label class="field-label" for="existingPhones">Telefone</label>
                <input id="existingPhones" name="existingPhones" type="text" />
              </div>
            </div>
            <button class="btn btn-primary" type="submit">Contratar este plano</button>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>

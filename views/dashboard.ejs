<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Dashboard - PetGus</title>

    <!-- CSS GLOBAL -->
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
  <div class="shell">
    <%- include('partials/sidebar', { user, currentPath }) %>

    <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">
              Olá,
              <%= user && user.name ? user.name.split(" ")[0] : "criador" %> 👋
            </h2>
            <div class="welcome-sub">
              Use o menu ao lado para acessar seus gatos e outros
              recursos do PetGus.
            </div>
          </div>
          <div class="actions">
            <% if (access && access.isAdmin) { %>
              <a href="/users" class="btn-primary btn">Usuários</a>
              <a href="/admin/financeiro" class="btn">Financeiro</a>
            <% } else { %>
              <a href="/cats/new" class="btn-primary btn">+ Novo gato</a>
              <a href="/cats" class="btn">Ver meus gatos</a>
            <% } %>
          </div>
        </div>

<% if (typeof billingReminder !== "undefined" && billingReminder) { %>
  <div class="content-card" style="border-left:4px solid #f26a1b; margin-bottom:20px; background:linear-gradient(135deg,#fff7ed 0%,#ffffff 80%);">
    <div class="content-title"><%= billingReminder.title %></div>
    <div class="content-sub">
      <%= billingReminder.message %>
      Vencimento em <strong><%= billingReminder.endDate.toLocaleDateString('pt-BR') %></strong>.
    </div>
    <div style="margin-top:10px;">
      <a href="<%= billingReminder.actionUrl || '/billing/pay' %>" class="btn btn-primary"><%= billingReminder.actionLabel || 'Renovar / pagar plano' %></a>
    </div>
  </div>
<% } %>

<% if (user && user.accountOrigin === "NON_ASSOCIATE" && user.subscriptionStatus !== "ACTIVE") { %>
  <div class="content-card" style="border-left:4px solid #d97706; margin-bottom:20px;">
    <div class="content-title">Plano em período de teste</div>
    <div class="content-sub">
      <% if (user.trialEndsAt) { %>
        <%
          const trialEndDate = new Date(user.trialEndsAt);
          const today = new Date();
          trialEndDate.setHours(23, 59, 59, 999);
          today.setHours(0, 0, 0, 0);
          const trialDaysLeft = Math.ceil((trialEndDate - today) / (1000 * 60 * 60 * 24));
        %>
        Seu teste gratuito vai até <strong><%= trialEndDate.toLocaleDateString('pt-BR') %></strong>.
        <% if (trialDaysLeft > 1) { %>
          Faltam <strong><%= trialDaysLeft %> dias</strong> para finalizar o teste gratuito.
        <% } else if (trialDaysLeft === 1) { %>
          Falta <strong>1 dia</strong> para finalizar o teste gratuito.
        <% } else if (trialDaysLeft === 0) { %>
          Seu teste gratuito finaliza hoje.
        <% } else { %>
          Seu teste gratuito já venceu. Ative um plano para manter o acesso.
        <% } %>
      <% } else { %>
        Seu acesso está em período de teste.
      <% } %>
      Após esse período, o acesso depende da ativação de um plano.
    </div>
    <div style="margin-top:10px;">
      <a href="/billing/pay" class="btn btn-primary">Comprar / ativar plano</a>
    </div>
  </div>
<% } %>

<% if (access && access.isAdmin && usersPendingApprovalCount > 0) { %>
  <div class="content-card" style="border-left: 4px solid #dc2626; margin-bottom: 20px;">
    <div class="content-title">👤 Novos cadastros</div>
    <div class="content-sub">
      Existem
      <strong><%= usersPendingApprovalCount %></strong>
      usuário(s) aguardando análise de cadastro.
    </div>
    <div style="margin-top:10px;">
      <a href="/users" class="btn btn-danger">
        Analisar cadastros →
      </a>
    </div>
  </div>
<% } %>

<%
  const dashboardRole = access && access.role ? String(access.role).toUpperCase() : "";
  const showUpgradeNotice = ["BASIC", "MASTER"].includes(dashboardRole);
%>
<% if (showUpgradeNotice) { %>
  <div class="content-card" style="border-left:4px solid #f26a1b; margin-bottom:20px; background:linear-gradient(135deg,#fff7ed 0%,#ffffff 78%);">
    <div class="content-title">Upgrade de plano</div>
    <div class="content-sub">
      <% if (dashboardRole === "BASIC") { %>
        Desbloqueie CRM, relatórios, administrativo financeiro e mais recursos para profissionalizar a gestão do gatil.
      <% } else { %>
        Libere o Premium para ter acesso completo, relatórios avançados, financeiro completo e maior capacidade de uso.
      <% } %>
    </div>
    <div style="margin-top:10px;">
      <a href="/billing/pay" class="btn btn-primary">Ver opções de upgrade</a>
    </div>
  </div>
<% } %>

<% if (typeof onboarding !== "undefined" && onboarding && !onboarding.complete) { %>
  <div class="content-card" style="margin-bottom:20px; border-left:4px solid #0ea5e9; background:linear-gradient(135deg,#f0f9ff 0%,#ffffff 76%);">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:14px; flex-wrap:wrap;">
      <div>
        <div class="content-title">Primeiros passos no PetGus</div>
        <div class="content-sub">
          Complete a configuração inicial para transformar o sistema na rotina real do seu gatil.
        </div>
      </div>
      <div class="status-pill is-blue"><%= onboarding.completedCount %>/<%= onboarding.total %> concluídos</div>
    </div>
    <div style="height:8px; overflow:hidden; border-radius:999px; background:#dbeafe; margin:14px 0 16px;">
      <div style="width:<%= onboarding.percent %>%; height:100%; background:linear-gradient(90deg,#0ea5e9,#f26a1b);"></div>
    </div>
    <div class="quick-grid">
      <% onboarding.steps.forEach(function(step) { %>
        <div class="quick-card" style="<%= step.done ? 'border-color:#bbf7d0; background:#f0fdf4;' : '' %>">
          <div class="quick-label"><%= step.done ? 'Concluído' : `Passo ${step.number}` %></div>
          <div class="quick-value"><%= step.title %></div>
          <div class="content-sub" style="font-size:12px; margin-top:5px;"><%= step.description %></div>
          <div class="quick-link" style="margin-top:10px;">
            <a href="<%= step.href %>"><%= step.done ? 'Revisar' : 'Fazer agora' %> →</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>


<% if (access && access.isAdmin && servicesPendingFFBCount > 0) { %>
  <div class="content-card" style="border-left: 4px solid #2563eb; margin-bottom: 20px;">
    <div class="content-title">📄 Serviços FFB</div>
    <div class="content-sub">
      Existem
      <strong><%= servicesPendingFFBCount %></strong>
      serviço(s) enviados para a Gatarina aguardando conferência.
    </div>
    <div style="margin-top:10px;">
      <a href="/ffb-services" class="btn btn-primary">
        Ver serviços →
      </a>
    </div>
  </div>
<% } %>

<% if (access && access.isAdmin && typeof adminOverview !== "undefined" && adminOverview) { %>
  <section class="content-card" style="margin-bottom:20px;">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:14px; flex-wrap:wrap;">
      <div>
        <div class="content-title title-with-help">
          Visão geral do sistema
          <button class="help-info-button" type="button" data-help-title="Visão geral do sistema" data-help-text="Mostra indicadores globais para o administrador acompanhar usuários, perfis, gatos cadastrados e sessões ativas recentes antes de realizar atualizações.">i</button>
        </div>
        <div class="content-sub">Resumo administrativo consolidado de todos os usuários.</div>
      </div>
      <a href="/users" class="btn">Gerenciar usuários</a>
    </div>

    <div class="metric-grid" style="margin-top:14px;">
      <div class="metric-card is-blue">
        <div class="metric-label">Usuários</div>
        <div class="metric-value"><%= adminOverview.totals.users %></div>
        <div class="metric-note">Ativos: <%= adminOverview.approval.active %> · Pendentes: <%= adminOverview.approval.pending %></div>
      </div>
      <div class="metric-card is-green">
        <div class="metric-label">Gatos cadastrados</div>
        <div class="metric-value"><%= adminOverview.totals.cats %></div>
        <div class="metric-note">Considerando todos os usuários</div>
      </div>
      <div class="metric-card is-purple">
        <div class="metric-label">Ninhadas</div>
        <div class="metric-value"><%= adminOverview.totals.litters %></div>
        <div class="metric-note">Total registrado no sistema</div>
      </div>
      <div class="metric-card is-yellow">
        <div class="metric-label">Filhotes</div>
        <div class="metric-value"><%= adminOverview.totals.kittens %></div>
        <div class="metric-note">Filhotes vinculados a ninhadas/listas</div>
      </div>
    </div>
  </section>

  <div class="metric-grid" style="margin-bottom:20px;">
    <section class="content-card">
      <div class="content-title">Usuários por perfil</div>
      <div class="content-sub">Distribuição atual dos perfis cadastrados.</div>
      <div class="record-list" style="margin-top:12px;">
        <% adminOverview.usersByRole.forEach(function(row) { %>
          <div class="record-row">
            <div class="record-main">
              <strong><%= row.label %></strong>
            </div>
            <span class="status-pill"><%= row.count %></span>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="content-card">
      <div class="content-title">Usuários logados (<%= adminOverview.activeUsers.length %>)</div>
      <div class="content-sub">
        Ativos nos últimos <%= adminOverview.activeWindowMinutes %> minutos. Ideal para conferir antes de atualizar o sistema.
      </div>
      <% if (adminOverview.activeUsers.length) { %>
        <div class="record-list" style="margin-top:12px;">
          <% adminOverview.activeUsers.forEach(function(activeUser) { %>
            <div class="record-row">
              <div class="record-main">
                <strong><%= activeUser.name %></strong>
                <div class="content-sub" style="font-size:12px; margin:2px 0 0;">
                  <%= activeUser.roleLabel %>
                  <% if (activeUser.viewingAsLabel) { %>
                    · visualizando <%= activeUser.viewingAsLabel %>
                  <% } %>
                </div>
              </div>
              <span class="status-pill is-green"><%= activeUser.lastSeenLabel %></span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty" style="margin-top:12px;">Nenhum usuário ativo recentemente.</div>
      <% } %>
    </section>
  </div>
<% } %>

<% if (access && !access.isAdmin && pendingServicesCount > 0) { %>
  <div class="content-card" style="border-left: 4px solid #f59e0b; margin-bottom: 20px;">
    <div class="content-title" style="display:flex; align-items:center; gap:8px;">
      ⚠️ Serviço com pendência
    </div>

    <div class="content-sub" style="margin-top:6px;">
      Você possui <strong><%= pendingServicesCount %></strong> serviço(s) com pendência.
    </div>

    <div style="margin-top:10px; display:flex; flex-direction:column; gap:10px;">
      <% pendingServices.forEach(function(s) { 
        const st = s.statuses?.[0];
      %>
        <div style="padding:10px; border:1px solid #eee; border-radius:10px;">
          <div style="font-size:13px;">
            <strong><%= s.type %></strong>
          </div>

          <div style="font-size:12px; color:#666; margin-top:4px;">
            Mensagem do administrador:
          </div>

          <div style="font-size:12px; margin-top:4px; white-space:pre-wrap;">
            <%= (st && st.pendingNote) ? st.pendingNote : "Sem mensagem." %>
          </div>

          <div style="margin-top:8px;">
            <a href="/my-services/<%= s.id %>" class="btn btn-warning">Ver serviço →</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>


        <% if (administrativePanel && !(access && access.isAdmin)) { %>
          <details class="content-card dashboard-panel" style="margin-bottom:20px;">
            <summary class="dashboard-panel-summary">
              <div>
                <div class="content-title title-with-help">
                  Painel Administrativo
                  <button class="help-info-button" type="button" data-help-title="Painel Administrativo" data-help-text="Resume receitas do mês, despesas do mês e contas próximas a receber ou pagar. Use para acompanhar rapidamente a parte financeira do gatil.">i</button>
                </div>
                <div class="content-sub">Indicadores financeiros principais do mês e próximos vencimentos.</div>
              </div>
              <span class="dashboard-panel-icon">+</span>
            </summary>
            <div class="dashboard-panel-body">
            <div class="metric-grid">
              <a class="metric-card is-blue" href="<%= access && access.canAccessRevenues ? '/receitas/lista' : '#' %>" style="text-decoration:none;">
                <div class="metric-label">Receitas do mês</div>
                <div class="metric-value" style="font-size:20px;"><%= administrativePanel.finance.incomeLabel %></div>
                <div class="metric-note">Saldo: <%= administrativePanel.finance.balanceLabel %></div>
              </a>
              <a class="metric-card is-red" href="<%= access && access.canAccessQuickLaunch ? '/despesas/lista' : '#' %>" style="text-decoration:none;">
                <div class="metric-label">Despesas do mês</div>
                <div class="metric-value" style="font-size:20px;"><%= administrativePanel.finance.expenseLabel %></div>
                <div class="metric-note">Lançamentos de despesas</div>
              </a>
              <a class="metric-card is-yellow" href="<%= access && access.canAccessRevenues ? '/administrativo/contas-a-receber' : '#' %>" style="text-decoration:none;">
                <div class="metric-label">Contas a receber</div>
                <div class="metric-value" style="font-size:20px;"><%= administrativePanel.finance.nextReceivableLabel %></div>
                <div class="metric-note">Próximos 15 dias: <%= administrativePanel.finance.nextReceivableCount %></div>
              </a>
              <a class="metric-card is-purple" href="<%= access && access.canAccessAdministrative ? '/administrativo/contas-a-pagar' : '#' %>" style="text-decoration:none;">
                <div class="metric-label">Contas a pagar</div>
                <div class="metric-value" style="font-size:20px;"><%= administrativePanel.finance.nextPayableLabel %></div>
                <div class="metric-note">Próximos 15 dias: <%= administrativePanel.finance.nextPayableCount %></div>
              </a>
            </div>

            <div class="dashboard-finance-lists">
              <section class="dashboard-finance-list">
                <div class="content-title" style="font-size:15px;">A receber nos próximos 15 dias</div>
                <% if (administrativePanel.finance.nextReceivableItems.length) { %>
                  <div class="record-list">
                    <% administrativePanel.finance.nextReceivableItems.forEach(function(item) { %>
                      <a class="record-row" href="<%= access && access.canAccessRevenues ? item.href : '#' %>" style="text-decoration:none; color:inherit;">
                        <div class="record-main">
                          <strong><%= item.dateLabel %> · <%= item.title %></strong>
                          <small><%= [item.client, item.parcelLabel].filter(Boolean).join(' · ') %></small>
                        </div>
                        <span class="status-pill is-green"><%= item.amountLabel %></span>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="content-sub">Nenhuma conta a receber nos próximos 15 dias.</div>
                <% } %>
              </section>

              <section class="dashboard-finance-list">
                <div class="content-title" style="font-size:15px;">A pagar nos próximos 15 dias</div>
                <% if (administrativePanel.finance.nextPayableItems.length) { %>
                  <div class="record-list">
                    <% administrativePanel.finance.nextPayableItems.forEach(function(item) { %>
                      <a class="record-row" href="<%= access && access.canAccessAdministrative ? item.href : '#' %>" style="text-decoration:none; color:inherit;">
                        <div class="record-main">
                          <strong><%= item.dateLabel %> · <%= item.title %></strong>
                          <small><%= item.sub || 'Conta a pagar' %></small>
                        </div>
                        <span class="status-pill is-red"><%= item.amountLabel %></span>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="content-sub">Nenhuma conta a pagar nos próximos 15 dias.</div>
                <% } %>
              </section>
            </div>
            </div>
          </details>
        <% } %>

        <% if (operationalPanel && !(access && access.isAdmin)) { %>
          <details class="content-card dashboard-panel" style="margin-bottom:20px;">
            <summary class="dashboard-panel-summary">
              <div>
                <div class="content-title title-with-help">
                  Painel Operacional
                  <button class="help-info-button" type="button" data-help-title="Painel Operacional" data-help-text="Mostra informações práticas da rotina do gatil, como filhotes disponíveis, gatas prontas para acasalar, vacinas vencidas e gatos em tratamento.">i</button>
                </div>
                <div class="content-sub">Resumo rápido para acompanhar rotina, reprodução e saúde do gatil.</div>
              </div>
              <span class="dashboard-panel-icon">+</span>
            </summary>
            <div class="metric-grid dashboard-panel-body">
              <a class="metric-card is-green" href="<%= access && access.canAccessKittensAdmin ? '/admin/kittens' : '#' %>" style="text-decoration:none;">
                <div class="metric-label">Filhotes disponíveis</div>
                <div class="metric-value"><%= operationalPanel.kittens.available %></div>
                <div class="metric-note">Reservados: <%= operationalPanel.kittens.reserved %></div>
              </a>
              <a class="metric-card is-purple" href="<%= access && access.canAccessMatingsAdmin ? '/admin/matings' : '#' %>" style="text-decoration:none;">
                <div class="metric-label">Gatas para acasalar</div>
                <div class="metric-value"><%= operationalPanel.matings.ready %></div>
                <div class="metric-note">Pausa: <%= operationalPanel.matings.pause %></div>
              </a>
              <a class="metric-card is-red" href="<%= access && access.canAccessVaccinationsAdmin ? '/admin/vaccinations' : '#' %>" style="text-decoration:none;">
                <div class="metric-label">Gatos com vacinas vencidas</div>
                <div class="metric-value"><%= operationalPanel.routines.overdueVaccinesCount %></div>
                <div class="metric-note">Vacinas com data vencida</div>
              </a>
              <a class="metric-card is-yellow" href="<%= access && access.canAccessTreatmentsAdmin ? '/admin/treatments' : '#' %>" style="text-decoration:none;">
                <div class="metric-label">Gatos em tratamento</div>
                <div class="metric-value"><%= operationalPanel.routines.activeTreatmentCount %></div>
                <div class="metric-note">Tratamentos ativos</div>
              </a>
            </div>
          </details>
        <% } %>



        <% if (!(access && access.isAdmin)) { %>
        <div class="content-card">
          <div class="content-title title-with-help">
            Atalhos rápidos
            <button class="help-info-button" type="button" data-help-title="Atalhos rápidos" data-help-text="Reúne caminhos curtos para ações usadas com frequência, como acessar a lista de gatos ou cadastrar um novo animal.">i</button>
          </div>
          <div class="content-sub">
            Gerêncie seus gatos nos atalhos abaixo.
          </div>

          <div class="quick-grid">
            <div class="quick-card">
              <div class="quick-label">Principal</div>
              <div class="quick-value">Meus gatos</div>
              <div class="quick-link">
                <a href="/cats">Acessar lista de gatos →</a>
              </div>
            </div>

            <div class="quick-card">
              <div class="quick-label">Cadastro</div>
              <div class="quick-value">Adicionar novo gato</div>
              <div class="quick-link">
                <a href="/cats/new">Ir para cadastro →</a>
              </div>
            </div>

            <% if (access && access.canAccessFfbServices) { %>
              <div class="quick-card">
                <div class="quick-label">Admin</div>
                <div class="quick-value">Serviços FFB</div>
                <div class="quick-link">
                  <a href="/ffb-services">Ver registros de ninhada →</a>
                </div>
              </div>
            <% } %>
          </div>
        </div>

<% } %>

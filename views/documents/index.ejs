<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Documentos - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Documentos</h2>
            <div class="welcome-sub">Contratos, atestados e manuais salvos por usuário.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card" style="border-left:4px solid #16a34a; margin-bottom:18px;">
            <div class="content-sub">Operação realizada com sucesso.</div>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="content-card" style="border-left:4px solid #b91c1c; margin-bottom:18px;">
            <div class="content-sub"><%= error %></div>
          </div>
        <% } %>

        <div class="grid-3" style="margin-bottom:18px;">
          <% Object.entries(documentTypes).forEach(function(entry) { const type = entry[0]; const config = entry[1]; %>
            <section class="content-card">
              <div class="content-title"><%= config.label %></div>
              <div class="content-sub" style="margin:8px 0 14px;">
                <% if (type === 'SALE_CONTRACT') { %>
                  Texto editável, comprador, gato e PDF.
                <% } else if (type === 'HEALTH_CERTIFICATE') { %>
                  Cabeçalho veterinário, data, gato e PDF.
                <% } else { %>
                  Manual com texto, anexos e envio por e-mail.
                <% } %>
                <br />
                <%= (grouped[type] || []).length %> documento(s) salvo(s).
              </div>
              <a class="btn btn-primary" href="/documentos/tipo/<%= config.route %>">Acessar</a>
            </section>
          <% }) %>
          <section class="content-card">
            <div class="content-title">Assinatura Eletrônica</div>
            <div class="content-sub" style="margin:8px 0 14px;">
              Envio de contratos do sistema, contratos externos ou outros PDFs para assinatura.
            </div>
            <a class="btn btn-primary" href="/documentos/assinaturas">Acessar</a>
          </section>
        </div>

        <section class="content-card" style="margin-bottom:18px;">
          <div class="history-section-head" style="align-items:flex-start; gap:16px; margin-bottom:14px;">
            <div>
              <div class="content-title">Reduzir tamanho de PDF</div>
              <div class="content-sub">
                Ferramenta rápida para diminuir PDFs antes de anexar no sistema. O arquivo não fica salvo.
              </div>
            </div>
            <div class="badge-soft" style="text-align:right;">
              <strong><%= compressionStats.used %></strong>
              <% if (compressionStats.isUnlimited) { %>
                usado(s) neste mês · Ilimitado
              <% } else { %>
                de <%= compressionStats.limit %> arquivo(s) no mês
              <% } %>
            </div>
          </div>

          <div class="grid-2" style="align-items:start;">
            <form method="post" action="/documentos/pdf/reduzir" enctype="multipart/form-data" class="form-grid" style="gap:14px;">
              <label>
                Arquivo PDF
                <input type="file" name="pdfFile" accept="application/pdf,.pdf" required <%= compressionStats.canUse ? '' : 'disabled' %> />
              </label>
              <label>
                Tamanho desejado em KB
                <input type="number" name="targetKb" min="10" step="1" placeholder="Ex.: 500" required <%= compressionStats.canUse ? '' : 'disabled' %> />
              </label>
              <div class="actions" style="grid-column:1 / -1;">
                <button class="btn btn-primary" type="submit" <%= compressionStats.canUse ? '' : 'disabled' %>>Baixar PDF reduzido</button>
              </div>
            </form>

            <div class="content-sub" style="background:#f8fafc; border:1px solid #e5e7eb; border-radius:8px; padding:14px;">
              <strong>Limite do seu perfil:</strong> <%= compressionStats.limitLabel %>.<br />
              <% if (!compressionStats.isUnlimited) { %>
                Você ainda pode reduzir <strong><%= compressionStats.remaining %></strong> arquivo(s) neste mês.
              <% } else { %>
                Seu perfil não possui limite mensal para esta ferramenta.
              <% } %>
              <br /><br />
              A redução é feita sem armazenar o arquivo. Em PDFs com imagens já muito compactadas, o tamanho final pode ficar acima do KB desejado.
            </div>
          </div>
        </section>

      </main>
    </div>
  </body>
</html>

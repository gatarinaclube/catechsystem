<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Assinatura Eletrônica - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Assinatura Eletrônica</h2>
            <div class="welcome-sub">Envie contratos do sistema, contratos externos ou outros PDFs para assinatura.</div>
          </div>
          <div class="actions">
            <a href="/documentos" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card" style="border-left:4px solid #16a34a; margin-bottom:18px;">
            <div class="content-sub">Link de assinatura criado com sucesso.</div>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="content-card" style="border-left:4px solid #b91c1c; margin-bottom:18px;">
            <div class="content-sub"><%= error %></div>
          </div>
        <% } %>

        <section class="content-card" style="margin-bottom:18px;">
          <div class="history-section-head" style="margin-bottom:12px;">
            <div>
              <div class="content-title">Novo envio para assinatura</div>
              <div class="content-sub">Selecione a origem do documento e os dados do assinante.</div>
            </div>
            <span class="status-pill <%= smtpSettings.isComplete ? 'is-green' : 'is-yellow' %>">
              <%= smtpSettings.isComplete ? 'SMTP configurado' : 'SMTP pendente' %>
            </span>
          </div>

          <% if (!smtpSettings.isComplete) { %>
            <div class="section-note" style="margin-bottom:12px;">
              Configure o SMTP em <a href="/settings">Configurações</a> para envio por e-mail e OTP. O link ainda poderá ser gerado para envio manual.
            </div>
          <% } %>

          <form method="post" action="/documentos/assinaturas/criar" enctype="multipart/form-data" id="signatureCreateForm">
            <div class="grid-2">
              <div class="field">
                <label class="field-label" for="documentKind">Tipo</label>
                <select id="documentKind" name="documentKind">
                  <option value="CONTRACT">Contrato</option>
                  <option value="OTHER">Outro Documento</option>
                </select>
              </div>
              <div class="field" id="contractSourceField">
                <label class="field-label" for="contractSource">Contrato</label>
                <select id="contractSource" name="contractSource">
                  <option value="SYSTEM">Contrato do Sistema</option>
                  <option value="EXTERNAL">Contrato Externo</option>
                </select>
              </div>
            </div>

            <div class="field" id="systemContractField" style="margin-top:12px;">
              <label class="field-label" for="systemDocumentId">Contrato do sistema ainda não assinado</label>
              <select id="systemDocumentId" name="systemDocumentId">
                <option value="">Selecione</option>
                <% systemContracts.forEach(function(contract) { %>
                  <option
                    value="<%= contract.id %>"
                    data-name="<%= contract.client?.fullName || '' %>"
                    data-email="<%= contract.client?.email || '' %>"
                    data-document="<%= contract.client?.document || '' %>"
                    data-phone="<%= contract.client?.phone || '' %>"
                  >
                    <%= contract.title %><%= contract.client ? ` · ${contract.client.fullName}` : '' %><%= contract.cat ? ` · ${contract.cat.name}` : '' %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div id="uploadDocumentFields" style="margin-top:12px;" hidden>
              <div class="grid-2">
                <div class="field">
                  <label class="field-label" for="externalTitle">Nome do documento</label>
                  <input id="externalTitle" name="externalTitle" type="text" placeholder="Ex.: Contrato externo, declaração, autorização" />
                </div>
                <div class="field">
                  <label class="field-label" for="signaturePdf">Arquivo PDF</label>
                  <input id="signaturePdf" name="signaturePdf" type="file" accept="application/pdf,.pdf" />
                </div>
              </div>
              <input type="hidden" id="signatureX" name="signatureX" />
              <input type="hidden" id="signatureY" name="signatureY" />
              <div class="grid-2" style="margin-top:12px;">
                <div class="field">
                  <label class="field-label" for="signaturePage">Página da assinatura</label>
                  <input id="signaturePage" name="signaturePage" type="number" min="1" step="1" value="1" />
                </div>
                <div class="field">
                  <label class="field-label">Local selecionado</label>
                  <div class="history-display" id="signaturePositionLabel">Clique na pré-visualização para marcar a assinatura.</div>
                </div>
              </div>
              <div class="pdf-signature-preview" id="pdfSignaturePreview" hidden>
                <iframe id="pdfPreviewFrame" title="Pré-visualização do PDF"></iframe>
                <button type="button" id="signatureMarker" aria-label="Posição da assinatura" hidden>Assinatura</button>
              </div>
            </div>

            <div class="grid-2" style="margin-top:14px;">
              <div class="field">
                <label class="field-label" for="signerName">Nome do assinante</label>
                <input id="signerName" name="signerName" type="text" />
              </div>
              <div class="field">
                <label class="field-label" for="signerDocument">CPF/CNPJ ou documento</label>
                <input id="signerDocument" name="signerDocument" type="text" />
              </div>
              <div class="field">
                <label class="field-label" for="signerEmail">E-mail</label>
                <input id="signerEmail" name="signerEmail" type="email" />
              </div>
              <div class="field">
                <label class="field-label" for="signerPhone">Telefone/WhatsApp</label>
                <input id="signerPhone" name="signerPhone" type="text" />
              </div>
            </div>

            <div class="form-actions" style="text-align:right; margin-top:14px;">
              <button type="submit" class="btn btn-primary">Gerar link / enviar e-mail</button>
            </div>
          </form>
        </section>

        <section class="content-card">
          <div class="documents-section-title">
            <div>
              <div class="content-title">Links e auditoria</div>
              <div class="content-sub">Acompanhe cada envio, acesso e assinatura.</div>
            </div>
          </div>

          <% if (!signatureRequests.length) { %>
            <div class="empty">Nenhum documento enviado para assinatura ainda.</div>
          <% } else { %>
            <div class="signature-request-list">
              <% signatureRequests.forEach(function(request) { %>
                <%
                  const statusClass =
                    request.status === 'SIGNED' ? 'is-green' :
                    request.status === 'BLOCKED' || request.status === 'CANCELED' ? 'is-red' :
                    request.status === 'OTP_SENT' || request.status === 'VIEWED' ? 'is-blue' :
                    'is-yellow';
                %>
                <article class="signature-request-card">
                  <div class="signature-request-head">
                    <div class="signature-request-person">
                      <div class="record-title"><%= request.document?.title || 'Documento' %></div>
                      <div class="record-sub"><%= request.signerName || 'Assinante' %> · <%= request.signerEmail || 'Sem e-mail cadastrado' %></div>
                    </div>
                    <span class="status-pill <%= statusClass %>"><%= request.statusLabel || request.status %></span>
                  </div>

                  <div class="signature-link-box">
                    <span>Link público</span>
                    <a href="<%= request.publicUrl %>" target="_blank" rel="noopener noreferrer"><%= request.publicUrl %></a>
                  </div>

                  <div class="signature-timeline">
                    <% request.timeline.forEach(function(item) { %>
                      <div class="signature-timeline-item">
                        <span class="signature-timeline-dot"></span>
                        <div>
                          <strong><%= item.title %></strong>
                          <p><%= item.value %></p>
                        </div>
                      </div>
                    <% }) %>
                  </div>

                  <div class="signature-action-bar">
                    <div class="signature-action-primary">
                      <% if (request.status !== 'CANCELED' && request.status !== 'BLOCKED') { %>
                        <a class="btn" href="<%= request.whatsappUrl %>" target="_blank" rel="noopener noreferrer">Enviar WhatsApp</a>
                      <% } %>
                      <% if (request.evidencePdfPath) { %>
                        <a class="btn btn-primary" href="<%= request.evidencePdfPath %>" target="_blank" rel="noopener noreferrer">PDF assinado</a>
                      <% } %>
                    </div>

                    <div class="signature-action-secondary">
                      <% if (request.status !== 'SIGNED' && request.status !== 'CANCELED') { %>
                        <% if (request.status === 'BLOCKED') { %>
                          <form method="post" action="/documentos/<%= request.documentId %>/assinatura/<%= request.id %>/desbloquear?returnTo=assinaturas">
                            <button type="submit" class="btn">Desbloquear</button>
                          </form>
                        <% } else { %>
                          <form method="post" action="/documentos/<%= request.documentId %>/assinatura/<%= request.id %>/bloquear?returnTo=assinaturas">
                            <button type="submit" class="btn">Bloquear</button>
                          </form>
                        <% } %>
                        <form method="post" action="/documentos/<%= request.documentId %>/assinatura/<%= request.id %>/cancelar?returnTo=assinaturas" onsubmit="return confirm('Cancelar este documento? O cliente não poderá mais acessar este link.');">
                          <button type="submit" class="btn signature-danger-button">Cancelar</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </section>
      </main>
    </div>

    <script>
      const documentKind = document.getElementById("documentKind");
      const contractSource = document.getElementById("contractSource");
      const contractSourceField = document.getElementById("contractSourceField");
      const systemContractField = document.getElementById("systemContractField");
      const uploadDocumentFields = document.getElementById("uploadDocumentFields");
      const systemDocumentId = document.getElementById("systemDocumentId");
      const signaturePdf = document.getElementById("signaturePdf");
      const pdfSignaturePreview = document.getElementById("pdfSignaturePreview");
      const pdfPreviewFrame = document.getElementById("pdfPreviewFrame");
      const signatureMarker = document.getElementById("signatureMarker");
      const signatureX = document.getElementById("signatureX");
      const signatureY = document.getElementById("signatureY");
      const signaturePositionLabel = document.getElementById("signaturePositionLabel");

      function syncSignatureMode() {
        const isContract = documentKind.value === "CONTRACT";
        const isSystemContract = isContract && contractSource.value === "SYSTEM";
        contractSourceField.hidden = !isContract;
        systemContractField.hidden = !isSystemContract;
        uploadDocumentFields.hidden = isSystemContract;
      }

      documentKind.addEventListener("change", syncSignatureMode);
      contractSource.addEventListener("change", syncSignatureMode);
      syncSignatureMode();

      systemDocumentId.addEventListener("change", () => {
        const selected = systemDocumentId.selectedOptions[0];
        document.getElementById("signerName").value = selected?.dataset?.name || "";
        document.getElementById("signerEmail").value = selected?.dataset?.email || "";
        document.getElementById("signerDocument").value = selected?.dataset?.document || "";
        document.getElementById("signerPhone").value = selected?.dataset?.phone || "";
      });

      signaturePdf.addEventListener("change", () => {
        const file = signaturePdf.files && signaturePdf.files[0];
        if (!file) return;
        pdfPreviewFrame.src = URL.createObjectURL(file);
        pdfSignaturePreview.hidden = false;
        signatureMarker.hidden = true;
        signatureX.value = "";
        signatureY.value = "";
        signaturePositionLabel.textContent = "Clique na pré-visualização para marcar a assinatura.";
      });

      pdfSignaturePreview.addEventListener("click", (event) => {
        if (event.target === signatureMarker) return;
        const rect = pdfSignaturePreview.getBoundingClientRect();
        const x = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));
        const y = Math.max(0, Math.min(1, (event.clientY - rect.top) / rect.height));
        signatureX.value = x.toFixed(4);
        signatureY.value = y.toFixed(4);
        signatureMarker.hidden = false;
        signatureMarker.style.left = `${x * 100}%`;
        signatureMarker.style.top = `${y * 100}%`;
        signaturePositionLabel.textContent = `Assinatura marcada em ${(x * 100).toFixed(1)}% x ${(y * 100).toFixed(1)}% da página informada.`;
      });
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Assinatura Eletrônica - PetGus</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Assinatura Eletrônica</h2>
            <div class="welcome-sub">Envie um PDF de contrato para um ou mais destinatários assinarem eletronicamente.</div>
          </div>
          <div class="actions">
            <a href="/documentos" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card" style="border-left:4px solid #16a34a; margin-bottom:18px;">
            <div class="content-sub">Contrato enviado para assinatura com sucesso.</div>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="content-card" style="border-left:4px solid #b91c1c; margin-bottom:18px;">
            <div class="content-sub"><%= error %></div>
          </div>
        <% } %>

        <section class="signature-workspace-card" style="margin-bottom:18px;">
          <div class="history-section-head" style="margin-bottom:12px;">
            <div>
              <div class="content-title">Novo documento</div>
              <div class="content-sub">Envie o PDF, informe os signatários e posicione assinaturas, rubricas e campos visíveis.</div>
            </div>
            <span class="status-pill <%= smtpSettings.isComplete ? 'is-green' : 'is-yellow' %>">
              <%= smtpSettings.isComplete ? 'SMTP configurado' : 'SMTP pendente' %>
            </span>
          </div>

          <% if (!smtpSettings.isComplete) { %>
            <div class="section-note" style="margin-bottom:12px;">
              Sem SMTP próprio, e-mails e OTPs serão enviados pelo remetente PetGus. Configure o SMTP em <a href="/settings">Configurações</a> para usar seu próprio domínio.
            </div>
          <% } %>

          <form method="post" action="/documentos/assinaturas/criar" enctype="multipart/form-data" id="signatureCreateForm">
            <div class="signature-workspace">
              <aside class="signature-setup-panel">
                <div class="signature-mode-tabs" aria-label="Modo de envio">
                  <button type="button" class="is-active">Enviar um arquivo</button>
                  <button type="button" disabled>Modelos</button>
                  <button type="button" disabled>WhatsApp</button>
                </div>

            <div class="grid-2">
              <div class="field">
                <label class="field-label" for="externalTitle">Contrato</label>
                <input id="externalTitle" name="externalTitle" type="text" placeholder="Ex.: Contrato do seu João" required />
              </div>
              <div class="field">
                <label class="field-label" for="signaturePdf">Upload de arquivo PDF de contrato</label>
                <input id="signaturePdf" name="signaturePdf" type="file" accept="application/pdf,.pdf" required />
              </div>
            </div>

            <div class="field" style="margin-top:12px;">
              <label class="field-label" for="contractNote">Observações ou informações sobre o contrato</label>
              <textarea
                id="contractNote"
                name="contractNote"
                rows="4"
                placeholder="Ex.: Informações importantes para o destinatário, prazo de assinatura, orientações de leitura ou condições combinadas."
              ></textarea>
            </div>

            <div class="field-panel signature-recipient-panel" style="margin-top:14px;">
              <div class="history-section-head" style="margin-bottom:10px;">
                <div>
                  <div class="content-title">Signatários</div>
                  <div class="content-sub">Digite o e-mail ou selecione clientes e fornecedores cadastrados.</div>
                </div>
                <button class="btn" type="button" id="addRecipientButton">+</button>
              </div>

              <div class="signature-order-toggle" aria-label="Ordem de assinatura">
                <button type="button" class="is-active">Sem ordem</button>
                <button type="button">Com ordem</button>
              </div>

              <datalist id="signatureEmailSuggestions">
                <% emailSuggestions.forEach(function(contact) { %>
                  <option value="<%= contact.email %>"><%= contact.label %></option>
                <% }) %>
              </datalist>

              <div id="recipientRows" class="signature-recipient-rows">
                <div class="signature-recipient-row" data-recipient-index="0">
                  <div class="field">
                    <label class="field-label">E-mail de destinatário</label>
                    <div class="signature-email-row">
                      <input name="recipientEmail" type="email" list="signatureEmailSuggestions" placeholder="cliente@email.com" required />
                      <button class="btn signature-select-target" type="button" data-target="recipient:0">Marcar assinatura</button>
                    </div>
                    <details class="signature-extra-options">
                      <summary>Mais opções +</summary>
                      <div class="grid-3">
                        <input type="text" name="recipientName" placeholder="Nome completo" />
                        <input type="text" name="recipientDocument" placeholder="CPF/CNPJ" />
                        <input type="text" name="recipientPhone" placeholder="Telefone" />
                      </div>
                    </details>
                    <input type="hidden" name="recipientSignatureX" />
                    <input type="hidden" name="recipientSignatureY" />
                    <input type="hidden" name="recipientSignaturePage" />
                    <input type="hidden" name="recipientSignaturePositions" />
                    <div class="history-display signature-position-summary" data-position-summary>Assinatura ainda não marcada.</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="field-panel" style="margin-top:14px;">
              <div class="history-section-head" style="margin-bottom:10px;">
                <div>
                  <div class="content-title">Minha Assinatura</div>
                  <div class="content-sub">Marque uma ou mais posições onde sua assinatura será aplicada no contrato.</div>
                </div>
                <button class="btn signature-select-target" type="button" data-target="sender">Marcar minha assinatura</button>
              </div>
              <div class="field">
                <label class="field-label">Locais selecionados</label>
                <div class="history-display" id="signaturePositionLabel">Faça upload do PDF e clique em "Marcar minha assinatura".</div>
              </div>
              <input type="hidden" id="senderSignaturePage" name="senderSignaturePage" />
              <input type="hidden" id="senderSignatureX" name="senderSignatureX" />
              <input type="hidden" id="senderSignatureY" name="senderSignatureY" />
              <input type="hidden" id="senderSignaturePositions" name="senderSignaturePositions" />
            </div>

            <div class="field-panel signature-field-panel" style="margin-top:14px;">
              <div class="content-title">Campos visíveis</div>
              <div class="content-sub">Selecione o campo e clique no PDF para posicionar. A marcação pode ser removida clicando nela.</div>
              <div class="signature-field-toolbar" role="toolbar" aria-label="Campos de assinatura">
                <button type="button" class="signature-field-button is-active" data-field-type="signature">Assinatura</button>
                <button type="button" class="signature-field-button" data-field-type="rubric">Rubrica</button>
                <button type="button" class="signature-field-button" data-field-type="name">Nome</button>
                <button type="button" class="signature-field-button" data-field-type="document">CPF</button>
                <button type="button" class="signature-field-button" data-field-type="date">Data</button>
              </div>
              <label class="field-label" for="signatureRepeatMode" style="margin-top:12px;">Repetir campo</label>
              <select id="signatureRepeatMode">
                <option value="page">Apenas nesta página</option>
                <option value="all">Repetir em todas as páginas</option>
                <option value="except-last">Repetir em todas as páginas exceto a última</option>
              </select>
            </div>

              </aside>

              <section class="signature-document-stage">
                <div class="signature-stage-head">
                  <div>
                    <strong>Pré-visualização do documento</strong>
                    <span>Role pelas páginas e clique no local onde cada campo deve aparecer.</span>
                  </div>
                  <span class="status-pill is-blue">PDF/A visual</span>
                </div>
            <div id="uploadDocumentFields" style="margin-top:12px;">
              <div class="pdf-signature-preview" id="pdfSignaturePreview" hidden>
                <div id="pdfPages" class="pdf-signature-pages" aria-label="Pré-visualização do PDF"></div>
              </div>
              <div class="signature-upload-drop" id="signatureUploadDrop">
                <strong>Arraste o documento aqui</strong>
                <span>ou selecione o arquivo PDF no painel lateral para pré-visualizar.</span>
              </div>
            </div>

            <div class="form-actions" style="text-align:right; margin-top:14px;">
              <button type="submit" class="btn btn-primary">Gerar links / enviar e-mails</button>
            </div>
              </section>
            </div>
          </form>
        </section>

        <section class="content-card signature-documents-panel">
          <div class="documents-section-title">
            <div>
              <div class="content-title">Documentos em Minha organização</div>
              <div class="content-sub">Acompanhe signatários, envio, abertura, assinatura e evidências de cada documento.</div>
            </div>
          </div>

          <% if (!signatureGroups.length) { %>
            <div class="empty">Nenhum contrato enviado para assinatura ainda.</div>
          <% } else { %>
            <div class="signature-request-list">
              <% signatureGroups.forEach(function(group) { %>
                <%
                  const signedCount = group.requests.filter(function(request) { return request.status === 'SIGNED'; }).length;
                  const activeCount = group.requests.filter(function(request) { return request.status !== 'CANCELED'; }).length || group.requests.length;
                  const pendingCount = Math.max(activeCount - signedCount, 0);
                  const groupStatusLabel = pendingCount > 0 ? `Aguardando (${signedCount} de ${activeCount})` : `Concluído (${signedCount} de ${activeCount})`;
                %>
                <article class="signature-request-card">
                  <div class="signature-request-head">
                    <div class="signature-request-person">
                      <div class="record-title"><%= group.document?.title || 'Contrato' %></div>
                      <div class="record-sub"><%= group.document?.createdAt ? new Date(group.document.createdAt).toLocaleString('pt-BR') : '' %></div>
                    </div>
                    <span class="status-pill <%= pendingCount > 0 ? 'is-yellow' : 'is-green' %>"><%= groupStatusLabel %></span>
                  </div>
                  <div class="signature-card-signers">
                    <% group.requests.forEach(function(request) { %>
                      <div class="<%= request.status === 'SIGNED' ? 'is-signed' : 'is-pending' %>">
                        <span><%= request.status === 'SIGNED' ? '✓' : '◷' %></span>
                        <strong><%= request.signatureSource === 'SENDER' ? 'Usuário remetente' : (request.signerName || request.signerEmail || 'Destinatário') %></strong>
                      </div>
                    <% }) %>
                  </div>
                  <div class="signature-request-head signature-request-actions-head">
                    <% if (group.senderRequest && group.senderRequest.status !== 'SIGNED' && group.senderRequest.status !== 'CANCELED' && group.senderRequest.status !== 'BLOCKED') { %>
                      <a class="btn btn-primary" href="<%= group.senderRequest.publicUrl %>" target="_blank" rel="noopener noreferrer">Assinar como remetente</a>
                    <% } else if (group.senderRequest && group.senderRequest.status === 'SIGNED') { %>
                      <span class="status-pill is-green">Remetente assinado</span>
                    <% } %>
                  </div>

                  <% if (group.document && group.document.body) { %>
                    <div class="section-note" style="margin-bottom:12px; white-space:pre-wrap;"><%= group.document.body %></div>
                  <% } %>

                  <div class="signature-recipient-status-list">
                    <% group.requests.forEach(function(request) { %>
                      <%
                        const statusClass =
                          request.status === 'SIGNED' ? 'is-green' :
                          request.status === 'BLOCKED' || request.status === 'CANCELED' ? 'is-red' :
                          request.status === 'OTP_SENT' || request.status === 'VIEWED' ? 'is-blue' :
                          'is-yellow';
                      %>
                      <div class="signature-recipient-status">
                        <div>
                          <strong><%= request.signatureSource === 'SENDER' ? 'Usuário remetente' : (request.signerName || request.signerEmail || 'Destinatário') %></strong>
                          <p><%= request.signerEmail || 'Sem e-mail' %></p>
                        </div>
                        <span class="status-pill <%= statusClass %>"><%= request.statusLabel || request.status %></span>
                        <div class="signature-recipient-actions">
                          <% if (request.status !== 'CANCELED' && request.status !== 'BLOCKED') { %>
                            <a class="btn" href="<%= request.whatsappUrl %>" target="_blank" rel="noopener noreferrer">WhatsApp</a>
                          <% } %>
                          <a class="btn" href="<%= request.publicUrl %>" target="_blank" rel="noopener noreferrer">Link</a>
                          <% if (request.evidencePdfPath) { %>
                            <a class="btn btn-primary" href="<%= request.evidencePdfPath %>" target="_blank" rel="noopener noreferrer">PDF assinado</a>
                          <% } %>
                          <% if (request.status !== 'SIGNED' && request.status !== 'CANCELED') { %>
                            <% if (request.status === 'BLOCKED') { %>
                              <form method="post" action="/documentos/<%= request.documentId %>/assinatura/<%= request.id %>/desbloquear?returnTo=assinaturas">
                                <button type="submit" class="btn">Desbloquear</button>
                              </form>
                            <% } else { %>
                              <form method="post" action="/documentos/<%= request.documentId %>/assinatura/<%= request.id %>/bloquear?returnTo=assinaturas">
                                <button type="submit" class="btn">Bloquear</button>
                              </form>
                            <% } %>
                            <form method="post" action="/documentos/<%= request.documentId %>/assinatura/<%= request.id %>/cancelar?returnTo=assinaturas" onsubmit="return confirm('Cancelar este link? O destinatário não poderá mais acessar.');">
                              <button type="submit" class="btn signature-danger-button">Cancelar</button>
                            </form>
                          <% } %>
                        </div>
                        <details class="signature-timeline-details">
                          <summary>Acompanhamento</summary>
                          <div class="signature-timeline">
                            <% request.timeline.forEach(function(item) { %>
                              <div class="signature-timeline-item">
                                <span class="signature-timeline-dot"></span>
                                <div>
                                  <strong><%= item.title %></strong>
                                  <p><%= item.value %></p>
                                </div>
                              </div>
                            <% }) %>
                          </div>
                        </details>
                      </div>
                    <% }) %>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </section>
      </main>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
      const emailSuggestions = <%- JSON.stringify(emailSuggestions || []).replace(/</g, '\\u003c') %>;
      const recipientRows = document.getElementById("recipientRows");
      const addRecipientButton = document.getElementById("addRecipientButton");
      const signaturePdf = document.getElementById("signaturePdf");
      const pdfSignaturePreview = document.getElementById("pdfSignaturePreview");
      const pdfPages = document.getElementById("pdfPages");
      const signaturePositionLabel = document.getElementById("signaturePositionLabel");
      const signatureUploadDrop = document.getElementById("signatureUploadDrop");
      const signatureRepeatMode = document.getElementById("signatureRepeatMode");
      let activeTarget = "sender";
      let activeFieldType = "signature";
      let recipientIndex = 1;
      let renderedPdfUrl = null;
      let renderedPageCount = 0;

      if (window.pdfjsLib) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
      }

      function findSuggestion(email) {
        const normalized = String(email || "").trim().toLowerCase();
        return emailSuggestions.find((item) => item.email === normalized);
      }

      function markerLabel(target) {
        if (target === "sender") return "Minha Assinatura";
        const index = target.split(":")[1];
        const email = recipientRows.querySelector(`[data-recipient-index="${index}"] input[name="recipientEmail"]`)?.value;
        return email || `Destinatário ${Number(index) + 1}`;
      }

      function fieldTypeLabel(type) {
        const labels = {
          signature: "Assinatura",
          rubric: "Rubrica",
          name: "Nome",
          document: "CPF",
          date: "Data",
        };
        return labels[type] || "Assinatura";
      }

      function markerText(target, type) {
        return `${fieldTypeLabel(type)} · ${markerLabel(target)}`;
      }

      function updateContactFields(row) {
        const emailInput = row.querySelector('input[name="recipientEmail"]');
        const contact = findSuggestion(emailInput.value);
        row.querySelector('input[name="recipientName"]').value = contact?.name || "";
        row.querySelector('input[name="recipientDocument"]').value = contact?.document || "";
        row.querySelector('input[name="recipientPhone"]').value = contact?.phone || "";
        const target = `recipient:${row.dataset.recipientIndex}`;
        pdfPages.querySelectorAll(`[data-target="${target}"]`).forEach((marker) => {
          marker.textContent = markerText(target, marker.dataset.fieldType || "signature");
        });
      }

      function wireRecipientRow(row) {
        row.querySelector('input[name="recipientEmail"]').addEventListener("input", () => updateContactFields(row));
        row.querySelector(".signature-select-target").addEventListener("click", (event) => {
          activeTarget = event.currentTarget.dataset.target;
          signaturePositionLabel.textContent = `Clique no PDF para marcar ${fieldTypeLabel(activeFieldType)}: ${markerLabel(activeTarget)}.`;
        });
      }

      function addRecipientRow() {
        const index = recipientIndex++;
        const row = document.createElement("div");
        row.className = "signature-recipient-row";
        row.dataset.recipientIndex = String(index);
        row.innerHTML = `
          <div class="field">
            <label class="field-label">E-mail de destinatário</label>
            <div class="signature-email-row">
              <input name="recipientEmail" type="email" list="signatureEmailSuggestions" placeholder="cliente@email.com" required />
              <button class="btn signature-select-target" type="button" data-target="recipient:${index}">Marcar assinatura</button>
              <button class="btn signature-remove-recipient" type="button">Remover</button>
            </div>
            <details class="signature-extra-options">
              <summary>Mais opções +</summary>
              <div class="grid-3">
                <input type="text" name="recipientName" placeholder="Nome completo" />
                <input type="text" name="recipientDocument" placeholder="CPF/CNPJ" />
                <input type="text" name="recipientPhone" placeholder="Telefone" />
              </div>
            </details>
            <input type="hidden" name="recipientSignatureX" />
            <input type="hidden" name="recipientSignatureY" />
            <input type="hidden" name="recipientSignaturePage" />
            <input type="hidden" name="recipientSignaturePositions" />
            <div class="history-display signature-position-summary" data-position-summary>Assinatura ainda não marcada.</div>
          </div>
        `;
        row.querySelector(".signature-remove-recipient").addEventListener("click", () => {
          row.remove();
          pdfPages.querySelectorAll(`[data-target="recipient:${index}"]`).forEach((marker) => marker.remove());
        });
        recipientRows.appendChild(row);
        wireRecipientRow(row);
      }

      function fieldsForTarget(target) {
        if (target === "sender") {
          return {
            page: document.getElementById("senderSignaturePage"),
            x: document.getElementById("senderSignatureX"),
            y: document.getElementById("senderSignatureY"),
            positions: document.getElementById("senderSignaturePositions"),
            summary: signaturePositionLabel,
          };
        }
        const index = target.split(":")[1];
        const row = recipientRows.querySelector(`[data-recipient-index="${index}"]`);
        if (!row) return null;
        return {
          page: row.querySelector('input[name="recipientSignaturePage"]'),
          x: row.querySelector('input[name="recipientSignatureX"]'),
          y: row.querySelector('input[name="recipientSignatureY"]'),
          positions: row.querySelector('input[name="recipientSignaturePositions"]'),
          summary: row.querySelector("[data-position-summary]"),
        };
      }

      function readPositions(fields) {
        try {
          const parsed = JSON.parse(fields?.positions?.value || "[]");
          return Array.isArray(parsed) ? parsed : [];
        } catch (_err) {
          return [];
        }
      }

      function writePositions(fields, positions) {
        const clean = positions.filter((position) => (
          Number.isFinite(Number(position.page)) &&
          Number.isFinite(Number(position.x)) &&
          Number.isFinite(Number(position.y))
        ));
        fields.positions.value = JSON.stringify(clean);
        const first = clean[0] || {};
        fields.page.value = first.page ? String(first.page) : "";
        fields.x.value = Number.isFinite(Number(first.x)) ? Number(first.x).toFixed(4) : "";
        fields.y.value = Number.isFinite(Number(first.y)) ? Number(first.y).toFixed(4) : "";
        updatePositionSummary(fields, clean);
        return clean;
      }

      function clearAllSignaturePositions() {
        const senderFields = fieldsForTarget("sender");
        if (senderFields) writePositions(senderFields, []);
        recipientRows.querySelectorAll(".signature-recipient-row").forEach((row) => {
          const target = `recipient:${row.dataset.recipientIndex}`;
          const fields = fieldsForTarget(target);
          if (fields) writePositions(fields, []);
        });
      }

      function updatePositionSummary(fields, positions) {
        if (!fields?.summary) return;
        if (!positions.length) {
          fields.summary.textContent = "Nenhum campo marcado.";
          return;
        }
        const pages = [...new Set(positions.map((position) => Number(position.page)).filter(Boolean))].sort((a, b) => a - b);
        fields.summary.textContent = `${positions.length} campo(s) marcado(s) na(s) página(s): ${pages.join(", ")}.`;
      }

      function removeTargetMarker(target, markerIndex) {
        const fields = fieldsForTarget(target);
        if (!fields) return;
        const positions = readPositions(fields).filter((position) => Number(position.index) !== Number(markerIndex));
        writePositions(fields, positions);
        pdfPages.querySelector(`[data-target="${target}"][data-marker-index="${markerIndex}"]`)?.remove();
        signaturePositionLabel.textContent = `Marcação removida para ${markerLabel(target)}.`;
      }

      function pagesForRepeat(clickedPage) {
        const mode = signatureRepeatMode?.value || "page";
        if (mode === "all") {
          return Array.from({ length: renderedPageCount || clickedPage }, (_item, index) => index + 1);
        }
        if (mode === "except-last") {
          const count = Math.max(1, (renderedPageCount || clickedPage) - 1);
          return Array.from({ length: count }, (_item, index) => index + 1);
        }
        return [clickedPage];
      }

      function addMarkerElement(target, markerIndex, pageNumber, x, y, fieldType) {
        const marker = document.createElement("button");
        marker.type = "button";
        marker.className = target === "sender" ? "signature-marker is-sender" : "signature-marker";
        marker.dataset.target = target;
        marker.dataset.markerIndex = String(markerIndex);
        marker.dataset.fieldType = fieldType;
        marker.title = "Clique para remover esta marcação";
        marker.addEventListener("click", (event) => {
          event.stopPropagation();
          removeTargetMarker(target, markerIndex);
        });
        marker.textContent = markerText(target, fieldType);
        marker.style.left = `${x * 100}%`;
        marker.style.top = `${y * 100}%`;
        const page = pdfPages.querySelector(`[data-page-number="${pageNumber}"] .pdf-signature-marker-layer`);
        page?.appendChild(marker);
      }

      function setTargetCoordinates(target, pageNumber, x, y) {
        const fields = fieldsForTarget(target);
        if (!fields) return;
        const positions = readPositions(fields);
        const targetPages = pagesForRepeat(pageNumber);
        targetPages.forEach((targetPage) => {
          const markerIndex = Date.now() + Math.floor(Math.random() * 100000);
          const position = {
            index: markerIndex,
            page: targetPage,
            x: Number(x.toFixed(4)),
            y: Number(y.toFixed(4)),
            type: activeFieldType,
          };
          positions.push(position);
          addMarkerElement(target, markerIndex, targetPage, x, y, activeFieldType);
        });
        writePositions(fields, positions);
        signaturePositionLabel.textContent = `${fieldTypeLabel(activeFieldType)} marcada para ${markerLabel(target)} em ${targetPages.length} página(s). Clique na marcação para excluir.`;
      }

      async function renderPdfPreview(file) {
        pdfSignaturePreview.hidden = false;
        if (!window.pdfjsLib) {
          pdfPages.innerHTML = '<div class="section-note">Não foi possível carregar o visualizador de PDF. Verifique a conexão e tente novamente.</div>';
          return;
        }
        const buffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data: buffer }).promise;
        renderedPageCount = pdf.numPages;
        pdfPages.innerHTML = "";
        if (signatureUploadDrop) signatureUploadDrop.hidden = true;
        for (let pageNumber = 1; pageNumber <= pdf.numPages; pageNumber += 1) {
          const page = await pdf.getPage(pageNumber);
          const containerWidth = Math.min(920, Math.max(320, pdfSignaturePreview.clientWidth - 36));
          const baseViewport = page.getViewport({ scale: 1 });
          const scale = containerWidth / baseViewport.width;
          const viewport = page.getViewport({ scale });
          const pageNode = document.createElement("div");
          pageNode.className = "pdf-signature-page";
          pageNode.dataset.pageNumber = String(pageNumber);
          pageNode.style.width = `${viewport.width}px`;
          pageNode.style.height = `${viewport.height}px`;

          const pageLabel = document.createElement("div");
          pageLabel.className = "pdf-signature-page-label";
          pageLabel.textContent = `Página ${pageNumber}`;

          const canvas = document.createElement("canvas");
          canvas.width = viewport.width;
          canvas.height = viewport.height;
          canvas.style.width = `${viewport.width}px`;
          canvas.style.height = `${viewport.height}px`;

          const markerLayer = document.createElement("div");
          markerLayer.className = "pdf-signature-marker-layer";

          pageNode.appendChild(canvas);
          pageNode.appendChild(markerLayer);
          pageNode.appendChild(pageLabel);
          pdfPages.appendChild(pageNode);
          await page.render({ canvasContext: canvas.getContext("2d"), viewport }).promise;
        }
        signaturePositionLabel.textContent = "Selecione o destinatário ou Minha Assinatura, role até a página desejada e clique em um ou mais locais de assinatura.";
      }

      document.querySelectorAll(".signature-select-target").forEach((button) => {
        button.addEventListener("click", (event) => {
          activeTarget = event.currentTarget.dataset.target;
          signaturePositionLabel.textContent = `Clique no PDF para marcar ${fieldTypeLabel(activeFieldType)}: ${markerLabel(activeTarget)}.`;
        });
      });
      document.querySelectorAll(".signature-field-button").forEach((button) => {
        button.addEventListener("click", () => {
          activeFieldType = button.dataset.fieldType || "signature";
          document.querySelectorAll(".signature-field-button").forEach((item) => item.classList.toggle("is-active", item === button));
          signaturePositionLabel.textContent = `Campo selecionado: ${fieldTypeLabel(activeFieldType)}. Clique no PDF para marcar ${markerLabel(activeTarget)}.`;
        });
      });
      document.querySelectorAll(".signature-recipient-row").forEach(wireRecipientRow);
      addRecipientButton.addEventListener("click", addRecipientRow);

      signaturePdf.addEventListener("change", () => {
        const file = signaturePdf.files && signaturePdf.files[0];
        if (!file) return;
        if (renderedPdfUrl) URL.revokeObjectURL(renderedPdfUrl);
        renderedPdfUrl = URL.createObjectURL(file);
        clearAllSignaturePositions();
        pdfPages.innerHTML = "";
        if (signatureUploadDrop) signatureUploadDrop.hidden = true;
        renderPdfPreview(file).catch(() => {
          pdfSignaturePreview.hidden = false;
          if (signatureUploadDrop) signatureUploadDrop.hidden = true;
          pdfPages.innerHTML = '<div class="section-note">Não foi possível abrir a pré-visualização deste PDF.</div>';
        });
      });

      if (signatureUploadDrop) {
        signatureUploadDrop.addEventListener("click", () => signaturePdf.click());
        ["dragenter", "dragover"].forEach((eventName) => {
          signatureUploadDrop.addEventListener(eventName, (event) => {
            event.preventDefault();
            signatureUploadDrop.classList.add("is-dragging");
          });
        });
        ["dragleave", "drop"].forEach((eventName) => {
          signatureUploadDrop.addEventListener(eventName, (event) => {
            event.preventDefault();
            signatureUploadDrop.classList.remove("is-dragging");
          });
        });
        signatureUploadDrop.addEventListener("drop", (event) => {
          const file = event.dataTransfer?.files?.[0];
          if (!file) return;
          const transfer = new DataTransfer();
          transfer.items.add(file);
          signaturePdf.files = transfer.files;
          signaturePdf.dispatchEvent(new Event("change", { bubbles: true }));
        });
      }

      pdfSignaturePreview.addEventListener("click", (event) => {
        if (event.target.closest(".signature-marker")) return;
        const pageNode = event.target.closest(".pdf-signature-page");
        if (!pageNode) return;
        const rect = pageNode.getBoundingClientRect();
        const x = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));
        const y = Math.max(0, Math.min(1, (event.clientY - rect.top) / rect.height));
        setTargetCoordinates(activeTarget, Number(pageNode.dataset.pageNumber || 1), x, y);
      });
    </script>
  </body>
</html>

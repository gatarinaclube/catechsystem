<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Esqueci Minha Senha - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body class="auth-body">
    <div class="auth-card">
      <div class="auth-logo">CaTech System</div>
      <h1 class="auth-title">Redefinir senha</h1>
      <div class="auth-subtitle">
        Informe o e-mail cadastrado para receber o link de redefinição.
      </div>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <% if (typeof success !== "undefined" && success) { %>
        <div class="auth-success"><%= success %></div>
      <% } %>

      <form method="post" action="/forgot-password" class="auth-form">
        <div class="auth-field">
          <label for="email">E-mail</label>
          <input
            id="email"
            type="email"
            name="email"
            placeholder="seu@email.com"
            required
          />
        </div>

        <button type="submit" class="auth-button">Enviar link</button>
      </form>

      <div class="auth-footer">
        <a href="/login">Voltar para o login</a>
      </div>
    </div>
  </body>
</html>

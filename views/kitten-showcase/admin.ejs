<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Vitrine de Filhotes - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Vitrine de Filhotes</h2>
            <div class="welcome-sub">Monte a página pública de filhotes disponíveis do seu gatil.</div>
            <% if (showcaseLimits && showcaseLimits.litters !== null) { %>
              <div class="section-note">
                Limite do seu perfil: <strong><%= showcaseLimits.littersLabel %></strong>.
                <% if (showcaseLimits.littersNote) { %><%= showcaseLimits.littersNote %><% } %>
              </div>
            <% } %>
            <% if (showcaseLimits && showcaseLimits.uploadLimitLabel) { %>
              <div class="section-note">
                Arquivos da vitrine: <strong>até <%= showcaseLimits.uploadLimitLabel %> por arquivo</strong>.
              </div>
            <% } %>
          </div>
          <div class="actions">
            <a id="publicLinkButton" class="btn" href="/vitrine/<%= showcase.slug %>" target="_blank">Abrir link</a>
            <button class="btn btn-primary" type="submit" form="showcaseForm">Salvar e publicar</button>
          </div>
        </div>

        <% if (error) { %>
          <div class="content-card alert-card"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="content-card success-card">Vitrine salva com sucesso.</div>
        <% } %>

        <form id="showcaseForm" method="post" action="/admin/vitrine-filhotes" enctype="multipart/form-data">
          <input type="hidden" id="payload" name="payload" />

          <section class="content-card showcase-panel">
            <div class="content-title">Cabeçalho público</div>
            <div class="showcase-header-editor">
              <div class="field-panel showcase-logo-panel">
                <div class="content-title">Logo</div>
                <% if (showcase.logoPath) { %>
                  <img class="showcase-logo-preview" src="<%= showcase.logoPath %>" alt="" />
                <% } else { %>
                  <div class="showcase-logo-placeholder">Logo</div>
                <% } %>
                <div class="field">
                  <label class="field-label" for="showcaseLogo">Logo do gatil</label>
                  <input id="showcaseLogo" name="showcaseLogo" type="file" accept="image/*" />
                  <input id="logoPath" type="hidden" value="<%= showcase.logoPath || '' %>" />
                </div>
                <div class="showcase-theme-editor">
                  <div class="content-title">Visual da página pública</div>
                  <div class="showcase-color-grid">
                    <label class="showcase-color-field">
                      <span>Fundo</span>
                      <input id="backgroundColor" type="color" value="<%= showcase.backgroundColor || '#f5f7f3' %>" />
                    </label>
                    <label class="showcase-color-field">
                      <span>Quadros</span>
                      <input id="cardColor" type="color" value="<%= showcase.cardColor || '#ffffff' %>" />
                    </label>
                    <label class="showcase-color-field">
                      <span>Escritas</span>
                      <input id="textColor" type="color" value="<%= showcase.textColor || '#1f2933' %>" />
                    </label>
                    <label class="showcase-color-field">
                      <span>Destaque</span>
                      <input id="accentColor" type="color" value="<%= showcase.accentColor || '#8a5a20' %>" />
                    </label>
                  </div>
                  <div class="showcase-theme-preview" id="showcaseThemePreview">
                    <div>
                      <strong>Nome do gatil</strong>
                      <span>Quadro da vitrine</span>
                    </div>
                    <em>Disponível</em>
                  </div>
                </div>
              </div>

              <div class="showcase-header-fields">
                <div class="grid-2">
                  <div class="field">
                    <label class="field-label" for="title">Nome do gatil</label>
                    <input id="title" data-profile="title" type="text" value="<%= showcase.title || '' %>" />
                  </div>
                  <div class="field">
                    <label class="field-label" for="slug">Link</label>
                    <div class="showcase-url-field">
                      <span><%= publicBaseUrl %>/</span>
                      <input id="slug" data-profile="slug" type="text" value="<%= showcase.slug || '' %>" />
                    </div>
                  </div>
                </div>

                <div class="grid-3 showcase-profile-grid">
                  <div class="field">
                    <label class="field-label" for="websiteUrl">Site</label>
                    <input id="websiteUrl" type="url" placeholder="https://..." value="<%= showcase.websiteUrl || '' %>" />
                  </div>
                  <div class="field">
                    <label class="field-label" for="instagramUrl">Instagram</label>
                    <input id="instagramUrl" type="url" placeholder="https://instagram.com/seugatil" value="<%= showcase.instagramUrl || '' %>" />
                  </div>
                  <div class="field">
                    <label class="field-label" for="whatsappUrl">WhatsApp</label>
                    <input id="whatsappUrl" type="text" placeholder="DDD + número ou link" value="<%= showcase.whatsappUrl || '' %>" />
                  </div>
                </div>

                <div class="field" style="margin-top:12px;">
                  <label class="field-label" for="intro">Texto de abertura</label>
                  <textarea id="intro" data-profile="intro" rows="5"><%= showcase.intro || '' %></textarea>
                </div>

                <div class="showcase-header-bottom">
                  <label class="showcase-toggle">
                    <input id="published" data-profile="published" type="checkbox" <%= showcase.published ? "checked" : "" %> />
                    <span>Publicado</span>
                  </label>
                </div>
              </div>
            </div>

            <div class="field-panel showcase-payment-panel">
              <div class="content-title">Formas de pagamento</div>
              <div class="showcase-payment-options">
                <label class="showcase-toggle">
                  <input id="paymentPix" type="checkbox" <%= showcase.paymentPix ? "checked" : "" %> />
                  <span>PIX</span>
                </label>
                <label class="showcase-toggle">
                  <input id="paymentCardCash" type="checkbox" <%= showcase.paymentCardCash ? "checked" : "" %> />
                  <span>Cartão à vista</span>
                </label>
                <label class="showcase-toggle">
                  <input id="paymentCardInstallments" type="checkbox" <%= showcase.paymentCardInstallments ? "checked" : "" %> />
                  <span>Cartão parcelado</span>
                </label>
                <div class="field showcase-installments-field" id="paymentInstallmentsField">
                  <label class="field-label" for="paymentInstallments">Parcelas</label>
                  <input id="paymentInstallments" type="number" min="2" max="24" step="1" value="<%= showcase.paymentInstallments || '' %>" />
                </div>
              </div>
              <div class="field" style="margin-top:12px;">
                <label class="field-label" for="paymentText">Texto sobre forma de pagamento</label>
                <textarea id="paymentText" rows="4" placeholder="Ex.: condições, reserva, sinal, parcelamento, orientações para contato"><%= showcase.paymentText || '' %></textarea>
              </div>
            </div>

            <div class="field-panel showcase-about-panel">
              <div class="content-title">Informações sobre o gatil</div>
              <div class="field">
                <label class="field-label" for="aboutText">Texto sobre o gatil</label>
                <textarea id="aboutText" rows="5" placeholder="Ex.: história do gatil, criação, socialização, entrega, acompanhamento e diferenciais"><%= showcase.aboutText || '' %></textarea>
              </div>
              <div class="field" style="margin-top:12px;">
                <label class="field-label" for="aboutPdf">Apresentação em PDF</label>
                <input id="aboutPdf" name="aboutPdf" type="file" accept="application/pdf" />
                <input id="aboutPdfPath" type="hidden" value="<%= showcase.aboutPdfPath || '' %>" />
                <% if (showcase.aboutPdfPath) { %>
                  <small>PDF atual anexado. Envie outro apenas se desejar substituir.</small>
                <% } %>
              </div>
            </div>

            <div class="field-panel showcase-evolution-panel">
              <div class="showcase-section-head">
                <div>
                  <div class="content-title">Evolução de Filhotes</div>
                  <div class="content-sub">
                    <% if (showcaseLimits.evolutionComparisons !== null) { %>
                      Seu perfil permite <%= showcaseLimits.evolutionComparisonsLabel %>.
                    <% } else { %>
                      Seu perfil permite comparativos ilimitados.
                    <% } %>
                  </div>
                </div>
                <button id="addComparisonButton" type="button" class="btn">+ comparativo</button>
              </div>
              <div class="field" style="margin-top:12px;">
                <label class="field-label" for="evolutionText">Texto antes das fotos</label>
                <textarea id="evolutionText" rows="4" placeholder="Ex.: veja a evolução dos filhotes desde a reserva até a fase adulta"><%= showcase.evolutionText || '' %></textarea>
              </div>
              <div id="comparisonsRoot" class="showcase-comparison-stack"></div>
            </div>
          </section>

          <div id="littersRoot" class="showcase-stack"></div>

          <div class="showcase-actions">
            <button id="addLitterButton" type="button" class="btn btn-primary">+ ninhada</button>
            <button type="submit" class="btn btn-primary">Salvar e publicar</button>
          </div>
        </form>
      </main>
    </div>

    <template id="litterTemplate">
      <section class="content-card showcase-litter" data-litter>
        <div class="showcase-section-head">
          <div>
            <div class="content-title" data-litter-title>Ninhada</div>
            <div class="content-sub">As ninhadas mais antigas aparecem primeiro no link público.</div>
          </div>
          <div class="actions">
            <button type="button" class="btn" data-hide-litter>Ocultar</button>
            <button type="button" class="btn" data-remove-litter>Remover</button>
          </div>
        </div>

        <button type="button" class="showcase-litter-summary" data-litter-summary>
          <span data-litter-summary-title>Ninhada oculta</span>
          <small data-litter-summary-sub>Editar ninhada</small>
        </button>

        <div class="showcase-litter-body" data-litter-body>

        <div class="grid-3">
          <div class="field">
            <label class="field-label">Data de nascimento</label>
            <input data-field="birthDate" type="date" required />
          </div>
          <div class="field">
            <label class="field-label">Previsão de entrega</label>
            <input data-field="deliveryForecast" type="date" required />
          </div>
          <label class="showcase-toggle">
            <input data-field="published" type="checkbox" checked />
            <span>Mostrar esta ninhada</span>
          </label>
        </div>

        <div class="field" style="margin-top:12px;">
          <label class="field-label">Observação sobre a ninhada</label>
          <textarea data-field="note" rows="3" placeholder="Ex.: informações gerais, previsão, condições ou detalhes importantes"></textarea>
        </div>

        <div class="showcase-parent-grid">
          <div class="field-panel">
            <div class="content-title">Pai</div>
            <div class="grid-2 showcase-parent-fields">
              <div class="field">
                <label class="field-label">Nome do Pai</label>
                <input data-field="fatherName" type="text" required />
              </div>
              <div class="field">
                <label class="field-label">Fotos do Pai</label>
                <input data-parent-photo="father" type="file" accept="image/*" multiple />
                <div class="showcase-parent-photo-grid" data-parent-photo-grid="father"></div>
              </div>
              <div class="field"><label class="field-label">Cor do Pai</label><input data-field="fatherColor" type="text" /></div>
              <div class="field"><label class="field-label">PKDef</label><select data-field="fatherPkdef"><option value="">Não mostrar</option><option>N/N</option><option>N/K</option></select></div>
              <div class="field"><label class="field-label">PRA</label><select data-field="fatherPra"><option value="">Não mostrar</option><option>N/N</option><option>N/PRA</option></select></div>
              <div class="field"><label class="field-label">HCM</label><input data-field="fatherHcm" type="text" placeholder="Negativo" /></div>
            </div>
            <div class="field" style="margin-top:12px;">
              <label class="field-label">Observação sobre o pai</label>
              <textarea data-field="fatherNote" rows="3" placeholder="Ex.: temperamento, títulos, origem ou informação relevante"></textarea>
            </div>
          </div>

          <div class="field-panel">
            <div class="content-title">Mãe</div>
            <div class="grid-2 showcase-parent-fields">
              <div class="field">
                <label class="field-label">Nome da Mãe</label>
                <input data-field="motherName" type="text" required />
              </div>
              <div class="field">
                <label class="field-label">Fotos da Mãe</label>
                <input data-parent-photo="mother" type="file" accept="image/*" multiple />
                <div class="showcase-parent-photo-grid" data-parent-photo-grid="mother"></div>
              </div>
              <div class="field"><label class="field-label">Cor da Mãe</label><input data-field="motherColor" type="text" /></div>
              <div class="field"><label class="field-label">PKDef</label><select data-field="motherPkdef"><option value="">Não mostrar</option><option>N/N</option><option>N/K</option></select></div>
              <div class="field"><label class="field-label">PRA</label><select data-field="motherPra"><option value="">Não mostrar</option><option>N/N</option><option>N/PRA</option></select></div>
              <div class="field"><label class="field-label">HCM</label><input data-field="motherHcm" type="text" placeholder="Negativo" /></div>
            </div>
            <div class="field" style="margin-top:12px;">
              <label class="field-label">Observação sobre a mãe</label>
              <textarea data-field="motherNote" rows="3" placeholder="Ex.: temperamento, maternidade, títulos ou informação relevante"></textarea>
            </div>
          </div>
        </div>

        <div class="showcase-kittens" data-kittens></div>
        <button type="button" class="btn" data-add-kitten>+ filhote</button>
        </div>
      </section>
    </template>

    <template id="comparisonTemplate">
      <article class="showcase-comparison" data-comparison draggable="true">
        <div class="showcase-kitten-head">
          <div class="content-title" data-comparison-title>Comparativo</div>
          <div class="actions">
            <button type="button" class="btn" data-remove-comparison>Remover</button>
          </div>
        </div>
        <div class="field">
          <label class="field-label">Identificação do filhote (opcional)</label>
          <input data-comparison-field="caption" type="text" placeholder="Ex.: Gael, macho azul, ninhada de janeiro" />
        </div>
        <div class="showcase-comparison-grid">
          <div class="field showcase-photo-input">
            <label class="field-label">Momento da reserva</label>
            <input data-comparison-photo="reservePhoto" type="file" accept="image/*" />
            <input data-comparison-field="reservePhoto" type="hidden" />
            <div class="showcase-photo-grid" data-comparison-preview="reservePhoto"></div>
          </div>
          <div class="field showcase-photo-input">
            <label class="field-label">Momento da entrega (4 meses)</label>
            <input data-comparison-photo="deliveryPhoto" type="file" accept="image/*" />
            <input data-comparison-field="deliveryPhoto" type="hidden" />
            <div class="showcase-photo-grid" data-comparison-preview="deliveryPhoto"></div>
          </div>
          <div class="field showcase-photo-input">
            <label class="field-label">1 ano de idade</label>
            <input data-comparison-photo="oneYearPhoto" type="file" accept="image/*" />
            <input data-comparison-field="oneYearPhoto" type="hidden" />
            <div class="showcase-photo-grid" data-comparison-preview="oneYearPhoto"></div>
          </div>
        </div>
      </article>
    </template>

    <template id="kittenTemplate">
      <article class="showcase-kitten" data-kitten draggable="true">
        <div class="showcase-kitten-head">
          <div class="content-title" data-kitten-title>Filhote</div>
          <div class="actions">
            <button type="button" class="btn" data-remove-kitten>Remover</button>
          </div>
        </div>
        <div class="grid-3">
          <div class="field">
            <label class="field-label">Nome do Filhote</label>
            <input data-kitten-field="name" type="text" />
          </div>
          <div class="field">
            <label class="field-label">Cor do Filhote</label>
            <input data-kitten-field="color" type="text" />
          </div>
          <div class="field">
            <label class="field-label">Sexo</label>
            <select data-kitten-field="sex" required>
              <option value="M">Macho</option>
              <option value="F">Femea</option>
            </select>
          </div>
        </div>
        <div class="showcase-kitten-row">
          <label class="showcase-toggle">
            <input data-kitten-field="available" type="checkbox" checked />
            <span>Disponível</span>
          </label>
          <div class="field showcase-photo-input">
            <label class="field-label">Fotos do filhote</label>
            <input data-photo-input type="file" multiple accept="image/*" />
          </div>
        </div>
        <div class="field">
          <label class="field-label">Observação sobre o filhote</label>
          <textarea data-kitten-field="note" rows="3" placeholder="Ex.: personalidade, preferência, condição de reserva ou detalhe individual"></textarea>
        </div>
        <div class="showcase-photo-grid" data-photo-grid></div>
      </article>
    </template>

    <script>
      window.__SHOWCASE__ = <%- JSON.stringify(showcase) %>;
      window.__SHOWCASE_LIMITS__ = <%- JSON.stringify(showcaseLimits) %>;
    </script>
    <script src="/js/kitten-showcase-admin.js"></script>
  </body>
</html>

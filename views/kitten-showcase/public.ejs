<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= showcase.title || settings?.catteryName || 'Filhotes disponíveis' %></title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/kitten-showcase-public.css" />
  </head>
  <body data-showcase-slug="<%= showcase.slug %>" style="--showcase-bg:<%= showcase.backgroundColor || '#f5f7f3' %>;--showcase-card:<%= showcase.cardColor || '#ffffff' %>;--showcase-text:<%= showcase.textColor || '#1f2933' %>;--showcase-accent:<%= showcase.accentColor || '#8a5a20' %>;">
    <% const headerLogo = showcase.logoPath || (settings && settings.logoPath); %>
    <% const totalKittens = litters.reduce(function(total, litter) { return total + litter.kittens.length; }, 0); %>
    <header class="showcase-hero">
      <div class="showcase-hero-brand">
        <% if (headerLogo) { %>
          <img class="showcase-logo protected-image" src="<%= headerLogo %>" alt="" draggable="false" />
        <% } %>
        <div>
          <p class="showcase-kicker">Filhotes disponíveis</p>
          <h1><%= showcase.title || settings?.catteryName || 'Gatil' %></h1>
          <% if (isAssociatedShowcase) { %>
            <p class="showcase-official-note">Página do sistema oficial da Associação Catarinense de Felinos - Gatarina.</p>
          <% } %>
        </div>
      </div>

      <div class="showcase-hero-grid">
        <div class="showcase-hero-copy">
          <% if (showcase.intro) { %>
            <p class="showcase-intro"><%= showcase.intro %></p>
          <% } %>
        </div>

        <aside class="showcase-summary-card">
          <div>
            <span>Ninhadas</span>
            <strong><%= litters.length %></strong>
          </div>
          <div>
            <span>Filhotes disponíveis</span>
            <strong><%= totalKittens %></strong>
          </div>
        </aside>

        <% if (showcase.websiteUrl || showcase.instagramUrl || showcase.whatsappUrl) { %>
          <div class="showcase-links">
            <% if (showcase.whatsappUrl) { %>
              <a class="is-primary" href="<%= showcase.whatsappUrl %>" target="_blank" rel="noopener noreferrer" data-analytics-click="WhatsApp">
                <span class="showcase-link-icon whatsapp-icon" aria-hidden="true">☎</span>
                <span>WhatsApp</span>
              </a>
            <% } %>
            <% if (showcase.instagramUrl) { %>
              <a href="<%= showcase.instagramUrl %>" target="_blank" rel="noopener noreferrer" data-analytics-click="Instagram">
                <span class="showcase-link-icon instagram-icon" aria-hidden="true">◉</span>
                <span>Instagram</span>
              </a>
            <% } %>
            <% if (showcase.websiteUrl) { %>
              <a href="<%= showcase.websiteUrl %>" target="_blank" rel="noopener noreferrer" data-analytics-click="Site">
                <span class="showcase-link-icon" aria-hidden="true">◎</span>
                <span>Site</span>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </header>

    <main class="showcase-main">
      <% if (!litters.length) { %>
        <section class="showcase-empty">Nenhuma ninhada disponível no momento.</section>
      <% } %>

      <% litters.forEach(function(litter) { %>
        <section class="public-litter" data-analytics-view="Ninhada <%= litter.birthDateLabel %>">
          <div class="public-litter-head">
            <div>
              <p class="public-label">Ninhada</p>
              <h2>Ninhada de <%= litter.birthDateLabel %></h2>
              <p>Previsão de entrega: <strong><%= litter.deliveryForecastLabel %></strong></p>
            </div>
            <span class="public-litter-count"><%= litter.kittens.length %> filhote<%= litter.kittens.length === 1 ? '' : 's' %></span>
          </div>
          <% if (litter.note) { %>
            <div class="public-litter-note"><%= litter.note %></div>
          <% } %>

          <div class="public-section-divider">Pais da ninhada</div>

          <div class="public-parent-grid">
            <% [
              { label: 'Pai', mobileLabel: 'Informações do Pai', name: litter.fatherName, photos: [litter.fatherPhoto, litter.fatherPhoto2].filter(Boolean), color: litter.fatherColor, note: litter.fatherNote, pkdef: litter.fatherPkdef, pra: litter.fatherPra, hcm: litter.fatherHcm },
              { label: 'Mãe', mobileLabel: 'Informações da Mãe', name: litter.motherName, photos: [litter.motherPhoto, litter.motherPhoto2].filter(Boolean), color: litter.motherColor, note: litter.motherNote, pkdef: litter.motherPkdef, pra: litter.motherPra, hcm: litter.motherHcm }
            ].forEach(function(parent) { %>
              <details class="public-parent" open>
                <summary class="public-parent-summary">
                  <span><%= parent.mobileLabel %></span>
                </summary>
                <div class="public-parent-content">
                  <% if (parent.photos.length) { %>
                    <button class="gallery-trigger public-parent-photo-stack" type="button" data-gallery='<%- JSON.stringify(parent.photos) %>' data-index="0" aria-label="Abrir fotos de <%= parent.name %>">
                      <img class="protected-image" src="<%= parent.photos[0] %>" alt="<%= parent.name %>" draggable="false" />
                      <% if (parent.photos.length > 1) { %><span>+<%= parent.photos.length - 1 %></span><% } %>
                    </button>
                  <% } %>
                  <div>
                    <p class="public-label"><%= parent.label %></p>
                    <h3><%= parent.name %></h3>
                    <% if (parent.note) { %>
                      <p class="public-parent-note"><%= parent.note %></p>
                    <% } %>
                    <dl>
                      <% if (parent.color) { %><div><dt>Cor</dt><dd><%= parent.color %></dd></div><% } %>
                      <% if (parent.pkdef) { %><div><dt>PKDef</dt><dd><%= parent.pkdef %></dd></div><% } %>
                      <% if (parent.pra) { %><div><dt>PRA</dt><dd><%= parent.pra %></dd></div><% } %>
                      <% if (parent.hcm) { %><div><dt>HCM</dt><dd><%= parent.hcm %></dd></div><% } %>
                    </dl>
                  </div>
                </div>
              </details>
            <% }) %>
          </div>

          <div class="public-section-divider">Filhotes</div>
          <div class="public-kitten-grid">
            <% litter.kittens.forEach(function(kitten) { %>
              <article class="public-kitten">
                <% if (kitten.photos.length) { %>
                  <div class="public-kitten-photos">
                    <button class="gallery-trigger public-kitten-main-trigger" type="button" data-gallery='<%- JSON.stringify(kitten.photos.map(function(photo) { return photo.path; })) %>' data-index="0" aria-label="Abrir fotos de <%= kitten.displayName %>">
                      <img class="public-kitten-main-photo protected-image" src="<%= kitten.photos[0].path %>" alt="<%= kitten.displayName %>" draggable="false" />
                    </button>
                    <% if (kitten.photos.length > 1) { %>
                      <div class="public-kitten-thumbs">
                        <% kitten.photos.slice(1, 5).forEach(function(photo, photoIndex) { %>
                          <button class="gallery-trigger" type="button" data-gallery='<%- JSON.stringify(kitten.photos.map(function(item) { return item.path; })) %>' data-index="<%= photoIndex + 1 %>" aria-label="Abrir foto">
                            <img class="protected-image" src="<%= photo.path %>" alt="" draggable="false" />
                          </button>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                <% } %>
                <div class="public-kitten-body">
                  <div class="public-kitten-title-row">
                    <h3><%= kitten.displayName %></h3>
                    <span><%= kitten.sex === 'M' ? 'Macho' : 'Femea' %></span>
                  </div>
                  <% if (kitten.color) { %>
                    <p class="public-kitten-color"><%= kitten.color %></p>
                  <% } %>
                  <% if (kitten.note) { %>
                    <p class="public-kitten-note"><%= kitten.note %></p>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% }) %>

      <% if (hasPaymentInfo) { %>
        <section class="public-info-section public-payment" data-analytics-view="Formas de pagamento">
          <div>
            <p class="public-label">Atendimento</p>
            <h2>Formas de pagamento</h2>
            <% if (showcase.paymentText) { %>
              <p class="public-info-text"><%= showcase.paymentText %></p>
            <% } %>
          </div>
          <% if (showcase.paymentPix || showcase.paymentCardCash || showcase.paymentCardInstallments) { %>
            <div class="public-payment-options">
              <% if (showcase.paymentPix) { %>
                <div class="public-payment-chip"><span class="payment-icon pix-icon">PIX</span><span>PIX</span></div>
              <% } %>
              <% if (showcase.paymentCardCash) { %>
                <div class="public-payment-chip"><span class="payment-icon card-icon">▣</span><span>Cartão à vista</span></div>
              <% } %>
              <% if (showcase.paymentCardInstallments) { %>
                <div class="public-payment-chip">
                  <span class="payment-icon card-icon">▣</span>
                  <span>Cartão parcelado<%= showcase.paymentInstallments ? ` em até ${showcase.paymentInstallments}x` : '' %></span>
                </div>
              <% } %>
            </div>
          <% } %>
        </section>
      <% } %>

      <% if (hasAboutInfo) { %>
        <section class="public-info-section public-about" data-analytics-view="Sobre o gatil">
          <div class="public-info-head">
            <p class="public-label">Gatil</p>
            <h2>Sobre o gatil</h2>
          </div>
          <% if (showcase.aboutText) { %>
            <p class="public-info-text"><%= showcase.aboutText %></p>
          <% } %>
          <% if (showcase.aboutPdfPath) { %>
            <div class="public-pdf-viewer">
              <iframe src="<%= showcase.aboutPdfPath %>#toolbar=1&navpanes=0" data-pdf-src="<%= showcase.aboutPdfPath %>" title="Apresentação do gatil"></iframe>
            <a href="<%= showcase.aboutPdfPath %>" target="_blank" rel="noopener noreferrer" data-analytics-click="Apresentação em PDF">Abrir apresentação em PDF</a>
            </div>
          <% } %>
        </section>
      <% } %>

      <% if (hasEvolutionInfo) { %>
        <section class="public-info-section public-evolution" data-analytics-view="Evolução de Filhotes">
          <div class="public-info-head">
            <p class="public-label">Crescimento</p>
            <h2>Evolução de Filhotes</h2>
          </div>
          <% if (showcase.evolutionText) { %>
            <p class="public-info-text"><%= showcase.evolutionText %></p>
          <% } %>
          <div class="public-evolution-grid">
            <% showcase.evolutionComparisons.forEach(function(comparison) { %>
              <article class="public-evolution-card">
                <% if (comparison.caption) { %>
                  <h3><%= comparison.caption %></h3>
                <% } %>
                <div class="public-evolution-photos">
                  <% [
                    { label: 'Momento da reserva', path: comparison.reservePhoto },
                    { label: 'Momento da entrega (4 meses)', path: comparison.deliveryPhoto },
                    { label: '1 ano de idade', path: comparison.oneYearPhoto }
                  ].forEach(function(item, index) { %>
                    <button class="gallery-trigger public-evolution-photo" type="button" data-gallery='<%- JSON.stringify([comparison.reservePhoto, comparison.deliveryPhoto, comparison.oneYearPhoto]) %>' data-index="<%= index %>" aria-label="Abrir foto - <%= item.label %>">
                      <img class="protected-image" src="<%= item.path %>" alt="<%= item.label %>" draggable="false" />
                      <span><%= item.label %></span>
                    </button>
                  <% }) %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>

      <% if (isAssociatedShowcase) { %>
        <section class="public-info-section public-recommendations" data-analytics-view="Recomendações da Associação">
          <div class="public-info-head">
            <p class="public-label">Orientação oficial</p>
            <h2>Recomendações da Associação Catarinense de Felinos para aquisição de um filhote</h2>
          </div>
          <div class="public-recommendation-list">
            <article>
              <h3>Filhotes entregues após 4 meses de idade.</h3>
              <p>Apenas receba um filhote de raça após completar 4 meses. Idade necessária para desmame natural e segurança imunológica dos filhotes.</p>
            </article>
            <article>
              <h3>Todos os filhotes devem ser castrados e microchipados antes da entrega.</h3>
            </article>
            <article>
              <h3>Todos os filhotes precisam ser registrados na Federação Internacional de Felinos (FIFe), através da Federação Felina Brasileira (FFB).</h3>
            </article>
            <article>
              <h3>Dê preferência para criadores que participam e tenham bons resultados em Competições de Beleza Felina.</h3>
              <p>Somente assim é possível ter certeza da procedência e qualidade genética dos filhotes a serem adquiridos.</p>
            </article>
          </div>
        </section>
      <% } %>
    </main>
    <div class="lightbox" id="showcaseLightbox" hidden>
      <button class="lightbox-close" type="button" aria-label="Fechar" data-analytics-click="Fechou foto ampliada">×</button>
      <button class="lightbox-nav lightbox-prev" type="button" aria-label="Foto anterior" data-analytics-click="Foto anterior">‹</button>
      <img class="protected-image" id="lightboxImage" alt="" draggable="false" />
      <button class="lightbox-nav lightbox-next" type="button" aria-label="Próxima foto" data-analytics-click="Próxima foto">›</button>
    </div>
    <script src="/js/kitten-showcase-public.js"></script>
    <script src="/js/kitten-showcase-analytics.js"></script>
  </body>
</html>

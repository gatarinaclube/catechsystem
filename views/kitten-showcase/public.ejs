<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= showcase.title || settings?.catteryName || 'Filhotes disponíveis' %></title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/kitten-showcase-public.css" />
  </head>
  <body>
    <header class="showcase-hero">
      <% const headerLogo = showcase.logoPath || (settings && settings.logoPath); %>
      <% if (headerLogo) { %>
        <img class="showcase-logo protected-image" src="<%= headerLogo %>" alt="" draggable="false" />
      <% } %>
      <div>
        <p class="showcase-kicker">Filhotes disponíveis</p>
        <h1><%= showcase.title || settings?.catteryName || 'Gatil' %></h1>
        <% if (showcase.intro) { %>
          <p class="showcase-intro"><%= showcase.intro %></p>
        <% } %>
        <% if (showcase.websiteUrl || showcase.instagramUrl || showcase.whatsappUrl) { %>
          <div class="showcase-links">
            <% if (showcase.websiteUrl) { %>
              <a href="<%= showcase.websiteUrl %>" target="_blank" rel="noopener noreferrer">
                <span class="showcase-link-icon" aria-hidden="true">◎</span>
                <span>Site</span>
              </a>
            <% } %>
            <% if (showcase.instagramUrl) { %>
              <a href="<%= showcase.instagramUrl %>" target="_blank" rel="noopener noreferrer">
                <span class="showcase-link-icon instagram-icon" aria-hidden="true">◉</span>
                <span>Instagram</span>
              </a>
            <% } %>
            <% if (showcase.whatsappUrl) { %>
              <a href="<%= showcase.whatsappUrl %>" target="_blank" rel="noopener noreferrer">
                <span class="showcase-link-icon whatsapp-icon" aria-hidden="true">☎</span>
                <span>WhatsApp</span>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </header>

    <main class="showcase-main">
      <% if (showcase.paymentPix || showcase.paymentCardCash || showcase.paymentCardInstallments) { %>
        <section class="public-payment">
          <h2>Formas de pagamento</h2>
          <div class="public-payment-options">
            <% if (showcase.paymentPix) { %>
              <div class="public-payment-chip"><span class="payment-icon pix-icon">PIX</span><span>PIX</span></div>
            <% } %>
            <% if (showcase.paymentCardCash) { %>
              <div class="public-payment-chip"><span class="payment-icon card-icon">▣</span><span>Cartão à vista</span></div>
            <% } %>
            <% if (showcase.paymentCardInstallments) { %>
              <div class="public-payment-chip">
                <span class="payment-icon card-icon">▣</span>
                <span>Cartão parcelado<%= showcase.paymentInstallments ? ` em até ${showcase.paymentInstallments}x` : '' %></span>
              </div>
            <% } %>
          </div>
        </section>
      <% } %>

      <% if (!litters.length) { %>
        <section class="showcase-empty">Nenhuma ninhada disponível no momento.</section>
      <% } %>

      <% litters.forEach(function(litter) { %>
        <section class="public-litter">
          <div class="public-litter-head">
            <div>
              <h2>Ninhada de <%= litter.birthDateLabel %></h2>
              <p>Previsão de entrega: <strong><%= litter.deliveryForecastLabel %></strong></p>
            </div>
          </div>

          <div class="public-parent-grid">
            <% [
              { label: 'Pai', name: litter.fatherName, photos: [litter.fatherPhoto, litter.fatherPhoto2].filter(Boolean), color: litter.fatherColor, pkdef: litter.fatherPkdef, pra: litter.fatherPra, hcm: litter.fatherHcm },
              { label: 'Mãe', name: litter.motherName, photos: [litter.motherPhoto, litter.motherPhoto2].filter(Boolean), color: litter.motherColor, pkdef: litter.motherPkdef, pra: litter.motherPra, hcm: litter.motherHcm }
            ].forEach(function(parent) { %>
              <article class="public-parent">
                <% if (parent.photos.length) { %>
                  <button class="gallery-trigger public-parent-photo-stack" type="button" data-gallery='<%- JSON.stringify(parent.photos) %>' data-index="0" aria-label="Abrir fotos de <%= parent.name %>">
                    <img class="protected-image" src="<%= parent.photos[0] %>" alt="<%= parent.name %>" draggable="false" />
                    <% if (parent.photos.length > 1) { %><span>+<%= parent.photos.length - 1 %></span><% } %>
                  </button>
                <% } %>
                <div>
                  <p class="public-label"><%= parent.label %></p>
                  <h3><%= parent.name %></h3>
                  <dl>
                    <% if (parent.color) { %><div><dt>Cor</dt><dd><%= parent.color %></dd></div><% } %>
                    <% if (parent.pkdef) { %><div><dt>PKDef</dt><dd><%= parent.pkdef %></dd></div><% } %>
                    <% if (parent.pra) { %><div><dt>PRA</dt><dd><%= parent.pra %></dd></div><% } %>
                    <% if (parent.hcm) { %><div><dt>HCM</dt><dd><%= parent.hcm %></dd></div><% } %>
                  </dl>
                </div>
              </article>
            <% }) %>
          </div>

          <div class="public-kitten-grid">
            <% litter.kittens.forEach(function(kitten) { %>
              <article class="public-kitten">
                <% if (kitten.photos.length) { %>
                  <div class="public-kitten-photos">
                    <button class="gallery-trigger public-kitten-main-trigger" type="button" data-gallery='<%- JSON.stringify(kitten.photos.map(function(photo) { return photo.path; })) %>' data-index="0" aria-label="Abrir fotos de <%= kitten.displayName %>">
                      <img class="public-kitten-main-photo protected-image" src="<%= kitten.photos[0].path %>" alt="<%= kitten.displayName %>" draggable="false" />
                    </button>
                    <% if (kitten.photos.length > 1) { %>
                      <div class="public-kitten-thumbs">
                        <% kitten.photos.slice(1, 5).forEach(function(photo, photoIndex) { %>
                          <button class="gallery-trigger" type="button" data-gallery='<%- JSON.stringify(kitten.photos.map(function(item) { return item.path; })) %>' data-index="<%= photoIndex + 1 %>" aria-label="Abrir foto">
                            <img class="protected-image" src="<%= photo.path %>" alt="" draggable="false" />
                          </button>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                <% } %>
                <div class="public-kitten-body">
                  <div class="public-kitten-title-row">
                    <h3><%= kitten.displayName %></h3>
                    <span><%= kitten.sex === 'M' ? 'Macho' : 'Femea' %></span>
                  </div>
                  <% if (kitten.color) { %>
                    <p><%= kitten.color %></p>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% }) %>
    </main>
    <div class="lightbox" id="showcaseLightbox" hidden>
      <button class="lightbox-close" type="button" aria-label="Fechar">×</button>
      <button class="lightbox-nav lightbox-prev" type="button" aria-label="Foto anterior">‹</button>
      <img class="protected-image" id="lightboxImage" alt="" draggable="false" />
      <button class="lightbox-nav lightbox-next" type="button" aria-label="Próxima foto">›</button>
    </div>
    <script src="/js/kitten-showcase-public.js"></script>
  </body>
</html>

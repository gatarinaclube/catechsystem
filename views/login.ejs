<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title><%= typeof title !== "undefined" ? title : "Login - CaTech" %></title>

    <!-- CSS GLOBAL -->
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body class="auth-body">
    <div class="auth-card">
      <div class="auth-logo">CaTech System</div>
      <h1 class="auth-title"><%= typeof title !== "undefined" ? title : "Bem-vindo" %></h1>
      <div class="auth-subtitle"><%= typeof subtitle !== "undefined" ? subtitle : "Faça login para acessar o painel" %></div>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <form method="post" action="<%= typeof formAction !== 'undefined' ? formAction : '/login' %>" class="auth-form">
        <div class="auth-field">
          <label for="email">E-mail</label>
          <input
            id="email"
            type="email"
            name="email"
            placeholder="seu@email.com"
            required
          />
        </div>

        <div class="auth-field">
          <label for="password">Senha</label>
          <input
            id="password"
            type="password"
            name="password"
            placeholder="********"
            required
          />
        </div>

        <button type="submit" class="auth-button">Entrar</button>
      </form>

      <% if (typeof showRegisterLink !== "undefined" && showRegisterLink) { %>
        <div class="auth-footer">
          <%= typeof registerText !== "undefined" ? registerText : "Ainda não é associado?" %>
          <a href="<%= typeof registerHref !== 'undefined' ? registerHref : '/register' %>"><%= typeof registerLabel !== "undefined" ? registerLabel : "Solicitar" %></a>
        </div>
      <% } %>
      <div class="auth-footer auth-footer-secondary">
        <a href="/forgot-password">Esqueci minha senha</a>
      </div>
      <% if (typeof alternateLoginHref !== "undefined" && alternateLoginHref) { %>
        <div class="auth-footer auth-footer-secondary">
          <a href="<%= alternateLoginHref %>"><%= alternateLoginLabel || "Outro login" %></a>
        </div>
      <% } %>
    </div>
  </body>
</html>

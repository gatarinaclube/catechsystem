<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Gestão de Microchip - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="app-shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main-content">
        <section class="card">
          <div class="section-header">
            <div>
              <h1 class="welcome-title">Gestão de Microchip</h1>
              <div class="content-sub">Cadastros públicos de animais identificados por microchip.</div>
            </div>
          </div>

          <form class="quick-form-grid" method="get" action="/admin/microchips">
            <label>
              Buscar por proprietário, animal ou microchip
              <input type="search" name="q" value="<%= query %>" placeholder="Digite parte do nome ou chip" />
            </label>
            <div class="form-actions">
              <button class="btn btn-primary" type="submit">Buscar</button>
              <a class="btn btn-light" href="/admin/microchips">Limpar</a>
            </div>
          </form>
        </section>

        <section class="card">
          <div class="table-responsive">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Proprietário</th>
                  <th>Animal</th>
                  <th>Microchip</th>
                  <th>Origem</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% if (!registrations.length) { %>
                  <tr><td colspan="6">Nenhum cadastro localizado.</td></tr>
                <% } %>
                <% registrations.forEach((item) => { %>
                  <tr>
                    <td><%= item.ownerName %></td>
                    <td><%= item.animalName %></td>
                    <td><%= formatMicrochip(item.microchip) %></td>
                    <td><%= item.source === 'INTERNAL' ? 'Cadastro interno' : 'Cadastro público' %></td>
                    <td><%= statusLabels[item.status] || item.status %></td>
                    <td><a class="btn btn-light btn-sm" href="<%= item.href %>">Abrir</a></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>

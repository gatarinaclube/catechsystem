<aside class="sidebar">
  <div>
    <div class="logo">CaTech System</div>
    <div class="logo-sub">Gatarina Clube</div>

    <div class="user-box">
<div class="user-name">
  <%= user && user.name ? user.name.split(" ")[0] : "Usuário" %>
</div>
      <div class="user-role">
        <%= access && access.roleLabel ? access.roleLabel : "Usuário" %>
      </div>
      <% if (user && user.clubs) { %>
        <div style="margin-top:6px; font-size: 11px;">
          Clubes: <%= user.clubs %>
        </div>
      <% } %>
    </div>

    <% if (access && access.canAccessMyProfile) { %>
  <div style="margin-top:8px; font-size:12px;">
    <a href="/meus-dados" style="color:inherit; text-decoration:none;">
      Meu Cadastro
    </a>
  </div>
<% } %>


    <div class="menu-title">Menu</div>

    <nav class="menu">
      <!-- PÁGINA INICIAL -->
      <a
        href="/dashboard"
        class="<%= (currentPath && currentPath.startsWith('/dashboard')) ? 'active' : '' %>"
      >
        <span class="menu-icon">🏠</span>
        <span>Página inicial</span>
      </a>

      <!-- Meus / Todos os gatos -->
      <a
        href="/cats"
        class="<%= (currentPath && currentPath.startsWith('/cats')) ? 'active' : '' %>"
      >
        <span class="menu-icon">🐾</span>
        <span>
          <%= (access && access.canViewAllCats) ? "Todos os gatos" : "Meus gatos" %>
        </span>
      </a>

      <!-- Serviços -->
      <a
        href="/services"
        class="<%= (currentPath && currentPath.startsWith('/services')) ? 'active' : '' %>"
      >
        <span class="menu-icon">🧾</span>
        <span>Serviços</span>
      </a>

      <!-- Serviços FFB (somente ADMIN) -->
      <% if (access && access.canAccessFfbServices) { %>
        <a
          href="/ffb-services"
          class="<%= (currentPath && currentPath.startsWith('/ffb-services')) ? 'active' : '' %>"
        >
          <span class="menu-icon">🛠️</span>
          <span>Serviços FFB</span>
        </a>
      <% } %>

      <!-- Usuários (somente ADMIN) -->
      <% if (access && access.canManageUsers) { %>
        <a
          href="/users"
          class="<%= (currentPath && currentPath.startsWith('/users')) ? 'active' : '' %>"
        >
          <span class="menu-icon">👥</span>
          <span>Usuários</span>
        </a>
      <% } %>

      <% if (access && access.canAccessBreeders) { %>
        <div
          style="
            margin: 14px 0 8px;
            padding-top: 12px;
            border-top: 1px solid #f59e0b;
            font-size: 11px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #f59e0b;
          "
        >
          Gestão do Gatil
        </div>
        <a
          href="/breeders"
          class="<%= (currentPath && currentPath.startsWith('/breeders')) ? 'active' : '' %>"
        >
          <span class="menu-icon">🐱</span>
          <span>Reprodutores</span>
        </a>
      <% } %>

      <% if (access && access.canAccessLittersAdmin) { %>
        <a
          href="/admin/litters"
          class="<%= (currentPath && currentPath.startsWith('/admin/litters')) ? 'active' : '' %>"
        >
          <span class="menu-icon">🐾</span>
          <span>Ninhadas</span>
        </a>
      <% } %>

      <% if (access && access.canAccessKittensAdmin) { %>
        <a
          href="/admin/kittens"
          class="<%= (currentPath && currentPath.startsWith('/admin/kittens')) ? 'active' : '' %>"
        >
          <span class="menu-icon">🐣</span>
          <span>Filhotes</span>
        </a>
      <% } %>

      <% if (access && access.canAccessMatingsAdmin) { %>
        <a
          href="/admin/matings"
          class="<%= (currentPath && currentPath.startsWith('/admin/matings')) ? 'active' : '' %>"
        >
          <span class="menu-icon">💞</span>
          <span>Acasalamentos</span>
        </a>
      <% } %>

      <% if (access && access.canAccessVaccinationsAdmin) { %>
        <a
          href="/admin/vaccinations"
          class="<%= (currentPath && currentPath.startsWith('/admin/vaccinations')) ? 'active' : '' %>"
        >
          <span class="menu-icon">💉</span>
          <span>Vacinação</span>
        </a>
      <% } %>

      <% if (access && access.canAccessDewormingAdmin) { %>
        <a
          href="/admin/deworming"
          class="<%= (currentPath && currentPath.startsWith('/admin/deworming')) ? 'active' : '' %>"
        >
          <span class="menu-icon">🧪</span>
          <span>Vermifugação</span>
        </a>
      <% } %>

      <% if (access && access.canAccessWeighingAdmin) { %>
        <a
          href="/admin/weighing"
          class="<%= (currentPath && currentPath.startsWith('/admin/weighing')) ? 'active' : '' %>"
        >
          <span class="menu-icon">⚖️</span>
          <span>Pesagem</span>
        </a>
      <% } %>

      <% if (access && access.canAccessExamsAdmin) { %>
        <a
          href="/admin/exams"
          class="<%= (currentPath && currentPath.startsWith('/admin/exams')) ? 'active' : '' %>"
        >
          <span class="menu-icon">🩺</span>
          <span>Exames</span>
        </a>
      <% } %>

    </nav>
  </div>

  <div class="menu-footer">
    <div>Logado como <%= user && user.email ? user.email : "" %></div>
    <div style="margin-top:6px;">
      <a href="/logout">Sair</a>
    </div>
  </div>
</aside>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Planos CaTech System - Gestão Completa para Gatil</title>
    <meta
      name="description"
      content="Compare os planos Básico, Master e Premium do CaTech System e comece com 7 dias grátis no Premium."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Plus+Jakarta+Sans:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/public-home.css" />
  </head>
  <body class="public-site-body">
    <header class="public-site-header">
      <a class="public-site-brand" href="/">
        <img src="/logos/catech-system-wide.png" alt="CaTech System" />
      </a>
      <nav class="public-site-nav" aria-label="Menu principal">
        <a href="/">Inicial</a>
        <a href="/planos">Planos</a>
        <a href="/microchip"><span aria-hidden="true">⌕</span> Microchip</a>
        <a href="/login">Login</a>
        <a href="/#contato">Contato</a>
      </nav>
    </header>

    <main>
      <section class="public-plans-section public-plans-page">
        <div class="public-section-heading">
          <span class="public-eyebrow">Planos para não associados</span>
          <h1>Comece com 7 dias grátis no Premium</h1>
          <p>
            Compare os recursos, escolha o plano ideal para o seu gatil e inicie o teste gratuito
            com acesso completo ao Premium.
          </p>
        </div>

        <%
          const planColumns = [
            { key: "basic", title: "Básico", href: "/planos/basic/cadastro" },
            { key: "master", title: "Master", href: "/planos/master/cadastro" },
            { key: "premium", title: "Premium", href: "/planos/premium/cadastro", featured: true }
          ];
          const planPositioning = [
            {
              key: "basic",
              title: "Básico",
              headline: "Para quem está começando",
              price: "R$ 14,90/mês",
              description: "Organize o essencial do gatil com cadastro, rotina sanitária e controle inicial dos filhotes.",
              benefits: ["Comece sem planilhas soltas", "Acompanhe saúde e histórico", "Tenha base para crescer com ordem"],
              href: "/planos/basic/cadastro"
            },
            {
              key: "master",
              title: "Master",
              headline: "Para gatil em crescimento",
              price: "R$ 24,90/mês",
              description: "Amplie a gestão com vitrine, CRM, documentos e relatórios para vender melhor e atender com mais profissionalismo.",
              benefits: ["Transforme visitas em contatos", "Ganhe presença pública com a vitrine", "Padronize documentos e atendimento"],
              href: "/planos/master/cadastro"
            },
            {
              key: "premium",
              title: "Premium",
              headline: "Para criador profissional",
              price: "R$ 34,90/mês",
              description: "Use o CaTech completo para gestão financeira, relatórios avançados, automações e operação sem limite.",
              benefits: ["Controle financeiro completo", "Relatórios para decisão", "Capacidade ilimitada para o gatil"],
              href: "/planos/premium/cadastro",
              featured: true
            }
          ];
          const commercialRows = [
            { label: "Recomendação", type: "text", values: { basic: ["Gatil iniciante", "Gatil pequeno", "Tutor de gatos"], master: ["Gatil médio"], premium: ["Gatil grande"] } },
            { label: "Pagamento mensal", type: "price", values: { basic: ["R$ 14,90", "mês"], master: ["R$ 24,90", "mês"], premium: ["R$ 34,90", "mês"] } },
            { label: "Pagamento 12X cartão", type: "price", values: { basic: ["12X Cartão", "R$ 149,90", "R$ 12,50/mês"], master: ["12X Cartão", "R$ 249,90", "R$ 20,83/mês"], premium: ["12X Cartão", "R$ 349,90", "R$ 29,16/mês"] } },
            { label: "Pagamento anual", type: "price", values: { basic: ["PIX", "R$ 120,00", "R$ 10,00/mês"], master: ["PIX", "R$ 200,00", "R$ 16,67/mês"], premium: ["PIX", "R$ 300,00", "R$ 25,00/mês"] } },
          ];
          const featureRows = (planComparisonRows || []).map(function(row) {
            if (row.type === "text") {
              return {
                label: row.label,
                type: row.type,
                values: {
                  basic: [row.values.basic],
                  master: [row.values.master],
                  premium: [row.values.premium]
                }
              };
            }
            return row;
          });
          const comparisonRows = commercialRows.concat(featureRows);
        %>

        <div class="public-plan-benefit-grid" aria-label="Escolha pelo momento do gatil">
          <% planPositioning.forEach(function(plan) { %>
            <article class="public-plan-benefit-card <%= plan.featured ? 'is-featured' : '' %>">
              <% if (plan.featured) { %>
                <span class="public-plan-badge">Mais completo</span>
              <% } %>
              <span class="public-plan-audience"><%= plan.headline %></span>
              <h2><%= plan.title %></h2>
              <div class="public-plan-benefit-price"><%= plan.price %></div>
              <p><%= plan.description %></p>
              <ul>
                <% plan.benefits.forEach(function(benefit) { %>
                  <li><%= benefit %></li>
                <% }) %>
              </ul>
              <a class="public-plan-benefit-button" href="<%= plan.href %>">
                <%= plan.featured ? 'Começar pelo Premium' : `Escolher ${plan.title}` %>
              </a>
            </article>
          <% }) %>
        </div>

        <div class="public-plan-table-card">
          <div class="public-plan-table-intro">
            <span class="public-eyebrow">Comparativo completo</span>
            <h2>Veja os recursos de cada plano</h2>
            <p>A tabela abaixo serve para conferir limites, módulos e formas de pagamento antes de contratar.</p>
          </div>
          <div class="public-plan-table-scroll">
            <table class="public-plan-comparison">
              <thead>
                <tr>
                  <th scope="col">Plano</th>
                  <% planColumns.forEach(function(plan) { %>
                    <th scope="col" class="<%= plan.featured ? 'is-featured' : '' %>">
                      <span><%= plan.title %></span>
                    </th>
                  <% }) %>
                </tr>
              </thead>
              <tbody>
                <% comparisonRows.forEach(function(row) { %>
                  <tr class="public-plan-row-<%= row.type %>">
                    <th scope="row"><%= row.label %></th>
                    <% planColumns.forEach(function(plan) { const value = row.values[plan.key]; %>
                      <td class="<%= plan.featured ? 'is-featured' : '' %>">
                        <% if (row.type === 'check') { %>
                          <span class="public-plan-status <%= value ? 'is-included' : 'is-not-included' %>">
                            <%= value ? '✓' : '×' %>
                          </span>
                        <% } else { %>
                          <span class="public-plan-cell-lines">
                            <% value.forEach(function(line, index) { %>
                              <span class="<%= row.type === 'price' && index === 1 ? 'is-price-main' : '' %>"><%= line %></span>
                            <% }) %>
                          </span>
                        <% } %>
                      </td>
                    <% }) %>
                  </tr>
                <% }) %>
              </tbody>
              <tfoot>
                <tr>
                  <th scope="row">Escolha seu plano</th>
                  <% planColumns.forEach(function(plan) { %>
                    <td class="<%= plan.featured ? 'is-featured' : '' %>">
                      <a class="public-plan-table-button" href="<%= plan.href %>">
                        <%= plan.key === 'premium' ? 'Testar Premium' : `Escolher ${plan.title}` %>
                      </a>
                    </td>
                  <% }) %>
                </tr>
              </tfoot>
            </table>
          </div>
          <div class="public-plan-footnote">
            <strong>Premium:</strong> teste gratuito por 7 dias para conhecer todos os recursos antes da contratação.
          </div>
        </div>
      </section>
    </main>

    <footer class="public-site-footer">
      <div>© 2026 Developed by PetGus & Partners</div>
      <div class="public-footer-help">
        <span>Sistema oficial da Associação Catarinense de Felinos - Gatarina</span>
        <a href="/#contato">Contato</a>
      </div>
    </footer>
  </body>
</html>

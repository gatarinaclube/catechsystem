<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lançamento Rápido - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: #f3f4f6;
        color: #1f2937;
        font-family: Arial, sans-serif;
      }
      .quick-shell {
        width: min(520px, 100%);
        margin: 0 auto;
        padding: 18px 14px 28px;
      }
      .quick-header {
        padding: 12px 2px 18px;
      }
      .quick-title {
        margin: 0;
        font-size: 24px;
        line-height: 1.15;
      }
      .quick-subtitle {
        margin-top: 6px;
        color: #6b7280;
        font-size: 13px;
      }
      .quick-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
      }
      .field {
        margin-bottom: 13px;
      }
      label {
        display: block;
        margin-bottom: 5px;
        color: #6b7280;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      input,
      select,
      textarea {
        width: 100%;
        min-height: 44px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 10px 12px;
        font: inherit;
        color: #111827;
        background: #ffffff;
      }
      textarea {
        min-height: 78px;
        resize: vertical;
      }
      input[type="file"] {
        padding: 9px;
      }
      .quick-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
      }
      .btn {
        width: 100%;
        min-height: 48px;
        border: 0;
        border-radius: 8px;
        background: #111827;
        color: #ffffff;
        font-weight: 700;
        cursor: pointer;
      }
      .message {
        margin-bottom: 12px;
        padding: 10px 12px;
        border-radius: 8px;
        font-size: 13px;
      }
      .message-success {
        background: #ecfdf5;
        color: #047857;
        border: 1px solid #a7f3d0;
      }
      .message-error {
        background: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fecaca;
      }
      .quick-footer {
        display: flex;
        justify-content: center;
        padding: 14px 0 0;
      }
      .quick-options-link {
        color: #9ca3af;
        font-size: 22px;
        text-decoration: none;
      }
      @media (min-width: 560px) {
        .quick-grid {
          grid-template-columns: 1fr 1fr;
          gap: 12px;
        }
      }
    </style>
  </head>
  <body>
    <main class="quick-shell">
      <header class="quick-header">
        <h1 class="quick-title">Lançamento Rápido</h1>
        <div class="quick-subtitle">Registro simples de despesas do gatil.</div>
      </header>

      <form class="quick-card" method="post" action="/lancamento" enctype="multipart/form-data">
        <% if (success) { %>
          <div class="message message-success">Lançamento salvo.</div>
        <% } %>
        <% if (error) { %>
          <div class="message message-error"><%= error %></div>
        <% } %>

        <div class="quick-grid">
          <div class="field">
            <label for="amount">Valor</label>
            <input id="amount" name="amount" inputmode="decimal" placeholder="R$ 0,00" required autofocus />
          </div>

          <div class="field">
            <label for="competenceDate">Competência</label>
            <input id="competenceDate" name="competenceDate" type="date" value="<%= today %>" />
          </div>
        </div>

        <div class="field">
          <label for="category">Categoria</label>
          <select id="category" name="category" required>
            <option value="">Selecione...</option>
            <% categories.forEach(function(item) { %>
              <option value="<%= item %>"><%= item %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <label for="paymentMethod">Forma de pagamento</label>
          <select id="paymentMethod" name="paymentMethod" required>
            <option value="">Selecione...</option>
            <% paymentMethods.forEach(function(item) { %>
              <option value="<%= item %>"><%= item %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <label for="supplier">Fornecedor</label>
          <select id="supplier" name="supplier" required>
            <option value="">Selecione...</option>
            <% suppliers.forEach(function(item) { %>
              <option value="<%= item %>"><%= item %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <label for="receipt">Foto/Comprovante</label>
          <input id="receipt" name="receipt" type="file" accept="image/*,application/pdf" capture="environment" required />
        </div>

        <div class="field">
          <label for="note">Observação</label>
          <textarea id="note" name="note" placeholder="Vacina filhotes ninhada B"></textarea>
        </div>

        <button type="submit" class="btn">Salvar lançamento</button>
      </form>

      <footer class="quick-footer">
        <a class="quick-options-link" href="/lancamento/opcoes" title="Categorias e fornecedores">⚙</a>
      </footer>
    </main>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Despesas - CaTech</title>
    <meta name="theme-color" content="#f39c12" />
    <% if (isPublicExpenseLink && publicExpenseToken) { %>
      <meta name="mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-title" content="Despesas" />
      <link rel="manifest" href="/despesas/u/<%= publicExpenseToken %>/manifest.webmanifest" />
      <link rel="apple-touch-icon" href="/logos/catech-icon.png" />
    <% } %>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/quick-finance.css" />
  </head>
  <body>
    <main class="quick-shell">
      <header class="quick-header">
        <h1 class="quick-title">Despesas</h1>
        <div class="quick-subtitle">
          <%= isPublicExpenseLink ? "Link rápido para lançamento pelo celular." : "Registro simples de despesas do gatil." %>
        </div>
      </header>

      <form class="quick-card" method="post" action="<%= formAction %>" enctype="multipart/form-data">
        <% if (success) { %>
          <div class="message message-success">Despesa salva.</div>
        <% } %>
        <% if (error) { %>
          <div class="message message-error"><%= error %></div>
        <% } %>

        <div class="quick-grid">
          <div class="field">
            <label for="amount">Valor</label>
            <input id="amount" name="amount" inputmode="decimal" placeholder="R$ 0,00" value="<%= expense.amount || '' %>" required autofocus />
          </div>

          <div class="field">
            <label for="competenceDate">Competência</label>
            <input id="competenceDate" name="competenceDate" type="date" value="<%= expense.competenceDate %>" />
          </div>
        </div>

        <div class="field">
          <div class="quick-field-head">
            <label for="supplier">Fornecedor</label>
          </div>
          <div class="quick-inline-field">
            <input
              id="supplier"
              name="supplier"
              list="supplierOptions"
              value="<%= expense.supplier || '' %>"
              placeholder="Digite nome, fantasia ou CNPJ"
              required
              autocomplete="off"
            />
            <% if (canManageSuppliers) { %>
              <% if (isPublicExpenseLink) { %>
                <button class="quick-field-icon" type="button" id="togglePublicSupplierForm" title="Cadastrar novo fornecedor" aria-label="Cadastrar novo fornecedor">＋</button>
              <% } else { %>
                <a class="quick-field-icon" href="/administrativo/fornecedores" title="Cadastrar novo fornecedor" aria-label="Cadastrar novo fornecedor">＋</a>
              <% } %>
            <% } %>
          </div>
          <datalist id="supplierOptions">
            <% (supplierChoices || []).forEach(function(item) { %>
              <option
                value="<%= item.name %>"
                data-category="<%= item.defaultCategory || '' %>"
                label="<%= item.label || '' %>"
              ></option>
            <% }) %>
          </datalist>
          <div id="supplierLookupStatus" class="quick-hint" aria-live="polite"></div>
        </div>

        <% if (isPublicExpenseLink) { %>
          <div class="quick-inline-panel" id="publicSupplierPanel" hidden>
            <div class="quick-panel-title">Novo fornecedor</div>
            <div class="quick-grid">
              <div class="field">
                <label for="newSupplierName">Nome Comercial</label>
                <input id="newSupplierName" form="publicSupplierForm" name="commercialName" autocomplete="off" />
              </div>
              <div class="field">
                <label for="newSupplierCategory">Categoria Padrão</label>
                <select id="newSupplierCategory" form="publicSupplierForm" name="defaultCategory">
                  <option value="">Selecione...</option>
                  <% categories.forEach(function(item) { %>
                    <option value="<%= item %>"><%= item %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="field">
              <label for="newSupplierCnpj">CNPJ</label>
              <input id="newSupplierCnpj" form="publicSupplierForm" name="cnpj" inputmode="numeric" placeholder="Opcional" />
            </div>
            <div class="quick-panel-actions">
              <button class="btn" type="submit" form="publicSupplierForm">Salvar fornecedor</button>
              <button class="btn quick-secondary-button" type="button" id="cancelPublicSupplierForm">Cancelar</button>
            </div>
          </div>
        <% } %>

        <div class="field">
          <label for="category">Categoria</label>
          <select id="category" name="category" required>
            <option value="">Selecione...</option>
            <% categories.forEach(function(item) { %>
              <option value="<%= item %>" <%= expense.category === item ? 'selected' : '' %>><%= item %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <label for="paymentMethod">Conta de Pagamento</label>
          <select id="paymentMethod" name="paymentMethod" required>
            <option value="">Selecione...</option>
            <% (paymentMethodChoices || []).forEach(function(item) { %>
              <option value="<%= item.name %>" data-credit-card="<%= item.isCreditCard ? 'YES' : 'NO' %>" <%= expense.paymentMethod === item.name ? 'selected' : '' %>><%= item.name %></option>
            <% }) %>
          </select>
        </div>

        <div id="creditFields" class="quick-grid">
          <div class="field">
            <label for="paymentMode">Crédito</label>
            <select id="paymentMode" name="paymentMode">
              <option value="">Selecione...</option>
              <option value="À vista" <%= expense.paymentMode === 'À vista' ? 'selected' : '' %>>À vista</option>
              <option value="Parcelado" <%= expense.paymentMode === 'Parcelado' ? 'selected' : '' %>>Parcelado</option>
            </select>
          </div>
          <div class="field" id="installmentsField">
            <label for="installments">Parcelas</label>
            <select id="installments" name="installments">
              <% for (let i = 1; i <= 12; i++) { %>
                <option value="<%= i %>" <%= String(expense.installments || '1') === String(i) ? 'selected' : '' %>><%= i %>x</option>
              <% } %>
            </select>
          </div>
        </div>

        <div id="parcelFields" class="quick-parcels"></div>

        <div class="field">
          <label for="receipt">Foto/Comprovante</label>
          <input id="receipt" name="receipt" type="file" accept="image/*,application/pdf" capture="environment" />
          <% if (expense.receiptPath) { %>
            <small>Comprovante já anexado. Envie outro arquivo apenas se desejar substituir.</small>
          <% } %>
        </div>

        <div class="field">
          <label for="note">Observação</label>
          <textarea id="note" name="note" placeholder="Vacina filhotes ninhada B"><%= expense.note || '' %></textarea>
        </div>

        <button type="submit" class="btn">Salvar despesa</button>
      </form>

      <% if (isPublicExpenseLink) { %>
        <form id="publicSupplierForm" method="post" action="/despesas/u/<%= publicExpenseToken %>/fornecedores"></form>
      <% } %>

      <% if (isPublicExpenseLink) { %>
        <div class="quick-install-card" id="quickInstallCard" hidden>
          <strong>Instalar no celular</strong>
          <span id="quickInstallText">Salve este lançamento rápido na tela inicial para abrir como aplicativo.</span>
          <button type="button" class="btn quick-install-button" id="quickInstallButton" hidden>Instalar agora</button>
        </div>
      <% } else { %>
        <footer class="quick-footer">
          <a class="quick-options-link" href="/despesas" title="Despesas lançadas">←</a>
          <a class="quick-options-link" href="<%= homePath %>" title="Página inicial">⌂</a>
          <% if (expense.id) { %>
            <form method="post" action="/despesas/<%= expense.id %>/delete" onsubmit="return confirm('Excluir esta despesa?');">
              <button type="submit" class="quick-options-link quick-icon-button" title="Excluir despesa">🗑</button>
            </form>
          <% } %>
        </footer>
      <% } %>
    </main>
    <script>
      const amount = document.getElementById("amount");
      const supplier = document.getElementById("supplier");
      const supplierLookupStatus = document.getElementById("supplierLookupStatus");
      const category = document.getElementById("category");
      const paymentMethod = document.getElementById("paymentMethod");
      const paymentMode = document.getElementById("paymentMode");
      const creditFields = document.getElementById("creditFields");
      const installmentsField = document.getElementById("installmentsField");
      const installments = document.getElementById("installments");
      const parcelFields = document.getElementById("parcelFields");
      const savedParcels = <%- JSON.stringify(expense.parcels || []) %>;
      const publicSupplierPanel = document.getElementById("publicSupplierPanel");
      const togglePublicSupplierForm = document.getElementById("togglePublicSupplierForm");
      const cancelPublicSupplierForm = document.getElementById("cancelPublicSupplierForm");

      function digits(value) {
        return String(value || "").replace(/\D/g, "");
      }

      function formatCnpj(value) {
        const cnpj = digits(value);
        if (cnpj.length !== 14) return value;
        return `${cnpj.slice(0, 2)}.${cnpj.slice(2, 5)}.${cnpj.slice(5, 8)}/${cnpj.slice(8, 12)}-${cnpj.slice(12)}`;
      }

      function setSupplierLookupStatus(message, type) {
        if (!supplierLookupStatus) return;
        supplierLookupStatus.textContent = message || "";
        supplierLookupStatus.classList.toggle("is-error", type === "error");
        supplierLookupStatus.classList.toggle("is-success", type === "success");
      }

      async function lookupSupplierByCnpj() {
        const typedSupplier = String(supplier.value || "").trim();
        const cnpj = digits(supplier.value);
        const selected = Array.from(document.querySelectorAll("#supplierOptions option"))
          .some((option) => option.value === supplier.value);
        if (selected || cnpj.length !== 14 || /[A-Za-zÀ-ÿ]/.test(typedSupplier)) return;

        setSupplierLookupStatus("Buscando dados do CNPJ...", "");
        try {
          const response = await fetch(`https://brasilapi.com.br/api/cnpj/v1/${cnpj}`);
          if (!response.ok) throw new Error("Consulta indisponível");
          const data = await response.json();
          const name = data.razao_social || data.nome_fantasia || "";
          supplier.value = name ? `${name} - CNPJ ${formatCnpj(cnpj)}` : `CNPJ ${formatCnpj(cnpj)}`;
          setSupplierLookupStatus("Fornecedor identificado pelo CNPJ sem criar cadastro fixo.", "success");
        } catch {
          supplier.value = `CNPJ ${formatCnpj(cnpj)}`;
          setSupplierLookupStatus("Não foi possível buscar a empresa. A despesa será salva apenas com o CNPJ.", "error");
        }
      }

      function formatMoneyInput(input) {
        const digits = String(input.value || "").replace(/\D/g, "");
        if (!digits) {
          input.value = "";
          return;
        }

        const cents = Number.parseInt(digits, 10);
        input.value = (cents / 100).toLocaleString("pt-BR", {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        });
      }

      function moneyToCents(value) {
        const digits = String(value || "").replace(/\D/g, "");
        return digits ? Number.parseInt(digits, 10) : 0;
      }

      function numberToMoney(value) {
        return Number(value || 0).toLocaleString("pt-BR", {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        });
      }

      function addMonths(dateText, monthsToAdd) {
        const parts = String(dateText || "").split("-").map(Number);
        const base = parts[0] && parts[1] && parts[2]
          ? new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]))
          : new Date();
        base.setUTCMonth(base.getUTCMonth() + monthsToAdd);
        return base.toISOString().slice(0, 10);
      }

      function selectedPaymentIsCreditCard() {
        const option = paymentMethod.options[paymentMethod.selectedIndex];
        return option && option.dataset.creditCard === "YES";
      }

      function splitAmount(totalCents, count) {
        const base = Math.floor(totalCents / count);
        const remainder = totalCents - base * count;
        return Array.from({ length: count }, (_, index) => base + (index < remainder ? 1 : 0));
      }

      function renderParcels() {
        const isParcelado = selectedPaymentIsCreditCard() && paymentMode.value === "Parcelado";
        parcelFields.innerHTML = "";
        if (!isParcelado) return;

        const count = Number(installments.value || 1);
        const amounts = splitAmount(moneyToCents(amount.value), count);
        const startDate = document.getElementById("competenceDate").value;

        for (let i = 1; i <= count; i += 1) {
          const saved = savedParcels.find((parcel) => Number(parcel.number) === i) || {};
          const parcelAmount = saved.amount || numberToMoney((amounts[i - 1] || 0) / 100);
          const parcelDate = saved.date || addMonths(startDate, i - 1);
          parcelFields.insertAdjacentHTML("beforeend", `
            <div class="parcel-card">
              <div class="content-title">${i}ª parcela</div>
              <div class="quick-grid">
                <div class="field">
                  <label>Valor</label>
                  <input class="money-input parcel-money-input" name="parcel${i}Amount" inputmode="decimal" value="${parcelAmount}">
                </div>
                <div class="field">
                  <label>Data na fatura</label>
                  <input name="parcel${i}Date" type="date" value="${parcelDate}">
                </div>
              </div>
            </div>
          `);
        }

        parcelFields.querySelectorAll(".money-input").forEach((input) => {
          input.addEventListener("input", () => formatMoneyInput(input));
          input.addEventListener("blur", () => formatMoneyInput(input));
        });
      }

      function refreshCreditFields() {
        const isCredit = selectedPaymentIsCreditCard();
        creditFields.style.display = isCredit ? "grid" : "none";
        paymentMode.required = isCredit;
        if (!isCredit) paymentMode.value = "";
        installmentsField.style.display = paymentMode.value === "Parcelado" ? "block" : "none";
        renderParcels();
      }

      function refreshCategoryFromSupplier() {
        const selected = Array.from(document.querySelectorAll("#supplierOptions option"))
          .find((option) => option.value === supplier.value);
        const defaultCategory = selected ? selected.dataset.category : "";
        if (defaultCategory) category.value = defaultCategory;
      }

      amount.addEventListener("input", () => formatMoneyInput(amount));
      amount.addEventListener("blur", () => formatMoneyInput(amount));
      supplier.addEventListener("change", refreshCategoryFromSupplier);
      supplier.addEventListener("input", refreshCategoryFromSupplier);
      supplier.addEventListener("blur", lookupSupplierByCnpj);
      if (togglePublicSupplierForm && publicSupplierPanel) {
        togglePublicSupplierForm.addEventListener("click", () => {
          publicSupplierPanel.hidden = !publicSupplierPanel.hidden;
          if (!publicSupplierPanel.hidden) {
            document.getElementById("newSupplierName")?.focus();
          }
        });
      }
      if (cancelPublicSupplierForm && publicSupplierPanel) {
        cancelPublicSupplierForm.addEventListener("click", () => {
          publicSupplierPanel.hidden = true;
        });
      }
      paymentMethod.addEventListener("change", refreshCreditFields);
      paymentMode.addEventListener("change", refreshCreditFields);
      installments.addEventListener("change", renderParcels);
      document.getElementById("competenceDate").addEventListener("change", renderParcels);
      amount.addEventListener("blur", renderParcels);
      formatMoneyInput(amount);
      refreshCategoryFromSupplier();
      refreshCreditFields();

      <% if (isPublicExpenseLink) { %>
        const quickInstallCard = document.getElementById("quickInstallCard");
        const quickInstallButton = document.getElementById("quickInstallButton");
        const quickInstallText = document.getElementById("quickInstallText");
        let deferredInstallPrompt = null;

        function isStandaloneApp() {
          return window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;
        }

        function isIosDevice() {
          return /iphone|ipad|ipod/i.test(window.navigator.userAgent || "");
        }

        if ("serviceWorker" in navigator) {
          navigator.serviceWorker.register("/service-worker.js").catch(() => {});
        }

        window.addEventListener("beforeinstallprompt", (event) => {
          if (isStandaloneApp()) return;
          event.preventDefault();
          deferredInstallPrompt = event;
          quickInstallCard.hidden = false;
          quickInstallButton.hidden = false;
          quickInstallText.textContent = "Toque em instalar para criar o ícone deste lançamento rápido na tela inicial.";
        });

        quickInstallButton.addEventListener("click", async () => {
          if (!deferredInstallPrompt) return;
          deferredInstallPrompt.prompt();
          await deferredInstallPrompt.userChoice.catch(() => null);
          deferredInstallPrompt = null;
          quickInstallCard.hidden = true;
        });

        window.addEventListener("appinstalled", () => {
          deferredInstallPrompt = null;
          quickInstallCard.hidden = true;
        });

        if (!isStandaloneApp() && isIosDevice()) {
          quickInstallCard.hidden = false;
          quickInstallButton.hidden = true;
          quickInstallText.textContent = "No iPhone, toque em Compartilhar e depois em Adicionar à Tela de Início.";
        }
      <% } %>
    </script>
  </body>
</html>

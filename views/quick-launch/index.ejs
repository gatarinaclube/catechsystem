<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Despesas - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/quick-finance.css" />
  </head>
  <body>
    <main class="quick-shell">
      <header class="quick-header">
        <h1 class="quick-title">Despesas</h1>
        <div class="quick-subtitle">Registro simples de despesas do gatil.</div>
      </header>

      <form class="quick-card" method="post" action="<%= formAction %>" enctype="multipart/form-data">
        <% if (success) { %>
          <div class="message message-success">Despesa salva.</div>
        <% } %>
        <% if (error) { %>
          <div class="message message-error"><%= error %></div>
        <% } %>

        <div class="quick-grid">
          <div class="field">
            <label for="amount">Valor</label>
            <input id="amount" name="amount" inputmode="decimal" placeholder="R$ 0,00" value="<%= expense.amount || '' %>" required autofocus />
          </div>

          <div class="field">
            <label for="competenceDate">Competência</label>
            <input id="competenceDate" name="competenceDate" type="date" value="<%= expense.competenceDate %>" />
          </div>
        </div>

        <div class="field">
          <div class="quick-field-head">
            <label for="supplier">Fornecedor</label>
            <% if (canManageSuppliers) { %>
              <a class="quick-field-icon" href="/administrativo/fornecedores" title="Cadastrar ou editar fornecedores">＋</a>
            <% } %>
          </div>
          <input
            id="supplier"
            name="supplier"
            list="supplierOptions"
            value="<%= expense.supplier || '' %>"
            placeholder="Digite nome, fantasia ou CNPJ"
            required
            autocomplete="off"
          />
          <datalist id="supplierOptions">
            <% (supplierChoices || []).forEach(function(item) { %>
              <option
                value="<%= item.name %>"
                data-category="<%= item.defaultCategory || '' %>"
                label="<%= item.label || '' %>"
              ></option>
            <% }) %>
          </datalist>
        </div>

        <div class="field">
          <label for="category">Categoria</label>
          <select id="category" name="category" required>
            <option value="">Selecione...</option>
            <% categories.forEach(function(item) { %>
              <option value="<%= item %>" <%= expense.category === item ? 'selected' : '' %>><%= item %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <label for="paymentMethod">Conta de Pagamento</label>
          <select id="paymentMethod" name="paymentMethod" required>
            <option value="">Selecione...</option>
            <% (paymentMethodChoices || []).forEach(function(item) { %>
              <option value="<%= item.name %>" data-credit-card="<%= item.isCreditCard ? 'YES' : 'NO' %>" <%= expense.paymentMethod === item.name ? 'selected' : '' %>><%= item.name %></option>
            <% }) %>
          </select>
        </div>

        <div id="creditFields" class="quick-grid">
          <div class="field">
            <label for="paymentMode">Crédito</label>
            <select id="paymentMode" name="paymentMode">
              <option value="">Selecione...</option>
              <option value="À vista" <%= expense.paymentMode === 'À vista' ? 'selected' : '' %>>À vista</option>
              <option value="Parcelado" <%= expense.paymentMode === 'Parcelado' ? 'selected' : '' %>>Parcelado</option>
            </select>
          </div>
          <div class="field" id="installmentsField">
            <label for="installments">Parcelas</label>
            <select id="installments" name="installments">
              <% for (let i = 1; i <= 12; i++) { %>
                <option value="<%= i %>" <%= String(expense.installments || '1') === String(i) ? 'selected' : '' %>><%= i %>x</option>
              <% } %>
            </select>
          </div>
        </div>

        <div id="parcelFields" class="quick-parcels"></div>

        <div class="field">
          <label for="receipt">Foto/Comprovante</label>
          <input id="receipt" name="receipt" type="file" accept="image/*,application/pdf" capture="environment" />
          <% if (expense.receiptPath) { %>
            <small>Comprovante já anexado. Envie outro arquivo apenas se desejar substituir.</small>
          <% } %>
        </div>

        <div class="field">
          <label for="note">Observação</label>
          <textarea id="note" name="note" placeholder="Vacina filhotes ninhada B"><%= expense.note || '' %></textarea>
        </div>

        <button type="submit" class="btn">Salvar despesa</button>
      </form>

      <footer class="quick-footer">
        <a class="quick-options-link" href="/despesas" title="Despesas lançadas">←</a>
        <a class="quick-options-link" href="/despesas/opcoes" title="Categorias, fornecedores e pagamentos">⚙</a>
        <a class="quick-options-link" href="<%= homePath %>" title="Página inicial">⌂</a>
        <% if (expense.id) { %>
          <form method="post" action="/despesas/<%= expense.id %>/delete" onsubmit="return confirm('Excluir esta despesa?');">
            <button type="submit" class="quick-options-link quick-icon-button" title="Excluir despesa">🗑</button>
          </form>
        <% } %>
      </footer>
    </main>
    <script>
      const amount = document.getElementById("amount");
      const supplier = document.getElementById("supplier");
      const category = document.getElementById("category");
      const paymentMethod = document.getElementById("paymentMethod");
      const paymentMode = document.getElementById("paymentMode");
      const creditFields = document.getElementById("creditFields");
      const installmentsField = document.getElementById("installmentsField");
      const installments = document.getElementById("installments");
      const parcelFields = document.getElementById("parcelFields");
      const savedParcels = <%- JSON.stringify(expense.parcels || []) %>;

      function formatMoneyInput(input) {
        const digits = String(input.value || "").replace(/\D/g, "");
        if (!digits) {
          input.value = "";
          return;
        }

        const cents = Number.parseInt(digits, 10);
        input.value = (cents / 100).toLocaleString("pt-BR", {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        });
      }

      function moneyToCents(value) {
        const digits = String(value || "").replace(/\D/g, "");
        return digits ? Number.parseInt(digits, 10) : 0;
      }

      function numberToMoney(value) {
        return Number(value || 0).toLocaleString("pt-BR", {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        });
      }

      function addMonths(dateText, monthsToAdd) {
        const parts = String(dateText || "").split("-").map(Number);
        const base = parts[0] && parts[1] && parts[2]
          ? new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]))
          : new Date();
        base.setUTCMonth(base.getUTCMonth() + monthsToAdd);
        return base.toISOString().slice(0, 10);
      }

      function selectedPaymentIsCreditCard() {
        const option = paymentMethod.options[paymentMethod.selectedIndex];
        return option && option.dataset.creditCard === "YES";
      }

      function splitAmount(totalCents, count) {
        const base = Math.floor(totalCents / count);
        const remainder = totalCents - base * count;
        return Array.from({ length: count }, (_, index) => base + (index < remainder ? 1 : 0));
      }

      function renderParcels() {
        const isParcelado = selectedPaymentIsCreditCard() && paymentMode.value === "Parcelado";
        parcelFields.innerHTML = "";
        if (!isParcelado) return;

        const count = Number(installments.value || 1);
        const amounts = splitAmount(moneyToCents(amount.value), count);
        const startDate = document.getElementById("competenceDate").value;

        for (let i = 1; i <= count; i += 1) {
          const saved = savedParcels.find((parcel) => Number(parcel.number) === i) || {};
          const parcelAmount = saved.amount || numberToMoney((amounts[i - 1] || 0) / 100);
          const parcelDate = saved.date || addMonths(startDate, i - 1);
          parcelFields.insertAdjacentHTML("beforeend", `
            <div class="parcel-card">
              <div class="content-title">${i}ª parcela</div>
              <div class="quick-grid">
                <div class="field">
                  <label>Valor</label>
                  <input class="money-input parcel-money-input" name="parcel${i}Amount" inputmode="decimal" value="${parcelAmount}">
                </div>
                <div class="field">
                  <label>Data na fatura</label>
                  <input name="parcel${i}Date" type="date" value="${parcelDate}">
                </div>
              </div>
            </div>
          `);
        }

        parcelFields.querySelectorAll(".money-input").forEach((input) => {
          input.addEventListener("input", () => formatMoneyInput(input));
          input.addEventListener("blur", () => formatMoneyInput(input));
        });
      }

      function refreshCreditFields() {
        const isCredit = selectedPaymentIsCreditCard();
        creditFields.style.display = isCredit ? "grid" : "none";
        paymentMode.required = isCredit;
        if (!isCredit) paymentMode.value = "";
        installmentsField.style.display = paymentMode.value === "Parcelado" ? "block" : "none";
        renderParcels();
      }

      function refreshCategoryFromSupplier() {
        const selected = Array.from(document.querySelectorAll("#supplierOptions option"))
          .find((option) => option.value === supplier.value);
        const defaultCategory = selected ? selected.dataset.category : "";
        if (defaultCategory) category.value = defaultCategory;
      }

      amount.addEventListener("input", () => formatMoneyInput(amount));
      amount.addEventListener("blur", () => formatMoneyInput(amount));
      supplier.addEventListener("change", refreshCategoryFromSupplier);
      supplier.addEventListener("input", refreshCategoryFromSupplier);
      paymentMethod.addEventListener("change", refreshCreditFields);
      paymentMode.addEventListener("change", refreshCreditFields);
      installments.addEventListener("change", renderParcels);
      document.getElementById("competenceDate").addEventListener("change", renderParcels);
      amount.addEventListener("blur", renderParcels);
      formatMoneyInput(amount);
      refreshCreditFields();
    </script>
  </body>
</html>

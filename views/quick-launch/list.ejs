<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Despesas - PetGus</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Despesas</h2>
            <div class="welcome-sub">Despesas lançadas para acompanhamento financeiro.</div>
          </div>
          <div class="actions">
            <a href="/despesas/novo" class="btn btn-primary">Lançar despesa</a>
            <a href="/administrativo" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card message message-success">Despesa salva.</div>
        <% } %>

        <div class="content-card" style="margin-bottom:18px;">
          <form method="get" action="/despesas" class="report-filter-grid">
            <div class="field">
              <label class="field-label" for="month">Mês</label>
              <input id="month" name="month" type="month" value="<%= month %>" />
            </div>
            <div class="report-filter-actions">
              <button type="submit" class="btn btn-primary">Filtrar</button>
              <a href="/despesas" class="btn">Limpar</a>
            </div>
          </form>
        </div>

        <div class="content-card module-list-card">
          <% if (!expenses.length) { %>
            <div class="empty">Nenhuma despesa lançada neste mês.</div>
          <% } else { %>
            <div class="record-list">
              <% expenses.forEach(function(expense) { %>
                <a class="record-row" href="/despesas/<%= expense.id %>" style="text-decoration:none;">
                  <div class="record-main">
                    <div class="record-title">
                      <%= expense.supplier || "Fornecedor não informado" %>
                    </div>
                    <div class="record-sub">
                      <%= expense.category || "Sem categoria" %>
                      <% if (expense.paymentMethod) { %>
                        · <%= expense.paymentMethod %>
                      <% } %>
                      <% if (expense.note) { %>
                        · <%= expense.note %>
                      <% } %>
                    </div>
                  </div>
                  <div class="record-meta">
                    <span class="status-pill is-red">Despesa</span>
                    <div style="margin-top:6px;"><%= expense.amountLabel %></div>
                    <div class="record-sub"><%= expense.dateLabel %></div>
                  </div>
                </a>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="pagination">
          <% if (hasPreviousPage) { %>
            <a class="btn" href="/despesas?month=<%= month %>&page=<%= page - 1 %>">Anterior</a>
          <% } %>
          <span class="content-sub">Página <%= page %> de <%= totalPages %></span>
          <% if (hasNextPage) { %>
            <a class="btn" href="/despesas?month=<%= month %>&page=<%= page + 1 %>">Próxima</a>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>

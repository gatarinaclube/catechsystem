<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Despesas Lançadas</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/quick-finance.css" />
  </head>
  <body>
    <main class="quick-shell">
      <header class="quick-header">
        <h1 class="quick-title">Despesas Lançadas</h1>
      </header>

      <form class="quick-card quick-filter-card" method="get" action="/despesas/lista">
        <div class="field">
          <label for="month">Mês</label>
          <input id="month" name="month" type="month" value="<%= month %>" />
        </div>
        <button type="submit" class="btn">Filtrar</button>
      </form>

      <div class="quick-card">
        <% if (!expenses.length) { %>
          <div class="empty">Nenhuma despesa lançada neste mês.</div>
        <% } else { %>
          <ul class="quick-list">
            <% expenses.forEach(function(expense) { %>
              <li>
                <a class="quick-expense-row" href="/despesas/<%= expense.id %>">
                  <span class="quick-expense-left">
                    <strong><%= expense.dateLabel %></strong>
                    <span><%= expense.amountLabel %></span>
                  </span>
                  <span class="quick-expense-supplier"><%= expense.supplier || '-' %></span>
                </a>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

      <div class="quick-pagination">
        <% if (hasPreviousPage) { %>
          <a class="btn" href="/despesas/lista?month=<%= month %>&page=<%= page - 1 %>">Anterior</a>
        <% } %>
        <span>Página <%= page %> de <%= totalPages %></span>
        <% if (hasNextPage) { %>
          <a class="btn" href="/despesas/lista?month=<%= month %>&page=<%= page + 1 %>">Próxima</a>
        <% } %>
      </div>

      <a class="back-link" href="/despesas">Voltar</a>
    </main>
  </body>
</html>

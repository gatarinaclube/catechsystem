<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Opções - Despesas</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/quick-finance.css" />
  </head>
  <body>
    <main class="quick-shell">
      <header class="quick-header">
        <h1 class="quick-title">Opções de Despesas</h1>
      </header>

      <form class="quick-card" method="post" action="/despesas/opcoes">
        <% if (success) { %>
          <div class="message message-success">Opção salva.</div>
        <% } %>
        <% if (error) { %>
          <div class="message message-error"><%= error %></div>
        <% } %>

        <div class="field">
          <label for="type">Tipo</label>
          <select id="type" name="type" required>
            <option value="CATEGORY">Nova Categoria</option>
            <option value="SUPPLIER">Novo Fornecedor</option>
            <option value="PAYMENT">Nova Forma de Pagamento</option>
          </select>
        </div>

        <div class="field">
          <label for="name">Nome</label>
          <input id="name" name="name" required autofocus />
        </div>

        <button type="submit" class="btn">Salvar opção</button>
      </form>

      <a class="back-link" href="/despesas">Voltar</a>
    </main>
  </body>
</html>

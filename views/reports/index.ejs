<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Relatórios - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Relatórios</h2>
            <div class="welcome-sub">Lista de relatórios estratégicos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="report-grid">
          <a class="report-card is-red" href="/reports/expenses">
            <span class="report-card-icon">D</span>
            <span class="report-card-title">Despesas</span>
            <span class="report-card-sub">Despesas por mês, período e conta de pagamento.</span>
            <span class="report-card-action">Abrir relatório</span>
          </a>

          <a class="report-card is-green" href="/reports/revenues">
            <span class="report-card-icon">R</span>
            <span class="report-card-title">Receitas</span>
            <span class="report-card-sub">Pagamentos recebidos, parcelas e contas vinculadas.</span>
            <span class="report-card-action">Abrir relatório</span>
          </a>

          <a class="report-card is-blue" href="/reports/cash-flow">
            <span class="report-card-icon">F</span>
            <span class="report-card-title">Fluxo de Caixa</span>
            <span class="report-card-sub">Entradas e saídas consolidadas por período e conta.</span>
            <span class="report-card-action">Abrir relatório</span>
          </a>

          <a class="report-card is-purple" href="/reports/accounting">
            <span class="report-card-icon">C</span>
            <span class="report-card-title">Contábil</span>
            <span class="report-card-sub">Receitas, a receber e despesas organizadas por mês.</span>
            <span class="report-card-action">Abrir relatório</span>
          </a>
        </div>
      </main>
    </div>
  </body>
</html>

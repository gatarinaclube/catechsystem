<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Relatórios - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Relatórios</h2>
            <div class="welcome-sub">Lista de relatórios estratégicos do gatil.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <div class="content-card module-list-card">
          <ul class="list">
            <li class="item">
              <div>
                <a class="item-link" href="/reports/expenses">Despesas</a>
                <div class="item-sub">Despesas por mês, período e conta.</div>
              </div>
            </li>
            <li class="item">
              <div>
                <a class="item-link" href="/reports/revenues">Receitas</a>
                <div class="item-sub">Receitas por mês, período e conta.</div>
              </div>
            </li>
            <li class="item">
              <div>
                <a class="item-link" href="/reports/cash-flow">Fluxo de Caixa</a>
                <div class="item-sub">Entradas e saídas consolidadas por período e conta.</div>
              </div>
            </li>
          </ul>
        </div>
      </main>
    </div>
  </body>
</html>

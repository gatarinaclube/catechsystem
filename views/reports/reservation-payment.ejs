<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Resumo Reserva/Pagamento - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .reservation-add-form {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) auto;
        gap: 12px;
        align-items: end;
      }
      .shell {
        max-width: 100vw;
      }
      .main {
        min-width: 0;
        max-width: calc(100vw - 260px);
        overflow: hidden;
      }
      .reservation-report-card {
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
      }
      .reservation-table-shell {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow: hidden;
      }
      .reservation-table-wrap {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: auto;
        overflow-y: visible;
        border: 1px solid var(--border-soft);
        border-radius: 12px;
        background: #ffffff;
      }
      .reservation-table {
        width: max-content;
        min-width: 100%;
        max-width: none;
        border-collapse: collapse;
        font-size: 12px;
        line-height: 1.25;
      }
      .reservation-scrollbar {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        height: 18px;
        margin-top: 8px;
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        background: #f8fafc;
        position: sticky;
        bottom: 0;
        z-index: 3;
      }
      .reservation-scrollbar-inner {
        height: 1px;
        min-width: 100%;
      }
      .reservation-table th,
      .reservation-table td {
        border: 1px solid #1f2937;
        padding: 4px 6px;
        vertical-align: middle;
        white-space: nowrap;
        width: 1%;
      }
      .reservation-table th {
        background: #a3a3a3;
        color: #111827;
        font-weight: 900;
        text-align: center;
      }
      .reservation-mother-cell {
        background: #bfd8ad;
        font-weight: 900;
        text-align: center;
        min-width: 118px;
      }
      .reservation-litter-cell {
        background: #bfd8ad;
        text-align: center;
        min-width: 92px;
      }
      .reservation-input,
      .reservation-select {
        width: 100%;
        min-width: 70px;
        border: 0;
        border-radius: 0;
        background: transparent;
        color: inherit;
        font: inherit;
        font-weight: 700;
        padding: 0;
      }
      .reservation-input:focus,
      .reservation-select:focus {
        outline: 2px solid rgba(37, 99, 235, 0.35);
        background: #ffffff;
      }
      .reservation-date {
        min-width: 96px;
      }
      .reservation-location {
        min-width: 118px;
      }
      .reservation-payment-dates {
        min-width: 150px;
      }
      .reservation-actions {
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }
      .reservation-icon-button {
        width: 22px;
        height: 22px;
        border-radius: 999px;
        border: 1px solid rgba(31, 41, 55, 0.25);
        background: rgba(255, 255, 255, 0.75);
        color: #64748b;
        cursor: pointer;
        font-size: 12px;
        font-weight: 800;
        line-height: 1;
      }
      .reservation-icon-button:hover {
        background: #fff7ed;
        border-color: #f97316;
        color: #9a3412;
      }
      .reservation-remove-litter {
        margin-top: 6px;
      }
      .reservation-litter-start > td {
        border-top-width: 4px;
        border-top-color: #0f172a;
      }
      .reservation-litter-end > td {
        border-bottom-width: 4px;
        border-bottom-color: #0f172a;
      }
      .reservation-hidden-list {
        margin-top: 14px;
        border: 1px dashed var(--border-soft);
        border-radius: 10px;
        background: #fffaf0;
        padding: 10px;
      }
      .reservation-hidden-list summary {
        cursor: pointer;
        font-weight: 800;
      }
      .reservation-hidden-items {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
      }
      .reservation-hidden-items button {
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        background: #ffffff;
        padding: 5px 9px;
        cursor: pointer;
        color: var(--text-main);
      }
      .reservation-table .amount {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      .reservation-table .is-available td:not(.reservation-mother-cell):not(.reservation-litter-cell) {
        background: #dbeafe;
      }
      .reservation-table .is-reserved td:not(.reservation-mother-cell):not(.reservation-litter-cell) {
        background: #c6e0b4;
      }
      .reservation-table .is-unavailable td:not(.reservation-mother-cell):not(.reservation-litter-cell) {
        background: #f9d5a7;
      }
      .reservation-table .is-delivered td:not(.reservation-mother-cell):not(.reservation-litter-cell) {
        background: #e5e7eb;
      }
      .reservation-table .is-deceased td:not(.reservation-mother-cell):not(.reservation-litter-cell) {
        background: #f4cccc;
        color: #991b1b;
      }
      .reservation-negative {
        color: #dc2626;
        font-weight: 900;
      }
      .reservation-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
        color: var(--text-muted);
        font-size: 12px;
      }
      .reservation-legend span {
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        padding: 5px 9px;
      }
      .legend-available { background: #dbeafe; }
      .legend-reserved { background: #c6e0b4; }
      .legend-unavailable { background: #f9d5a7; }
      .legend-delivered { background: #e5e7eb; }
      .reservation-mother-cell.is-registration-pending,
      .reservation-litter-cell.is-registration-pending {
        background: #f9d5a7;
      }
      @media (max-width: 900px) {
        .main {
          max-width: 100vw;
        }
      }
      @media (max-width: 700px) {
        .reservation-add-form {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Resumo Reserva/Pagamento</h2>
            <div class="welcome-sub">Acompanhamento de ninhadas, reservas, entregas, manuais, frete e pagamentos dos filhotes.</div>
          </div>
          <div class="actions">
            <a href="/reports" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card" style="border-left:4px solid #16a34a; margin-bottom:18px;">
            <div class="content-sub">Resumo salvo com sucesso.</div>
          </div>
        <% } %>

        <% if (error) { %>
          <div class="content-card" style="border-left:4px solid #b91c1c; margin-bottom:18px;">
            <div class="content-sub"><%= error %></div>
          </div>
        <% } %>

        <section class="content-card module-panel">
          <div class="content-title">Adicionar Ninhada</div>
          <div class="content-sub">Digite o número, nome da mãe, pai, data de nascimento ou escolha uma das opções encontradas.</div>
          <form class="reservation-add-form" method="post" action="/reports/resumo-reserva-pagamento/add">
            <div class="field">
              <label class="field-label" for="litterQuery">Buscar ninhada</label>
              <input id="litterQuery" name="litterQuery" list="litterOptions" placeholder="Ex.: Estrela, 21/01/2025, número da ninhada..." autocomplete="off" />
              <input id="litterId" name="litterId" type="hidden" />
              <datalist id="litterOptions">
                <% litterOptions.forEach(function(option) { %>
                  <option data-id="<%= option.id %>" value="<%= option.label %>"></option>
                <% }) %>
              </datalist>
            </div>
            <button class="btn btn-primary" type="submit">Adicionar ninhada</button>
          </form>
        </section>

        <form method="post" action="/reports/resumo-reserva-pagamento/save">
          <section class="content-card reservation-report-card">
            <div class="report-summary">
              <div>
                <div class="content-title">Ninhadas no resumo</div>
                <div class="content-sub"><%= summaries.length %> ninhada(s) adicionada(s).</div>
              </div>
              <% if (summaries.length) { %>
                <button class="btn btn-primary" type="submit">Salvar alterações</button>
              <% } %>
            </div>

            <div class="reservation-legend">
              <span class="legend-available">Disponível</span>
              <span class="legend-reserved">Reservado/com receita</span>
              <span class="legend-unavailable">Indisponível/sem receita</span>
              <span class="legend-delivered">Entregue</span>
            </div>

            <% if (!summaries.length) { %>
              <div class="empty" style="margin-top:14px;">Nenhuma ninhada adicionada ao resumo.</div>
            <% } else { %>
              <div class="reservation-table-shell">
                <% summaries.forEach(function(summary) { %>
                  <input type="hidden" name="summaryIds[]" value="<%= summary.id %>" />
                <% }) %>
                <div class="reservation-table-wrap" style="margin-top:14px;" id="reservationTableWrap">
                  <table class="reservation-table">
                    <thead>
                      <tr>
                        <th>Mãe</th>
                        <th>Nascimento</th>
                        <th>Reg. Ninhada</th>
                        <th>Gato</th>
                        <th>Nome do Gato</th>
                        <th>Entrega</th>
                        <th>Comprador</th>
                        <th>Local / Entrega</th>
                        <th>Reserva Aérea</th>
                        <th>Valor</th>
                        <th>Frete</th>
                        <th>Total</th>
                        <th>Pago</th>
                        <th>Restam</th>
                        <th>Datas de Pagamento</th>
                        <th>Conta/Nota</th>
                        <th>Grupo</th>
                        <th>Manual</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% summaries.forEach(function(summary) { %>
                        <% const kittens = summary.kittens.length ? summary.kittens : [{ empty: true, rowClass: 'is-unavailable' }]; %>
                        <% kittens.forEach(function(kitten, index) { %>
                          <tr class="<%= kitten.rowClass %> <%= index === 0 ? 'reservation-litter-start' : '' %> <%= index === kittens.length - 1 ? 'reservation-litter-end' : '' %>">
                            <% if (index === 0) { %>
                              <% const registrationPendingClass = summary.registrationStatus === 'Solicitar' ? 'is-registration-pending' : ''; %>
                              <td class="reservation-mother-cell <%= registrationPendingClass %>" rowspan="<%= kittens.length %>">
                                <div><%= summary.motherShortName || '-' %></div>
                                <button
                                  class="reservation-icon-button reservation-remove-litter"
                                  type="submit"
                                  title="Remover ninhada do resumo"
                                  aria-label="Remover ninhada do resumo"
                                  formaction="/reports/resumo-reserva-pagamento/remove-litter"
                                  formmethod="post"
                                  name="removeSummary"
                                  value="<%= summary.id %>"
                                  data-confirm-action="Remover esta ninhada do resumo? A ninhada original não será apagada."
                                >×</button>
                              </td>
                              <td class="reservation-litter-cell <%= registrationPendingClass %>" rowspan="<%= kittens.length %>"><%= summary.litterBirthLabel || '-' %></td>
                              <td class="reservation-litter-cell <%= registrationPendingClass %>" rowspan="<%= kittens.length %>">
                                <select class="reservation-select" name="registrationStatus_<%= summary.id %>">
                                  <% registrationOptions.forEach(function(option) { %>
                                    <option value="<%= option %>" <%= summary.registrationStatus === option ? 'selected' : '' %>><%= option %></option>
                                  <% }) %>
                                </select>
                              </td>
                          <% } %>

                          <% if (kitten.empty) { %>
                            <td colspan="15">Nenhum filhote visível nesta ninhada.</td>
                          <% } else { %>
                            <td>
                              <span class="reservation-actions">
                                <strong><%= kitten.kittenNumberLabel %></strong>
                                <button
                                  class="reservation-icon-button"
                                  type="submit"
                                  title="Ocultar filhote"
                                  aria-label="Ocultar filhote"
                                  formaction="/reports/resumo-reserva-pagamento/hide-kitten"
                                  formmethod="post"
                                  name="hideKitten"
                                  value="<%= summary.id %>:<%= kitten.id %>"
                                >–</button>
                              </span>
                            </td>
                            <td><strong><%= kitten.kittenNameLabel %></strong></td>
                            <td>
                              <input class="reservation-input reservation-date" type="date" name="kittenRow_<%= summary.id %>_<%= kitten.id %>_deliveryDate" value="<%= kitten.deliveryDateInput %>" />
                            </td>
                            <td><%= kitten.buyerFirstName || '' %></td>
                            <td>
                              <input class="reservation-input reservation-location" name="kittenRow_<%= summary.id %>_<%= kitten.id %>_deliveryLocation" value="<%= kitten.deliveryLocation %>" placeholder="Cidade/local" />
                            </td>
                            <td>
                              <select class="reservation-select" name="kittenRow_<%= summary.id %>_<%= kitten.id %>_airReservation">
                                <% airReservationOptions.forEach(function(option) { %>
                                    <option value="<%= option %>" <%= kitten.airReservation === option ? 'selected' : '' %>><%= option %></option>
                                <% }) %>
                              </select>
                            </td>
                            <td class="amount"><%= kitten.valueLabel || '' %></td>
                            <td class="amount"><%= kitten.freightLabel || '' %></td>
                            <td class="amount"><strong><%= kitten.totalLabel || '' %></strong></td>
                            <td class="amount"><strong><%= kitten.paidLabel || '' %></strong></td>
                            <td class="amount <%= kitten.remainingLabel && !/^R\$\s?0/.test(kitten.remainingLabel) ? 'reservation-negative' : '' %>"><%= kitten.remainingLabel || '' %></td>
                            <td class="reservation-payment-dates"><%= kitten.paymentDates || '' %></td>
                            <td><%= kitten.accountNote || '' %></td>
                            <td>
                              <select class="reservation-select" name="kittenRow_<%= summary.id %>_<%= kitten.id %>_groupStatus">
                                <% yesNoOptions.forEach(function(option) { %>
                                    <option value="<%= option %>" <%= kitten.groupStatus === option ? 'selected' : '' %>><%= option %></option>
                                  <% }) %>
                                </select>
                              </td>
                              <td>
                                <select class="reservation-select" name="kittenRow_<%= summary.id %>_<%= kitten.id %>_manualStatus">
                                  <% manualOptions.forEach(function(option) { %>
                                    <option value="<%= option %>" <%= kitten.manualStatus === option ? 'selected' : '' %>><%= option %></option>
                                <% }) %>
                              </select>
                            </td>
                          <% } %>
                        </tr>
                      <% }) %>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
                <div class="reservation-scrollbar" id="reservationScrollbar" aria-label="Rolagem horizontal da tabela">
                  <div class="reservation-scrollbar-inner" id="reservationScrollbarInner"></div>
                </div>
              </div>
              <%
                const summariesWithHiddenKittens = summaries.filter(function(summary) {
                  return summary.hiddenKittens && summary.hiddenKittens.length;
                });
              %>
              <% if (summariesWithHiddenKittens.length) { %>
                <details class="reservation-hidden-list">
                  <summary>Filhotes ocultos</summary>
                  <% summariesWithHiddenKittens.forEach(function(summary) { %>
                    <div class="content-sub" style="margin-top:10px;"><strong><%= summary.motherShortName || '-' %></strong></div>
                    <div class="reservation-hidden-items">
                      <% summary.hiddenKittens.forEach(function(kitten) { %>
                        <button
                          type="submit"
                          formaction="/reports/resumo-reserva-pagamento/show-kitten"
                          formmethod="post"
                          name="showKitten"
                          value="<%= summary.id %>:<%= kitten.id %>"
                          title="Voltar a exibir este filhote"
                        >
                          <%= kitten.kittenNumberLabel %> - <%= kitten.kittenNameLabel %>
                        </button>
                      <% }) %>
                    </div>
                  <% }) %>
                </details>
              <% } %>
              <div class="actions" style="justify-content:flex-end; margin-top:14px;">
                <button class="btn btn-primary" type="submit">Salvar alterações</button>
              </div>
            <% } %>
          </section>
        </form>
      </main>
    </div>

    <script>
      const litterInput = document.getElementById("litterQuery");
      const litterIdInput = document.getElementById("litterId");
      const litterOptions = Array.from(document.querySelectorAll("#litterOptions option"));

      litterInput?.addEventListener("input", () => {
        const selected = litterOptions.find((option) => option.value === litterInput.value);
        litterIdInput.value = selected ? selected.dataset.id || "" : "";
      });

      document.querySelectorAll("[data-confirm-action]").forEach((button) => {
        button.addEventListener("click", (event) => {
          if (!window.confirm(button.dataset.confirmAction || "Confirmar esta ação?")) {
            event.preventDefault();
          }
        });
      });

      const tableWrap = document.getElementById("reservationTableWrap");
      const bottomScrollbar = document.getElementById("reservationScrollbar");
      const bottomScrollbarInner = document.getElementById("reservationScrollbarInner");

      if (tableWrap && bottomScrollbar && bottomScrollbarInner) {
        const table = tableWrap.querySelector(".reservation-table");

        const syncWidth = () => {
          const tableWidth = table ? table.scrollWidth : 0;
          const scrollWidth = Math.max(tableWidth, tableWrap.scrollWidth, tableWrap.clientWidth);
          bottomScrollbarInner.style.width = `${scrollWidth}px`;
          bottomScrollbar.style.display = scrollWidth > tableWrap.clientWidth ? "block" : "none";
          bottomScrollbar.scrollLeft = tableWrap.scrollLeft;
        };
        let syncingFromTable = false;
        let syncingFromBar = false;

        tableWrap.addEventListener("scroll", () => {
          if (syncingFromBar) return;
          syncingFromTable = true;
          bottomScrollbar.scrollLeft = tableWrap.scrollLeft;
          syncingFromTable = false;
        });

        bottomScrollbar.addEventListener("scroll", () => {
          if (syncingFromTable) return;
          syncingFromBar = true;
          tableWrap.scrollLeft = bottomScrollbar.scrollLeft;
          syncingFromBar = false;
        });

        requestAnimationFrame(syncWidth);
        window.addEventListener("resize", syncWidth);
        window.addEventListener("load", syncWidth);

        if ("ResizeObserver" in window) {
          const resizeObserver = new ResizeObserver(syncWidth);
          resizeObserver.observe(tableWrap);
          if (table) resizeObserver.observe(table);
        }
      }
    </script>
  </body>
</html>

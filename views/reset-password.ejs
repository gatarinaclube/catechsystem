<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Nova Senha - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body class="auth-body">
    <div class="auth-card">
      <div class="auth-logo">CaTech System</div>
      <h1 class="auth-title">Nova senha</h1>
      <div class="auth-subtitle">
        Crie uma nova senha para acessar o sistema.
      </div>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>

      <% if (typeof success !== "undefined" && success) { %>
        <div class="auth-success"><%= success %></div>
      <% } %>

      <% if (token) { %>
        <form method="post" action="/reset-password/<%= token %>" class="auth-form">
          <div class="auth-field">
            <label for="password">Nova senha</label>
            <input
              id="password"
              type="password"
              name="password"
              placeholder="********"
              minlength="6"
              required
            />
          </div>

          <div class="auth-field">
            <label for="confirmPassword">Confirmar senha</label>
            <input
              id="confirmPassword"
              type="password"
              name="confirmPassword"
              placeholder="********"
              minlength="6"
              required
            />
          </div>

          <button type="submit" class="auth-button">Salvar nova senha</button>
        </form>
      <% } %>

      <div class="auth-footer">
        <a href="/login">Voltar para o login</a>
      </div>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Receitas Registradas</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/quick-finance.css" />
  </head>
  <body>
    <main class="quick-shell">
      <header class="quick-header">
        <h1 class="quick-title">Receitas Registradas</h1>
      </header>

      <form class="quick-card quick-filter-card" method="get" action="/receitas/lista">
        <div class="field">
          <label for="month">Mês</label>
          <input id="month" name="month" type="month" value="<%= month %>" />
        </div>
        <button type="submit" class="btn">Filtrar</button>
      </form>

      <div class="quick-card">
        <% if (!revenues.length) { %>
          <div class="empty">Nenhuma receita registrada neste mês.</div>
        <% } else { %>
          <ul class="quick-list">
            <% revenues.forEach(function(revenue) { %>
              <li>
                <a href="/receitas/<%= revenue.id %>">
                  <strong><%= revenue.kittenLabel || '-' %></strong>
                  <span><%= revenue.client ? revenue.client.fullName : '-' %></span>
                </a>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </div>

      <div class="quick-pagination">
        <% if (hasPreviousPage) { %>
          <a class="btn" href="/receitas/lista?month=<%= month %>&page=<%= page - 1 %>">Anterior</a>
        <% } %>
        <span>Página <%= page %> de <%= totalPages %></span>
        <% if (hasNextPage) { %>
          <a class="btn" href="/receitas/lista?month=<%= month %>&page=<%= page + 1 %>">Próxima</a>
        <% } %>
      </div>

      <a class="back-link" href="/receitas">Voltar</a>
    </main>
  </body>
</html>

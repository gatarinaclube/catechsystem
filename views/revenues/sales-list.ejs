<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Vendas - PetGus</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Vendas</h2>
            <div class="welcome-sub">Receitas registradas para acompanhamento de pagamentos.</div>
          </div>
          <div class="actions">
            <a href="/receitas" class="btn btn-primary">Nova Venda</a>
          </div>
        </div>

        <div class="content-card module-list-card">
          <% if (!revenues.length) { %>
            <div class="empty">Nenhuma venda registrada.</div>
          <% } else { %>
            <div class="record-list">
              <% revenues.forEach(function(revenue) { %>
                <div class="record-row">
                  <a class="record-row-main-link" href="/vendas/<%= revenue.id %>?returnTo=<%= encodeURIComponent('/vendas') %>">
                    <div class="record-main">
                      <div class="record-title">
                        <%= revenue.kittenLabel || "Venda sem filhote" %>
                      </div>
                      <div class="record-sub">
                        <%= revenue.client ? revenue.client.fullName : "Cliente desconhecido" %>
                        <% if (revenue.paymentAccount) { %>
                          · <%= revenue.paymentAccount %>
                        <% } %>
                        <% if (revenue.invoiceNumber) { %>
                          · NF <%= revenue.invoiceNumber %>
                        <% } %>
                      </div>
                    </div>
                    <div class="record-meta">
                      <span class="status-pill is-green">Venda</span>
                      <div style="margin-top:6px;">
                      <%= (Number(revenue.totalAmountCents || 0) / 100).toLocaleString("pt-BR", { style: "currency", currency: "BRL" }) %>
                      </div>
                    </div>
                  </a>
                  <form class="record-row-delete" method="post" action="/vendas/<%= revenue.id %>/delete" onsubmit="return confirm('Excluir esta receita/venda?');">
                    <input type="hidden" name="returnTo" value="/vendas" />
                    <button class="record-delete-button" type="submit" title="Excluir receita/venda" aria-label="Excluir receita/venda">🗑</button>
                  </form>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>

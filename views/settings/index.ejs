<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Configurações - CaTech</title>
    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/cattery-admin.css" />
    <style>
      .settings-options {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 10px;
      }
      .settings-check {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--border-soft);
        border-radius: 8px;
        padding: 10px 12px;
        background: #ffffff;
        font-size: 13px;
      }
      .settings-toggle-row {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: center;
        margin-top: 12px;
      }
      .settings-switch {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 800;
      }
      .settings-switch input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }
      .settings-switch-track {
        position: relative;
        width: 50px;
        height: 28px;
        border-radius: 999px;
        background: #cbd5e1;
        transition: 0.2s ease;
      }
      .settings-switch-track::after {
        content: "";
        position: absolute;
        top: 4px;
        left: 4px;
        width: 20px;
        height: 20px;
        border-radius: 999px;
        background: #ffffff;
        box-shadow: 0 2px 6px rgba(15, 23, 42, 0.22);
        transition: 0.2s ease;
      }
      .settings-switch input:checked + .settings-switch-track {
        background: #16a34a;
      }
      .settings-switch input:checked + .settings-switch-track::after {
        transform: translateX(22px);
      }
      .settings-collapsible {
        margin-top: 14px;
      }
      .breed-picker {
        display: grid;
        grid-template-columns: minmax(220px, 360px) auto;
        gap: 10px;
        align-items: end;
        margin-top: 10px;
      }
      .breed-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
      }
      .breed-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        padding: 6px 10px;
        background: rgba(245, 158, 11, 0.08);
        color: var(--text-main);
        font-size: 13px;
      }
      .breed-chip button {
        border: none;
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        font-size: 16px;
        line-height: 1;
        padding: 0;
      }
      .logo-panel {
        display: grid;
        grid-template-columns: 180px minmax(0, 1fr);
        gap: 18px;
        align-items: center;
        margin-top: 12px;
      }
      .logo-preview {
        width: 180px;
        height: 110px;
        border: 1px dashed var(--border-soft);
        border-radius: 8px;
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        color: var(--text-muted);
        font-size: 12px;
        text-align: center;
        padding: 10px;
      }
      .logo-preview img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
      }
      .plan-limit-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 14px;
        font-size: 13px;
      }
      .plan-limit-table th,
      .plan-limit-table td {
        border-bottom: 1px solid var(--border-soft);
        padding: 10px 8px;
        text-align: left;
        vertical-align: top;
      }
      .plan-limit-table th {
        color: var(--text-muted);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .plan-limit-table input {
        min-width: 92px;
      }
      .plan-limit-profile {
        font-weight: 800;
        color: var(--text-main);
      }
      @media (max-width: 700px) {
        .breed-picker,
        .logo-panel {
          grid-template-columns: 1fr;
        }
        .plan-limit-table {
          display: block;
          overflow-x: auto;
          white-space: nowrap;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>
      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Configurações</h2>
            <div class="welcome-sub">Preferências do login para dados do gatil, raças e exames.</div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">Voltar</a>
          </div>
        </div>

        <% if (success) { %>
          <div class="content-card" style="border-left:4px solid #16a34a; margin-bottom:18px;">
            <div class="content-sub">Configurações salvas com sucesso.</div>
          </div>
        <% } %>

        <% if (error) { %>
          <div class="content-card" style="border-left:4px solid #b91c1c; margin-bottom:18px;">
            <div class="content-sub"><%= error %></div>
          </div>
        <% } %>

        <form method="post" action="/settings" enctype="multipart/form-data">
          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Link rápido de despesas</div>
            <div class="content-sub">Use este endereço para salvar o lançamento rápido na tela inicial do celular.</div>
            <div class="field" style="margin-top:12px;">
              <label class="field-label" for="expensePublicLink">Link para salvar no celular</label>
              <input
                id="expensePublicLink"
                type="text"
                value="<%= expensePublicLink || '' %>"
                readonly
                onclick="this.select()"
              />
              <div class="section-note">
                Abra este link no celular e use “Adicionar à tela inicial” no Android ou “Adicionar à Tela de Início” no iPhone.
              </div>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Dados do Gatil</div>
            <div class="grid-2" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="catteryName">Nome do Gatil</label>
                <input id="catteryName" name="catteryName" type="text" value="<%= settings.catteryName || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="catteryEmail">E-mail</label>
                <input id="catteryEmail" name="catteryEmail" type="email" value="<%= settings.catteryEmail || '' %>" />
              </div>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Dados do Veterinário</div>
            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="veterinarian">Veterinário</label>
                <input id="veterinarian" name="veterinarian" type="text" value="<%= settings.veterinarian || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="crmv">CRMV</label>
                <input id="crmv" name="crmv" type="text" value="<%= settings.crmv || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="crmvUf">UF</label>
                <select id="crmvUf" name="crmvUf">
                  <option value="">UF</option>
                  <% ["AC","AL","AP","AM","BA","CE","DF","ES","GO","MA","MT","MS","MG","PA","PB","PR","PE","PI","RJ","RN","RS","RO","RR","SC","SP","SE","TO"].forEach(function(uf) { %>
                    <option value="<%= uf %>" <%= settings.crmvUf === uf ? "selected" : "" %>><%= uf %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="veterinarianClinicName">Clínica Veterinária</label>
                <input id="veterinarianClinicName" name="veterinarianClinicName" type="text" value="<%= settings.veterinarianClinicName || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="veterinarianTradeName">Nome Fantasia</label>
                <input id="veterinarianTradeName" name="veterinarianTradeName" type="text" value="<%= settings.veterinarianTradeName || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="veterinarianCnpj">CNPJ</label>
                <input id="veterinarianCnpj" name="veterinarianCnpj" type="text" value="<%= settings.veterinarianCnpj || '' %>" />
              </div>
            </div>
            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="veterinarianAddress">Endereço</label>
                <input id="veterinarianAddress" name="veterinarianAddress" type="text" value="<%= settings.veterinarianAddress || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="veterinarianCity">Cidade</label>
                <input id="veterinarianCity" name="veterinarianCity" type="text" value="<%= settings.veterinarianCity || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="veterinarianCep">CEP</label>
                <input id="veterinarianCep" name="veterinarianCep" type="text" value="<%= settings.veterinarianCep || '' %>" />
              </div>
            </div>
            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="veterinarianState">Estado</label>
                <input id="veterinarianState" name="veterinarianState" type="text" value="<%= settings.veterinarianState || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="veterinarianPhone">Telefone</label>
                <input id="veterinarianPhone" name="veterinarianPhone" type="text" value="<%= settings.veterinarianPhone || '' %>" />
              </div>
              <div class="field">
                <label class="field-label" for="veterinarianMobile">Celular</label>
                <input id="veterinarianMobile" name="veterinarianMobile" type="text" value="<%= settings.veterinarianMobile || '' %>" />
              </div>
            </div>
            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="veterinarianEmail">E-mail</label>
                <input id="veterinarianEmail" name="veterinarianEmail" type="email" value="<%= settings.veterinarianEmail || '' %>" />
              </div>
            </div>
            <div class="section-note">
              Quando preenchidas, essas informações poderão ser utilizadas em documentos do sistema,
              como atestados de saúde e outros documentos pertinentes.
            </div>
            <div class="logo-panel" style="margin-top:14px;">
              <div class="logo-preview">
                <% if (settings.veterinarianLogoPath) { %>
                  <img src="<%= settings.veterinarianLogoPath %>" alt="Logo do veterinário" />
                <% } else { %>
                  Nenhum logo veterinário
                <% } %>
              </div>
              <div class="field">
                <label class="field-label" for="veterinarianLogo">Logo do veterinário</label>
                <input id="veterinarianLogo" name="veterinarianLogo" type="file" accept="image/png,image/jpeg,image/webp" />
                <div class="section-note">
                  Usado no cabeçalho do Atestado de Saúde quando essa opção for escolhida no documento.
                </div>
              </div>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Logo do Gatil</div>
            <div class="logo-panel">
              <div class="logo-preview">
                <% if (settings.logoPath) { %>
                  <img src="<%= settings.logoPath %>" alt="Logo do gatil" />
                <% } else { %>
                  Nenhum logo enviado
                <% } %>
              </div>
              <div class="field">
                <label class="field-label" for="logo">Enviar logo</label>
                <input id="logo" name="logo" type="file" accept="image/png,image/jpeg,image/webp" />
                <div class="section-note">
                  Formatos aceitos: PNG, JPG ou WEBP. Tamanho máximo: 2 MB.
                  Para impressão, prefira PNG com fundo transparente e proporção horizontal,
                  perto de 1200 x 600 px.
                </div>
              </div>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="history-section-head" style="margin-bottom:12px;">
              <div>
                <div class="content-title">E-mail do Usuário</div>
                <div class="content-sub">SMTP próprio usado em e-mail marketing e envio de documentos.</div>
              </div>
              <span class="status-pill <%= settings.smtpSettings && settings.smtpSettings.isComplete ? 'is-green' : 'is-yellow' %>">
                <%= settings.smtpSettings && settings.smtpSettings.isComplete ? 'SMTP configurado' : 'SMTP não configurado' %>
              </span>
            </div>
            <div class="grid-2">
              <div class="field">
                <label class="field-label" for="fromName">Nome do remetente</label>
                <input id="fromName" name="fromName" type="text" value="<%= settings.smtpSettings?.fromName || '' %>" placeholder="Nome do gatil" />
              </div>
              <div class="field">
                <label class="field-label" for="fromEmail">E-mail remetente</label>
                <input id="fromEmail" name="fromEmail" type="email" value="<%= settings.smtpSettings?.fromEmail || '' %>" placeholder="contato@seudominio.com" />
              </div>
            </div>
            <div class="grid-3" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="smtpHost">Servidor SMTP</label>
                <input id="smtpHost" name="smtpHost" type="text" value="<%= settings.smtpSettings?.host || '' %>" placeholder="smtp.seudominio.com" />
              </div>
              <div class="field">
                <label class="field-label" for="smtpPort">Porta</label>
                <input id="smtpPort" name="smtpPort" type="number" min="1" max="65535" value="<%= settings.smtpSettings?.port || 587 %>" />
              </div>
              <div class="field">
                <label class="field-label">&nbsp;</label>
                <label class="settings-check" style="margin:0;">
                  <input type="checkbox" name="smtpSecure" <%= settings.smtpSettings?.secure ? 'checked' : '' %> />
                  <span>Usar SSL/TLS</span>
                </label>
              </div>
            </div>
            <div class="grid-2" style="margin-top:12px;">
              <div class="field">
                <label class="field-label" for="smtpUser">Usuário SMTP</label>
                <input id="smtpUser" name="smtpUser" type="text" value="<%= settings.smtpSettings?.user || '' %>" autocomplete="off" />
              </div>
              <div class="field">
                <label class="field-label" for="smtpPassword">Senha SMTP</label>
                <input id="smtpPassword" name="smtpPassword" type="password" placeholder="<%= settings.smtpSettings?.hasPassword ? 'Senha já cadastrada' : 'Senha ou senha de app' %>" autocomplete="new-password" />
              </div>
            </div>
            <% if (settings.smtpSettings?.hasPassword) { %>
              <label class="settings-check" style="margin-top:12px;">
                <input type="checkbox" name="clearSmtpPassword" />
                <span>Remover senha SMTP salva</span>
              </label>
            <% } %>
            <div class="section-note">
              Para enviar manuais e campanhas, configure um SMTP próprio do usuário. As notificações gerais do sistema continuam usando a configuração global.
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Membro</div>
            <div class="settings-options">
              <% membershipOptions.forEach(function(option) { %>
                <label class="settings-check">
                  <input type="checkbox" name="memberships" value="<%= option %>" <%= settings.memberships.includes(option) ? "checked" : "" %> />
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Raças</div>
            <div class="breed-picker">
              <div class="field">
                <label class="field-label" for="breedSelect">Selecionar raça</label>
                <select id="breedSelect">
                  <option value="">Selecione...</option>
                  <% breedOptions.forEach(function(option) { %>
                    <option value="<%= option %>"><%= option %></option>
                  <% }) %>
                </select>
              </div>
              <button type="button" class="btn btn-primary" id="addBreed">+</button>
            </div>
            <div class="breed-list" id="breedList"></div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Exames</div>
            <div class="settings-options">
              <% examOptions.forEach(function(option) { %>
                <label class="settings-check">
                  <input type="checkbox" name="exams" value="<%= option %>" <%= settings.exams.includes(option) ? "checked" : "" %> />
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
          </div>

          <div class="content-card" style="margin-bottom:18px;">
            <div class="content-title">Aviso automático de vacinas</div>
            <div class="section-note">
              Quando ativado, o sistema envia e-mail avisando sobre vacinas próximas do vencimento,
              conforme a antecedência e os grupos de gatos selecionados.
            </div>

            <div class="settings-toggle-row">
              <label class="settings-switch">
                <input
                  id="vaccineReminderEnabled"
                  name="vaccineReminderEnabled"
                  type="checkbox"
                  <%= settings.vaccineReminderEnabled ? "checked" : "" %>
                />
                <span class="settings-switch-track"></span>
                <span>Enviar e-mail automático</span>
              </label>
            </div>

            <div class="settings-collapsible" id="vaccineReminderFields">
              <div class="section-note" style="margin-top:0;">
                Regras usadas para calcular os vencimentos das vacinas no módulo Vacinação, Painel e nos e-mails automáticos.
              </div>
              <div class="grid-3" style="margin-top:12px;">
                <div class="field">
                  <label class="field-label" for="antirabicFirstDoseMonths">Primeira dose Antirrábica (meses)</label>
                  <input
                    id="antirabicFirstDoseMonths"
                    name="antirabicFirstDoseMonths"
                    type="number"
                    min="1"
                    step="1"
                    value="<%= settings.antirabicFirstDoseMonths ?? 3 %>"
                  />
                </div>
                <div class="field">
                  <label class="field-label" for="antirabicAnnualBooster">Reforço Antirrábica Anual</label>
                  <select id="antirabicAnnualBooster" name="antirabicAnnualBooster">
                    <option value="YES" <%= settings.antirabicAnnualBooster ? "selected" : "" %>>Sim</option>
                    <option value="NO" <%= !settings.antirabicAnnualBooster ? "selected" : "" %>>Não</option>
                  </select>
                </div>
                <div class="field" id="antirabicIntervalField">
                  <label class="field-label" for="antirabicBoosterIntervalYears">Intervalo Antirrábica (anos)</label>
                  <input
                    id="antirabicBoosterIntervalYears"
                    name="antirabicBoosterIntervalYears"
                    type="number"
                    min="1"
                    step="1"
                    value="<%= settings.antirabicBoosterIntervalYears ?? 1 %>"
                  />
                </div>
              </div>

              <div class="grid-3" style="margin-top:12px;">
                <div class="field">
                  <label class="field-label" for="felineFirstDoseMonths">Primeira dose Feline (meses)</label>
                  <input
                    id="felineFirstDoseMonths"
                    name="felineFirstDoseMonths"
                    type="number"
                    min="1"
                    step="1"
                    value="<%= settings.felineFirstDoseMonths ?? 2 %>"
                  />
                </div>
                <div class="field">
                  <label class="field-label" for="felineSecondDoseDays">Segunda dose Feline (dias após a primeira)</label>
                  <input
                    id="felineSecondDoseDays"
                    name="felineSecondDoseDays"
                    type="number"
                    min="1"
                    step="1"
                    value="<%= settings.felineSecondDoseDays ?? 21 %>"
                  />
                </div>
                <div class="field">
                  <label class="field-label" for="felineThirdDoseDays">Terceira dose Feline (dias após a segunda)</label>
                  <input
                    id="felineThirdDoseDays"
                    name="felineThirdDoseDays"
                    type="number"
                    min="1"
                    step="1"
                    value="<%= settings.felineThirdDoseDays ?? '' %>"
                    placeholder="Deixe vazio para não usar terceira dose"
                  />
                </div>
              </div>

              <div class="grid-3" style="margin-top:12px;">
                <div class="field">
                  <label class="field-label" for="felineAnnualBooster">Reforço Feline Anual</label>
                  <select id="felineAnnualBooster" name="felineAnnualBooster">
                    <option value="YES" <%= settings.felineAnnualBooster ? "selected" : "" %>>Sim</option>
                    <option value="NO" <%= !settings.felineAnnualBooster ? "selected" : "" %>>Não</option>
                  </select>
                </div>
                <div class="field" id="felineIntervalField">
                  <label class="field-label" for="felineBoosterIntervalYears">Intervalo Feline (anos)</label>
                  <input
                    id="felineBoosterIntervalYears"
                    name="felineBoosterIntervalYears"
                    type="number"
                    min="1"
                    step="1"
                    value="<%= settings.felineBoosterIntervalYears ?? 1 %>"
                  />
                </div>
              </div>

              <div class="grid-3">
                <div class="field">
                  <label class="field-label" for="vaccineReminderDaysBefore">Avisar quantos dias antes?</label>
                  <input
                    id="vaccineReminderDaysBefore"
                    name="vaccineReminderDaysBefore"
                    type="number"
                    min="0"
                    step="1"
                    value="<%= settings.vaccineReminderDaysBefore ?? 15 %>"
                  />
                </div>
              </div>

              <div class="field" style="margin-top:14px;">
                <label class="field-label">Receber notificações de</label>
                <div class="settings-options">
                  <% vaccineReminderGroupOptions.forEach(function(option) { %>
                    <label class="settings-check">
                      <input
                        type="checkbox"
                        name="vaccineReminderGroups"
                        value="<%= option.value %>"
                        <%= settings.vaccineReminderGroups.includes(option.value) ? "checked" : "" %>
                      />
                      <span><%= option.label %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>

          <% if (canManagePlanLimits) { %>
            <div class="content-card" style="margin-bottom:18px;">
              <div class="content-title">Limites dos perfis</div>
              <div class="section-note">
                As alterações abaixo valem automaticamente para todos os usuários do respectivo perfil.
                Deixe os campos de quantidade em branco para permitir uso ilimitado.
              </div>
              <table class="plan-limit-table">
                <thead>
                  <tr>
                    <th>Perfil</th>
                    <th>Arquivo máx. (MB)</th>
                    <th>Padreadores</th>
                    <th>Ninhadas na vitrine</th>
                    <th>Comparativos na vitrine</th>
                    <th>Ninhadas por ano</th>
                    <th>Filhotes por ano</th>
                  </tr>
                </thead>
                <tbody>
                  <% planLimits.forEach(function(plan) { %>
                    <tr>
                      <td class="plan-limit-profile"><%= plan.label %></td>
                      <td>
                        <input
                          name="plan_<%= plan.role %>_uploadLimitMb"
                          type="number"
                          min="0.1"
                          step="0.1"
                          value="<%= plan.uploadLimitMb || '' %>"
                        />
                      </td>
                      <td>
                        <input name="plan_<%= plan.role %>_breeders" type="number" min="0" step="1" value="<%= plan.breeders ?? '' %>" />
                      </td>
                      <td>
                        <input name="plan_<%= plan.role %>_showcaseLitters" type="number" min="0" step="1" value="<%= plan.showcaseLitters ?? '' %>" />
                      </td>
                      <td>
                        <input name="plan_<%= plan.role %>_showcaseEvolutionComparisons" type="number" min="0" step="1" value="<%= plan.showcaseEvolutionComparisons ?? '' %>" />
                      </td>
                      <td>
                        <input name="plan_<%= plan.role %>_littersPerYear" type="number" min="0" step="1" value="<%= plan.littersPerYear ?? '' %>" />
                      </td>
                      <td>
                        <input name="plan_<%= plan.role %>_kittensPerYear" type="number" min="0" step="1" value="<%= plan.kittensPerYear ?? '' %>" />
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <div class="form-actions" style="text-align:right;">
            <button type="submit" class="btn btn-primary">Salvar</button>
          </div>
        </form>
      </main>
    </div>

    <script>
      (function () {
        const selectedBreeds = new Set(<%- JSON.stringify(settings.breeds || []) %>);
        const breedSelect = document.getElementById("breedSelect");
        const addBreed = document.getElementById("addBreed");
        const breedList = document.getElementById("breedList");

        function renderBreeds() {
          breedList.innerHTML = "";

          if (!selectedBreeds.size) {
            const empty = document.createElement("div");
            empty.className = "empty";
            empty.textContent = "Nenhuma raça selecionada.";
            breedList.appendChild(empty);
            return;
          }

          Array.from(selectedBreeds).sort().forEach((breed) => {
            const chip = document.createElement("span");
            chip.className = "breed-chip";

            const label = document.createElement("span");
            label.textContent = breed;

            const input = document.createElement("input");
            input.type = "hidden";
            input.name = "breeds";
            input.value = breed;

            const remove = document.createElement("button");
            remove.type = "button";
            remove.textContent = "×";
            remove.addEventListener("click", () => {
              selectedBreeds.delete(breed);
              renderBreeds();
            });

            chip.appendChild(label);
            chip.appendChild(input);
            chip.appendChild(remove);
            breedList.appendChild(chip);
          });
        }

        addBreed.addEventListener("click", () => {
          if (!breedSelect.value) return;
          selectedBreeds.add(breedSelect.value);
          breedSelect.value = "";
          renderBreeds();
        });

        renderBreeds();

        const vaccineToggle = document.getElementById("vaccineReminderEnabled");
        const vaccineFields = document.getElementById("vaccineReminderFields");
        const antirabicAnnualBooster = document.getElementById("antirabicAnnualBooster");
        const antirabicIntervalField = document.getElementById("antirabicIntervalField");
        const felineAnnualBooster = document.getElementById("felineAnnualBooster");
        const felineIntervalField = document.getElementById("felineIntervalField");
        function refreshVaccineFields() {
          if (!vaccineToggle || !vaccineFields) return;
          vaccineFields.style.display = vaccineToggle.checked ? "block" : "none";
        }
        function refreshVaccineIntervals() {
          if (antirabicAnnualBooster && antirabicIntervalField) {
            antirabicIntervalField.style.display = antirabicAnnualBooster.value === "NO" ? "block" : "none";
          }
          if (felineAnnualBooster && felineIntervalField) {
            felineIntervalField.style.display = felineAnnualBooster.value === "NO" ? "block" : "none";
          }
        }
        vaccineToggle?.addEventListener("change", refreshVaccineFields);
        antirabicAnnualBooster?.addEventListener("change", refreshVaccineIntervals);
        felineAnnualBooster?.addEventListener("change", refreshVaccineIntervals);
        refreshVaccineFields();
        refreshVaccineIntervals();
      })();
    </script>
  </body>
</html>

<form
  method="post"
  action="/users/<%= u.id %>/quick-update"
  style="display:flex; flex-wrap:nowrap; gap:8px; justify-content:flex-end; align-items:center; max-width:none;"
>
  <select name="approvalStatus" style="width:126px; min-width:126px;">
    <% approvalOptions.forEach(function(option) { %>
      <option
        value="<%= option.value %>"
        <%= u.approvalStatus === option.value ? "selected" : "" %>
      >
        <%= option.label %>
      </option>
    <% }) %>
  </select>

  <select name="role" style="width:132px; min-width:132px;">
    <% roleOptions.forEach(function(option) { %>
      <option
        value="<%= option.value %>"
        <%= u.role === option.value ? "selected" : "" %>
      >
        <%= option.label %>
      </option>
    <% }) %>
  </select>

  <label
    title="Liberar acesso interno à Gatofilia"
    style="display:inline-flex; align-items:center; gap:5px; min-width:86px; font-size:12px; color:var(--text-muted);"
  >
    <input
      type="checkbox"
      name="gatofiliaAccess"
      <%= u.gatofiliaAccess ? "checked" : "" %>
      style="width:14px; height:14px;"
    />
    Gatofilia
  </label>

  <button type="submit" class="btn btn-primary">Salvar</button>
  <a href="/users/<%= u.id %>" class="btn">Detalhes</a>
</form>

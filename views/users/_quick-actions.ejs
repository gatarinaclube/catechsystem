<form
  method="post"
  action="/users/<%= u.id %>/quick-update"
  class="user-quick-form"
  data-user-quick-form
>
  <select
    name="approvalStatus"
    class="quick-pill quick-pill-status quick-status-<%= u.approvalStatus || 'INDEFERIDO' %>"
    aria-label="Status do cadastro"
  >
    <% approvalOptions.forEach(function(option) { %>
      <option
        value="<%= option.value %>"
        <%= u.approvalStatus === option.value ? "selected" : "" %>
      >
        <%= option.label %>
      </option>
    <% }) %>
  </select>

  <select name="role" class="quick-pill quick-pill-role" aria-label="Perfil do usuário">
    <% roleOptions.forEach(function(option) { %>
      <option
        value="<%= option.value %>"
        <%= u.role === option.value ? "selected" : "" %>
      >
        <%= option.label %>
      </option>
    <% }) %>
  </select>

  <label
    title="Liberar acesso interno à Gatofilia"
    class="quick-gatofilia-toggle"
  >
    <input
      type="checkbox"
      name="gatofiliaAccess"
      <%= u.gatofiliaAccess ? "checked" : "" %>
    />
    Gatofilia
  </label>
  <span class="quick-save-state" data-quick-save-state></span>
</form>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Usuários - PetGus</title>

    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Usuários</h2>
            <div class="welcome-sub">
              Gerenciamento de usuários por perfil. Clique no nome para ver os detalhes.
            </div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">← Voltar ao início</a>
          </div>
        </div>

        <div class="content-card" style="border-left:4px solid #d97706;">
          <div class="content-title">Usuários em teste gratuito</div>
          <div class="content-sub">
            Usuários de planos não associados que ainda estão no período de 7 dias grátis.
          </div>

          <% if (!trialUsers || !trialUsers.length) { %>
            <div class="empty" style="margin-top:12px;">Nenhum usuário em teste no momento.</div>
          <% } else { %>
            <ul class="list" style="margin-top:12px;">
              <% trialUsers.forEach(function(u) { %>
                <%
                  const endDate = u.trialEndsAt ? new Date(u.trialEndsAt) : null;
                  let daysLabel = "Sem data final";
                  if (endDate) {
                    const today = new Date();
                    const trialEnd = new Date(endDate);
                    trialEnd.setHours(23, 59, 59, 999);
                    today.setHours(0, 0, 0, 0);
                    const daysLeft = Math.ceil((trialEnd - today) / (1000 * 60 * 60 * 24));
                    if (daysLeft > 1) daysLabel = `${daysLeft} dias restantes`;
                    else if (daysLeft === 1) daysLabel = "1 dia restante";
                    else if (daysLeft === 0) daysLabel = "Finaliza hoje";
                    else daysLabel = "Teste vencido";
                  }
                %>
                <li class="item">
                  <div>
                    <a class="item-link" href="/users/<%= u.id %>"><%= u.name || "(sem nome)" %></a>
                    <div class="item-sub">
                      Email: <%= u.email || "-" %>
                      • Plano: <%= u.selectedPlan || "-" %>
                      <% if (endDate) { %>
                        • Fim do teste: <%= endDate.toLocaleDateString('pt-BR') %>
                      <% } %>
                    </div>
                  </div>
                  <span class="badge-status <%= daysLabel === 'Teste vencido' ? 'badge-status--inactive' : 'badge-status--new' %>">
                    <%= daysLabel %>
                  </span>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>

        <div class="content-card">
          <% userGroups.forEach(function(group) { %>
            <section style="margin-bottom: 20px;">
              <h3 class="section-title"><%= group.title %></h3>
              <% if (!group.users || !group.users.length) { %>
                <div class="empty">Nenhum usuário nesta divisão.</div>
              <% } else { %>
                <ul class="list">
                  <% group.users.forEach(function(u) { %>
                    <% const status = u.approvalStatus || "INDEFERIDO"; %>
                    <li class="item">
                      <div>
                        <a class="item-link" href="/users/<%= u.id %>">
                          <%= u.name || "(sem nome)" %>
                        </a>
                        <div class="item-sub">
                          Email: <%= u.email || "-" %>
                          <% if (status !== "RESTRICOES") { %>
                            • Perfil: <%= u.roleLabel || "Usuário" %>
                          <% } %>
                          <% if (u.createdAt && status === "INDEFERIDO") { %>
                            • Cadastro: <%= new Date(u.createdAt).toLocaleString('pt-BR') %>
                          <% } %>
                          <% if (u.gatofiliaAccess) { %>
                            • Gatofilia liberado
                          <% } %>
                        </div>
                      </div>
                      <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; justify-content:flex-end;">
                        <% if (status === "DEFERIDO") { %>
                          <span class="badge-status badge-status--active">Ativo</span>
                        <% } else if (status === "RESTRICOES") { %>
                          <span class="badge-status badge-status--inactive">Restrição</span>
                        <% } else { %>
                          <span class="badge-status badge-status--new">Novo cadastro</span>
                        <% } %>
                        <% if (u.role !== 'ADMIN') { %>
                          <form method="post" action="/users/<%= u.id %>/view-as" style="margin:0;">
                            <button
                              class="btn"
                              type="submit"
                              onclick="return confirm('Visualizar o sistema como este usuário em modo somente leitura?');"
                            >
                              Visualizar
                            </button>
                          </form>
                        <% } %>
                        <%- include('_quick-actions', { u, roleOptions, approvalOptions }) %>
                      </div>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </section>
          <% }); %>

          <div class="list-footer">
            <div>
              <span class="badge-role">Perfis SaaS</span>
            </div>
            <div>
              Total de usuários:
              <strong>
                <%= userGroups.reduce(function(total, group) { return total + group.users.length; }, 0) %>
              </strong>
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>

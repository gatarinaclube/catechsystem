<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Usuários - PetGus</title>

    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <style>
      .user-list-item {
        align-items: center;
        gap: 14px;
        min-height: 54px;
      }

      .user-list-main {
        min-width: 220px;
      }

      .user-list-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
      }

      .user-quick-form {
        display: flex;
        flex-wrap: nowrap;
        gap: 8px;
        justify-content: flex-end;
        align-items: center;
        max-width: none;
        margin: 0;
      }

      .quick-pill {
        height: 34px;
        border-radius: 999px;
        border: 1px solid var(--border-soft);
        padding: 0 30px 0 12px;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
      }

      .quick-pill:focus {
        outline: none;
        box-shadow: 0 0 0 3px rgba(217, 119, 6, 0.18);
      }

      .quick-pill-role {
        min-width: 150px;
        background: #ffffff;
        color: var(--text-main);
      }

      .quick-pill-status {
        min-width: 112px;
      }

      .quick-status-DEFERIDO {
        background: #dcfce7;
        border-color: #86efac;
        color: #166534;
      }

      .quick-status-INDEFERIDO {
        background: #fef3c7;
        border-color: #fcd34d;
        color: #92400e;
      }

      .quick-status-RESTRICOES {
        background: #fee2e2;
        border-color: #fca5a5;
        color: #991b1b;
      }

      .quick-gatofilia-toggle {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        min-width: 78px;
        font-size: 12px;
        color: var(--text-muted);
      }

      .quick-gatofilia-toggle input {
        width: 14px;
        height: 14px;
      }

      .quick-save-state {
        min-width: 42px;
        font-size: 11px;
        color: var(--text-muted);
      }

      .quick-save-state.is-ok {
        color: #15803d;
      }

      .quick-save-state.is-error {
        color: #b91c1c;
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">Usuários</h2>
            <div class="welcome-sub">
              Gerenciamento de usuários por perfil. Clique no nome para ver os detalhes.
            </div>
          </div>
          <div class="actions">
            <a href="/dashboard" class="btn">← Voltar ao início</a>
          </div>
        </div>

        <div class="content-card" style="border-left:4px solid #d97706;">
          <div class="content-title">Usuários em teste gratuito</div>
          <div class="content-sub">
            Usuários de planos não associados que ainda estão no período de 7 dias grátis.
          </div>

          <% if (!trialUsers || !trialUsers.length) { %>
            <div class="empty" style="margin-top:12px;">Nenhum usuário em teste no momento.</div>
          <% } else { %>
            <ul class="list" style="margin-top:12px;">
              <% trialUsers.forEach(function(u) { %>
                <%
                  const endDate = u.trialEndsAt ? new Date(u.trialEndsAt) : null;
                  let daysLabel = "Sem data final";
                  if (endDate) {
                    const today = new Date();
                    const trialEnd = new Date(endDate);
                    trialEnd.setHours(23, 59, 59, 999);
                    today.setHours(0, 0, 0, 0);
                    const daysLeft = Math.ceil((trialEnd - today) / (1000 * 60 * 60 * 24));
                    if (daysLeft > 1) daysLabel = `${daysLeft} dias restantes`;
                    else if (daysLeft === 1) daysLabel = "1 dia restante";
                    else if (daysLeft === 0) daysLabel = "Finaliza hoje";
                    else daysLabel = "Teste vencido";
                  }
                %>
                <li class="item">
                  <div>
                    <a class="item-link" href="/users/<%= u.id %>"><%= u.name || "(sem nome)" %></a>
                    <div class="item-sub">
                      Email: <%= u.email || "-" %>
                      • Plano: <%= u.selectedPlan || "-" %>
                      <% if (endDate) { %>
                        • Fim do teste: <%= endDate.toLocaleDateString('pt-BR') %>
                      <% } %>
                    </div>
                  </div>
                  <span class="badge-status <%= daysLabel === 'Teste vencido' ? 'badge-status--inactive' : 'badge-status--new' %>">
                    <%= daysLabel %>
                  </span>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>

        <div class="content-card">
          <% userGroups.forEach(function(group) { %>
            <section style="margin-bottom: 20px;">
              <h3 class="section-title"><%= group.title %></h3>
              <% if (!group.users || !group.users.length) { %>
                <div class="empty">Nenhum usuário nesta divisão.</div>
              <% } else { %>
                <ul class="list">
                  <% group.users.forEach(function(u) { %>
                    <% const status = u.approvalStatus || "INDEFERIDO"; %>
                    <li class="item user-list-item">
                      <div class="user-list-main">
                        <a class="item-link" href="/users/<%= u.id %>">
                          <%= u.name || "(sem nome)" %>
                        </a>
                        <div class="item-sub">
                          <%= u.email || "-" %>
                        </div>
                      </div>
                      <div class="user-list-actions">
                        <% if (u.role !== 'ADMIN') { %>
                          <form method="post" action="/users/<%= u.id %>/view-as" style="margin:0;">
                            <button
                              class="btn"
                              type="submit"
                              onclick="return confirm('Visualizar o sistema como este usuário em modo somente leitura?');"
                            >
                              Visualizar
                            </button>
                          </form>
                        <% } %>
                        <%- include('_quick-actions', { u, roleOptions, approvalOptions }) %>
                      </div>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </section>
          <% }); %>

          <div class="list-footer">
            <div>
              <span class="badge-role">Perfis SaaS</span>
            </div>
            <div>
              Total de usuários:
              <strong>
                <%= userGroups.reduce(function(total, group) { return total + group.users.length; }, 0) %>
              </strong>
            </div>
          </div>
        </div>
      </main>
    </div>
    <script>
      (function () {
        const statusClasses = ["quick-status-DEFERIDO", "quick-status-INDEFERIDO", "quick-status-RESTRICOES"];

        function refreshStatusClass(select) {
          select.classList.remove(...statusClasses);
          select.classList.add(`quick-status-${select.value || "INDEFERIDO"}`);
        }

        async function saveQuickForm(form) {
          const state = form.querySelector("[data-quick-save-state]");
          const statusSelect = form.querySelector("[name='approvalStatus']");
          if (state) {
            state.textContent = "Salvando...";
            state.className = "quick-save-state";
          }

          try {
            const payload = new URLSearchParams(new FormData(form));
            const response = await fetch(form.action, {
              method: "POST",
              headers: {
                "Accept": "application/json",
                "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
              },
              body: payload.toString(),
            });

            if (!response.ok) throw new Error("Falha ao salvar");
            if (statusSelect) refreshStatusClass(statusSelect);
            if (state) {
              state.textContent = "Salvo";
              state.className = "quick-save-state is-ok";
              window.setTimeout(() => {
                state.textContent = "";
                state.className = "quick-save-state";
              }, 1800);
            }
          } catch (err) {
            if (state) {
              state.textContent = "Erro";
              state.className = "quick-save-state is-error";
            }
          }
        }

        document.querySelectorAll("[data-user-quick-form]").forEach((form) => {
          form.addEventListener("submit", (event) => {
            event.preventDefault();
            saveQuickForm(form);
          });
          form.querySelectorAll("select,input[type='checkbox']").forEach((field) => {
            field.addEventListener("change", () => saveQuickForm(form));
          });
        });
      })();
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <title>Meus Dados - PetGus</title>
  <link rel="stylesheet" href="/css/theme.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/cattery-admin.css" />
</head>
<body>
<div class="shell">
  <%- include('../partials/sidebar', { user, currentPath }) %>

  <main class="main">
    <div class="header">
      <div>
        <div class="title-main">Meus Dados</div>
        <div class="title-sub">
          Visualize e edite seus dados cadastrais
        </div>
      </div>
    </div>

    <form method="post" action="/meus-dados">
      <div class="content">

        <div class="section">
          <div class="section-title">Informações do Usuário</div>

          <div class="grid-3">
            <div class="field">
              <label class="field-label">Nome</label>
              <input type="text" value="<%= user.name || '' %>" readonly />
            </div>

            <div class="field">
              <label class="field-label">CPF</label>
              <input type="text" value="<%= user.cpf || '' %>" readonly />
            </div>

            <div class="field">
              <label class="field-label">País</label>
              <input type="text" name="country" value="<%= user.country || '' %>" />
            </div>
          </div>

          <div class="grid-3">
            <div class="field">
              <label class="field-label">Endereço</label>
              <input type="text" name="address" value="<%= user.address || '' %>" />
            </div>

            <div class="field">
              <label class="field-label">Cidade</label>
              <input type="text" name="city" value="<%= user.city || '' %>" />
            </div>

            <div class="field">
              <label class="field-label">Estado</label>
              <input type="text" name="state" value="<%= user.state || '' %>" />
            </div>
          </div>

          <div class="grid-3">
            <div class="field">
              <label class="field-label">CEP</label>
              <input type="text" name="cep" value="<%= user.cep || '' %>" />
            </div>

            <div class="field">
              <label class="field-label">Telefone(s)</label>
              <input type="text" name="phones" value="<%= user.phones || '' %>" />
            </div>

            <div class="field">
              <label class="field-label">E-mail</label>
              <input type="email" name="email" value="<%= user.email || '' %>" />
            </div>
          </div>
        </div>

        <% if (typeof profilePlanSummary !== 'undefined' && profilePlanSummary) { %>
          <div class="section">
            <div class="section-title">Plano contratado</div>
            <div class="profile-plan-summary">
              <div class="profile-plan-summary-item">
                <span>Plano contratado</span>
                <strong><%= profilePlanSummary.selectedPlan || profilePlanSummary.planLabel %></strong>
              </div>
              <div class="profile-plan-summary-item">
                <span>Perfil atual</span>
                <strong><%= profilePlanSummary.planLabel %></strong>
              </div>
              <div class="profile-plan-summary-item">
                <span>Origem do acesso</span>
                <strong><%= profilePlanSummary.originLabel %></strong>
              </div>
              <div class="profile-plan-summary-item">
                <span>Status</span>
                <strong><%= profilePlanSummary.statusLabel %></strong>
              </div>
              <div class="profile-plan-summary-item">
                <span>Vencimento do plano</span>
                <strong><%= profilePlanSummary.expirationLabel %></strong>
              </div>
              <% if (profilePlanSummary.activatedAtLabel) { %>
                <div class="profile-plan-summary-item">
                  <span>Ativado em</span>
                  <strong><%= profilePlanSummary.activatedAtLabel %></strong>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>

        <% if (typeof profilePlanCards !== 'undefined' && profilePlanCards.length) { %>
          <div class="section">
            <div class="section-title">Perfis e limitações</div>

            <div class="profile-plan-grid">
              <% profilePlanCards.forEach((plan) => { %>
                <div class="profile-plan-card <%= plan.isCurrent ? 'profile-plan-card--current' : '' %>">
                  <div class="profile-plan-header">
                    <div class="profile-plan-name"><%= plan.title %></div>
                    <% if (plan.isCurrent) { %>
                      <span class="profile-plan-badge">Perfil atual</span>
                    <% } %>
                  </div>

                  <div class="profile-plan-list">
                    <% plan.rows.forEach((item) => { %>
                      <div class="profile-plan-item">
                        <span><%= item.label %></span>
                        <% if (item.type === "check") { %>
                          <strong class="<%= item.value ? 'is-allowed' : 'is-blocked' %>">
                            <%= item.value ? '✅' : '❌' %>
                          </strong>
                        <% } else { %>
                          <strong><%= item.value %></strong>
                        <% } %>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <div class="footer">
          <button type="submit" class="btn btn-primary">
            Salvar alterações
          </button>
        </div>

      </div>
    </form>
  </main>
</div>
</body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Detalhes do usuário - PetGus</title>

    <link rel="stylesheet" href="/css/theme.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body>
    <div class="shell">
      <%- include('../partials/sidebar', { user, currentPath }) %>

      <main class="main">
        <div class="main-header">
          <div>
            <h2 class="welcome-title">
              <%= userDetail.name || "Usuário sem nome" %>
            </h2>
            <div class="welcome-sub">
              Detalhes do usuário e controle de aprovação.
            </div>
          </div>
          <div class="actions">
            <a href="/users" class="btn">← Voltar à lista</a>
          </div>
        </div>

        <div class="content-card">
          <!-- FORMULÁRIO COMPLETO -->
          <form method="post" action="/users/<%= userDetail.id %>">
            <!-- INFORMAÇÕES BÁSICAS / CADASTRAIS -->
            <section style="margin-bottom:16px;">
              <h3 class="section-title">Informações do usuário</h3>


              <div class="grid-3">

                <div class="field">
                  <label class="field-label" for="name">Nome</label>
                  <input
                    id="name"
                    type="text"
                    name="name"
                    value="<%= userDetail.name || "" %>"
                  />
                </div>

                <div class="field">
                  <label class="field-label" for="cpf">CPF</label>
                  <input
                    id="cpf"
                    type="text"
                    name="cpf"
                    inputmode="numeric"
                    maxlength="18"
                    value="<%= userDetail.cpf || "" %>"
                  />
                </div>
                <div class="field">
                  <label class="field-label" for="country">País</label>
                  <input
                    id="country"
                    type="text"
                    name="country"
                    value="<%= userDetail.country || "" %>"
                  />
                </div>
              </div>


              <div class="grid-3">

                <div class="field">
                  <label class="field-label" for="address">Endereço</label>
                  <input
                    id="address"
                    type="text"
                    name="address"
                    value="<%= userDetail.address || "" %>"
                  />
                  </div>

                <div class="field">
                  <label class="field-label" for="city">Cidade</label>
                  <input
                    id="city"
                    type="text"
                    name="city"
                    value="<%= userDetail.city || "" %>"
                  />
                </div>

                <div class="field">
                  <label class="field-label" for="state">Estado</label>
                  <input
                    id="state"
                    type="text"
                    name="state"
                    value="<%= userDetail.state || "" %>"
                  />
               </div>
              </div>

              <div class="grid-3">

                <div class="field">
                  <label class="field-label" for="cep">CEP</label>
                  <input
                    id="cep"
                    type="text"
                    name="cep"
                    value="<%= userDetail.cep || "" %>"
                  />
                </div>

                                <div class="field">
                  <label class="field-label" for="phones">Telefone(s)</label>
                  <input
                    id="phones"
                    type="text"
                    name="phones"
                    value="<%= userDetail.phones || "" %>"
                  />
                </div>

                <div class="field">
                  <label class="field-label" for="email">E-mail</label>
                  <input
                    id="email"
                    type="email"
                    name="email"
                    value="<%= userDetail.email || "" %>"
                  />
                </div>
              </div>

              </div>

<!-- GATIL FIFe -->
<div class="grid-3" style="margin-top:10px;">
  <div class="field">
    <label class="field-label">
      Possui Gatil Registrado na FIFe?
    </label>

    <div style="display:flex; gap:24px; margin-top:6px;">
      <label class="checkbox-label">
        <input
          type="radio"
          name="hasFifeCattery"
          value="YES"
          <%= userDetail.hasFifeCattery === "YES" ? "checked" : "" %>
          onclick="toggleFifeCatteryEdit(true)"
        />
        Sim
      </label>

      <label class="checkbox-label">
        <input
          type="radio"
          name="hasFifeCattery"
          value="NO"
          <%= userDetail.hasFifeCattery === "NO" ? "checked" : "" %>
          onclick="toggleFifeCatteryEdit(false)"
        />
        Não
      </label>
    </div>
  </div>

<div
  class="field"
  id="fifeCatteryEditBlock"
  <%= userDetail.hasFifeCattery === 'YES' ? '' : 'hidden' %>
>

    <label class="field-label" for="fifeCatteryName">
      Qual o nome do seu gatil FIFe?
    </label>
    <input
      id="fifeCatteryName"
      type="text"
      name="fifeCatteryName"
      value="<%= userDetail.fifeCatteryName || '' %>"
      placeholder="Nome do gatil conforme registro FIFe"
    />
  </div>
</div>


              <div class="grid-3" style="margin-top:10px;">
                <div class="field">
                  <label class="field-label" for="clubs">Clubes</label>
                  <input
                    id="clubs"
                    type="text"
                    name="clubs"
                    value="<%= userDetail.clubs || "" %>"
                  />
                  <small style="font-size:11px; color:var(--text-muted);">
                    Ex.: Gatarina, CBG, AMACOON...
                  </small>
                </div>

                <div class="field">
                  <label class="field-label" for="role">Perfil</label>
                  <select id="role" name="role">
                    <% roleOptions.forEach(function(option) { %>
                      <option
                        value="<%= option.value %>"
                        <%= userDetail.role === option.value ? "selected" : "" %>
                      >
                        <%= option.label %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="field">
                  <label class="field-label" for="gatofiliaAccess">Gatofilia</label>
                  <label style="display:flex; align-items:center; gap:8px; min-height:38px;">
                    <input
                      id="gatofiliaAccess"
                      type="checkbox"
                      name="gatofiliaAccess"
                      <%= userDetail.gatofiliaAccess ? "checked" : "" %>
                    />
                    <span>Liberar acesso aos conteúdos e aulas</span>
                  </label>
                  <small style="font-size:11px; color:var(--text-muted);">
                    Quando ativo, o usuário verá o atalho Gatofilia no menu e poderá acessar a área interna.
                  </small>
                </div>
              </div>

              <% if (userDetail.createdAt) { %>
                <p style="margin-top:10px; font-size:12px; color:var(--text-muted);">
                  <strong>Data de cadastro:</strong>
                  <%= new Date(userDetail.createdAt).toLocaleString('pt-BR') %>
                </p>
              <% } %>

            </section>

            <!-- CONTROLE DE APROVAÇÃO -->
            <section style="margin-bottom:16px;">
              <h3 class="section-title">Situação do cadastro</h3>


                <div class="grid-3" style="margin-top:10px;">
              <div class="field">
                <label class="field-label" for="approvalStatus">
                  Status de aprovação
                </label>
                <select id="approvalStatus" name="approvalStatus">
                  <option
                    value="INDEFERIDO"
                    <%= (userDetail.approvalStatus === "INDEFERIDO" || !userDetail.approvalStatus) ? "selected" : "" %>
                  >
                    Indeferido (Novo cadastro)
                  </option>
                  <option
                    value="DEFERIDO"
                    <%= userDetail.approvalStatus === "DEFERIDO" ? "selected" : "" %>
                  >
                    Deferido (Ativo)
                  </option>
                  <option
                    value="RESTRICOES"
                    <%= userDetail.approvalStatus === "RESTRICOES" ? "selected" : "" %>
                  >
                    Restrições (Inativo)
                  </option>
                </select>
                <small style="font-size:11px; color:var(--text-muted);">
                  • Indeferido: fica na lista "Novo Cadastro" e não pode fazer login.<br/>
                  • Deferido: vai para "Ativos" e pode fazer login normalmente.<br/>
                  • Restrições: vai para "Inativos" e não pode fazer login.
                </small>
              </div>
              </div>

              <div class="field" style="margin-top:12px;">
                <label class="field-label" for="adminNotes">
                  Observações internas
                </label>
                <textarea
                  id="adminNotes"
                  name="adminNotes"
                  rows="4"
                  style="width:100%;"
                ><%= userDetail.adminNotes || "" %></textarea>
                <small style="font-size:11px; color:var(--text-muted);">
                  Use este campo para registrar motivos de deferimento, indeferimento ou restrições.
                </small>
              </div>
            </section>

            <section style="margin-bottom:16px;">
              <h3 class="section-title">Origem, plano e pagamento</h3>
              <div class="content-sub" style="margin-top:4px;">
                O campo <strong>Perfil</strong> define os acessos do sistema. A <strong>Origem</strong> separa solicitações de associação dos planos comerciais.
              </div>
              <div style="margin-top:10px; display:flex; flex-wrap:wrap; gap:8px; align-items:center;">
                <button class="btn" type="button" id="startTrialButton">
                  Colocar em teste por 7 dias
                </button>
                <small style="font-size:11px; color:var(--text-muted);">
                  Preenche automaticamente como plano não associado, Premium em teste, cadastro ativo e fim do teste em 7 dias.
                </small>
              </div>
              <div class="grid-3" style="margin-top:10px;">
                <div class="field">
                  <label class="field-label" for="accountOrigin">Origem do cadastro</label>
                  <select id="accountOrigin" name="accountOrigin">
                    <option value="" <%= !userDetail.accountOrigin ? "selected" : "" %>>Interno / manual</option>
                    <option value="ASSOCIATE" <%= userDetail.accountOrigin === "ASSOCIATE" ? "selected" : "" %>>Solicitação de associação Gatarina</option>
                    <option value="NON_ASSOCIATE" <%= userDetail.accountOrigin === "NON_ASSOCIATE" ? "selected" : "" %>>Plano não associado</option>
                  </select>
                </div>
                <div class="field">
                  <label class="field-label" for="selectedPlan">Plano escolhido</label>
                  <select id="selectedPlan" name="selectedPlan">
                    <option value="" <%= !userDetail.selectedPlan ? "selected" : "" %>>Não informado</option>
                    <option value="BASIC" <%= userDetail.selectedPlan === "BASIC" ? "selected" : "" %>>Básico</option>
                    <option value="MASTER" <%= userDetail.selectedPlan === "MASTER" ? "selected" : "" %>>Master</option>
                    <option value="PREMIUM" <%= userDetail.selectedPlan === "PREMIUM" ? "selected" : "" %>>Premium</option>
                    <option value="ASSOCIADO_A" <%= userDetail.selectedPlan === "ASSOCIADO_A" ? "selected" : "" %>>Associado Master</option>
                    <option value="ASSOCIADO_PREMIUM" <%= userDetail.selectedPlan === "ASSOCIADO_PREMIUM" ? "selected" : "" %>>Associado Premium</option>
                    <option value="ASSOCIADO_B" <%= userDetail.selectedPlan === "ASSOCIADO_B" ? "selected" : "" %>>Associado Básico</option>
                  </select>
                </div>
                <div class="field">
                  <label class="field-label" for="subscriptionStatus">Status da assinatura</label>
                  <select id="subscriptionStatus" name="subscriptionStatus">
                    <option value="" <%= !userDetail.subscriptionStatus ? "selected" : "" %>>Não informado</option>
                    <option value="TRIALING" <%= userDetail.subscriptionStatus === "TRIALING" ? "selected" : "" %>>Teste gratuito</option>
                    <option value="ACTIVE" <%= userDetail.subscriptionStatus === "ACTIVE" ? "selected" : "" %>>Pago / ativo</option>
                    <option value="PENDING" <%= userDetail.subscriptionStatus === "PENDING" ? "selected" : "" %>>Pagamento pendente</option>
                    <option value="PENDING_ASSOCIATION_PAYMENT" <%= userDetail.subscriptionStatus === "PENDING_ASSOCIATION_PAYMENT" ? "selected" : "" %>>Associação pendente de pagamento</option>
                    <option value="EXPIRED" <%= userDetail.subscriptionStatus === "EXPIRED" ? "selected" : "" %>>Teste vencido</option>
                    <option value="CANCELED" <%= userDetail.subscriptionStatus === "CANCELED" ? "selected" : "" %>>Cancelado</option>
                  </select>
                </div>
              </div>
              <div class="grid-3" style="margin-top:10px;">
                <div class="field">
                  <label class="field-label" for="trialEndsAt">Vencimento do acesso</label>
                  <input
                    id="trialEndsAt"
                    name="trialEndsAt"
                    type="date"
                    value="<%= userDetail.trialEndsAt ? userDetail.trialEndsAt.toISOString().slice(0,10) : '' %>"
                  />
                </div>
                <div class="field">
                  <label class="field-label">Ativação do plano</label>
                  <input
                    type="text"
                    value="<%= userDetail.planActivatedAt ? new Date(userDetail.planActivatedAt).toLocaleString('pt-BR') : 'Ainda não ativado' %>"
                    readonly
                  />
                </div>
              </div>
              <div class="grid-3" style="margin-top:10px;">
                <div class="field">
                  <label class="field-label">Cliente Asaas</label>
                  <input type="text" value="<%= userDetail.asaasCustomerId || '-' %>" readonly />
                </div>
                <div class="field">
                  <label class="field-label">Assinatura Asaas</label>
                  <input type="text" value="<%= userDetail.asaasSubscriptionId || '-' %>" readonly />
                </div>
                <div class="field">
                  <label class="field-label">Último evento Asaas</label>
                  <input type="text" value="<%= userDetail.asaasLastEvent || '-' %>" readonly />
                </div>
              </div>
              <% if (userDetail.asaasPaymentUrl) { %>
                <div style="margin-top:10px;">
                  <a class="btn" href="<%= userDetail.asaasPaymentUrl %>" target="_blank" rel="noopener">Abrir cobrança Asaas</a>
                </div>
              <% } %>
              <small style="font-size:11px; color:var(--text-muted);">
                Plano não associado: o pagamento altera automaticamente status e perfil comercial. Solicitação de associação: o pagamento libera como Associado Master/Premium até 31/07, e o administrador pode ajustar o perfil depois.
              </small>
            </section>

            <div class="footer" style="margin-top:16px;">
              <button type="submit" class="btn btn-primary">
                Salvar alterações
              </button>
            </div>
          </form>

          <!-- HISTÓRICO (LOGS) -->
          <section style="margin-top:20px;">
            <h3 class="section-title">Histórico de ações</h3>
            <% if (!logs || !logs.length) { %>
              <div class="empty">
                Ainda não há registros de histórico para este usuário.
              </div>
            <% } else { %>
              <ul class="list">
                <% logs.forEach(function(log) { %>
                  <li class="item">
                    <div>
                      <div class="item-sub">
                        <strong><%= new Date(log.createdAt).toLocaleString('pt-BR') %></strong>
                      </div>
                      <div><%= log.description %></div>
                    </div>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </section>
        </div>
      </main>
    </div>
    <script>
      (function () {
        const button = document.getElementById("startTrialButton");
        if (!button) return;

        function setValue(id, value) {
          const field = document.getElementById(id);
          if (field) field.value = value;
        }

        button.addEventListener("click", function () {
          const trialEnd = new Date();
          trialEnd.setDate(trialEnd.getDate() + 7);
          const yyyy = trialEnd.getFullYear();
          const mm = String(trialEnd.getMonth() + 1).padStart(2, "0");
          const dd = String(trialEnd.getDate()).padStart(2, "0");

          setValue("accountOrigin", "NON_ASSOCIATE");
          setValue("selectedPlan", "PREMIUM");
          setValue("subscriptionStatus", "TRIALING");
          setValue("trialEndsAt", `${yyyy}-${mm}-${dd}`);
          setValue("role", "PREMIUM");
          setValue("approvalStatus", "DEFERIDO");
        });
      })();
    </script>
  </body>
</html>
